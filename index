            onchange="updateCropSlot(${idx},'irrigation',this.value)">${irrigOpts}</select>
          <label class="slot-mgmt-lbl">🚜</label>
          <select class="slot-mgmt-select" title="Tillage before/during this crop"
            onchange="updateCropSlot(${idx},'tillage',this.value)">${tillOpts}</select>
          <label class="slot-mgmt-lbl" title="Residue management type">🌱</label>
          <select class="slot-mgmt-select" onchange="updateCropSlot(${idx},'residue',this.value);updateCropSlot(${idx},'residue_pct',null)">${resOpts}</select>
