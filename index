/* ── Terrain suitability helpers (2.4.1–2.4.7) ──────────────────────
   getTerrainSuitabilityNote(type, id): returns a warning string if
   terrain makes this crop/tree unsuitable or sub-optimal.
   Returns null if terrain data unavailable or no issue.
────────────────────────────────────────────────────────────────────── */
function getTerrainSuitabilityNote(type, id) {
  if (!ST.terrain || !ST.terrainAdj) return null;
  const slope_max  = ST.terrainAdj.slope_max  ?? 0;
  const slope_mean = ST.terrainAdj.slope_mean ?? 0;
  const twi_mean   = ST.terrainAdj.twi_mean   ?? 0;
  const elev_mean  = ST.terrainAdj.elev_mean  ?? 0;
  const risk_max   = ST.terrainAdj.risk_max   ?? 0;
  const riparianPresent = Array.from(ST.terrain.riparian||[]).some(v=>v>0);

  const notes = [];

  if (type === 'crop') {
    const limit = CROP_SLOPE_LIMITS[id] ?? CROP_SLOPE_LIMITS._default;
    if (slope_max > limit) {
      notes.push(`⚠ Slope ${slope_max.toFixed(0)}° > ${limit}° crop limit`);
    }
    // 2.4.2: TWI → irrigation need
    if (twi_mean < 5 && ['rice_wetland','sugarcane'].includes(id)) {
      notes.push('💧 Low TWI — high irrigation demand');
    }
    if (twi_mean > 8 && id === 'potato') {
      notes.push('💧 High TWI — waterlogging risk for potato');
    }
  }

  if (type === 'tree') {
    const sp = TREE_SPECIES[id];
    if (!sp) return null;

    // 2.4.4: Slope class → tree species filter
    if (sp.max_slope && slope_max > sp.max_slope) {
      notes.push(`⚠ Slope ${slope_max.toFixed(0)}° > ${sp.max_slope}° species limit`);
    }

    // 2.4.7: Elevation range check
    if (sp.elevation_range) {
      const [minE, maxE] = sp.elevation_range;
      if (elev_mean < minE) {
        notes.push(`🏔 Elevation ${elev_mean.toFixed(0)}m below species minimum ${minE}m`);
      } else if (elev_mean > maxE) {
        notes.push(`🏔 Elevation ${elev_mean.toFixed(0)}m above species maximum ${maxE}m`);
      }
    }

    // 2.4.5: Riparian → deep-rooting species priority
    if (riparianPresent && ['gliricidia','albizzia','bamboo_bambusa','bamboo_dendrocalamus',
                             'casuarina','sesbania'].includes(id)) {
      notes.push('🌊 Riparian zones present — excellent placement on drainage lines');
    }

    // 2.4.6: Landslide risk → root reinforcement species
    if (risk_max > 0.6 && ['bamboo_bambusa','bamboo_dendrocalamus','casuarina',
                            'dalbergia','teak'].includes(id)) {
      notes.push('⚠ High landslide risk — root reinforcement species: excellent choice');
    }
  }

  return notes.length ? notes.join(' · ') : null;
}

/* 2.4.3: Aspect × latitude → optimal tree density for target canopy cover */
function calcOptimalTreeDensity(targetCanoxyPct, treeId, age_class) {
  if (!ST.terrain || !ST.terrainAdj) return null;
  const asp = ST.terrainAdj.asp_mean ?? 180;
  const lat = ST.lat ?? 20;
  const sp  = TREE_SPECIES[treeId];
  if (!sp) return null;

  // Base shade cast at reference (100 trees/ha, mature)
  const baseCast = sp.shade_cast ?? 20;  // % per 100 trees/ha

  // Aspect correction: south-facing at Indian latitudes → more direct sun
  // → wider spacing needed for same canopy cover target
  const southFacing = asp > 90 && asp < 270;
  const latFactor   = 1.0 + (southFacing ? Math.sin(lat * Math.PI/180) * 0.2 : 0);

  const ageFactor   = { young:0.25, mid:0.60, mat:1.00, old:1.00 }[age_class] || 0.60;
  const effectivePctPer100 = baseCast * ageFactor / latFactor;
  if (effectivePctPer100 < 1) return null;

  const optimalDensity = Math.round((targetCanoxyPct / effectivePctPer100) * 100);
  return Math.min(500, Math.max(20, optimalDensity));
}

