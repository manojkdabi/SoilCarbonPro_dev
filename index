<script>
// ─── DEV PANEL ───
let _devClickCount = 0, _devClickTimer = null;

document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && document.getElementById('dev-panel').style.display !== 'none') {
    closeDevPanel();
  }
});
function devTriggerClick() {
  _devClickCount++;
  clearTimeout(_devClickTimer);
  _devClickTimer = setTimeout(() => { _devClickCount = 0; }, 2000);
  if (_devClickCount >= 3) {
    _devClickCount = 0;
    openDevPanel();
  }
}

function openDevPanel() {
  const p = document.getElementById('dev-panel');
  p.style.display = 'flex';
  // Init SVG pan-zoom
  initDevSvgPanZoom();
}
function closeDevPanel() {
  document.getElementById('dev-panel').style.display = 'none';
}

function devTab(idx) {
  document.querySelectorAll('.dev-tab').forEach((t,i) => t.classList.toggle('active', i===idx));
  document.querySelectorAll('.dev-tab-body').forEach((b,i) => {
    b.style.display = i===idx ? (idx===0 ? 'block' : 'block') : 'none';
  });
  if (idx===0) initDevSvgPanZoom();
}

// SVG Pan + Zoom
let _svgVx=0, _svgVy=0, _svgScale=1, _svgDragging=false, _svgDragStart={x:0,y:0};
const SVG_W=1100, SVG_H=3100;

function initDevSvgPanZoom() {
  const container = document.getElementById('dev-tab-0');
  const svg = document.getElementById('dev-wf-svg');
  if (!svg || svg._panZoomInit) return;
  svg._panZoomInit = true;

  // Fit to container initially
  const cw = container.clientWidth || 1200;
  const ch = container.clientHeight || 800;
  _svgScale = Math.min(cw/SVG_W, ch/SVG_H) * 0.95;
  _svgVx = (cw - SVG_W*_svgScale)/2;
  _svgVy = 20;
  applyDevTransform(svg);

  svg.addEventListener('wheel', e => {
    e.preventDefault();
    const delta = e.deltaY > 0 ? 0.88 : 1.14;
    const rect = svg.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    _svgVx = mx - (mx - _svgVx)*delta;
    _svgVy = my - (my - _svgVy)*delta;
    _svgScale = Math.max(0.15, Math.min(4, _svgScale*delta));
    applyDevTransform(svg);
  }, {passive:false});

  svg.addEventListener('mousedown', e => {
    _svgDragging=true;
    _svgDragStart={x:e.clientX-_svgVx, y:e.clientY-_svgVy};
    svg.style.cursor='grabbing';
  });
  window.addEventListener('mousemove', e => {
    if(!_svgDragging) return;
    _svgVx = e.clientX - _svgDragStart.x;
    _svgVy = e.clientY - _svgDragStart.y;
    applyDevTransform(svg);
  });
  window.addEventListener('mouseup', () => {
    _svgDragging=false;
    const svg2 = document.getElementById('dev-wf-svg');
    if(svg2) svg2.style.cursor='grab';
  });
}

function applyDevTransform(svg) {
  svg.setAttribute('viewBox',
    `${-_svgVx/_svgScale} ${-_svgVy/_svgScale} ${SVG_W/_svgScale * (svg.clientWidth/SVG_W || 1)} ${SVG_H/_svgScale * (svg.clientHeight/SVG_H || 1)}`
  );
}
</script>

