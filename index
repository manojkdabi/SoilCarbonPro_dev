async function submitAssessment() {
  if (!SUPABASE_URL || !SUPABASE_ANON) {
    showToast('⚠ Supabase not configured — set SUPABASE_URL and SUPABASE_ANON in source');
    return;
  }

  const mrv   = generateMRVProtocol();
  const crops = ST.farm.crops.map(s => CROPS[s.id]?.name?.split('(')[0].trim() || s.id).join(', ');
  const trees = ST.farm.trees?.map(t => t.id).join(',') || null;

  // Identity values collected via modal (openSubmitModal / confirmSubmitAssessment)
  const agentName  = ST._agentName  || 'Unknown agent';
  const farmerName = ST._farmerName || 'Unknown farmer';
  const village    = ST._village    || '';
  const district   = ST._district   || '';
  const khasra     = ST._khasra     || null;

  // Determine pathway eligibility from feas flags
  const feas = ST.feas || {};
  const pathwayAWD     = !!(feas.awdEligible     ?? ST.farm.history?.waterlog !== 'no');
  const pathwayBiochar = !!(feas.biocharEligible  ?? !feas.nolist?.includes('biochar'));
  const pathwayRegen   = !!(feas.regenEligible    ?? true);
  const pathwayERW     = !!(feas.erwEligible      ?? false);

  const payload = {
    // Identity
    agent_name:         agentName,
    farmer_name:        farmerName,
    village:            ST._village  || null,
    district:           district || null,
    state:              ST._state || null,
    khasra_number:      khasra,

    // Location
    location_name:      ST.locationName || null,
    lat:                ST.lat,
    lon:                ST.lon,
    field_area_ha:      ST.fieldAreaHa,
    boundary_geojson:   ST.fieldBoundary
                          ? JSON.parse(JSON.stringify(ST.fieldBoundary))
                          : null,

    // Soil baseline
    mineralogy:         ST.mineralogy,
    analysis_depth_cm:  ST.analysisDepth,
    soc_baseline_pct:   parseFloat(mrv.soc1) || null,
    cstock_tha:         parseFloat(mrv.cstock) || null,
    clay_pct:           ST.derived?.clay ?? null,
    ph:                 ST.derived?.ph   ?? null,
    bulk_density:       ST.derived?.bd   ?? null,
    cec_cmolkg:         ST.derived?.cec  ?? null,
    data_source:        ST.derived?.spatial ? 'soilgrids+spatial' : 'soilgrids',

    // CDR targets
    target_tha:         ST.targetTha   || null,
    target_year:        ST.targetYear  || null,
    bau_endpoint_tha:   ST.derived?.bau_endpoint || null,
    feas_score:         ST.feas?.score || null,
    pathway_awg:        pathwayAWD,
    pathway_erw:        pathwayERW,
    pathway_biochar:    pathwayBiochar,
    pathway_regen:      pathwayRegen,

    // Farm system
    crop_rotation:      crops,
    tillage:            ST.farm.crops[0]?.tillage || ST.farm.tillage || null,
    irrigation:         ST.farm.crops[0]?.irrigation || ST.farm.irrigation || null,
    trees:              trees,
    tree_area_frac:     ST.farm.treeAreaFraction || null,
    waterlogging:       ST.farm.history?.waterlog || null,

    // MRV
    mrv_composites:     mrv.nComposites,
    mrv_subsamples:     mrv.subSamples,
    mrv_timing:         mrv.timing     || null,
    soc_uncertainty_pct:mrv.uncertainty ? parseFloat(mrv.uncertainty) || null : null,
    soc_cv_pct:         ST.derived.spatial?.soc?.cv_pct || null,

    // Spatial
    interp_mode:        _rkMode ? 'rk' : _krigingMode ? 'ok' : 'idw',
    rk_r2:              ST.rkFit?.rSquared || null,
    pixel_count:        ST.derived.spatial?.soc?.n_valid || null,

    // Terrain
    dem_source:         ST.dem?.source || null,
    slope_mean_deg:     ST.terrain?.stats?.slope?.mean || null,
    slope_max_deg:      ST.terrain?.stats?.slope?.max  || null,
    twi_mean:           ST.terrain?.stats?.twi?.mean   || null,
    terrain_flags:      ST.terrainAdj?.crossChecks?.join(' | ') || null,

    // Full snapshot
    session_json: JSON.stringify({
      farm:    ST.farm,
      derived: {
        cstock:       ST.derived.cstock,
        uncertainty:  ST.derived.uncertainty,
        bau_endpoint: ST.derived.bau_endpoint,
        spatial:      ST.derived.spatial ? {
          soc: ST.derived.spatial.soc,
          clay: ST.derived.spatial.clay,
        } : null,
      },
      feas:    ST.feas,
      rkFit:   ST.rkFit,
    }),
  };

  const btn = document.getElementById('submit-assessment-btn');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Submitting…'; }

  try {
    const resp = await fetch(`${SUPABASE_URL}/rest/v1/assessments`, {
      method: 'POST',
      headers: {
        'Content-Type':  'application/json',
        'apikey':        SUPABASE_ANON,
        'Authorization': `Bearer ${SUPABASE_ANON}`,
        'Prefer':        'return=minimal',
      },
      body: JSON.stringify(payload),
    });
    if (resp.ok || resp.status === 201) {
      showToast('✓ Assessment submitted to database');
      if (btn) {
        btn.textContent = '✓ Submitted';
        btn.style.background = 'var(--green-2)';
        btn.style.color = 'white';
      }
    } else {
      const err = await resp.text();
      const statusMessages = {
        400: 'Invalid data — please check all fields',
        401: 'Authorization failed — check configuration',
        403: 'Permission denied — contact administrator',
        409: 'Duplicate entry — assessment may already exist',
        422: 'Validation error — some fields have invalid values',
        500: 'Server error — please try again later',
        503: 'Service unavailable — please try again later',
      };
      const msg = statusMessages[resp.status] || `Submit failed (${resp.status})`;
      showToast('⚠ ' + msg);
      console.error('Supabase error:', err);
      if (btn) { btn.disabled = false; btn.textContent = '☁ Submit'; }
    }
  } catch(e) {
    showToast('Submit error: ' + e.message);
    if (btn) { btn.disabled = false; btn.textContent = '☁ Submit'; }
  }
}
