    'Climate: Open-Meteo 5-yr archive. MAT/MAP averaged from daily data.',
    'Biochar: tropical stability discount 0.85x, annual decay 0.7%/yr.',
    'C input estimates from IPCC Tier 1 defaults for residues; rhizodeposition per crop type.',
    'Results are scenario projections only — field validation required before investment decisions.',
    'Phase 2 BAU does not account for management change by farmer between visits.',
  ];
  doc.setFontSize(7); doc.setTextColor(74,74,50);
  assumptions.forEach(a => {
    const lines = doc.splitTextToSize(`• ${a}`, cW);
    doc.text(lines, pad+2, y); y += lines.length * 3.8;
  });

  // Footer
  doc.setFillColor(14,74,58);
  doc.rect(0,280,210,17,'F');
  doc.setFont('helvetica','normal'); doc.setFontSize(7); doc.setTextColor(160,210,190);
  doc.text('SoilCarbon Pro — Target Solver  ·  RothC / Hassink / Open-Meteo / ISRIC SoilGrids v2', pad, 287);
  doc.text('Phase 3 · Practice Prescriptions', W-pad, 287, {align:'right'});

  const fname = `Prescription_${(ST.locationName||'field').replace(/[^a-zA-Z0-9]/g,'_')}_${new Date().toISOString().slice(0,10)}.pdf`;
  doc.save(fname);
}

/* ═══════════════════════════════════════════════════════
   CSV EXPORT
═══════════════════════════════════════════════════════ */
function exportCSV() {
  const tab = ST.solverTab;
  const results = ST.solverResults[tab];
  if (!results || results.length === 0) return;
  const selected = results[ST.selectedBundle[tab]];
  if (!selected) return;

  const bau = ST.bau?.trajectory || [];
  let csv = 'Year,BAU_tCha,Bundle_tCha,Target_tCha,Hassink_cap_tCha\n';
  selected.traj.forEach((pt, i) => {
    csv += `${pt.year},${bau[i]?.soc?.toFixed(2)??''},${pt.soc.toFixed(2)},${ST.targetTha?.toFixed(2)??''},${ST.derived.hassinkCap?.toFixed(2)??''}\n`;
  });

  const blob = new Blob([csv], {type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `SOC_trajectory_${(ST.locationName||'site').replace(/[^a-zA-Z0-9]/g,'_')}.csv`;
  a.click();
}


function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return [r,g,b];
}
