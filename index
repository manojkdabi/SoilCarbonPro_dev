function renderPickerList(idx, query) {
  const list = document.getElementById(`crop-list-${idx}`);
  if (!list) return;
  const q = query.toLowerCase().trim();
  const currentId = ST.farm.crops[idx]?.id;

  // Group crops
  const groups = {};
  Object.entries(CROPS).forEach(([k, v]) => {
    if (q) {
      const match = v.name.toLowerCase().includes(q) ||
                    (v.sci||'').toLowerCase().includes(q) ||
                    v.group.toLowerCase().includes(q) ||
                    k.toLowerCase().includes(q);
      if (!match) return;
    }
    const g = v.group;
    if (!groups[g]) groups[g] = [];
    groups[g].push([k, v]);
  });

  if (!Object.keys(groups).length) {
    list.innerHTML = `<div class="crop-picker-empty">No crops match "${query}"</div>`;
    return;
  }

  // GROUP_ORDER defines display sequence
  const GROUP_ORDER = [
    'Cereals', 'Millets',
    'Pulses — Kharif', 'Pulses — Rabi', 'Pulses — Arid',
    'Oilseeds — Rabi', 'Oilseeds — Kharif',
    'Sugar, Fibre & Industrial',
    'Spices — Arid / Rabi', 'Spices — Humid / Kharif',
    'Vegetables & Root Crops', 'Fruits & Orchards',
    'Plantation & Tree Crops', 'Fodder & Cover Crops', 'Fallow'
  ];

  const orderedGroups = GROUP_ORDER.filter(g => groups[g])
    .concat(Object.keys(groups).filter(g => !GROUP_ORDER.includes(g)));

  let html = '';
  orderedGroups.forEach(grp => {
    const crops = groups[grp];
    html += `<div class="crop-picker-group">${grp}</div>`;
    crops.forEach(([k, v]) => {
      const sel = k === currentId ? ' selected' : '';
      const nfix = v.n_fix ? ' <span class="crop-picker-nfix" title="N-fixing">N₂</span>' : '';
      html += `<div class="crop-picker-item${sel}" onclick="selectCrop(${idx},'${k}')">
        <span class="cpi-icon">${v.icon}</span>
        <span class="cpi-name">${v.name}${nfix}</span>
        <span class="cpi-sci">${v.sci}</span>
        <span class="cpi-season">${v.season}</span>
        <span class="cpi-cin">${(v.base_cin*(1+v.rhizodep)).toFixed(2)} tC</span>
      </div>`;
    });
  });
  list.innerHTML = html;
}

function selectCrop(idx, cropId) {
  // Update crop ID and reset calendar to new crop's defaults
  ST.farm.crops[idx].id = cropId;
  const cal = getCropCalendar(cropId);
  ST.farm.crops[idx].sow_month     = cal.sow;
  ST.farm.crops[idx].harvest_month = cal.harvest;
  ST.farm.crops[idx].residue_pct   = null;  // reset to crop-type default on crop change
  closeAllCropPickers();
  renderRotationSlots();
  inferDepthFromCrops();
  triggerBAU();
}


