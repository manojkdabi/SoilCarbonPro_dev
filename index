    wrap.innerHTML += `
      <div class="crop-picker-wrap" id="rot-slot-${idx}">
        <div class="crop-picker-row">
          <span class="crop-picker-num">${idx+1}</span>
          <div class="crop-picker-selected" onclick="openCropPicker(${idx})" id="crop-sel-${idx}">
            <span class="crop-picker-icon">${crop.icon}</span>
            <span class="crop-picker-name">${crop.name}</span>
            <span class="crop-picker-sci">${crop.sci}</span>
            <span class="crop-picker-season">${crop.season}</span>
            <span class="crop-picker-chevron">▾</span>
