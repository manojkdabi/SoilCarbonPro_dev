<body>

  <!-- Loading splash (dismissed on DOMContentLoaded) -->
  <div id="scp-splash">
    <svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="25" cy="25" r="20" stroke="#1a5c48" stroke-width="4"/>
      <path d="M25 5 A20 20 0 0 1 45 25" stroke="#4ecda0" stroke-width="4" stroke-linecap="round"/>
