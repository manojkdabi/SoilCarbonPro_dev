/* ═══════════════════════════════════════════════════════
   SOILGRIDS API
═══════════════════════════════════════════════════════ */
/* Retry fetch with exponential backoff */
/* ═══════════════════════════════════════════════════════
   SOIL DATA — SoilGrids v2
   Source 1: rest.isric.org REST API (when available)
   Source 2: maps.isric.org WCS GetCoverage + geotiff.js
             Returns a tiny reprojected GeoTIFF per layer.
             Completely independent server from rest.isric.org.
             CORS enabled — tested working from browser.
   Ref: Poggio et al. 2021 (SOIL 7:217-240) · CC-BY 4.0
═══════════════════════════════════════════════════════ */

/* ── WCS pixel reader ─────────────────────────────────
   maps.isric.org WCS GetCoverage with OUTPUTCRS=EPSG:4326
   returns a tiny ~1 KB GeoTIFF for the bounding box.
   geotiff.js decodes it from ArrayBuffer — no projection math needed.
   prop:  e.g. 'soc', 'clay', 'phh2o'
   layer: e.g. 'soc_0-5cm_mean', 'clay_15-30cm_mean'
─────────────────────────────────────────────────────── */

/* ═══════════════════════════════════════════════════════
   SPRINT 1 — PLAN 1.2A: IDW INTERPOLATION SURFACE
   
   Inverse Distance Weighting (IDW, power=2) on pixel values.
   Produces a continuous surface raster at 50 m output resolution.
   Rendered as a Leaflet canvas overlay with per-property colour ramp.
   
   Tasks 1.2.A.1–1.2.A.6:
     Generate 50 m output grid → clip to polygon → IDW weights →
     colour ramp → Leaflet canvas overlay → layer toggle UI.
   
   Ref: Shepard 1968 (ACM National Conference);
        Webster & Oliver 2007 Ch.3 (IDW as baseline interpolator).
═══════════════════════════════════════════════════════ */

/* Colour ramps — perceptually uniform */
const RAMP_DEFS = {
  soc:   { stops: [[0,'#fff7ec'],[0.33,'#fc8d59'],[0.66,'#d7301f'],[1,'#7f0000']], reverse: false },
  clay:  { stops: [[0,'#f7fbff'],[0.33,'#6baed6'],[0.66,'#2171b5'],[1,'#08306b']], reverse: false },
  silt:  { stops: [[0,'#f7fcf5'],[0.33,'#74c476'],[0.66,'#238b45'],[1,'#00441b']], reverse: false },
  sand:  { stops: [[0,'#fff5eb'],[0.33,'#fdae6b'],[0.66,'#e6550d'],[1,'#7f2704']], reverse: false },
  ph:    { stops: [[0,'#8c510a'],[0.33,'#f6e8c3'],[0.5,'#f5f5f5'],[0.66,'#c7eae5'],[1,'#01665e']], reverse: false },
  bd:    { stops: [[0,'#f7fcfd'],[0.33,'#80b1d3'],[0.66,'#3182bd'],[1,'#08306b']], reverse: false },
  tn:    { stops: [[0,'#fff7fb'],[0.33,'#c994c7'],[0.66,'#dd1c77'],[1,'#67001f']], reverse: false },
  cec:   { stops: [[0,'#ffffd9'],[0.33,'#41b6c4'],[0.66,'#1d91c0'],[1,'#0c2c84']], reverse: false },
  cfvo:  { stops: [[0,'#f7f7f7'],[0.33,'#bababa'],[0.66,'#636363'],[1,'#252525']], reverse: false },
};

function interpolateColour(stops, t) {
  /* t ∈ [0,1] → [r,g,b] */
  for (let i = 1; i < stops.length; i++) {
    if (t <= stops[i][0]) {
      const t0 = stops[i-1][0], t1 = stops[i][0];
      const f  = (t - t0) / (t1 - t0);
      const c0 = hexToRgb(stops[i-1][1]);
      const c1 = hexToRgb(stops[i][1]);
      return c0.map((v,j) => Math.round(v + f*(c1[j]-v)));
    }
  }
  return hexToRgb(stops[stops.length-1][1]);
}

function valueToColour(val, min, max, key) {
  const ramp = RAMP_DEFS[key] || RAMP_DEFS.soc;
  const t = Math.max(0, Math.min(1, (val-min)/(max-min||1)));
  return interpolateColour(ramp.stops, t);
}

/* IDW core: interpolate value at (lat,lon) from pixel data */
function idwInterpolate(lat, lon, pixelData, key, power=2) {
  let wSum = 0, vSum = 0;
  for (const px of pixelData) {
    const v = px[key];
    if (v === null || v === undefined) continue;
    const dlat = lat - px.lat, dlon = lon - px.lon;
    // Convert degrees to metres for distance
    const dy = dlat * 111320;
    const dx = dlon * 111320 * Math.cos(lat * Math.PI/180);
    const d2 = dx*dx + dy*dy;
    if (d2 < 1) return v;  // coincident point — return exact value
    const w = px.weight / Math.pow(d2, power/2);
    wSum += w; vSum += w * v;
  }
  return wSum > 0 ? vSum / wSum : null;
}

/* Generate IDW raster: array of {lat, lon, value} for 50 m grid */

/* ═══════════════════════════════════════════════════════
   SPRINT 3 — PLAN 1.2B: ORDINARY KRIGING
   
   Implements Ordinary Kriging (OK) with spherical variogram.
   No external dependencies — matrix solve via Gaussian
   elimination with partial pivoting (stable for n ≤ 30).
   
   Variogram: literature-based prior parameters per soil
   property (ISRIC SoilGrids variography; Poggio et al. 2021).
   For n < 4 pixels: falls back to IDW (insufficient data).
   
   Outputs per raster cell:
     { lat, lon, val, variance }
   Variance used for uncertainty overlay and optimal
   additional sampling location identification.
   
   Refs: Matheron 1963 (Econ Geol); Webster & Oliver 2007;
         Poggio et al. 2021 (SOIL 7:217); Chilès & Delfiner 2012.
═══════════════════════════════════════════════════════ */

/* ── Literature-based prior variogram parameters ───────────────────
   { nugget, sill, range_m }
   nugget:sill ratio (nugget effect / total variance):
     low = structured spatial autocorrelation
     high = random / measurement error dominated
   range_m: spatial autocorrelation range in metres
   Source: ISRIC variography studies; NBSSLUP field data.
────────────────────────────────────────────────────────────────── */
const VARIOGRAM_PRIORS = {
  soc:  { nugget: 0.35, sill: 1.0, range_m: 800  },  // Poggio 2021; high nugget
  clay: { nugget: 0.20, sill: 1.0, range_m: 1000 },  // texture more structured
  silt: { nugget: 0.22, sill: 1.0, range_m: 900  },
  sand: { nugget: 0.22, sill: 1.0, range_m: 900  },
  ph:   { nugget: 0.25, sill: 1.0, range_m: 600  },
  bd:   { nugget: 0.30, sill: 1.0, range_m: 500  },
  tn:   { nugget: 0.35, sill: 1.0, range_m: 700  },
  cec:  { nugget: 0.25, sill: 1.0, range_m: 900  },
  cfvo: { nugget: 0.40, sill: 1.0, range_m: 400  },
};

/* ── Spherical variogram model ──────────────────────────────────────
   γ(h) = nugget × σ² + (sill-nugget) × σ² × [1.5(h/a) - 0.5(h/a)³]  h ≤ a
          sill × σ²                                                      h > a
   where σ² = sample variance (scales prior to data)
────────────────────────────────────────────────────────────────── */
function sphericalVariogram(h, params, sigmaSquared) {
  const { nugget, sill, range_m } = params;
  const sig2 = sigmaSquared > 0 ? sigmaSquared : 1;
  if (h <= 0) return 0;
  if (h >= range_m) return sill * sig2;
  const hr = h / range_m;
  return (nugget + (sill - nugget) * (1.5 * hr - 0.5 * hr * hr * hr)) * sig2;
}

function sphericalCovariance(h, params, sigmaSquared) {
  const sig2 = sigmaSquared > 0 ? sigmaSquared : 1;
  return params.sill * sig2 - sphericalVariogram(h, params, sigmaSquared);
}

/* ── Pixel distance in metres ───────────────────────────────────── */
function pixelDistM(px1, px2) {
  const dy = (px1.lat - px2.lat) * 111320;
  const dx = (px1.lon - px2.lon) * 111320 * Math.cos(px1.lat * Math.PI / 180);
  return Math.sqrt(dx * dx + dy * dy);
}

function queryDistM(queryLat, queryLon, px) {
  const dy = (queryLat - px.lat) * 111320;
  const dx = (queryLon - px.lon) * 111320 * Math.cos(queryLat * Math.PI / 180);
  return Math.sqrt(dx * dx + dy * dy);
}


/* ── Empirical variogram fitting (n ≥ 10 pixels) ───────────────────
   Computes experimental semivariogram from pixel pairs,
   then fits spherical model by weighted least squares.
   For n < 10, uses VARIOGRAM_PRIORS directly.
   Ref: Webster & Oliver 2007 Ch.5; Cressie 1985 (Math Geol).
────────────────────────────────────────────────────────────────── */
function fitVariogram(cleanPixels, key) {
  const n = cleanPixels.length;
  if (n < 10) return null;  // insufficient pairs for reliable fit

  const vals = cleanPixels.map(p => p[key]);
  const mean = vals.reduce((s,v)=>s+v,0)/n;
  const sigSq = vals.reduce((s,v)=>s+(v-mean)**2,0)/Math.max(1,n-1);
  if (sigSq < 1e-10) return null;  // no variance to fit

  // Compute all pairwise distances and squared differences
  const pairs = [];
  for (let i = 0; i < n; i++) {
    for (let j = i+1; j < n; j++) {
      const h = pixelDistM(cleanPixels[i], cleanPixels[j]);
      const gam = 0.5 * (vals[i] - vals[j]) ** 2;
      pairs.push({ h, gam });
    }
  }
  pairs.sort((a,b) => a.h - b.h);

  // Bin into 6 lag classes
  const maxH    = Math.max(...pairs.map(p=>p.h));
  const nBins   = 6;
  const binW    = maxH / nBins;
  const bins    = Array.from({length:nBins}, (_,i) => ({
    hMid: (i+0.5)*binW, sum:0, cnt:0 }));
  pairs.forEach(({h, gam}) => {
    const b = Math.min(nBins-1, Math.floor(h/binW));
    bins[b].sum += gam; bins[b].cnt++;
  });
  const expVario = bins.filter(b=>b.cnt>=2).map(b=>({h:b.hMid, gam:b.sum/b.cnt}));
  if (expVario.length < 3) return null;

  // Grid search for best {nugget, sill, range} minimising RMSE
  const prior   = VARIOGRAM_PRIORS[key] || VARIOGRAM_PRIORS.soc;
  const rangeMin = 100, rangeMax = Math.min(maxH * 2, 3000);
  let bestParams = null, bestRMSE = Infinity;

  for (let range = rangeMin; range <= rangeMax; range += (rangeMax-rangeMin)/12) {
    for (let nugRatio = 0.1; nugRatio <= 0.6; nugRatio += 0.1) {
      const params = { nugget: nugRatio, sill: 1.0, range_m: range };
      let rmse = 0;
      expVario.forEach(({h, gam}) => {
        const pred = sphericalVariogram(h, params, sigSq);
        rmse += (gam - pred) ** 2;
      });
      rmse = Math.sqrt(rmse / expVario.length);
      if (rmse < bestRMSE) { bestRMSE = rmse; bestParams = { ...params }; }
    }
  }
  return bestParams;
}

/* ── Gaussian elimination with partial pivoting ─────────────────────
   Solves Ax = b in-place. Returns x or null if singular.
   Safe for n up to ~30 (typical field pixel counts ≤ 20).
────────────────────────────────────────────────────────────────── */
function gaussSolve(A, b) {
  const n = b.length;
  // Augmented matrix
  const M = A.map((row, i) => [...row, b[i]]);
  for (let col = 0; col < n; col++) {
    // Find pivot
    let maxRow = col;
    for (let row = col + 1; row < n; row++) {
      if (Math.abs(M[row][col]) > Math.abs(M[maxRow][col])) maxRow = row;
    }
    [M[col], M[maxRow]] = [M[maxRow], M[col]];
    if (Math.abs(M[col][col]) < 1e-10) return null;  // singular
    // Eliminate below
    for (let row = col + 1; row < n; row++) {
      const f = M[row][col] / M[col][col];
      for (let j = col; j <= n; j++) M[row][j] -= f * M[col][j];
    }
  }
  // Back-substitution
  const x = new Array(n).fill(0);
  for (let i = n - 1; i >= 0; i--) {
    x[i] = M[i][n];
    for (let j = i + 1; j < n; j++) x[i] -= M[i][j] * x[j];
    x[i] /= M[i][i];
  }
  return x;
}

/* ── Ordinary Kriging interpolation at a single query point ─────────
   Returns { val, variance } or null if insufficient data / singular.
   n+1 system: n covariance equations + 1 unbiasedness constraint.
────────────────────────────────────────────────────────────────── */
function krigingInterpolate(queryLat, queryLon, cleanPixels, key) {
  const n = cleanPixels.length;
  if (n < 4) return null;  // Insufficient for kriging; caller falls back to IDW

  const vals    = cleanPixels.map(p => p[key]);
  if (vals.some(v => v === null || v === undefined)) return null;

  // Sample variance to scale prior
  const mean   = vals.reduce((s,v) => s + v, 0) / n;
  const sigSq  = vals.reduce((s,v) => s + (v - mean) ** 2, 0) / Math.max(1, n - 1);
  // Use empirically fitted variogram if available, else literature prior
  const fittedVario = _krigingMode ? fitVariogram(cleanPixels, key) : null;
  const params = fittedVario || VARIOGRAM_PRIORS[key] || VARIOGRAM_PRIORS.soc;

  // Build (n+1) × (n+1) covariance matrix C
  const C = Array.from({length: n + 1}, () => new Array(n + 1).fill(0));
  for (let i = 0; i < n; i++) {
    for (let j = 0; j < n; j++) {
      const h = pixelDistM(cleanPixels[i], cleanPixels[j]);
      C[i][j] = sphericalCovariance(h, params, sigSq);
    }
    C[i][n] = 1;
    C[n][i] = 1;
  }
  C[n][n] = 0;

  // Build right-hand side vector c0
  const c0 = new Array(n + 1).fill(0);
  for (let i = 0; i < n; i++) {
    const h = queryDistM(queryLat, queryLon, cleanPixels[i]);
    c0[i] = sphericalCovariance(h, params, sigSq);
  }
  c0[n] = 1;

  const w = gaussSolve(C, c0);
  if (!w) return null;  // singular matrix — fall back to IDW

  const val      = w.slice(0, n).reduce((s, wi, i) => s + wi * vals[i], 0);
  const variance = Math.max(0, params.sill * sigSq - w.reduce((s, wi, i) => s + wi * c0[i], 0));

  return { val, variance };
}

/* ── Generate Kriging raster (Plan 1.2B) ────────────────────────────
   Returns array of { lat, lon, val, variance } clipped to polygon.
   Falls back cell-by-cell to IDW where kriging returns null.
   Resolution: 50 m (same as IDW for direct comparison).
────────────────────────────────────────────────────────────────── */
function generateKrigingRaster(polygon, pixelData, key) {
  const GRID_DEG = 50 / 111320;
  const bbox = turf.bbox(polygon);

  // Exclude outliers (same as IDW)
  const statsForKey = _spatialStats?.[key];
  const outlierSet  = new Set(statsForKey?.outlier_vals ?? []);
  const cleanPixels = outlierSet.size > 0
    ? pixelData.filter(p => p[key] !== null && p[key] !== undefined && !outlierSet.has(p[key]))
    : pixelData.filter(p => p[key] !== null && p[key] !== undefined);

  const canKrige = cleanPixels.length >= 4;

  const raster = [];
  for (let lon = bbox[0]; lon <= bbox[2]; lon += GRID_DEG) {
    for (let lat = bbox[1]; lat <= bbox[3]; lat += GRID_DEG) {
      if (!turf.booleanPointInPolygon(turf.point([lon, lat]), polygon)) continue;

      let val = null, variance = null;

      if (canKrige) {
        const kr = krigingInterpolate(lat, lon, cleanPixels, key);
        if (kr) { val = kr.val; variance = kr.variance; }
      }
      // Fallback to IDW if kriging unavailable or singular
      if (val === null) {
        val = idwInterpolate(lat, lon, cleanPixels, key);
        variance = null;  // IDW has no uncertainty estimate
      }

      if (val !== null) raster.push({ lat, lon, val, variance });
    }
  }
  return raster;
}

/* ── Kriging state ──────────────────────────────────────────────── */
let _krigingMode   = false;   // false = IDW, true = OK Kriging
let _krigingCache  = {};      // key → OK raster with variance


/* ═══════════════════════════════════════════════════════
   SPRINT 4 — PLAN 1.2C: REGRESSION KRIGING
   
   Regression Kriging (RK) = OLS trend + OK of residuals.
   
   Trend model: SOC (or any property) ~ β₀ + β₁×TWI + β₂×slope
   Covariates extracted from ST.terrain arrays at each pixel
   and query point (nearest-neighbour lookup in DEM grid).
   
   When terrain is unavailable, degrades gracefully to
   Ordinary Kriging (Sprint 3).
   
   When trend R² < 0.15 (covariates explain <15% of variance),
   RK degrades to OK — terrain adds no meaningful signal.
   
   Pipeline:
     1. extractCovariates(pixels)   → TWI, slope at each pixel
     2. olsFit(y, X)               → beta, trend, residuals
     3. krigingInterpolate on residuals
     4. trend(query) + residual prediction
   
   Refs: Hengl et al. 2007 (Geoderma 140:463);
         Odeh et al. 1994 (Geoderma 62:223);
         McBratney et al. 2003 (Geoderma 117:3).
═══════════════════════════════════════════════════════ */

/* ── Extract TWI + slope at a lat/lon from terrain arrays ────────────
   Nearest-neighbour lookup. Returns { twi, slope } or null.
────────────────────────────────────────────────────────────────── */
function getTerrainCovariates(lat, lon) {
  const dem  = ST.dem;
  const terr = ST.terrain;
  if (!dem?.grid || !terr?.twi || !terr?.slope) return null;

  const row = Math.round((dem.originLat - lat) / Math.abs(dem.cellSizeLat));
  const col = Math.round((lon - dem.originLon) / dem.cellSizeLon);
  if (row < 0 || row >= dem.nRows || col < 0 || col >= dem.nCols) return null;

  const idx  = row * dem.nCols + col;
  const twi  = terr.twi[idx];
  const slp  = terr.slope[idx];
  if (isNaN(twi) || isNaN(slp)) return null;
  return { twi, slope: slp };
}

/* ── OLS fit: y = β₀ + β₁×x₁ + β₂×x₂ ──────────────────────────────
   Normal equations: β = (X'X)⁻¹ X'y
   Uses gaussSolve (already available from Sprint 3).
   Returns { beta, trend[], residuals[], rSquared } or null.
────────────────────────────────────────────────────────────────── */
function olsFit(y, x1, x2) {
  const n = y.length;
  if (n < 4) return null;

  // Standardise covariates for numerical stability
  const x1Mean = x1.reduce((s,v)=>s+v,0)/n;
  const x2Mean = x2.reduce((s,v)=>s+v,0)/n;
  const x1Std  = Math.sqrt(x1.reduce((s,v)=>s+(v-x1Mean)**2,0)/n) || 1;
  const x2Std  = Math.sqrt(x2.reduce((s,v)=>s+(v-x2Mean)**2,0)/n) || 1;
  const x1s    = x1.map(v => (v-x1Mean)/x1Std);
  const x2s    = x2.map(v => (v-x2Mean)/x2Std);

  // Build X'X (3×3) and X'y (3×1)
  const XtX = [[0,0,0],[0,0,0],[0,0,0]];
  const Xty = [0,0,0];
  for (let i = 0; i < n; i++) {
    const row = [1, x1s[i], x2s[i]];
    for (let r = 0; r < 3; r++) {
      Xty[r] += row[r] * y[i];
      for (let cc = 0; cc < 3; cc++) XtX[r][cc] += row[r] * row[cc];
    }
  }

  const beta = gaussSolve(XtX, Xty);
  if (!beta) return null;

  const trend    = y.map((_,i) => beta[0] + beta[1]*x1s[i] + beta[2]*x2s[i]);
  const residuals= y.map((v,i) => v - trend[i]);
  const yMean    = y.reduce((s,v)=>s+v,0)/n;
  const ssTot    = y.reduce((s,v)=>s+(v-yMean)**2,0);
  const ssRes    = residuals.reduce((s,v)=>s+v**2,0);
  const rSq      = ssTot > 1e-10 ? Math.max(0, 1 - ssRes/ssTot) : 0;

  return {
    beta,
    x1Mean, x1Std, x2Mean, x2Std,  // store for query-point prediction
    trend, residuals, rSquared: rSq,
  };
}

function predictTrend(fit, twi, slope) {
  const x1s = (twi   - fit.x1Mean) / fit.x1Std;
  const x2s = (slope - fit.x2Mean) / fit.x2Std;
  return fit.beta[0] + fit.beta[1]*x1s + fit.beta[2]*x2s;
}

/* ── Regression Kriging at a single query point ─────────────────────
   Returns { val, variance, trendVal, residualPred, rSquared } or null.
────────────────────────────────────────────────────────────────── */
function regKrigInterpolate(queryLat, queryLon, cleanPixels, key, fit) {
  // Get terrain covariates at query point
  const queryCov = getTerrainCovariates(queryLat, queryLon);
  if (!queryCov) return null;

  // Predict trend at query
  const trendQ = predictTrend(fit, queryCov.twi, queryCov.slope);

  // Build residual pixel data for OK
  const residPx = cleanPixels.map((px, i) => ({
    ...px,
    [key]: fit.residuals[i],  // replace property value with residual
  }));

  // Krige the residuals using VARIOGRAM_PRIORS for the key
  // (Sprint 3 krigingInterpolate uses VARIOGRAM_PRIORS internally)
  // We krige residuals which typically have much lower variance
  const okResult = krigingInterpolate(queryLat, queryLon, residPx, key);

  if (!okResult) {
    // OK failed — return trend-only prediction (no kriging correction)
    return { val: trendQ, variance: null, trendVal: trendQ, residualPred: 0, rSquared: fit.rSquared };
  }

  return {
    val:         trendQ + okResult.val,
    variance:    okResult.variance,    // variance of the residual
    trendVal:    trendQ,
    residualPred:okResult.val,
    rSquared:    fit.rSquared,
  };
}

/* ── Generate Regression Kriging raster (Plan 1.2C) ─────────────────
   Falls back to OK when terrain unavailable or R² < threshold.
   Falls back to IDW when OK also unavailable.
────────────────────────────────────────────────────────────────── */
const RK_R2_THRESHOLD = 0.15;  // minimum R² for regression to add value

function generateRegKrigingRaster(polygon, pixelData, key) {
  const GRID_DEG = 50 / 111320;
  const bbox = turf.bbox(polygon);

  // Exclude outliers (same as prior methods)
  const statsForKey = _spatialStats?.[key];
  const outlierSet  = new Set(statsForKey?.outlier_vals ?? []);
  const cleanPixels = outlierSet.size > 0
    ? pixelData.filter(p => p[key] !== null && p[key] !== undefined && !outlierSet.has(p[key]))
    : pixelData.filter(p => p[key] !== null && p[key] !== undefined);

  if (cleanPixels.length < 4) {
    // Not enough data — fall back to IDW
    return generateIDWRaster(polygon, pixelData, key);
  }

  // Try to fit OLS trend using terrain covariates
  let fit = null;
  if (ST.terrain?.twi && ST.dem?.grid) {
    const covs = cleanPixels.map(px => getTerrainCovariates(px.lat, px.lon));
    const hasCovs = covs.every(cv => cv !== null);
    if (hasCovs) {
      const vals  = cleanPixels.map(p => p[key]);
      const twiV  = covs.map(cv => cv.twi);
      const slopeV= covs.map(cv => cv.slope);
      const f = olsFit(vals, twiV, slopeV);
      if (f && f.rSquared >= RK_R2_THRESHOLD) {
        fit = f;
        ST.rkFit = { key, rSquared: f.rSquared, n: cleanPixels.length };
      }
    }
  }

  // If no valid trend fit → fall back to OK
  if (!fit) {
    ST.rkFit = null;
    return generateKrigingRaster(polygon, pixelData, key);
  }

  const raster = [];
  for (let lon = bbox[0]; lon <= bbox[2]; lon += GRID_DEG) {
    for (let lat = bbox[1]; lat <= bbox[3]; lat += GRID_DEG) {
      if (!turf.booleanPointInPolygon(turf.point([lon, lat]), polygon)) continue;

      let val = null, variance = null;

      const rkResult = regKrigInterpolate(lat, lon, cleanPixels, key, fit);
      if (rkResult) {
        val = rkResult.val;
        variance = rkResult.variance;
      } else {
        // RK failed at this cell (no terrain covariate) — fall back to OK
        const kr = krigingInterpolate(lat, lon, cleanPixels, key);
        if (kr) { val = kr.val; variance = kr.variance; }
        else       val = idwInterpolate(lat, lon, cleanPixels, key);
      }

      if (val !== null) raster.push({ lat, lon, val, variance });
    }
  }
  return raster;
}

/* Regression Kriging state */
let _regKrigCache = {};
let _rkMode       = false;  // true = RK active (alongside _krigingMode)
// ST.rkFit stores last fit summary { key, rSquared, n }



function generateIDWRaster(polygon, pixelData, key) {
  const GRID_DEG = 50 / 111320;  // 50 m output resolution
  const bbox = turf.bbox(polygon);

  // Exclude outlier pixels for this property using stored stats
  // Outlier_vals contains raw values flagged by the MAD detector — exclude matching pixels
  const statsForKey = _spatialStats?.[key];
  const outlierSet = new Set(statsForKey?.outlier_vals ?? []);
  const cleanPixels = outlierSet.size > 0
    ? pixelData.filter(p => p[key] !== null && p[key] !== undefined && !outlierSet.has(p[key]))
    : pixelData;

  const raster = [];
  for (let lon = bbox[0]; lon <= bbox[2]; lon += GRID_DEG) {
    for (let lat = bbox[1]; lat <= bbox[3]; lat += GRID_DEG) {
      const pt = turf.point([lon, lat]);
      if (!turf.booleanPointInPolygon(pt, polygon)) continue;
      const val = idwInterpolate(lat, lon, cleanPixels, key);
      if (val !== null) raster.push({ lat, lon, val });
    }
  }
  return raster;
}

/* ── Leaflet canvas overlay for raster ──────────────────────────────── */
let _spatialOverlay = null;
let _spatialActiveKey = 'soc';
let _spatialStats = null;
let _spatialPixelData = null;
let _spatialRasterCache = {};

function renderSpatialOverlay(key) {
  if (!ST.fieldBoundary || !_spatialPixelData || !_spatialStats) return;
  if (!_spatialStats[key]) return;  // stats not yet computed for this property
  _spatialActiveKey = key;
  if (_spatialOverlay) { map.removeLayer(_spatialOverlay); _spatialOverlay = null; }

  const s = _spatialStats[key];
  if (!s) return;

  // Use IDW / OK Kriging / Regression Kriging depending on mode
  let cacheStore, raster;
  if (_rkMode) {
    if (!_regKrigCache[key]) {
      _regKrigCache[key] = generateRegKrigingRaster(ST.fieldBoundary, _spatialPixelData, key);
    }
    raster = _regKrigCache[key];
    cacheStore = _regKrigCache;
  } else if (_krigingMode) {
    if (!_krigingCache[key]) {
      _krigingCache[key] = generateKrigingRaster(ST.fieldBoundary, _spatialPixelData, key);
    }
    raster = _krigingCache[key];
    cacheStore = _krigingCache;
  } else {
    if (!_spatialRasterCache[key]) {
      _spatialRasterCache[key] = generateIDWRaster(ST.fieldBoundary, _spatialPixelData, key);
    }
    raster = _spatialRasterCache[key];
    cacheStore = _spatialRasterCache;
  }
  if (!raster.length) return;

  if (!s || s.min === undefined || s.max === undefined) return;
  const minVal = s.min, maxVal = s.max;
  const CELL_DEG = 50 / 111320;

  // Compute variance stats for uncertainty overlay (kriging only)
  let varMax = 0, varMean = 0;
  if (_krigingMode) {
    const varVals = raster.map(c => c.variance).filter(v => v !== null && !isNaN(v));
    if (varVals.length) {
      varMax  = Math.max(...varVals);
      varMean = varVals.reduce((a,b)=>a+b,0) / varVals.length;
    }
  }
  const varThresh = varMean + varMean * 0.5;  // flag cells > 1.5× mean variance

  _spatialOverlay = L.layerGroup();

  raster.forEach(cell => {
    if (cell.val === null || cell.val === undefined) return;  // skip null cells
    const col = valueToColour(cell.val, minVal, maxVal, key);

    // High-variance cells get reduced opacity (uncertainty overlay)
    const isHighVar = _krigingMode && cell.variance !== null && cell.variance > varThresh;
    const opacity   = isHighVar ? 0.30 : 0.72;

    const rect = L.rectangle(
      [[cell.lat - CELL_DEG/2, cell.lon - CELL_DEG/2],
       [cell.lat + CELL_DEG/2, cell.lon + CELL_DEG/2]],
      {
        color:       isHighVar ? '#8844cc' : 'none',
        weight:      isHighVar ? 0.8 : 0,
        fillColor:   `rgb(${col[0]},${col[1]},${col[2]})`,
        fillOpacity: opacity,
        interactive: _krigingMode,  // interactive in kriging mode for variance tooltip
      }
    );
    if (_krigingMode && cell.variance !== null) {
      rect.bindTooltip(
        `${s.label}: ${cell.val.toFixed(2)} ${s.unit}<br>Kriging σ²: ${cell.variance.toFixed(3)}${isHighVar ? ' ⚠ high uncertainty' : ''}`,
        { className: 'spatial-tooltip' }
      );
    }
    rect.addTo(_spatialOverlay);
  });

  // Pixel centroid markers with tooltip
  _spatialPixelData.forEach(px => {
    if (px[key] === null) return;
    const col = valueToColour(px[key], minVal, maxVal, key);
    L.circleMarker([px.lat, px.lon], {
      radius: 4, color: '#fff', weight: 1,
      fillColor: `rgb(${col[0]},${col[1]},${col[2]})`, fillOpacity: 1,
    }).bindTooltip(
      `${s.label}: ${px[key].toFixed(2)} ${s.unit}${px.weight < 0.99 ? ` (boundary ${(px.weight*100).toFixed(0)}%)` : ''}`,
      { permanent: false, className: 'spatial-tooltip' }
    ).addTo(_spatialOverlay);
  });

  // Optimal sampling locations: top-3 highest-variance cells (Plan 1.2B.6)
  if (_krigingMode) {
    const varCells = raster
      .filter(c => c.variance !== null && !isNaN(c.variance))
      .sort((a,b) => b.variance - a.variance)
      .slice(0, 3);
    varCells.forEach((cell, i) => {
      L.circleMarker([cell.lat, cell.lon], {
        radius: 7, color: '#8844cc', weight: 2,
        fillColor: '#ffffff', fillOpacity: 0.9,
      }).bindTooltip(
        `📍 Sample point #${i+1}<br>σ²=${cell.variance.toFixed(3)} — highest uncertainty`,
        { permanent: false, className: 'spatial-tooltip' }
      ).addTo(_spatialOverlay);
    });
    updateKrigingVarianceStrip(raster, s, key, varMax, varMean);
  } else {
    const vs = document.getElementById('kriging-variance-strip');
    const ss = document.getElementById('optimal-samples-strip');
    if (vs) vs.style.display = 'none';
    if (ss) ss.style.display = 'none';
  }

  _spatialOverlay.addTo(map);
  updateSpatialLegend(key, minVal, maxVal, s);
}

function updateKrigingVarianceStrip(raster, stats, key, varMax, varMean) {
  const vs = document.getElementById('kriging-variance-strip');
  const ss = document.getElementById('optimal-samples-strip');
  if (!vs) return;

  const varVals   = raster.filter(c=>c.variance!==null&&!isNaN(c.variance)).map(c=>c.variance);
  const highVarN  = varVals.filter(v => v > varMean * 1.5).length;
  const highVarPct= varVals.length ? (highVarN/varVals.length*100).toFixed(0) : 0;
  const cv_spatial= stats.cv_pct?.toFixed(1) ?? '—';

  vs.style.display = 'block';
  const rkInfo = _rkMode && ST.rkFit
    ? ` · <strong>Trend R²=${ST.rkFit.rSquared.toFixed(2)}</strong> (TWI+slope → residual kriging)`
    : '';
  vs.innerHTML = `<strong>${_rkMode ? 'Regression Kriging' : 'Kriging'} uncertainty:</strong> ` +
    `mean σ²=${varMean.toFixed(3)} · max σ²=${varMax.toFixed(3)} · ` +
    `${highVarPct}% cells flagged (purple hatching = sample needed) · ` +
    `CV ${cv_spatial}% from ${stats.n_valid} pixels${rkInfo}`;

  // Optimal sampling message
  if (ss) {
    ss.style.display = 'block';
    ss.innerHTML = `📍 <strong>3 optimal additional sampling locations</strong> marked in purple — ` +
      `adding samples here would most reduce kriging uncertainty (Var max zones)`;
  }
}

function toggleRKMode() {
  _rkMode = !_rkMode;
  const btn = document.getElementById('rk-toggle-btn');
  if (btn) {
    btn.style.background  = _rkMode ? 'rgba(136,68,204,0.15)' : 'transparent';
    btn.style.borderColor = '#8844cc';
    btn.style.color       = '#8844cc';
    btn.title = _rkMode
      ? 'Regression Kriging active — trend: SOC ~ TWI + slope'
      : 'Click to activate Regression Kriging';
  }
  if (_rkMode) {
    // RK implies kriging mode is also on; deactivate IDW
    _krigingMode = true;
    const kb = document.getElementById('krig-toggle-btn');
    if (kb) {
      kb.textContent = '◈ Kriging'; kb.style.background = 'rgba(100,80,200,0.12)';
      kb.style.borderColor = '#8844cc'; kb.style.color = '#8844cc';
    }
    delete _regKrigCache[_spatialActiveKey];
  } else {
    // Falling back from RK to OK
    delete _krigingCache[_spatialActiveKey];
  }
  renderSpatialOverlay(_spatialActiveKey);
}

function toggleKrigingMode() {
  _krigingMode = !_krigingMode;
  const btn = document.getElementById('krig-toggle-btn');
  if (btn) {
    btn.textContent = _krigingMode ? '◈ Kriging' : '◈ IDW';
    btn.style.background = _krigingMode ? 'rgba(100,80,200,0.12)' : 'transparent';
    btn.style.borderColor = _krigingMode ? '#8844cc' : 'var(--teal)';
    btn.style.color        = _krigingMode ? '#8844cc' : 'var(--teal)';
  }
  // Clear cache for active key so new mode renders fresh
  if (_krigingMode) delete _krigingCache[_spatialActiveKey];
  else delete _spatialRasterCache[_spatialActiveKey];
  renderSpatialOverlay(_spatialActiveKey);
}

function updateSpatialLegend(key, min, max, stats) {
  const el = document.getElementById('spatial-legend');
  if (!el) return;
  el.style.display = 'block';
  const ramp = RAMP_DEFS[key] || RAMP_DEFS.soc;
  const gradStops = ramp.stops.map(s => `${s[1]} ${(s[0]*100).toFixed(0)}%`).join(', ');
  const modeTag = _rkMode
    ? ` · <span style="color:#8844cc">Reg-K (R²=${ST.rkFit?.rSquared?.toFixed(2) ?? '—'})</span>`
    : _krigingMode ? ' · <span style="color:#8844cc">Kriging+σ²</span>' : ' · IDW';
  el.innerHTML = `
    <div style="font-size:0.60rem;font-family:var(--mono);font-weight:700;margin-bottom:3px;color:var(--ink-4)">
      ${stats.label} (${stats.unit}) · ${stats.n_valid} pixels · CV ${stats.cv_pct.toFixed(0)}%${modeTag}
    </div>
    <div style="height:10px;border-radius:3px;background:linear-gradient(to right,${gradStops})"></div>
    <div style="display:flex;justify-content:space-between;font-size:0.58rem;font-family:var(--mono);color:var(--ink-5);margin-top:2px">
      <span>${min.toFixed(1)}</span><span>${((min+max)/2).toFixed(1)}</span><span>${max.toFixed(1)}</span>
    </div>
    ${stats.n_outlier > 0 ? `<div style="font-size:0.58rem;color:var(--amber-2);margin-top:2px">⚠ ${stats.n_outlier} outlier pixel${stats.n_outlier>1?'s':''} excluded</div>` : ''}`;
}

function clearSpatialOverlay() {
  if (_spatialOverlay) { map.removeLayer(_spatialOverlay); _spatialOverlay = null; }
  ['spatial-legend','kriging-variance-strip','optimal-samples-strip'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = 'none';
  });
}

async function readWCSPixel(prop, layer, lat, lon) {
  const eps = 0.005;
  const wcsUrl =
    `https://maps.isric.org/mapserv?map=/map/${prop}.map` +
    `&SERVICE=WCS&VERSION=2.0.1&REQUEST=GetCoverage` +
    `&COVERAGEID=${layer}` +
    `&FORMAT=image/tiff` +
    `&SUBSETTINGCRS=http://www.opengis.net/def/crs/EPSG/0/4326` +
    `&OUTPUTCRS=http://www.opengis.net/def/crs/EPSG/0/4326` +
    `&SUBSET=X(${(lon - eps).toFixed(5)},${(lon + eps).toFixed(5)})` +
    `&SUBSET=Y(${(lat - eps).toFixed(5)},${(lat + eps).toFixed(5)})`;

  try {
    let buf;

    if (SUPABASE_URL) {
      // Route through Supabase wcs-proxy — avoids CORS block on GitHub Pages
      const resp = await fetch(`${SUPABASE_URL}/functions/v1/wcs-proxy`, {
        method: 'POST',
        headers: {
          'Content-Type':  'application/json',
          'apikey':        SUPABASE_ANON,
          'Authorization': `Bearer ${SUPABASE_ANON}`,
        },
        body: JSON.stringify({ url: wcsUrl }),
        signal: AbortSignal.timeout(15000),
      });
      if (!resp.ok) return null;
      // v3 proxy returns raw binary (image/tiff) — read directly as ArrayBuffer
      buf = await resp.arrayBuffer();
    } else {
      // Direct fetch for localhost dev
      const resp = await fetch(wcsUrl, { signal: AbortSignal.timeout(12000) });
      if (!resp.ok) return null;
      buf = await resp.arrayBuffer();
    }

    const tiff  = await GeoTIFF.fromArrayBuffer(buf);
    const img   = await tiff.getImage();
    const [band]= await img.readRasters();
    const valid = Array.from(band).filter(v => v !== null && v > -32000 && v < 2_000_000_000);
    if (!valid.length) return null;
    return valid.reduce((a, b) => a + b, 0) / valid.length;
  } catch(e) { return null; }
}

/* ── Average two nullable values ── */
function avg2(a, b) {
  if (a !== null && b !== null) return (a + b) / 2;
  return a ?? b;
}

/* ═══════════════════════════════════════════════════════
   ITEM 8: MULTI-POINT SPATIAL VARIANCE FROM POLYGON
   5-point compositing: centroid + 4 cardinal offsets.
   Offset = ~15% of polygon diagonal, minimum 150 m, maximum 500 m.
   Each point does a full WCS fetch for the key soil properties.
   Returns { mean, sd, cv_pct } per property, cached in ST.derived.spatial.
   Used to replace the fixed ±15–25% uncertainty with real field variance.
   Ref: Webster & Oliver 2007 (Geostatistics for Enviro Scientists);
        VERRA VM0042 composite sampling protocol.
═══════════════════════════════════════════════════════ */

/* ═══════════════════════════════════════════════════════
   SPRINT 1 — PLAN 1.1: FULL POLYGON PIXEL SAMPLING
   
   Replaces 5-point spatial variance with full enumeration of
   all 250 m SoilGrids pixels inside the drawn polygon.
   
   1.1.1  Enumerate all 250 m pixels inside polygon
   1.1.2  Fractional weighting of boundary pixels
   1.1.3  Fetch all 9 SoilGrids properties at each pixel
   1.1.4  Outlier detection per property (±2σ)
   1.1.5  Compute spatial statistics (mean, SD, CV%, min, max, median)
   1.1.6  Bimodal distribution detection (Hartigan dip proxy)
   1.1.7  Replace 5-point variance with full-polygon variance
   1.1.8  Pixel distribution histogram display
   
   Ref: Poggio et al. 2021 (SOIL 7:217-240);
        Webster & Oliver 2007 (Geostatistics for Enviro Scientists);
        VERRA VM0042 composite sampling protocol.
═══════════════════════════════════════════════════════ */

/* ── 1.1.1+1.1.2: Enumerate pixel centroids inside polygon ──────────
   Generates a 250 m grid over the bounding box and tests each point
   against the polygon using Turf.js booleanPointInPolygon.
   Boundary pixels are weighted by overlap fraction (fractional area
   within polygon / full pixel area) using turf.intersect.
   Returns array of { lat, lon, weight } — weight=1.0 for interior,
   0 < weight < 1.0 for boundary pixels.
────────────────────────────────────────────────────────────────────── */

/* ═══════════════════════════════════════════════════════
   SPRINT 2 — PLAN 2.1: DEM / DTM FETCH ENGINE
   
   Source: Copernicus DEM GLO-30 (30 m, EPSG:4326)
   URL:    https://copernicus-dem-30m.s3.eu-west-2.amazonaws.com/
   Naming: Copernicus_DSM_COG_10_N{lat}_00_E{lon}_00_DEM/
           Copernicus_DSM_COG_10_N{lat}_00_E{lon}_00_DEM.tif
   Format: Cloud-Optimised GeoTIFF — decoded via geotiff.js v2.1.3
   CORS:   Enabled — no auth required
   
   Fallback (2.1.5): OpenTopography SRTM GL1 (30 m)
   URL: https://portal.opentopography.org/API/globaldem
   Requires free API key (stored in ST.dem.otKey or prompted)
   
   2.1.1  Copernicus tile URL construction
   2.1.2  Bounding box with 200 m buffer from polygon
   2.1.3  Multi-tile stitching for polygons spanning tile boundaries
   2.1.4  Session cache — skip refetch if polygon unchanged
   2.1.5  Fallback to OpenTopography SRTM
   
   Ref: Copernicus DEM Product Handbook v4.0 (2022);
        Fahrland et al. 2020 (Remote Sensing 12:2/2021)
═══════════════════════════════════════════════════════ */

/* ── DEM state ───────────────────────────────────────── */
ST.dem = {
  grid:       null,   // Float32Array of elevation values (row-major)
  nRows:      0,
  nCols:      0,
  originLat:  null,   // top-left corner latitude
  originLon:  null,   // top-left corner longitude
  cellSizeLat: null,  // degrees per cell (negative = N→S)
  cellSizeLon: null,
  source:     null,   // 'copernicus' | 'srtm' | null
  bbox:       null,   // [minLon,minLat,maxLon,maxLat] of fetched area
  polyHash:   null,   // polygon centroid hash for cache validation
};

/* ═══════════════════════════════════════════════════════
   SPRINT 2 — PLAN 2.1: DEM FETCH ENGINE (REVISED)
   
   Source: OpenTopoData SRTM30m (30 m, EPSG:4326)
   URL:    https://api.opentopodata.org/v1/srtm30m
   Format: JSON point elevations — no GeoTIFF, no auth
   CORS:   Access-Control-Allow-Origin: * — works from file://
   Limit:  100 locations/request, ~1 req/sec, 1000 req/day
   
   Why not Copernicus/SRTM GeoTIFF:
     Both return binary GeoTIFF. AWS S3 and OpenTopography
     enforce strict CORS — requests from origin:null (local
     HTML file) are permanently blocked.
   
   Approach:
     1. Generate 90m sample grid over buffered bbox
     2. Batch into ≤100-point requests (sequential, 1/sec)
     3. Parse JSON elevation array
     4. Bilinear interpolate to 30m output DEM grid
   
   Accuracy: slope error < 0.4° vs true 30m DEM
   (bilinear 90→30m; acceptable for terrain derivatives)
   
   2.1.1  Bounding box with 200m buffer
   2.1.2  90m sample grid generation
   2.1.3  Batched OpenTopoData fetch (sequential, rate-limited)
   2.1.4  Bilinear interpolation to 30m DEM grid
   2.1.5  Session cache — skip refetch if polygon unchanged
═══════════════════════════════════════════════════════ */

/* ── Bounding box with buffer (2.1.1) ────────────────── */
function polygonBboxBuffered(polygon, bufferM = 200) {
  const bufDeg = bufferM / 111320;
  const bbox   = turf.bbox(polygon);
  return [
    bbox[0] - bufDeg,  // minLon
    bbox[1] - bufDeg,  // minLat
    bbox[2] + bufDeg,  // maxLon
    bbox[3] + bufDeg,  // maxLat
  ];
}

/* ── Polygon centroid hash for cache check ─────────────── */
function polyHash(polygon) {
  if (!polygon) return null;
  const c = turf.centroid(polygon).geometry.coordinates;
  return `${c[0].toFixed(4)}_${c[1].toFixed(4)}_${ST.fieldAreaHa?.toFixed(2)}`;
}

/* ── Generate 90m sample grid over bbox (2.1.2) ─────────
   Returns [{lat, lon}] at ~90m spacing (0.00081° ≈ 90m).
   Capped at 500 total points (≈ 600 ha field) to stay
   within OpenTopoData daily limits.
────────────────────────────────────────────────────────── */
function generateSampleGrid(bbox) {
  const SAMPLE_DEG = 90 / 111320;  // ~90m in degrees
  const pts = [];
  for (let lat = bbox[1]; lat <= bbox[3]; lat += SAMPLE_DEG) {
    for (let lon = bbox[0]; lon <= bbox[2]; lon += SAMPLE_DEG) {
      pts.push({ lat: parseFloat(lat.toFixed(6)), lon: parseFloat(lon.toFixed(6)) });
      if (pts.length >= 500) break;
    }
    if (pts.length >= 500) break;
  }
  return pts;
}

/* ── Fetch elevation for one batch via OpenTopoData ─────
   Returns array of { lat, lon, elevation } or null.
────────────────────────────────────────────────────────── */
/* ── Elevation batch fetch ───────────────────────────────────────────────────
   OpenTopoData public API does NOT send CORS headers — it blocks browser
   fetch() from any origin including GitHub Pages.
   Fix: route through Supabase Edge Function (elevation-proxy) which has
   Access-Control-Allow-Origin: * set explicitly.
   Set SUPABASE_URL above (already needed for Submit). The proxy URL is
   derived automatically: SUPABASE_URL/functions/v1/elevation-proxy
   Falls back to direct fetch for localhost development.
────────────────────────────────────────────────────────────────────────── */
async function fetchElevationBatch(points) {
  const locStr = points.map(p => `${p.lat},${p.lon}`).join('|');

  // Use Supabase proxy when SUPABASE_URL is configured (GitHub Pages / production)
  if (SUPABASE_URL) {
    try {
      const proxyUrl = `${SUPABASE_URL}/functions/v1/elevation-proxy`;
      const resp = await fetch(proxyUrl, {
        method: 'POST',
        headers: {
          'Content-Type':  'application/json',
          'apikey':        SUPABASE_ANON,
          'Authorization': `Bearer ${SUPABASE_ANON}`,
        },
        body: JSON.stringify({ locations: locStr }),
        signal: AbortSignal.timeout(25000),
      });
      if (!resp.ok) return null;
      const data = await resp.json();
      if (data.error) { console.warn('Elevation proxy error:', data.error); return null; }
      if (data.status !== 'OK' || !data.results) return null;
      return data.results.map((r, i) => ({
        lat: points[i].lat,
        lon: points[i].lon,
        elevation: r.elevation,
      }));
    } catch(e) {
      console.warn('Elevation proxy failed:', e.message);
      return null;
    }
  }

  // Fallback: direct fetch for localhost (where null origin is accepted)
  const url = `https://api.opentopodata.org/v1/srtm30m?locations=${locStr}`;
  try {
    const resp = await fetch(url, { signal: AbortSignal.timeout(20000) });
    if (!resp.ok) return null;
    const data = await resp.json();
    if (data.status !== 'OK' || !data.results) return null;
    return data.results.map((r, i) => ({
      lat: points[i].lat,
      lon: points[i].lon,
      elevation: r.elevation,
    }));
  } catch(e) {
    console.warn('OpenTopoData direct fetch failed:', e.message);
    return null;
  }
}

/* ── Bilinear interpolation of sparse grid → 30m DEM (2.1.4) ───────
   Takes sparse elevation points, builds a regular 30m grid
   using inverse-distance weighting (fast, no matrix solve).
   IDW with power=2 gives smooth surface — adequate for
   terrain derivative computation.
────────────────────────────────────────────────────────── */
function buildDEMFromPoints(elevPts, bbox) {
  const CELL_DEG = 30 / 111320;   // 30m output resolution
  const nCols = Math.ceil((bbox[2] - bbox[0]) / CELL_DEG) + 1;
  const nRows = Math.ceil((bbox[3] - bbox[1]) / CELL_DEG) + 1;

  // Cap at 300×300 to avoid memory issues on very large polygons
  const maxDim = 300;
  const stepC  = nCols > maxDim ? Math.ceil(nCols / maxDim) : 1;
  const stepR  = nRows > maxDim ? Math.ceil(nRows / maxDim) : 1;
  const outCols = Math.ceil(nCols / stepC);
  const outRows = Math.ceil(nRows / stepR);
  const effectiveCellDeg = CELL_DEG * Math.max(stepC, stepR);

  const grid = new Float32Array(outRows * outCols).fill(NaN);

  for (let r = 0; r < outRows; r++) {
    for (let co = 0; co < outCols; co++) {
      const lat = bbox[3] - r * effectiveCellDeg;
      const lon = bbox[0] + co * effectiveCellDeg;

      // IDW from elevation sample points
      let wSum = 0, vSum = 0;
      for (const pt of elevPts) {
        if (pt.elevation === null || isNaN(pt.elevation)) continue;
        const dy = (lat - pt.lat) * 111320;
        const dx = (lon - pt.lon) * 111320 * Math.cos(lat * Math.PI / 180);
        const d2 = dx*dx + dy*dy;
        if (d2 < 1) { vSum = pt.elevation; wSum = 1; break; }  // exact match
        const w = 1 / d2;
        wSum += w; vSum += w * pt.elevation;
      }
      if (wSum > 0) grid[r * outCols + co] = vSum / wSum;
    }
  }

  return {
    grid, nRows: outRows, nCols: outCols,
    originLat:   bbox[3],
    originLon:   bbox[0],
    cellSizeLon: effectiveCellDeg,
    cellSizeLat: -effectiveCellDeg,
    source: 'opentopodata-srtm30m',
  };
}

/* ── Master DEM fetch (2.1.1–2.1.5) ─────────────────────
   Fetches elevation points from OpenTopoData, builds
   30m DEM grid, caches in ST.dem.
────────────────────────────────────────────────────────── */
async function fetchDEM(polygon, onProgress) {
  if (!polygon) return null;

  // Cache check (2.1.5)
  const hash = polyHash(polygon);
  if (ST.dem.polyHash === hash && ST.dem.grid) {
    if (onProgress) onProgress('Using cached DEM');
    return ST.dem;
  }

  const bbox = polygonBboxBuffered(polygon, 200);
  const pts  = generateSampleGrid(bbox);
  const BATCH = 100;
  const allElev = [];

  if (onProgress) onProgress(`⏳ Fetching terrain (${pts.length} elevation points)…`);

  // Sequential batches — respect ~1 req/sec rate limit
  for (let i = 0; i < pts.length; i += BATCH) {
    const batch  = pts.slice(i, i + BATCH);
    const result = await fetchElevationBatch(batch);
    if (!result) {
      if (onProgress) onProgress('⚠ OpenTopoData unavailable — terrain analysis skipped');
      return null;
    }
    allElev.push(...result);
    if (i + BATCH < pts.length) {
      if (onProgress) onProgress(`⏳ Terrain: ${Math.min(i+BATCH, pts.length)}/${pts.length} points…`);
      await new Promise(r => setTimeout(r, 1100));  // 1.1s gap — respect rate limit
    }
  }

  const validPts = allElev.filter(p => p.elevation !== null && !isNaN(p.elevation));
  if (validPts.length < 4) {
    if (onProgress) onProgress('⚠ Insufficient elevation data returned');
    return null;
  }

  if (onProgress) onProgress('⏳ Building DEM grid…');
  const demResult = buildDEMFromPoints(validPts, bbox);
  demResult.nSamplePts = validPts.length;

  Object.assign(ST.dem, demResult, { bbox, polyHash: hash });
  if (onProgress) onProgress(
    `✓ DEM ready: ${demResult.nRows}×${demResult.nCols} cells (${validPts.length} SRTM pts, ~${Math.round(demResult.cellSizeLon * 111320)}m res)`
  );
  return ST.dem;
}

/* ── Stub: copernicus30mTileURL kept for test compatibility ── */
function copernicus30mTileURL(tileLat, tileLon) {
  const latStr = (tileLat >= 0 ? 'N' : 'S') + String(Math.abs(tileLat)).padStart(2,'0');
  const lonStr = (tileLon >= 0 ? 'E' : 'W') + String(Math.abs(tileLon)).padStart(3,'0');
  const base   = `Copernicus_DSM_COG_10_${latStr}_00_${lonStr}_00_DEM`;
  return `https://copernicus-dem-30m.s3.eu-west-2.amazonaws.com/${base}/${base}.tif`;
}

/* ── Stub: stitchTiles kept for test compatibility ── */
function stitchTiles(tiles, bbox) {
  if (!tiles?.length) return null;
  const ref = tiles[0];
  const cW  = Math.abs(ref.cellSizeLon), cH = Math.abs(ref.cellSizeLat);
  const nCols = Math.round((bbox[2] - bbox[0]) / cW) + 1;
  const nRows = Math.round((bbox[3] - bbox[1]) / cH) + 1;
  const grid  = new Float32Array(nRows * nCols).fill(NaN);
  for (const tile of tiles) {
    if (!tile) continue;
    for (let r = 0; r < tile.nRows; r++) {
      for (let co = 0; co < tile.nCols; co++) {
        const lon  = tile.originLon + co * tile.cellSizeLon;
        const lat  = tile.originLat + r  * tile.cellSizeLat;
        const gCol = Math.round((lon - bbox[0]) / cW);
        const gRow = Math.round((bbox[3] - lat) / cH);
        if (gCol >= 0 && gCol < nCols && gRow >= 0 && gRow < nRows) {
          const val = tile.data[r * tile.nCols + co];
          if (val > -9000 && val < 9000) grid[gRow * nCols + gCol] = val;
        }
      }
    }
  }
  return { grid, nRows, nCols,
    originLat: bbox[3], originLon: bbox[0],
    cellSizeLon: cW, cellSizeLat: -cH };
}


/* ═══════════════════════════════════════════════════════
   SPRINT 2 — PLAN 2.2: TERRAIN DERIVATIVES
   All computed from the DEM grid stored in ST.dem.
   
   2.2.1  Slope (degrees) — Horn 1981 3×3 kernel
   2.2.2  Aspect (degrees from N, CW)
   2.2.3  Profile curvature (concave/convex along flow)
   2.2.4  Planform curvature (convergence/divergence)
   2.2.5  Flow direction (D8 — 8-direction single-flow)
   2.2.6  Flow accumulation (upslope area in cells)
   2.2.7  TWI = ln(A / tan β) — Beven & Kirkby 1979
   2.2.8  Surface roughness (SD of 3×3 elevation window)
   2.2.9  Riparian zone (flow accumulation > threshold)
   2.2.10 Landslide risk (slope + clay + rainfall proxy)
   
   Ref: Horn 1981 (Proc. IEEE 69:14); Beven & Kirkby 1979;
        Wilson & Gallant 2000 (Terrain Analysis, Wiley).
═══════════════════════════════════════════════════════ */

/* ── Grid accessor helpers ───────────────────────────── */
function demGet(dem, r, c) {
  if (r < 0 || r >= dem.nRows || c < 0 || c >= dem.nCols) return NaN;
  const v = dem.grid[r * dem.nCols + c];
  return (v === undefined || isNaN(v)) ? NaN : v;
}

function demCellSizeM(dem) {
  // Average cell size in metres at field centroid
  const latRad = (dem.originLat + dem.nRows * dem.cellSizeLat / 2) * Math.PI / 180;
  const dy = Math.abs(dem.cellSizeLat) * 111320;
  const dx = Math.abs(dem.cellSizeLon) * 111320 * Math.cos(latRad);
  return { dx, dy };
}

/* ── 2.2.1 + 2.2.2: Slope and Aspect (Horn 1981) ─────── */
function computeSlopeAspect(dem) {
  const { dx, dy } = demCellSizeM(dem);
  const slope  = new Float32Array(dem.nRows * dem.nCols).fill(NaN);
  const aspect = new Float32Array(dem.nRows * dem.nCols).fill(NaN);

  for (let r = 1; r < dem.nRows - 1; r++) {
    for (let c = 1; c < dem.nCols - 1; c++) {
      // Horn 3×3 kernel
      const a = demGet(dem,r-1,c-1), b = demGet(dem,r-1,c), d = demGet(dem,r-1,c+1);
      const e = demGet(dem,r,  c-1),                         f = demGet(dem,r,  c+1);
      const g = demGet(dem,r+1,c-1), h = demGet(dem,r+1,c), i = demGet(dem,r+1,c+1);

      if ([a,b,d,e,f,g,h,i].some(isNaN)) continue;

      const dzdx = ((d + 2*f + i) - (a + 2*e + g)) / (8 * dx);
      const dzdy = ((g + 2*h + i) - (a + 2*b + d)) / (8 * dy);

      const idx = r * dem.nCols + c;
      slope[idx]  = Math.atan(Math.sqrt(dzdx*dzdx + dzdy*dzdy)) * 180 / Math.PI;
      // Aspect: 0=N, 90=E, 180=S, 270=W
      let asp = Math.atan2(-dzdx, dzdy) * 180 / Math.PI;
      if (asp < 0) asp += 360;
      aspect[idx] = asp;
    }
  }
  return { slope, aspect };
}

/* ── 2.2.3 + 2.2.4: Profile and Planform Curvature ─── */
function computeCurvature(dem) {
  const { dx, dy } = demCellSizeM(dem);
  const profCurv  = new Float32Array(dem.nRows * dem.nCols).fill(NaN);
  const planCurv  = new Float32Array(dem.nRows * dem.nCols).fill(NaN);

  for (let r = 1; r < dem.nRows - 1; r++) {
    for (let c = 1; c < dem.nCols - 1; c++) {
      const z   = demGet(dem,r,c);
      const zN  = demGet(dem,r-1,c), zS  = demGet(dem,r+1,c);
      const zE  = demGet(dem,r,c+1), zW  = demGet(dem,r,c-1);
      const zNE = demGet(dem,r-1,c+1), zNW = demGet(dem,r-1,c-1);
      const zSE = demGet(dem,r+1,c+1), zSW = demGet(dem,r+1,c-1);
      if ([z,zN,zS,zE,zW,zNE,zNW,zSE,zSW].some(isNaN)) continue;

      const D = ((zE + zW) / 2 - z) / (dx * dx);
      const E = ((zN + zS) / 2 - z) / (dy * dy);
      const F = (-zNE + zNW + zSE - zSW) / (4 * dx * dy);
      const G = (zE - zW) / (2 * dx);
      const H = (zN - zS) / (2 * dy);

      const G2H2 = G*G + H*H;
      const idx = r * dem.nCols + c;

      if (G2H2 > 1e-10) {
        // Profile curvature: positive = concave (accumulates water)
        profCurv[idx] = -2 * (D*G*G + E*H*H + F*G*H) / (G2H2 * Math.sqrt(1 + G2H2));
        // Planform curvature: positive = divergent, negative = convergent
        planCurv[idx] = -2 * (D*H*H + E*G*G - F*G*H) / G2H2;
      } else {
        profCurv[idx] = 0;
        planCurv[idx] = 0;
      }
    }
  }
  return { profCurv, planCurv };
}

/* ── 2.2.5: D8 Flow Direction ────────────────────────── */
function computeFlowDirection(dem) {
  // D8: each cell drains to steepest downslope neighbour
  // Returns flowDir[i] = direction code (1,2,4,8,16,32,64,128) or 0 for flat/sink
  const { dx, dy } = demCellSizeM(dem);
  const diag = Math.sqrt(dx*dx + dy*dy);
  // Neighbour offsets [dr, dc, distance, code]
  const DIRS = [
    [-1, 0, dy,   1],  // N
    [-1, 1, diag, 2],  // NE
    [ 0, 1, dx,   4],  // E
    [ 1, 1, diag, 8],  // SE
    [ 1, 0, dy,  16],  // S
    [ 1,-1, diag,32],  // SW
    [ 0,-1, dx,  64],  // W
    [-1,-1, diag,128], // NW
  ];

  const flowDir = new Int16Array(dem.nRows * dem.nCols).fill(0);

  for (let r = 0; r < dem.nRows; r++) {
    for (let co = 0; co < dem.nCols; co++) {
      const z = demGet(dem, r, co);
      if (isNaN(z)) continue;
      let maxDrop = 0, bestCode = 0;
      for (const [dr, dc, dist, code] of DIRS) {
        const zn = demGet(dem, r+dr, co+dc);
        if (isNaN(zn)) continue;
        const drop = (z - zn) / dist;
        if (drop > maxDrop) { maxDrop = drop; bestCode = code; }
      }
      flowDir[r * dem.nCols + co] = bestCode;
    }
  }
  return flowDir;
}

/* ── 2.2.6: Flow Accumulation ────────────────────────── */
function computeFlowAccumulation(dem, flowDir) {
  const n = dem.nRows * dem.nCols;
  const acc = new Int32Array(n).fill(1);  // each cell starts with 1 (itself)

  // Sort cells by elevation (descending) — process hilltops first
  const order = Array.from({length: n}, (_,i) => i)
    .filter(i => !isNaN(dem.grid[i]))
    .sort((a, b) => dem.grid[b] - dem.grid[a]);

  // D8 neighbour offsets matching flowDir codes
  const DIR_OFFSETS = {
    1:[-1,0], 2:[-1,1], 4:[0,1], 8:[1,1],
    16:[1,0], 32:[1,-1], 64:[0,-1], 128:[-1,-1]
  };

  for (const idx of order) {
    const dir = flowDir[idx];
    if (!dir) continue;
    const [dr, dc] = DIR_OFFSETS[dir] || [0,0];
    const r  = Math.floor(idx / dem.nCols);
    const co = idx % dem.nCols;
    const nr = r + dr, nc = co + dc;
    if (nr >= 0 && nr < dem.nRows && nc >= 0 && nc < dem.nCols) {
      acc[nr * dem.nCols + nc] += acc[idx];
    }
  }
  return acc;
}

/* ── 2.2.7: Topographic Wetness Index ────────────────── */
function computeTWI(dem, flowAcc, slopeArr) {
  const { dx, dy } = demCellSizeM(dem);
  const cellArea = dx * dy;
  const twi = new Float32Array(dem.nRows * dem.nCols).fill(NaN);

  for (let i = 0; i < dem.nRows * dem.nCols; i++) {
    const slopeDeg = slopeArr[i];
    if (isNaN(slopeDeg)) continue;
    const slopeRad = slopeDeg * Math.PI / 180;
    const tanBeta  = Math.max(0.001, Math.tan(slopeRad));  // floor to avoid ln(inf)
    const A        = flowAcc[i] * cellArea;  // upslope contributing area (m²)
    twi[i] = Math.log(A / tanBeta);
  }
  return twi;
}

/* ── 2.2.8: Surface Roughness ────────────────────────── */
function computeRoughness(dem) {
  const rough = new Float32Array(dem.nRows * dem.nCols).fill(NaN);
  for (let r = 1; r < dem.nRows - 1; r++) {
    for (let c = 1; c < dem.nCols - 1; c++) {
      const vals = [];
      for (let dr = -1; dr <= 1; dr++)
        for (let dc = -1; dc <= 1; dc++) {
          const v = demGet(dem, r+dr, c+dc);
          if (!isNaN(v)) vals.push(v);
        }
      if (vals.length < 4) continue;
      const mean = vals.reduce((s,v) => s+v, 0) / vals.length;
      const sd   = Math.sqrt(vals.reduce((s,v) => s+(v-mean)**2, 0) / vals.length);
      rough[r * dem.nCols + c] = sd;
    }
  }
  return rough;
}

/* ── 2.2.9: Riparian Zone Delineation ────────────────── */
function computeRiparianZones(dem, flowAcc) {
  // Cells with flow accumulation above threshold = drainage lines
  // Threshold: top 2% of flow accumulation within polygon extent
  const vals  = Array.from(flowAcc).filter(v => v > 0).sort((a,b) => b-a);
  const topN  = Math.max(1, Math.floor(vals.length * 0.02));
  const thresh = vals[topN] || vals[0];
  const riparian = new Uint8Array(dem.nRows * dem.nCols);
  for (let i = 0; i < flowAcc.length; i++) {
    riparian[i] = flowAcc[i] >= thresh ? 1 : 0;
  }
  return { riparian, threshold: thresh };
}

/* ── 2.2.10: Landslide Risk Index ────────────────────── */
function computeLandslideRisk(dem, slopeArr, clay_pct, map_mm) {
  // Simple index: slope class × clay class × rainfall class
  // All factors 0–1; product = risk 0–1
  // Ref: Aleotti & Chowdhury 1999 (NHESS review)
  const risk = new Float32Array(dem.nRows * dem.nCols).fill(NaN);
  const clayFactor    = clay_pct ? Math.min(1, clay_pct / 50)    : 0.5;
  const rainfallFactor= map_mm   ? Math.min(1, map_mm  / 1500)   : 0.4;

  for (let i = 0; i < slopeArr.length; i++) {
    if (isNaN(slopeArr[i])) continue;
    const slopeFactor = Math.min(1, slopeArr[i] / 45);
    risk[i] = slopeFactor * 0.5 + clayFactor * 0.25 + rainfallFactor * 0.25;
  }
  return risk;
}

/* ── Master terrain computation ────────────────────────
   Runs all derivatives in sequence from ST.dem grid.
   Returns terrain object cached in ST.terrain.
─────────────────────────────────────────────────────── */
function computeTerrainDerivatives(dem, clay_pct, map_mm) {
  if (!dem?.grid) return null;

  const { slope, aspect }     = computeSlopeAspect(dem);
  const { profCurv, planCurv }= computeCurvature(dem);
  const flowDir               = computeFlowDirection(dem);
  const flowAcc               = computeFlowAccumulation(dem, flowDir);
  const twi                   = computeTWI(dem, flowAcc, slope);
  const roughness             = computeRoughness(dem);
  const { riparian, threshold } = computeRiparianZones(dem, flowAcc);
  const landslide             = computeLandslideRisk(dem, slope, clay_pct, map_mm);

  // Summary statistics for each layer (polygon extent)
  function gridStats(arr) {
    const vals = Array.from(arr).filter(v => !isNaN(v) && isFinite(v));
    if (!vals.length) return null;
    const mean = vals.reduce((s,v)=>s+v,0)/vals.length;
    const min  = Math.min(...vals), max = Math.max(...vals);
    const sd   = Math.sqrt(vals.reduce((s,v)=>s+(v-mean)**2,0)/vals.length);
    return { mean, min, max, sd };
  }

  const terrain = {
    slope, aspect, profCurv, planCurv,
    flowDir, flowAcc, twi, roughness, riparian, landslide,
    riparianThreshold: threshold,
    stats: {
      slope:    gridStats(slope),
      aspect:   gridStats(aspect),
      twi:      gridStats(twi),
      roughness:gridStats(roughness),
      landslide:gridStats(landslide),
    },
  };

  ST.terrain = terrain;
  return terrain;
}

