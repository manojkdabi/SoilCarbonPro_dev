function calcCropCin(slot) {
  const c = CROPS[slot.id];
  if (!c) return 0;
  const ndviScale = ST.satData?.ndviScale ?? 1.0;
  // Item 4: use user-set residue_pct when available; else RESIDUE_FRAC default
  const defaultFrac = RESIDUE_FRAC[slot.residue]?.frac ?? 1.0;
  const resFrac = (slot.residue_pct !== undefined && slot.residue_pct !== null)
    ? slot.residue_pct / 100
    : defaultFrac;
  return (c.base_cin * resFrac + c.base_cin * c.rhizodep) * ndviScale;
}

/* ── Per-slot DPM:RPM quality function ──────────────────────────
   Applies residue management and N-availability adjustments to the
   base crop DPM:RPM ratio (Items 3 + 6).
   Called from calcAvgDpmRpm() and buildRegenCin().
───────────────────────────────────────────────────────────────── */
function calcSlotDpmRpm(slot, idx, ph1) {
  const crop = CROPS[slot.id];
  if (!crop) return 1.44;
  let r = crop.dpm_rpm;

  // Item 6a — Residue management modifier
  // Surface retain: physical litter layer slows DPM → more RPM-like
  // Ref: Skjemstad et al. 2004 Soil Till Res 76:17-26
  if (slot.residue === 'surface') {
    r *= 0.85;
  } else if (slot.residue === 'incorporate') {
    // Incorporation accelerates DPM through soil contact
    // Ref: Curtin & Fraser 2003 Eur J Soil Sci 54:547-557
    r *= 1.10;
  }
  // burn/remove: no residue to protect or incorporate — use base value

  // Item 6b — Acidic pH slows early DPM decomposition
  // Ref: Kemmitt et al. 2006 Soil Biol Biochem 38:1823-1831
  if (ph1 !== null && ph1 < 5.5) {
    r *= 0.90;
  }

  // Item 3 — N-fix legacy effect: legume in preceding slot raises N
  // availability for the following crop's residue decomposition,
  // improving microbial CUE and shifting C toward stable HUM pool.
  // Ref: Recous et al. 1995 Soil Biol Biochem 27:1529-1538
  if (idx > 0) {
    const prevCrop = CROPS[ST.farm.crops[idx-1]?.id];
    if (prevCrop?.n_fix === true) {
      r *= 0.88;  // higher N → more C to HUM, lower effective DPM:RPM
    }
  }

  return Math.max(0.15, Math.min(3.0, r));
}

function calcAvgDpmRpm() {
  /* Weighted average DPM:RPM across crop residues AND organic amendments.
     Crop residues use calcSlotDpmRpm() which applies:
       - residue management modifier (surface/incorporate/burn)
       - pH modifier for acidic soils
       - n_fix legacy benefit from preceding legume slot
     Organic amendments use material-specific dpm_rpm from ORGANICS_DEF. */
  const ph1 = paramVal('ph1');
  let totalCin = 0, wDpm = 0;
  ST.farm.crops.forEach((slot, idx) => {
    const c = CROPS[slot.id]; if (!c) return;
    const cin = calcCropCin(slot);
    totalCin += cin;
    wDpm += cin * calcSlotDpmRpm(slot, idx, ph1);
  });
  // Organic amendments — use material-specific dpm_rpm
  Object.entries(ST.farm.organics).forEach(([key, state]) => {
    if (!state.on) return;
    const def = ORGANICS_DEF[key];
    const cin = state.rate * def.net_c;
    totalCin += cin;
    wDpm += cin * (def.dpm_rpm ?? 1.44);
  });
  return totalCin > 0 ? wDpm / totalCin : 1.44;
}

function addCropSlot() {
  if (ST.farm.crops.length >= 3) return;
  const _cal = getCropCalendar('wheat');
  ST.farm.crops.push({ id: 'wheat', residue: 'surface', residue_pct: null, tillage: 'shallow', irrigation: 'rainfed',
    sow_month: _cal.sow, harvest_month: _cal.harvest });
  renderRotationSlots();
  inferDepthFromCrops();
}

function removeCropSlot(idx) {
  ST.farm.crops.splice(idx, 1);
  renderRotationSlots();
  inferDepthFromCrops();
}

function updateCropSlot(idx, field, val) {
  ST.farm.crops[idx][field] = val;
  renderRotationSlots();
  if (field === 'id') inferDepthFromCrops();
}

function updateCropCinSummary() {
  const wrap = document.getElementById('crop-cin-summary');
  const rows = document.getElementById('crop-cin-rows');
  if (ST.farm.crops.length === 0) { wrap.style.display = 'none'; return; }
  wrap.style.display = 'block';
  let html = '';
  let total = 0;
  ST.farm.crops.forEach(slot => {
    const c = CROPS[slot.id]; if (!c) return;
    const _defFrac = RESIDUE_FRAC[slot.residue]?.frac ?? 1.0;
    const _resFrac = (slot.residue_pct !== null && slot.residue_pct !== undefined)
      ? slot.residue_pct / 100 : _defFrac;
    const res_cin = c.base_cin * _resFrac;
    const rhizo_cin = c.base_cin * c.rhizodep;
    const cin = res_cin + rhizo_cin;
    total += cin;
    html += `<div class="cin-row">
      <span class="cin-row-label">${c.name} (residue ${Math.round(_resFrac*100)}% + rhizo)</span>
      <span class="cin-row-val">${cin.toFixed(2)} t C/ha</span>
    </div>`;
  });
  html += `<div class="cin-row" style="border-top:1px solid var(--green-mid);margin-top:3px;padding-top:3px">
    <span class="cin-row-label" style="font-weight:700">Total crop C (annual)</span>
    <span class="cin-row-val" style="font-size:0.88rem">${total.toFixed(2)} t C/ha</span>
  </div>`;
  rows.innerHTML = html;
}

