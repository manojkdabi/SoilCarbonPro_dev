/* ── Irrigation (legacy farm-level + slot update) ── */
function setIrrigation(key, slotIdx) {
  // If slotIdx specified, update that slot only; otherwise update all slots
  if (slotIdx !== undefined) {
    if (ST.farm.crops[slotIdx]) ST.farm.crops[slotIdx].irrigation = key;
  } else {
    // Automation path: update all slots that haven't been manually overridden
    ST.farm.crops.forEach(slot => { slot.irrigation = key; });
  }
  // Keep legacy field as nearest match for solver backward compat
  ST.farm.irrigation = key;
  renderRotationSlots();
  triggerBAU();
}

/* ── Tillage (legacy farm-level + slot update) ── */
function setTillage(key, slotIdx) {
  if (slotIdx !== undefined) {
    if (ST.farm.crops[slotIdx]) ST.farm.crops[slotIdx].tillage = key;
  } else {
    ST.farm.crops.forEach(slot => { slot.tillage = key; });
  }
  ST.farm.tillage = key;
  renderRotationSlots();
  triggerBAU();
}

