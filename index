/* ═══════════════════════════════════════════════════════
   MINERALOGY GEO-CLASSIFIER  (NBSS&LUP soil zone boundaries)
═══════════════════════════════════════════════════════ */
function inferMineralogy(lat, lon) {
  // Returns {key, confidence, reason}
  // Priority order: Aridisol > Vertisol > Paddy > Alfisol > Alluvial
  // Bounding boxes derived from NBSS&LUP 1:250k soil map + FAO soil atlas

  // ── 1. Desert / Arid (Aridisol) — Thar + Rann of Kutch ──
  if (lat >= 23.5 && lat <= 31.0 && lon >= 68.0 && lon <= 73.5)
    return { key:'aridisol', conf:'high', reason:'Thar Desert — Aridisol (Rajasthan · W. Gujarat)' };
  if (lat >= 22.0 && lat <= 24.5 && lon >= 68.0 && lon <= 72.5)
    return { key:'aridisol', conf:'high', reason:'Rann of Kutch — Aridisol (W. Gujarat)' };

  // ── 2. Black Cotton Vertisol — Deccan Trap basalt ──
  if (lat >= 17.5 && lat <= 21.8 && lon >= 73.5 && lon <= 80.5)
    return { key:'vertisol', conf:'high', reason:'Deccan Trap basalt — Black Cotton Vertisol (Maharashtra)' };
  if (lat >= 20.0 && lat <= 24.2 && lon >= 76.5 && lon <= 82.5)
    return { key:'vertisol', conf:'medium', reason:'Central India Vertisol belt (MP · Chhattisgarh)' };
  if (lat >= 15.5 && lat <= 18.5 && lon >= 77.0 && lon <= 81.0)
    return { key:'vertisol', conf:'medium', reason:'Deccan Vertisol (Telangana · N. AP)' };
  if (lat >= 21.5 && lat <= 24.0 && lon >= 72.5 && lon <= 75.5)
    return { key:'vertisol', conf:'medium', reason:'Gujarat Vertisol (Saurashtra · N. Gujarat)' };

  // ── 3. Paddy / Flooded — coastal & delta zones ──
  if (lat >= 8.0  && lat <= 12.5 && lon >= 75.5 && lon <= 77.5)
    return { key:'paddy', conf:'medium', reason:'Kerala coastal lowlands / backwater paddy soils' };
  if (lat >= 21.5 && lat <= 23.5 && lon >= 87.5 && lon <= 90.5)
    return { key:'paddy', conf:'medium', reason:'Ganga–Brahmaputra delta (WB coast) — paddy Inceptisol' };
  if (lat >= 19.0 && lat <= 21.2 && lon >= 84.5 && lon <= 87.5)
    return { key:'paddy', conf:'medium', reason:'Mahanadi delta — Odisha coastal paddy soils' };
  if (lat >= 10.3 && lat <= 11.5 && lon >= 78.5 && lon <= 80.2)
    return { key:'paddy', conf:'medium', reason:'Cauvery delta (Tamil Nadu) — paddy soils' };

  // ── 4. Red / Lateritic Alfisol — Peninsular shield ──
  if (lat >= 8.0  && lat <= 15.0 && lon >= 77.0 && lon <= 80.5)
    return { key:'alfisol', conf:'high', reason:'Peninsular shield — Red Lateritic Alfisol (Tamil Nadu · S. Karnataka)' };
  if (lat >= 12.0 && lat <= 17.5 && lon >= 74.5 && lon <= 78.5)
    return { key:'alfisol', conf:'high', reason:'Karnataka Deccan — Red Alfisol / Laterite' };
  if (lat >= 14.0 && lat <= 19.5 && lon >= 79.5 && lon <= 84.0)
    return { key:'alfisol', conf:'medium', reason:'Eastern Ghats / AP Red Alfisol' };
  if (lat >= 19.0 && lat <= 25.0 && lon >= 82.5 && lon <= 87.5)
    return { key:'alfisol', conf:'medium', reason:'Jharkhand · Odisha · Chhattisgarh laterite / Alfisol' };
  if (lat >= 23.0 && lat <= 28.5 && lon >= 88.5 && lon <= 96.5)
    return { key:'alfisol', conf:'low', reason:'NE India — Ultisol / Lateritic (classified as Alfisol)' };

  // ── 5. IGP Alluvial — north India plains ──
  if (lat >= 22.0 && lat <= 32.5 && lon >= 72.0 && lon <= 89.0)
    return { key:'alluvial', conf:'high', reason:'Indo-Gangetic Plain — Alluvial (Entisol / Inceptisol)' };

  // ── 6. Rest of India / outside ──
  if (lat >= 8.0 && lat <= 35.0 && lon >= 68.0 && lon <= 97.5)
    return { key:'alluvial', conf:'low', reason:'India — soil class uncertain; defaulting to alluvial' };

  return { key:'alluvial', conf:'low', reason:'Outside India — defaulting to alluvial reference' };
}

function applyMineralogyFromLocation(lat, lon) {
  const result = inferMineralogy(lat, lon);
  setMineralogy(result.key, 'auto');
  const note = document.getElementById('mineral-autodetect');
  const text = document.getElementById('mineral-autodetect-text');
  if (note && text) {
    const confIcon = result.conf === 'high' ? '📍' : result.conf === 'medium' ? '🟡' : '⚠';
    text.textContent = `${confIcon} Auto-detected: ${result.reason}`;
    note.style.display = 'block';
    // Colour by confidence
    note.style.background = result.conf === 'high'   ? 'var(--teal-lt)'  :
                             result.conf === 'medium' ? 'var(--blue-lt)'  : 'var(--amber-lt)';
    note.style.borderColor = result.conf === 'high'   ? 'var(--teal)'    :
                             result.conf === 'medium' ? 'var(--blue)'     : 'var(--amber)';
    note.style.color       = result.conf === 'high'   ? 'var(--teal)'    :
                             result.conf === 'medium' ? 'var(--blue)'     : 'var(--amber)';
  }
}

function setMineralogy(m, source) {
  ST.mineralogy = m;
  ST.mineralogy_source = source || 'manual';
  ['alluvial','vertisol','alfisol','paddy','aridisol'].forEach(mc => {
    const el = document.getElementById(`mc-${mc}`);
    if (!el) return;
    el.classList.toggle('selected', mc === m);
    // Remove any old auto badge
    el.querySelectorAll('.mineral-auto-badge').forEach(b => b.remove());
  });
  // Add auto badge to selected card when auto-detected
  if (source === 'auto') {
    const sel = document.getElementById(`mc-${m}`);
    if (sel) {
      const badge = document.createElement('div');
      badge.className = 'mineral-auto-badge';
      badge.style.cssText = 'font-size:0.58rem;font-family:var(--mono);color:var(--teal);margin-top:4px;font-weight:600;letter-spacing:0.04em';
      badge.textContent = '✦ AUTO-DETECTED FROM MAP PIN';
      sel.appendChild(badge);
    }
  } else {
    // Manual override: update the note
    const note = document.getElementById('mineral-autodetect');
    const text = document.getElementById('mineral-autodetect-text');
    if (note && note.style.display !== 'none' && text) {
