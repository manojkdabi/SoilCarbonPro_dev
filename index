    doc.text(depth, pad+48, y);
    doc.text(method, pad+68, y);
    doc.text(unit, pad+128, y);
    doc.setFont('helvetica','bold');
    doc.setTextColor(priority === 'MANDATORY' ? hexToRgb(col.red).join(',') ? col.red : '#8a1a1a' : col.amber);
