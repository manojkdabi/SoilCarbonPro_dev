      note:`range: ${bau_low.toFixed(1)}–${bau_high.toFixed(1)}` },
    { dot:'#1a2e6a', label:`Your target SOC`,
      val:target !== null ? `${target.toFixed(1)} t C/ha` : '— (set in Phase 1)',
