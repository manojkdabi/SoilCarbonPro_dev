/* Item 7: Layer-specific target input handler */
function onLayerTargetInput(layer, val) {
  const v = parseFloat(val);
  if (layer === 1) ST.targetL1_tha = isNaN(v) ? null : v;
  else             ST.targetL2_tha = isNaN(v) ? null : v;
  // Update aggregate target = L1 + L2 if both are set
  if (ST.targetL1_tha !== null && ST.targetL2_tha !== null) {
    const agg = ST.targetL1_tha + ST.targetL2_tha;
    ST.targetTha = agg;
    ST.targetPct = null;
    if (!document.getElementById('target-tha').matches(':focus'))
      document.getElementById('target-tha').value = agg.toFixed(1);
    calcCeiling();
  }
}

function onTargetInput(type) {
  const cstock = ST.derived.cstock;
  const socPct1 = ST.derived.socPct1;

  if (type === 'pct') {
    const v = parseFloat(document.getElementById('target-pct').value);
    ST.targetPct = isNaN(v) ? null : v;
    ST.targetTha = null;
    // convert to t C/ha if possible
    if (v && cstock && socPct1) {
      const ratio = cstock / socPct1;
      const tha = v * ratio;
      ST.targetTha = tha;
      document.getElementById('target-tha').value = tha.toFixed(1);
    }
  } else {
    const v = parseFloat(document.getElementById('target-tha').value);
    ST.targetTha = isNaN(v) ? null : v;
    ST.targetPct = null;
    if (v && cstock && socPct1) {
      const pct = v / cstock * socPct1;
      ST.targetPct = pct;
      document.getElementById('target-pct').value = pct.toFixed(2);
    }
  }
  calcCeiling();
  maybeAutoRunSolver('target');
  updateWizardState();
}

