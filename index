/* ── renderPhenologyClassification: crop type confidence from NDVI + NDWI + NDRE pattern ── */
function renderPhenologyClassification(ndviClim, ndwiClim, ndreClim) {
  const el = document.getElementById('sat-phenology');
  if (!el) return;
  const valid = ndviClim.map((v,i) => ({mo:i,v})).filter(x=>x.v!==null);
  if (!valid.length) return;
  const peakMo = valid.reduce((a,b) => b.v>a.v ? b : a).mo;
  const peakNDVI = valid[valid.length-1] ? Math.max(...valid.map(x=>x.v)) : 0;
  const minNDVI  = Math.min(...valid.map(x=>x.v));
  const MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  let phenoMatch = 'Unknown', confidence = '—', matchedCrops = '';
  if (peakNDVI > 0.5 && minNDVI > 0.3) {
    phenoMatch = 'Perennial / year-round green'; confidence = '75%';
    matchedCrops = 'Sugarcane, Banana, Plantation crops';
  } else if ([5,6,7,8,9].includes(peakMo)) {
    if (peakMo <= 7) { phenoMatch = 'Kharif early (Jun–Aug peak)'; confidence = '70%'; matchedCrops = 'Maize, Bajra, Soybean'; }
    else { phenoMatch = 'Kharif late (Aug–Oct peak)'; confidence = '70%'; matchedCrops = 'Cotton, Rice, Pigeon pea'; }
  } else if ([10,11,0,1,2].includes(peakMo)) {
    phenoMatch = 'Rabi (Nov–Mar peak)'; confidence = '78%';
    matchedCrops = 'Wheat, Mustard, Chickpea';
  } else {
    phenoMatch = 'Ambiguous / mixed'; confidence = '45%'; matchedCrops = 'Multiple crops possible';
  }

  // ── NDWI refinement: flooded-rice detection (monsoon Jun–Sep NDWI > 0.05) ──
  let riceSignal = false;
  let ndwiNote = '';
  if (ndwiClim) {
    const monsoonNDWI = [5,6,7,8].map(mo => ndwiClim[mo]).filter(v => v !== null); // Jun–Sep, 0-indexed
    if (monsoonNDWI.length) {
      const peakNDWI = Math.max(...monsoonNDWI);
      if (peakNDWI > 0.05) {
        riceSignal = true;
        ndwiNote = `NDWI peak ${peakNDWI.toFixed(2)} (Jun–Sep) → flooded/irrigated signal`;
        if (phenoMatch.includes('Kharif late')) {
          matchedCrops = 'Rice (flooded · high confidence), Cotton, Pigeon pea';
          confidence = '82%';
        }
      }
    }
  }

  // ── NDRE refinement: wheat vs mustard separation (Rabi Nov–Feb NDRE) ──
  let ndreNote = '';
  if (ndreClim && phenoMatch.includes('Rabi')) {
    const rabiNDRE = [10,11,0,1].map(mo => ndreClim[mo]).filter(v => v !== null); // Nov–Feb, 0-indexed (wraps year)
    if (rabiNDRE.length) {
      const meanRabiNDRE = rabiNDRE.reduce((a,b)=>a+b,0) / rabiNDRE.length;
      if (meanRabiNDRE > 0.22) {
        matchedCrops = 'Wheat (high NDRE · dense canopy), Chickpea';
        confidence = '85%';
        ndreNote = `mean Rabi NDRE ${meanRabiNDRE.toFixed(2)} → dense cereal canopy`;
      } else if (meanRabiNDRE > 0.14) {
        matchedCrops = 'Mustard / Rapeseed, Wheat, Chickpea';
        confidence = '80%';
        ndreNote = `mean Rabi NDRE ${meanRabiNDRE.toFixed(2)} → moderate canopy`;
      } else {
        ndreNote = `mean Rabi NDRE ${meanRabiNDRE.toFixed(2)}`;
      }
    }
  }

  const bandNotes = [ndwiNote, ndreNote].filter(Boolean).join(' · ');

  // Check against interview
  const interviewCrop = ST.farm.crops[0]?.id;
  const interviewSeason = CROPS[interviewCrop]?.season;
  const satSeason = phenoMatch.toLowerCase().includes('kharif') ? 'Kharif'
                  : phenoMatch.toLowerCase().includes('rabi')   ? 'Rabi'
                  : phenoMatch.toLowerCase().includes('perenni')? 'Perennial' : null;
  const seasonMatch = satSeason && interviewSeason
    ? (interviewSeason === satSeason || interviewSeason === 'Both')
    : null;

  el.style.display = 'block';
  el.innerHTML =
    `<div style="font-size:0.60rem;font-weight:700;color:#2d6a4f;margin-bottom:3px">
       PHENOLOGY CLASSIFICATION</div>` +
    `Peak NDVI: <strong>${peakNDVI.toFixed(2)}</strong> in
     <strong>${MONTH_NAMES[peakMo]}</strong> &ensp;
     Pattern: <strong>${phenoMatch}</strong> (confidence: ${confidence})<br>` +
    `<span style="color:var(--ink-5);font-size:0.62rem">Likely crops: ${matchedCrops}</span>` +
    (bandNotes ? `<br><span style="color:var(--ink-5);font-size:0.60rem">🛰 ${bandNotes}</span>` : '') +
    (seasonMatch !== null ? `<br><span style="color:${seasonMatch?'var(--green-2)':'var(--amber-2)'}">
       ${seasonMatch ? '✓ Matches' : '⚠ Differs from'} interview crop season (${interviewSeason})</span>` : '');
}

/* ── renderSatScaleStrip: Cin comparison and scale factor ── */
