  else if (source === 'lab')          el.classList.add('has-value');
}

/* ═══════════════════════════════════════════════════════
   PEDOTRANSFER: BD from SOC (Rawls 1983 simplified)
═══════════════════════════════════════════════════════ */
function calcPedotransferBD(soc_gkg, clay_pct) {
  /* Benites et al. 2007 (Geoderma 139:90-97) — tropical soils calibration.
     Includes clay correction absent from Rawls 1983.
     clay_pct optional; falls back to Rawls if not supplied.
     BD_max(clay) = 1.85 - 0.006×clay% (physical upper bound for clay content) */
  if (soc_gkg === null || soc_gkg <= 0) return null;
  const om_pct = soc_gkg / 10 * 1.724;   // SOC% → OM% via van Bemmelen factor
  let bd;
  if (clay_pct !== null && clay_pct !== undefined) {
    if (clay_pct > 60) {
      // Heavy clay form (Benites 2007 eq.2)
      bd = 1 / (0.6268 + 0.0361 * om_pct);
    } else {
      // General tropical form (Benites 2007 eq.1)
      bd = 1.660 - 0.318 * Math.sqrt(om_pct) - 0.00487 * clay_pct;
    }
    // Physical upper bound: dense packing limited by clay skeleton
    const bd_max = 1.85 - 0.006 * clay_pct;
    bd = Math.min(bd, bd_max);
  } else {
    // Fallback: Rawls 1983 (no clay data available)
    const soc_pct = soc_gkg / 10;
    bd = 1.66 - 0.318 * Math.sqrt(soc_pct);
  }
  return Math.max(0.85, Math.min(1.85, bd));
}

