  // Table headers
  doc.setFillColor(240,236,226); doc.rect(pad, y-4, cW, 7, 'F');
  doc.setFont('helvetica','bold'); doc.setFontSize(7); doc.setTextColor(col.mid);
  ['Parameter','Depth(s)','Analytical Method','Units','Priority'].forEach((h, i) => {
    const xs = [0,46,66,126,146];
    doc.text(h, pad+xs[i]+2, y);
  });
  doc.setDrawColor(col.light); doc.line(pad, y+2, W-pad, y+2);
  y += 8;

  headerRow('TIER 1 — MANDATORY (every farmer, every field)', '#1e5c26');

  const t1params = [
    ['Total SOC', '0–15 cm and 15–30 cm', 'Walkley-Black or TOC combustion (NOT LOI)', 'g/kg or %', 'MANDATORY'],
    ['Bulk Density', '0–15 cm and 15–30 cm', 'Undisturbed core (metal ring) — see BD protocol', 'g/cm³', 'MANDATORY'],
    ['pH (water)', '0–15 cm and 15–30 cm', '1:2.5 soil:water suspension, pH meter', 'pH units', 'MANDATORY'],
    ['EC', '0–15 cm', '1:2.5 suspension, conductivity meter', 'dS/m', 'MANDATORY'],
    ['Clay %', '0–15 cm and 15–30 cm', 'Bouyoucos hydrometer or pipette method', '%', 'MANDATORY'],
    ['Silt %', '0–15 cm and 15–30 cm', 'Bouyoucos hydrometer or pipette method', '%', 'MANDATORY'],
    ['Sand %', '0–15 cm and 15–30 cm', 'Bouyoucos hydrometer (cross-check: must sum ≈100%)', '%', 'MANDATORY'],
    ['POXC (Active C)', '0–15 cm', 'KMnO₄ colorimetry — 0.02M, 10 min (Weil et al. 2003)', 'mg/kg', 'MANDATORY'],
    ['Total N', '0–15 cm', 'Kjeldahl digestion', '%', 'MANDATORY'],
    ['Available P', '0–15 cm', 'Olsen extraction (NaHCO₃, pH 8.5)', 'kg/ha', 'Recommended'],
    ['Available K', '0–15 cm', 'Neutral ammonium acetate extraction', 'kg/ha', 'Recommended'],
  ];
  t1params.forEach((r, i) => paramRow(i, ...r));

  y += 3;
