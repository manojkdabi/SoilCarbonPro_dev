/* ═══════════════════════════════════════════════════════════════════
   TEXTURE FEASIBILITY
   Evaluates physical soil constraints on agronomic practice options.
   Called from recalcAll() whenever soil params change.
   Returns structured flags stored in ST.derived.textureFeas.

   Thresholds derived from:
     Raised bed: Kar & Verma 2012 (ICAR); Kienzler et al. 2012 (Field Crops Res)
     Cover crops on sand: Snapp et al. 2005 (Plant Soil); FAO 2010 soilless dryland
     No-till on heavy clay: Alvarez 2005 (Soil Till Res); Soane & van Ouwerkerk 1994
     Compost on sand: Lal 2006 (Plant Soil); Bhattacharyya et al. 2012 (Agric Ecosyst)
     Biochar on sand: Basso et al. 2013 (GCB Bioenergy); Islami et al. 2011
     Brassica cover penetration: Williams & Weil 2004 (Plant Soil)
   Severity:
     'block'   — physically impossible, exclude from solver options
     'caution' — possible but significantly sub-optimal, flag on card
     'boost'   — practice is MORE effective than average on this soil
═══════════════════════════════════════════════════════════════════ */
function evaluateTextureFeasibility() {
  const clay = paramVal('clay1') ?? 25;
  const sand = paramVal('sand1') ?? Math.max(0, 100 - clay - (paramVal('silt1') ?? 0));
  const silt = paramVal('silt1') ?? Math.max(0, 100 - clay - sand);
  const soc  = paramVal('soc1')  ?? 0;
  const irrig = ST.farm.crops?.[0]?.irrigation || 'rainfed';
  const hasIrrig = irrig !== 'rainfed';
  const waterlog = ST.farm.history?.waterlog || 'none';
  const mineral  = ST.mineralogy || 'alluvial';

  const flags = [];

  // ── Raised bed ────────────────────────────────────────────────────────────
  if (clay < 15) {
    flags.push({
      practice: 'raised_bed',
      severity: 'block',
      short:    'Raised bed infeasible on sand',
      detail:   `Clay ${clay.toFixed(0)}% < 15% — beds slump after irrigation. Minimum ~18% clay required for structural integrity. Ref: ICAR raised bed guidelines (2012).`,
    });
  } else if (clay < 18) {
    flags.push({
      practice: 'raised_bed',
      severity: 'caution',
      short:    'Raised bed marginal — low clay',
      detail:   `Clay ${clay.toFixed(0)}% is below the recommended 18% threshold. Bed structure may deteriorate. Add 2–3 t/ha FYM before bed formation to improve cohesion.`,
    });
  }
  if (mineral === 'vertisol' && clay > 50) {
    flags.push({
      practice: 'raised_bed',
      severity: 'caution',
      short:    'Raised bed on Vertisol — seasonal cracking',
      detail:   `Vertisol clay ${clay.toFixed(0)}% — smectite shrink-swell will cause seasonal cracking of bed walls. Beds need reforming annually after monsoon. Ref: ICRISAT Vertisol agronomics.`,
    });
  }

  // ── No-till on heavy clay ─────────────────────────────────────────────────
  if (clay > 50 && soc < 0.5 && !hasIrrig) {
    flags.push({
      practice: 'no_till',
      severity: 'caution',
      short:    'No-till compaction risk — heavy clay, low SOC',
      detail:   `Clay ${clay.toFixed(0)}% with SOC ${soc.toFixed(2)}% — no-till on degraded heavy clay causes surface compaction and anaerobic microsites. Build SOC > 0.5% first with compost before converting. Ref: Alvarez 2005 (Soil Till Res 78:229).`,
    });
  }

  // ── Cover crops on sandy soils ────────────────────────────────────────────
  if (sand > 70 && !hasIrrig) {
    flags.push({
      practice: 'cover_crop',
      severity: 'block',
      short:    'Cover crop establishment risky — sandy, rainfed',
      detail:   `Sand ${sand.toFixed(0)}% rainfed — insufficient field capacity for cover crop establishment without supplemental irrigation. Legumes and brassicas fail to establish in dry periods. Ref: Snapp et al. 2005 (Plant Soil 274).`,
    });
  } else if (sand > 60 && !hasIrrig) {
    flags.push({
      practice: 'cover_crop',
      severity: 'caution',
      short:    'Cover crop — choose drought-tolerant species',
      detail:   `Sand ${sand.toFixed(0)}% — prefer drought-tolerant species: cowpea, moth bean, horse gram. Avoid moisture-demanding species (oats, berseem). Ref: FAO dryland cover crop guidelines.`,
    });
  }

  // ── Brassica/radish bio-tillage on heavy clay ─────────────────────────────
  if (clay > 45) {
    flags.push({
      practice: 'cover_brassica',
      severity: 'caution',
      short:    'Brassica cover crop — tap root penetration limited',
      detail:   `Clay ${clay.toFixed(0)}% > 45% — brassica and radish tap roots cannot penetrate compacted clay subsoil, reducing bio-tillage benefit. Prefer legume CC for nitrogen benefit instead. Ref: Williams & Weil 2004 (Plant Soil 263).`,
    });
  }

  // ── Compost mineralisation on sand ───────────────────────────────────────
  if (sand > 65) {
    flags.push({
      practice: 'compost',
      severity: 'caution',
      short:    'Compost decomposes faster in sandy soils',
      detail:   `Sand ${sand.toFixed(0)}% — low clay means less physical protection for compost-derived OM. Cin benefit is real but short-lived. Annual or bi-annual application recommended rather than single large dose. Ref: Lal 2006 (Plant Soil 284:227).`,
    });
  }

  // ── Biochar — BOOST on sandy soils ───────────────────────────────────────
  if (sand > 60) {
    flags.push({
      practice: 'biochar',
      severity: 'boost',
      short:    'Biochar highly recommended — sandy soil',
      detail:   `Sand ${sand.toFixed(0)}% — biochar dramatically improves CEC and water retention in sandy soils. Effect size 2–3× greater than on clay soils. Prioritise biochar for sandy fields. Ref: Basso et al. 2013 (GCB Bioenergy 5:375); Islami et al. 2011.`,
    });
  }

  // ── Waterlogging + cover crop ─────────────────────────────────────────────
  if ((waterlog === 'severe' || waterlog === 'partial') && clay > 40) {
    flags.push({
      practice: 'cover_grass',
      severity: 'caution',
      short:    'Grass cover crops risk waterlogging death',
      detail:   `Waterlogging + clay ${clay.toFixed(0)}% — grass cover crops (oats, barley) may drown in prolonged standing water. Prefer raised bed + legume CC combination to manage excess water. Ref: FAO waterlogged soil management.`,
    });
  }

  // ── Deep inversion on sand ────────────────────────────────────────────────
  if (sand > 65) {
    flags.push({
      practice: 'deep_inversion',
      severity: 'caution',
      short:    'Deep inversion — destroys limited structure in sand',
      detail:   `Sand ${sand.toFixed(0)}% — inversion tillage in sandy soils destroys micro-aggregates and accelerates drying. Minimum or no-till preferred. Only use deep inversion for hard pan breakup if confirmed by soil pit.`,
    });
  }

  return flags;
}

/* ── updateTextureFeasStrip: render warnings above solver cards ── */
function updateTextureFeasStrip() {
  const strip = document.getElementById('texture-feas-strip');
  if (!strip) return;
  const flags = ST.derived.textureFeas || [];
  if (!flags.length) { strip.style.display = 'none'; return; }

  const html = flags.map(f => {
    const cls = f.severity === 'block'   ? 'tw-block'
              : f.severity === 'boost'   ? 'tw-boost'
              : 'tw-caution';
    const icon = f.severity === 'block'  ? '⛔'
               : f.severity === 'boost'  ? '✅'
               : '⚠';
    return `<div class="texture-warn ${cls}" title="${f.detail}">
      ${icon} <strong>${f.short}</strong>
      <span style="opacity:0.8"> · ${f.detail}</span>
    </div>`;
  }).join('');

  strip.innerHTML = html;
  strip.style.display = flags.length ? 'block' : 'none';
}

function recalcAll() {
  // Resolve values with fallbacks
  const soc1 = paramVal('soc1');
  const soc2 = paramVal('soc2');

  // BD with pedotransfer fallback
  let bd1 = paramVal('bd1');
  let bd2 = paramVal('bd2');
  let bd1_src = getParam('bd1').source;
  let bd2_src = getParam('bd2').source;

  if (bd1 === null && soc1 !== null) {
    const _clay1pt = paramVal('clay1');
    bd1 = calcPedotransferBD(soc1, _clay1pt);
    bd1_src = 'pedotransfer';
    const der = document.getElementById('der-bd1');
    const _ptLabel1 = _clay1pt !== null ? 'Benites 2007' : 'Rawls 1983';
    if (der) der.textContent = `PT: ${bd1?.toFixed(2)} g/cm³ (${_ptLabel1})`;
    updateBadge('bd1-derived', 'pedotransfer');
  } else {
    const der = document.getElementById('der-bd1');
    if (der) der.textContent = '';
  }

  if (bd2 === null && soc2 !== null) {
    const _clay2pt = paramVal('clay2') ?? paramVal('clay1');
    bd2 = calcPedotransferBD(soc2, _clay2pt);
    bd2_src = 'pedotransfer';
    const _ptLabel2 = _clay2pt !== null ? 'Benites 2007' : 'Rawls 1983';
    const der = document.getElementById('der-bd2');
    if (der) der.textContent = `PT: ${bd2?.toFixed(2)} g/cm³ (${_ptLabel2})`;
  } else {
    const der = document.getElementById('der-bd2');
    if (der) der.textContent = '';
  }

  const clay1 = paramVal('clay1');
  const silt1 = paramVal('silt1');
  const clay2 = paramVal('clay2');
  const silt2 = paramVal('silt2');

  // H1: BD > BD_max(clay) — physically impossible combination
  // BD_max = 1.85 - 0.006×clay% (clay skeleton limits dense packing)
  if (bd1 !== null && clay1 !== null) {
    const bd_max1 = 1.85 - 0.006 * clay1;
    const bd1_warn = document.getElementById('der-bd1');
    if (bd1 > bd_max1 + 0.02) {  // 0.02 tolerance for rounding
      if (bd1_warn) {
        bd1_warn.textContent = `⛔ BD ${bd1} > BD_max ${bd_max1.toFixed(2)} for clay ${clay1}% — physically impossible`;
        bd1_warn.style.color = 'var(--red, #c02828)';
      }
    }
  }

  // Sand auto-calc if clay + silt known
  if (clay1 !== null && silt1 !== null && paramVal('sand1') === null) {
    const autoSand = Math.max(0, 100 - clay1 - silt1);
    document.getElementById('sand1-auto').textContent = `Auto: ${autoSand.toFixed(1)}% (100 − clay − silt)`;
  } else {
    const note = document.getElementById('sand1-auto');
    if (note) note.textContent = '';
  }

  // Texture sum check
  ['1','2'].forEach(layer => {
    const c = paramVal(`clay${layer}`);
    const si = paramVal(`silt${layer}`);
    const sa = paramVal(`sand${layer}`);
    const warn = document.getElementById(`texture-warn${layer}`);
    if (warn && c !== null && si !== null && sa !== null) {
      const sum = c + si + sa;
      if (Math.abs(sum - 100) > 2.5) {
        warn.textContent = `⚠ Clay + Silt + Sand = ${sum.toFixed(1)}% (should be ≈ 100%)`;
      } else {
        warn.textContent = '';
      }
    } else if (warn) {
      warn.textContent = '';
    }
  });

  // Derived SOC%
  const socPct1 = soc1 !== null ? soc1 / 10 : null;
  const socPct2 = soc2 !== null ? soc2 / 10 : null;

  // Show SOC% in derived
  const der_soc1 = document.getElementById('der-soc1');
  if (der_soc1 && socPct1 !== null) {
    let socNote = `= ${socPct1.toFixed(2)}%`;
    if (soc1 > 80) {
      // C2: RothC not valid for histosols/peaty soils
      socNote += ' ⛔ >80 g/kg — RothC invalid for organic soils (histosol/peat territory). Results unreliable.';
      der_soc1.style.color = 'var(--red, #c02828)';
    } else if (soc1 > 50) {
      socNote += ' ⚠ >50 g/kg — very high; verify lab method. RothC accuracy reduced above this range.';
      der_soc1.style.color = 'var(--amber-2)';
    } else {
      der_soc1.style.color = '';
    }
    der_soc1.textContent = socNote;
  } else if (der_soc1) der_soc1.textContent = '';

  const der_soc2 = document.getElementById('der-soc2');
  if (der_soc2 && socPct2 !== null) {
    let soc2Note = `= ${socPct2.toFixed(2)}%`;
    // H4: Inverted depth profile — subsoil SOC > topsoil SOC
    if (soc1 !== null && soc2 !== null && soc2 > soc1 * 1.10) {
      soc2Note += ` ⚠ Subsoil SOC > topsoil — unusual. Verify: buried A horizon? Alluvial deposition? C stock may be overestimated.`;
      der_soc2.style.color = 'var(--amber-2)';
    } else {
      der_soc2.style.color = '';
    }
    der_soc2.textContent = soc2Note;
  } else if (der_soc2) der_soc2.textContent = '';

  // pH notes
  const ph1 = paramVal('ph1');
  const der_ph1 = document.getElementById('der-ph1');
  if (der_ph1 && ph1 !== null) {
    let note = '';
    if (ph1 < 5.5) note = 'Acidic — Al/Mn toxicity risk; fPH suppressed';
    else if (ph1 < 6.5) note = 'Moderately acidic — adequate range';
    else if (ph1 < 7.5) note = 'Near-neutral — optimal for microbial CUE';
    else if (ph1 < 8.5) note = 'Alkaline — CaCO₃ likely; check caco3';
    else note = 'Strongly alkaline — decomposition suppressed';

    // H2: Mineralogy × pH compatibility check
    const MINERAL_PH_RANGES = {
      alluvial: [6.0, 8.5], vertisol: [6.5, 9.0],
      alfisol:  [5.0, 6.8], paddy:    [5.5, 7.5], aridisol: [7.5, 9.5],
    };
    const mRange = MINERAL_PH_RANGES[ST.mineralogy];
    if (mRange && (ph1 < mRange[0] - 0.3 || ph1 > mRange[1] + 0.3)) {
      note += ` ⚠ pH ${ph1.toFixed(1)} outside expected range for ${ST.mineralogy} (${mRange[0]}–${mRange[1]}) — check mineralogy or pH entry`;
      der_ph1.style.color = 'var(--amber-2)';
    } else {
      der_ph1.style.color = '';
    }
    der_ph1.textContent = note;
  } else if (der_ph1) der_ph1.textContent = '';

  // Show theta_fc and theta_wp in derived panel (transparency for MRV)
  const der_tfc = document.getElementById('der-theta-fc');
  if (der_tfc && ST.derived?.theta_fc != null) {
    der_tfc.textContent =
      `θ_fc ${ST.derived.theta_fc.toFixed(3)} · θ_wp ${ST.derived.theta_wp?.toFixed(3)} m³/m³`
      + ` (Saxton & Rawls 2006)`;
  } else if (der_tfc) der_tfc.textContent = '';

  // EC warning
  const ec1 = paramVal('ec1');
  const der_ec1 = document.getElementById('der-ec1');
  if (der_ec1 && ec1 !== null) {
    if (ec1 >= 4.0) der_ec1.textContent = '⚠ EC ≥ 4.0 dS/m: HARD BYPASS — no crop response possible';
    else if (ec1 >= 2.0) der_ec1.textContent = 'Moderate salinity — yield drag; EC correction applied';
    else der_ec1.textContent = 'Non-saline';
  } else if (der_ec1) der_ec1.textContent = '';

  // C:N from TN + N₀ mineralisation potential (Stanford & Smith 1972)
  const tn1 = paramVal('tn1');
  const der_tn1 = document.getElementById('der-tn1');
  if (der_tn1 && soc1 !== null && tn1 !== null && tn1 > 0) {
    const cn = (soc1/10) / tn1;
    const n0 = calcN0Stanford();
    const n0str = (n0 !== null && ST.climate) ? `  ·  N₀ ≈ ${n0} kg N/ha/yr` : '';
    der_tn1.textContent = `C:N = ${cn.toFixed(1)}${n0str}`;
  } else if (der_tn1) der_tn1.textContent = '';

  // ── CEC MINERALOGY HINT ──
  const cec1 = paramVal('cec1');

  // ITEM C: CEC cross-check PTF (Breeuwsma et al. 1986)
  // CEC_pred = 0.621×clay% + 0.185×OM% — independent of measured CEC
  // Flags possible analytical error or unusual mineralogy
  if (cec1 !== null && clay1 !== null && soc1 !== null) {
    const om_pct_cec = soc1 / 10 * 1.724;
    const cec_pred = 0.621 * clay1 + 0.185 * om_pct_cec;
    const cec_ratio = cec1 / cec_pred;
    const cecCheckEl = document.getElementById('der-cec1-check');
    if (cecCheckEl) {
      if (cec_ratio > 1.8) {
        cecCheckEl.textContent = `⚠ CEC ${cec1} cmol/kg is ${(cec_ratio).toFixed(1)}× predicted (${cec_pred.toFixed(1)}) — possible allophanic/andic mineralogy or analytical error`;
        cecCheckEl.style.color = 'var(--amber-2)';
      } else if (cec_ratio < 0.5) {
        cecCheckEl.textContent = `⚠ CEC ${cec1} cmol/kg is only ${(cec_ratio*100).toFixed(0)}% of predicted (${cec_pred.toFixed(1)}) — possible calcareous saturation masking exchange sites`;
        cecCheckEl.style.color = 'var(--amber-2)';
      } else {
        cecCheckEl.textContent = `✓ CEC consistent with PTF (Breeuwsma 1986 pred: ${cec_pred.toFixed(1)} cmol/kg)`;
        cecCheckEl.style.color = 'var(--green-2)';
      }
    }
    // Cache for compatibility checks
    ST.derived.cec_pred = cec_pred;
    ST.derived.cec_ratio = cec_ratio;
  }

  const der_cec1 = document.getElementById('der-cec1');
  if (der_cec1 && cec1 !== null) {
    let hint, col;
    if (cec1 >= 30)      { hint = '2:1 clays dominant (smectite/vermiculite)'; col = 'var(--teal)'; }
    else if (cec1 >= 18) { hint = '2:1 mixed mineralogy (illite/smectite)';    col = 'var(--blue)'; }
    else if (cec1 >= 8)  { hint = 'Mixed 1:1 / 2:1 (illite/kaolinite)';        col = 'var(--ink-4)'; }
    else                 { hint = '1:1 clays dominant (kaolinite/oxides)';      col = 'var(--amber)'; }
    der_cec1.textContent = hint;
    der_cec1.style.color = col;
  } else if (der_cec1) der_cec1.textContent = '';

  // POXC diagnostic
  const poxc1 = paramVal('poxc1');
  const poxcInd = document.getElementById('poxc-indicator');
  if (poxcInd && poxc1 !== null && soc1 !== null && soc1 > 0) {
    const ratio = poxc1 / (soc1 * 100); // poxc in mg/kg, soc in g/kg → SOC in mg/kg × 1000... actually ratio = poxc_mg/kg / soc_mg/kg
    // SOC in g/kg → mg/kg = × 1000
    const socMgKg = soc1 * 1000;
    const poxcRatio = poxc1 / socMgKg;
    poxcInd.style.display = 'block';
    if (poxcRatio > 0.05) {
      poxcInd.className = 'poxc-indicator building';
      poxcInd.textContent = `🌱 POXC/SOC = ${(poxcRatio).toFixed(3)} > 0.05 — Biologically active · Building phase`;
    } else if (poxcRatio >= 0.02) {
      poxcInd.className = 'poxc-indicator stable';
      poxcInd.textContent = `⚖ POXC/SOC = ${(poxcRatio).toFixed(3)} — Balanced · Stable trajectory`;
    } else {
      poxcInd.className = 'poxc-indicator declining';
      poxcInd.textContent = `⚠ POXC/SOC = ${(poxcRatio).toFixed(3)} < 0.02 — Biology suppressed · Likely declining`;
    }
  } else if (poxcInd) {
    poxcInd.style.display = 'none';
  }

  // MAOM/POM fractions
  const pom1 = paramVal('pom1');
  const maom1 = paramVal('maom1');
  const der_pom1 = document.getElementById('der-pom1');
  const der_maom1 = document.getElementById('der-maom1');
  if (der_pom1 && pom1 !== null && soc1 !== null) {
    const pomPct = (pom1/soc1)*100;
    if (pom1 > soc1) {
      der_pom1.textContent = `⛔ ${pom1} > SOC ${soc1} g/kg — impossible`;
      der_pom1.style.color = 'var(--red, #c02828)';
    } else {
      der_pom1.textContent = `${pomPct.toFixed(0)}% of SOC`;
      der_pom1.style.color = '';
    }
  } else if (der_pom1) der_pom1.textContent = '';

  if (der_maom1 && maom1 !== null && soc1 !== null) {
    const maomPct = (maom1/soc1)*100;
    const pomVal = pom1 ?? 0;
    if (maom1 > soc1) {
      der_maom1.textContent = `⛔ ${maom1} > SOC ${soc1} g/kg — impossible`;
      der_maom1.style.color = 'var(--red, #c02828)';
    } else if ((pomVal + maom1) > soc1 * 1.05) {
      // C3: POM + MAOM > SOC (5% tolerance for rounding)
      der_maom1.textContent = `⛔ POM+MAOM = ${(pomVal+maom1).toFixed(1)} > SOC ${soc1} g/kg — impossible`;
      der_maom1.style.color = 'var(--red, #c02828)';
    } else {
      der_maom1.textContent = `${maomPct.toFixed(0)}% of SOC`;
      der_maom1.style.color = '';
    }
  } else if (der_maom1) der_maom1.textContent = '';

  // ── C STOCK CALCULATION ──
  const depth = ST.analysisDepth;
  let cstock = null;

  if (soc1 !== null) {
    const d1 = Math.min(depth, 15);
    const bd1_eff = bd1 || 1.3;
    const stock1 = soc1 * bd1_eff * d1 / 100;  // t C/ha

    if (depth <= 15) {
      cstock = stock1;
    } else {
      const d2 = Math.min(depth - 15, 15);
      // Use soc2 if available, else estimate 70% of soc1
      const soc2_eff = soc2 !== null ? soc2 : soc1 * 0.70;
      const bd2_eff = bd2 || (bd1 ? bd1 + 0.08 : 1.38);
      const stock2 = soc2_eff * bd2_eff * d2 / 100;
      cstock = stock1 + stock2;
      if (depth > 30) {
        // Estimate deeper layers from profile decay
        const d3 = depth - 30;
        const soc3_est = soc2_eff * 0.60;
        const bd3_est = bd2_eff + 0.06;
        cstock += soc3_est * bd3_est * d3 / 100;
      }
    }
  }

  ST.derived.cstock = cstock;

  // ── COARSE FRAGMENT (STONE) CORRECTION ──
  const cfvo1 = paramVal('cfvo1');
  const der_cfvo1 = document.getElementById('der-cfvo1');
  if (cfvo1 !== null && cstock !== null) {
    const cf_pct = Math.min(cfvo1, 70); // cap at 70% (physical limit)
    const correction = 1 - cf_pct / 100;
    cstock = cstock * correction;
    ST.derived.cstock = cstock;
    if (der_cfvo1) {
      if (cf_pct > 5) {
        der_cfvo1.textContent = `−${cf_pct.toFixed(0)}% C stock (stone corr.)`;
        der_cfvo1.style.color = cf_pct > 20 ? 'var(--amber)' : 'var(--teal)';
      } else {
        der_cfvo1.textContent = `Negligible stone effect`;
        der_cfvo1.style.color = 'var(--ink-4)';
      }
    }
  } else if (der_cfvo1) {
    der_cfvo1.textContent = '';
  }
  ST.derived.socPct1 = socPct1;
  ST.derived.socPct2 = socPct2;

  // ── HASSINK CEILING ──
  let hassinkCap = null;
  if (clay1 !== null && silt1 !== null && bd1 !== null) {
    const d1 = Math.min(depth, 15);
    let cap = (4.09 + 0.37 * (clay1 + silt1)) * bd1 * d1 / 100;

    if (depth > 15 && clay2 !== null && silt2 !== null) {
      const bd2_eff = bd2 || bd1 + 0.08;
      const d2 = Math.min(depth - 15, 15);
      cap += (4.09 + 0.37 * (clay2 + silt2)) * bd2_eff * d2 / 100;
    } else if (depth > 15 && clay2 === null) {
      // Estimate subsoil cap from surface
      const bd2_eff = bd1 + 0.08;
      cap += (4.09 + 0.37 * (clay1 + silt1)) * bd2_eff * 15 / 100;
    }

    if (depth > 30) {
      const d3 = depth - 30;
      const clay3 = clay2 || clay1;
      const silt3 = silt2 || silt1;
      cap += (4.09 + 0.37 * (clay3 + silt3)) * (bd2 || bd1 + 0.10) * d3 / 100;
    }

    const mult = MINERAL_MULT[ST.mineralogy];
    hassinkCap = cap * mult;
  }

  ST.derived.hassinkCap = hassinkCap;
  ST.derived.agroCeil = hassinkCap ? hassinkCap * 0.82 : null;

  // ── SAXTON & RAWLS PTF — theta_fc / theta_wp / PAW ──────────────
  // Compute from available texture + SOC data.
  // Uses full Saxton & Rawls 2006 form (Pass 4, Item 9+A+B).
  if (clay1 !== null) {
    const sand1  = paramVal('sand1') ?? Math.max(0, 100 - (clay1||0) - (silt1||0));
    const om_pct = soc1 !== null ? (soc1/10) * 1.724 : 1.0;  // SOC%→OM% van Bemmelen
    const tfc    = saxtonTheta_fc(sand1, clay1, om_pct);
    const twp    = saxtonTheta_wp(clay1, om_pct);
    const depth  = ST.analysisDepth || 30;
    const paw_mm = (tfc - twp) * depth * 10;  // m³/m³ × depth(cm) × 10 → mm

    ST.derived.theta_fc = tfc;
    ST.derived.theta_wp = twp;
    ST.derived.paw_mm   = paw_mm;

    // Display PAW in uncertainty strip detail
    const pawEl = document.getElementById('paw-display');
    if (pawEl) {
      let pawClass = paw_mm > 120 ? 'paw-high' : paw_mm > 70 ? 'paw-med' : 'paw-low';
      let pawNote  = paw_mm > 120 ? 'High water-holding — good buffer for crop water stress'
                   : paw_mm > 70  ? 'Moderate water-holding capacity'
                   : 'Low water-holding — crops vulnerable to moisture stress';
      pawEl.innerHTML = `<span class="paw-label">Plant-Available Water</span>
        <span class="paw-val ${pawClass}">${paw_mm.toFixed(0)} mm / ${depth} cm</span>
        <span class="paw-note">θ_fc ${tfc.toFixed(3)} · θ_wp ${twp.toFixed(3)} m³/m³ · ${pawNote}</span>`;
    }

    // Below-wilting-point months flag (uses ERA5 if available)
    if (ST.climate?.monthly) {
      const bwpMonths = ST.climate.monthly
        .map((mo, i) => ({ mo: i, sm: mo.soil_moist ?? precipToSoilMoist(mo.precip, tfc, twp) }))
        .filter(m => m.sm < twp);
      ST.derived.bwp_months = bwpMonths.map(m => m.mo);
      const bwpEl = document.getElementById('bwp-display');
      const MO_SH = ['J','F','M','A','M','J','J','A','S','O','N','D'];
      if (bwpEl) {
        if (bwpMonths.length > 0) {
          bwpEl.innerHTML = `<span style="color:var(--amber-2)">⚠ Below wilting point: ${bwpMonths.map(m=>MO_SH[m.mo]).join(' ')} — soil desiccation risk; fW near 0 these months</span>`;
        } else {
          bwpEl.innerHTML = `<span style="color:var(--green-2)">✓ Soil moisture above wilting point all year</span>`;
        }
      }
    }
  } else {
    ST.derived.theta_fc = null;
    ST.derived.theta_wp = null;
    ST.derived.paw_mm   = null;
  }

  // ── UNCERTAINTY ──
  if (cstock !== null) {
    // σ_soil: function of data sources
    const socSrc = getParam('soc1').source;
    const bdSrc = bd1_src;
    let sigma_pct;
    if (socSrc === 'lab' && bdSrc === 'lab') sigma_pct = 0.05;
    else if (socSrc === 'lab' && bdSrc === 'pedotransfer') sigma_pct = 0.10;
    else if (socSrc === 'lab') sigma_pct = 0.12;
    else sigma_pct = 0.22; // soilgrids or default

    const sigma = cstock * sigma_pct;
    ST.derived.uncertainty = sigma;
    updateUncertaintyMeter(cstock, sigma, sigma_pct);
  } else {
    ST.derived.uncertainty = null;
    updateUncertaintyMeterEmpty();
  }

  // ── TARGET CONVERSION ──
  if (ST.targetPct !== null && cstock !== null && soc1 !== null && bd1 !== null) {
    // t C/ha = target_pct/100 × BD × depth (cm) × 10000/1000
    // simplified: use same BD/depth ratio as current stock
    const ratio = cstock / (socPct1 || 1);  // t C/ha per 1% SOC at surface
    const targetTha = ST.targetPct * ratio / socPct1 * (soc1/10) * (cstock / cstock);
    // More direct: target_pct% = target_gkg/10; stock = soc_gkg * BD * depth / 100
    const target_gkg = ST.targetPct * 10;
    const targetStockEst = (target_gkg / soc1) * cstock;  // scale proportionally
    if (!document.getElementById('target-tha').matches(':focus')) {
      ST.targetTha = targetStockEst;
      document.getElementById('target-tha').value = targetStockEst.toFixed(1);
    }
  }

  // Update target conversion note
  if (cstock !== null && soc1 !== null) {
    document.getElementById('target-conversion-note').textContent =
      `Conversion based on ${bd1 ? 'measured' : 'estimated'} BD and ${depth} cm profile — 1% SOC ≈ ${(cstock/(socPct1||1)).toFixed(1)} t C/ha on this site.`;
  }

  // Trigger ceiling calc
  calcCeiling();
  // Item B: update regional baseline display
  if (typeof updateRegionalBaselineDisplay === 'function') updateRegionalBaselineDisplay();

  // Item 7: show layer target UI when 30cm profile is set
  const ltWrap = document.getElementById('layer-target-wrap');
  if (ltWrap) {
    const showLayer = ST.analysisDepth >= 30 && soc1 !== null;
    ltWrap.style.display = showLayer ? 'block' : 'none';
    if (showLayer) {
      // Show current layer stocks as reference
      const stock1 = soc1 !== null && bd1 !== null
        ? (soc1 * (bd1||1.3) * 15 / 100).toFixed(1) : '—';
      const soc2v = paramVal('soc2'); const bd2v = paramVal('bd2') || (bd1 ? bd1+0.08 : 1.38);
      const soc2eff = soc2v ?? (soc1 * 0.70);
      const stock2 = soc1 !== null ? (soc2eff * bd2v * 15 / 100).toFixed(1) : '—';
      const ltNote = document.getElementById('layer-target-note');
      if (ltNote) ltNote.textContent =
        `Current: L1=${stock1} t C/ha · L2=${stock2} t C/ha`;
    }
  }

  // Update wizard stepper state
  updateWizardState();
  // Update summary strip and audit panel
  if (typeof updateSoilSummaryStrip === 'function') updateSoilSummaryStrip();
  // Texture feasibility evaluation — updates ST.derived.textureFeas
  ST.derived.textureFeas = evaluateTextureFeasibility();
  updateTextureFeasStrip();
}

/* ═══════════════════════════════════════════════════════
   UNCERTAINTY METER
═══════════════════════════════════════════════════════ */
function updateUncertaintyMeter(cstock, sigma, sigma_pct) {
  const pct_good = 1 - sigma_pct;
  const bar = document.getElementById('uncertainty-bar');
  const cstockEl = document.getElementById('unc-cstock');
  const rangeEl = document.getElementById('unc-range');
  const detailEl = document.getElementById('unc-detail');

  bar.style.width = `${Math.round(pct_good * 100)}%`;

  // Colour: red → amber → green based on sigma_pct
  if (sigma_pct >= 0.18) bar.style.background = '#c02828';
  else if (sigma_pct >= 0.10) bar.style.background = '#c07a10';
  else bar.style.background = '#2e8040';

  cstockEl.textContent = `${cstock.toFixed(1)} t C/ha`;
  rangeEl.textContent = `± ${sigma.toFixed(1)} t C/ha (${Math.round(sigma_pct*100)}% uncertainty · 0–${ST.analysisDepth} cm)`;

  // If field polygon drawn, update total-field values
  updateFieldInfoStrip();

  const socSrc = getParam('soc1').source;
  const bdSrc = getParam('bd1').source;
  let detail = '';
  if (socSrc !== 'lab') detail += '→ Add lab-measured SOC (Walkley-Black) to cut uncertainty. ';
  if (bdSrc !== 'lab') detail += '→ Undisturbed BD core eliminates largest single error source. ';
  if (paramVal('pom1') === null) detail += '→ POM+MAOM fractionation (Tier 2) reduces model error to ±10%. ';
  if (!detail) detail = 'All critical Tier 1+2 parameters measured. Excellent data quality.';
  detailEl.textContent = detail;
}

function updateUncertaintyMeterEmpty() {
  document.getElementById('uncertainty-bar').style.width = '100%';
  document.getElementById('uncertainty-bar').style.background = '#c02828';
  document.getElementById('unc-cstock').textContent = '— t C/ha';
  document.getElementById('unc-range').textContent = '± — t C/ha (0–30 cm)';
  document.getElementById('unc-detail').textContent = 'Enter SOC and bulk density to compute C stock estimate.';
}

/* ═══════════════════════════════════════════════════════
   CEILING DIAGNOSIS
═══════════════════════════════════════════════════════ */
function calcCeiling() {
  const cstock = ST.derived.cstock;
  const hassinkCap = ST.derived.hassinkCap;
  const agroCeil = ST.derived.agroCeil;
  const targetTha = ST.targetTha || (ST.targetPct !== null && cstock !== null ?
    ST.targetPct / (ST.derived.socPct1 || 1) * cstock : null);

  const emptyEl = document.getElementById('ceiling-empty');
  const outputEl = document.getElementById('ceiling-output');

  if (cstock === null || hassinkCap === null || targetTha === null) {
    emptyEl.style.display = 'block';
    outputEl.style.display = 'none';
    let msg = 'Ceiling diagnosis requires: ';
    const missing = [];
    if (cstock === null) missing.push('current SOC (enter soc1 + bd1)');
    if (hassinkCap === null) missing.push('soil texture (clay, silt)');
    if (targetTha === null) missing.push('target SOC');
    emptyEl.textContent = msg + missing.join('; ') + '.';
    return;
  }

  emptyEl.style.display = 'none';
  outputEl.style.display = 'block';

  const sigma = ST.derived.uncertainty || 0;
  const effective_target = ST.confidence === 'conservative' ? targetTha + sigma : targetTha;

  // Determine outcome
  let outcome, headline, sub, icon;

  if (effective_target > hassinkCap) {
    outcome = 'red';
    icon = '🔴';
    headline = 'Physically Constrained — Target Exceeds Hassink Cap';
    sub = `Your target of ${effective_target.toFixed(1)} t C/ha exceeds this soil's mineralogical capacity to bind organic matter (${hassinkCap.toFixed(1)} t C/ha). The solver is blocked. A revised target of ${(hassinkCap * 0.85).toFixed(1)} t C/ha (85% of cap) is suggested.`;
  } else if (effective_target > agroCeil) {
    outcome = 'orange';
    icon = '🟠';
    headline = 'Biochar Required — Regen Practices Alone Insufficient';
    sub = `Your target (${effective_target.toFixed(1)} t C/ha) lies above the achievable ceiling for regenerative practices alone (est. ${agroCeil.toFixed(1)} t C/ha) but within the physical cap (${hassinkCap.toFixed(1)} t C/ha). Biochar is required to reach the target within this soil's MAOM capacity.`;
  } else if (effective_target > agroCeil * 0.75) {
    outcome = 'amber';
    icon = '🟡';
    headline = 'Achievable — Sustained High-Intensity Management Required';
    sub = `Target (${effective_target.toFixed(1)} t C/ha) is within reach (${Math.round(effective_target/agroCeil*100)}% of agronomic ceiling) but demands sustained best-practice management. Conservative confidence mode recommended for planning.`;
  } else {
    outcome = 'green';
    icon = '🟢';
    headline = 'Achievable — Comfortable Headroom Available';
    sub = `Target (${effective_target.toFixed(1)} t C/ha) is ${Math.round(effective_target/agroCeil*100)}% of the agronomic ceiling — multiple practice pathways can reach it. Proceed to farmer interview (Phase 2) for specific recommendations.`;
  }

  ST.derived.outcome = outcome;

  // Update outcome banner
  const banner = document.getElementById('outcome-banner');
  banner.className = `outcome-banner ${outcome}`;
  document.getElementById('outcome-icon').textContent = icon;
  document.getElementById('outcome-headline').textContent = headline;
  document.getElementById('outcome-sub').textContent = sub;

  // Update reference table
  document.getElementById('ref-current').textContent =
    `${cstock.toFixed(1)} t C/ha (${(ST.derived.socPct1||0).toFixed(2)}%)`;
  document.getElementById('ref-current-note').textContent =
    getParam('soc1').source === 'lab' ? 'Lab measured' : 'SoilGrids estimate ± 22%';

  document.getElementById('ref-target').textContent =
    `${targetTha.toFixed(1)} t C/ha (${(ST.targetPct||0).toFixed(2)}%)`;
  document.getElementById('ref-target-note').textContent =
    ST.confidence === 'conservative' ? `Conservative: effective = ${effective_target.toFixed(1)} t C/ha` : 'Central estimate';

  document.getElementById('ref-agro').textContent = `${agroCeil.toFixed(1)} t C/ha`;
  document.getElementById('ref-hassink').textContent = `${hassinkCap.toFixed(1)} t C/ha`;
  document.getElementById('ref-hassink-note').textContent =
    `Hassink (1997) × ${MINERAL_MULT[ST.mineralogy].toFixed(2)} ${ST.mineralogy} correction · clay+silt based`;

  // Build explanation
  buildExplanation(cstock, hassinkCap, agroCeil, targetTha, effective_target, outcome);

  // MAOM diagnostic
  buildMaomDiag();

  // Render gauge
  renderGauge(cstock, targetTha, agroCeil, hassinkCap, sigma);
}

function buildExplanation(cur, cap, agro, target, eff_target, outcome) {
  const gap = eff_target - cur;
  const capUtilPct = Math.round(cur / cap * 100);
  const clay1 = paramVal('clay1');
  const silt1 = paramVal('silt1');
  const ph1 = paramVal('ph1');

  let html = '';

  html += `<p>Current soil C stock of <strong>${cur.toFixed(1)} t C/ha</strong> represents <strong>${capUtilPct}% of the Hassink mineralogical capacity</strong> (${cap.toFixed(1)} t C/ha). `;

  if (capUtilPct >= 85) {
    html += `The mineral matrix is near saturation — this soil's primary priority is <strong>protecting existing C</strong> (no-till, reduced disturbance), not adding more.`;
  } else if (capUtilPct >= 60) {
    html += `There is meaningful remaining capacity, but achieving it requires sustained high-quality C inputs and stable microbial processing conditions.`;
  } else {
    html += `Significant capacity remains. The soil can accept substantial C input from improved management practices.`;
  }
  html += `</p>`;

  // L2: Target > 2× current SOC — flag extreme ambition
  if (target !== null && cur !== null && target > cur * 2.0) {
    html += `<p style="color:var(--amber-2);font-size:0.74rem">⚠ Target (${target.toFixed(1)} t C/ha) is more than 2× current stock (${cur.toFixed(1)} t C/ha). This is highly ambitious — verify this is realistic for the soil type and management system. Carbon project standards typically expect 0.3–1.5 t C/ha/yr increments.</p>`;
  }

  if (gap > 0) {
    html += `<p>Gap to target: <strong>${gap.toFixed(1)} t C/ha</strong> over the target period. `;
    if (outcome === 'red') {
      html += `This gap <strong>cannot be closed</strong> on this soil — the Hassink cap is a physical ceiling set by the mineral surface area available for organic matter binding. Lowering the target to ${(cap * 0.85).toFixed(1)} t C/ha is recommended.`;
    } else if (outcome === 'orange') {
      html += `Regenerative practices alone (est. max ${agro.toFixed(1)} t C/ha) fall ${(eff_target - agro).toFixed(1)} t C/ha short. Biochar applications will be required as an additional stable C pool that bypasses the biological processing bottleneck.`;
    } else {
      html += `The gap is within the range achievable through improved management practices. Phase 2 (farmer interview + BAU trajectory) will reveal how much of this gap is already closing under current practice versus remaining to be addressed.`;
    }
    html += `</p>`;
  } else {
    html += `<p><strong>Current C stock already meets or exceeds the target.</strong> The tool will still compute BAU trajectory in Phase 2 to confirm the soil is not on a declining trajectory that will require management to maintain this level.</p>`;
  }

  // Mineralogy note
  const mult = MINERAL_MULT[ST.mineralogy];
  if (ST.mineralogy !== 'alluvial') {
    const minNote = {
      vertisol: 'Smectite clay (Black Cotton) has very high specific surface area (SSA ~800 m²/g) — the Hassink ceiling on this soil is substantially higher than the equation alone suggests. Permanent negative charge and 2:1 expanding lattice enhance organo-mineral bonding via cation bridging.',
      alfisol:  'Kaolinite-dominant clay (Red/Lateritic) has low SSA (~10–30 m²/g) and pH-dependent charge — the Hassink ceiling is lower than the equation suggests. 1:1 non-expanding structure limits clay–humus complex formation.',
      paddy:    'Fe/Al oxide contribution in paddy soils provides additional organo-mineral bonding capacity beyond the clay+silt term. Reductive dissolution and re-precipitation cycles under flooding generate reactive short-range-order Fe minerals that strongly adsorb dissolved OC.',
      aridisol: 'Desert/Arid soils (Aridisols — Torripsamments, Haplocambids, Petrocalcids of Rajasthan and W. Gujarat) carry illite-dominated 2:1 phyllosilicates with moderate SSA (~100 m²/g), but widespread CaCO₃ coatings physically mask reactive mineral surfaces and substantially reduce the effective MAOM-binding capacity. Singh et al. (2007) report mean SOC of only 4.55 Mg/ha in 0–15 cm under desert conditions. Soil inorganic carbon (SIC — pedogenic carbonates + lithogenic CaCO₃) often exceeds SOC on a stock basis and is not tracked by this model — measure and report SIC separately. The RothC fW modifier (strongly moisture-limited) is the dominant constraint on decomposition in this soil type. Model note (Item 8): physical macroaggregate protection of C during dry seasons is not captured by MAOM-only ceiling — actual C persistence may be slightly higher than this estimate.',
    }[ST.mineralogy] || '';
    html += `<p><em>Mineralogy note:</em> ${minNote} Hassink multiplier: ×${mult.toFixed(2)}.</p>`;
  }

  // ITEM 5: Hassink depth limitation note
  if (paramVal('clay2') === null && paramVal('silt2') === null) {
    html += `<p style="font-size:0.70rem;color:var(--ink-5);font-style:italic">⚠ Model note: Hassink MAOM ceiling uses surface-layer clay+silt only. If subsoil clay% differs substantially, enter subsoil texture for a profile-level ceiling. Ref: Don et al. 2007 (Plant Soil 297:31–42).</p>`;
  }

  // pH note
  if (ph1 !== null && ph1 < 6.0) {
    html += `<p><em>pH alert:</em> Soil pH of ${ph1} suppresses microbial CUE and MAOM formation efficiency. Lime application to bring pH toward 6.5 is the highest-priority intervention on this soil — it will improve C stabilisation independent of C input rate.</p>`;
  }

  // Aridisol-specific SIC alert
  if (ST.mineralogy === 'aridisol') {
    const sic_flag = ph1 !== null && ph1 >= 7.8;
    html += `<div style="background:var(--amber-lt);border:1px solid var(--amber-mid);border-radius:var(--radius);padding:10px 12px;margin-top:10px;font-size:0.76rem;line-height:1.6">
      <strong>⚠ Desert Soil — Inorganic Carbon Advisory</strong><br>
      Aridisols typically carry 10–75 Mg SIC/ha as pedogenic CaCO₃, calcic (Bk) or petrocalcic (Bkm) horizons.
      ${sic_flag ? `<br>⚠ pH ${ph1?.toFixed(1)} confirms active carbonate system — dissolution/reprecipitation of CaCO₃ drives significant C fluxes not captured by RothC.` : ''}
      <br><strong>Recommended additions to field protocol:</strong>
      measure soil inorganic carbon (SIC) by pressure calcimeter or acid treatment at each depth;
      report SIC stock alongside SOC; consider USDA Aridisol suborder (Torripsamments for sandy; Haplocambids for loamy; Petrocalcids for cemented calcic) to select correct depth constraint for C sequestration.
      <br><span style="font-size:0.68rem;color:var(--amber)">Ref: Singh SK et al. (2007) J. Arid Environments 68:408–421 · Monger HC & Gallegos RA (2000) in Soils &amp; Global Change</span>
    </div>`;
  }

  document.getElementById('explanation-card').innerHTML = html;

  // ── AUTOMATION 5: SOC TARGET SUGGESTION ──
  const tSuggest = document.getElementById('target-suggest');
  const tSuggestText = document.getElementById('target-suggest-text');
  const tSuggestRef  = document.getElementById('target-suggest-ref');
  if (tSuggest && tSuggestText && tSuggestRef) {
    const s = suggestSOCTarget();
    if (s) {
      const arrow = s.suggestedPct > (soc1/10) ? '↑' : '→';
      tSuggestText.innerHTML =
        `💡 Suggested target: <strong>${s.suggestedPct.toFixed(2)}% SOC</strong> ` +
        `(${arrow} from current ~${(soc1/10).toFixed(2)}%) — ${s.rationale}. ` +
        `Good-practice baseline for ${s.aridClass} ${s.minKey} soils: ${s.good.toFixed(2)}%; ` +
        `high-potential: ${s.high.toFixed(2)}%.`;
      tSuggestRef.textContent =
        'Ref: Srinivasarao et al. 2014 (Curr Sci 107:1739) · Bhattacharyya et al. 2008 (Geoderma 146:452) · NBSS&LUP baseline SOC · Click target field to use or override';
      tSuggest.style.display = 'block';
      // Colour by how far below potential current SOC is
      const gap = s.high - (soc1/10);
      tSuggest.style.background = gap > 0.5 ? 'var(--amber-lt)' : 'var(--teal-lt)';
      tSuggest.style.borderColor = gap > 0.5 ? 'var(--amber)' : 'var(--teal)';
      tSuggest.style.color       = gap > 0.5 ? 'var(--amber)' : 'var(--teal)';
    } else {
      tSuggest.style.display = 'none';
    }
  }
}

function buildMaomDiag() {
  const pom1 = paramVal('pom1');
  const maom1 = paramVal('maom1');
  const cap = ST.derived.hassinkCap;
  const wrap = document.getElementById('maom-diag-wrap');

  if (pom1 === null || maom1 === null || cap === null) {
    wrap.innerHTML = '';
    return;
  }

  const bd1 = paramVal('bd1') || 1.3;
  const maomStock = maom1 * bd1 * 15 / 100;  // rough t C/ha for MAOM in 0-15cm
  const pomStock = pom1 * bd1 * 15 / 100;

  // cap is for full profile; estimate 0-15cm cap
  const capLayer1 = cap * (15 / ST.analysisDepth);
  const maomCapPct = maomStock / capLayer1;

  const maomHigh = maomCapPct > 0.7;
  const pomHigh = pomStock > 1.0;  // >1 t C/ha POM in 0-15cm = abundant

  let cls, title, text;
  if (!maomHigh && !pomHigh) {
    cls = 'maom-diag-ll'; title = 'MAOM/POM PATTERN: C-Depleted';
    text = 'Both stable (MAOM) and labile (POM) fractions are low. Priority: rebuild soil biology first (pH correction, compost), then increase C input quality and quantity.';
  } else if (!maomHigh && pomHigh) {
    cls = 'maom-diag-lh'; title = 'MAOM/POM PATTERN: Inputs Arriving, Stabilisation Limited';
    text = 'Adequate POM input but poor MAOM formation. Bottleneck is microbial processing efficiency (CUE). Priority: improve C:N ratio of inputs, reduce disturbance, optimise pH, increase Ca²⁺ saturation.';
  } else if (maomHigh && !pomHigh) {
    cls = 'maom-diag-hl'; title = 'MAOM/POM PATTERN: Near Mineral Ceiling';
    text = 'MAOM approaching saturation capacity. Priority shifts to protecting existing C (no-till, aggregate building) rather than adding more. Further MAOM gains are limited by available mineral surface area.';
  } else {
    cls = 'maom-diag-hh'; title = 'MAOM/POM PATTERN: Well-Functioning Carbon System';
    text = 'Both stable and labile fractions healthy. Maintain current practices. Marginal additional gain possible through profile deepening or crop diversification.';
  }

  wrap.innerHTML = `<div class="maom-diagnostic ${cls}"><h5>${title}</h5><span>${text}</span></div>`;
}

/* ═══════════════════════════════════════════════════════
   GAUGE SVG
═══════════════════════════════════════════════════════ */
function renderGauge(current, target, agroCeil, hassinkCap, sigma) {
  const svg = document.getElementById('gauge-svg');
  const W = 400, padL = 10, padR = 10;
  const trackW = W - padL - padR;
  const trackY = 52, trackH = 12;
  const maxVal = hassinkCap * 1.12;

  const toX = v => padL + (v / maxVal) * trackW;

  let svgContent = '';

  // Gradient zones background
  const greenEnd = toX(agroCeil);
  const amberEnd = toX(hassinkCap);

  // Green zone
  svgContent += `<rect x="${padL}" y="${trackY}" width="${greenEnd-padL}" height="${trackH}" fill="#c0e0c4" rx="6"/>`;
  // Amber zone
  svgContent += `<rect x="${greenEnd}" y="${trackY}" width="${amberEnd-greenEnd}" height="${trackH}" fill="#f2ddb0"/>`;
  // Red zone
  svgContent += `<rect x="${amberEnd}" y="${trackY}" width="${toX(maxVal)-amberEnd}" height="${trackH}" fill="#f0c0c0" rx="0" style="border-radius:0 6px 6px 0"/>`;

  // Track border
  svgContent += `<rect x="${padL}" y="${trackY}" width="${trackW}" height="${trackH}" fill="none" stroke="#9a9a7a" stroke-width="1" rx="6"/>`;

  // Uncertainty band around current
  if (sigma > 0) {
    const lo = Math.max(0, toX(current - sigma));
    const hi = Math.min(toX(maxVal), toX(current + sigma));
    svgContent += `<rect x="${lo}" y="${trackY-2}" width="${hi-lo}" height="${trackH+4}" fill="rgba(26,60,26,0.13)" rx="3"/>`;
  }

  // Agronomic ceiling marker
  const acX = toX(agroCeil);
  svgContent += `<line x1="${acX}" y1="${trackY-6}" x2="${acX}" y2="${trackY+trackH+2}" stroke="#c07a10" stroke-width="1.5" stroke-dasharray="3,2"/>`;
  svgContent += `<text x="${acX}" y="${trackY-9}" text-anchor="middle" font-size="9" fill="#9a5e08" font-family="IBM Plex Sans">Agro. max</text>`;
  svgContent += `<polygon points="${acX-5},${trackY-6} ${acX+5},${trackY-6} ${acX},${trackY-1}" fill="#c07a10"/>`;

  // Hassink cap wall
  const hcX = toX(hassinkCap);
  svgContent += `<rect x="${hcX-2}" y="${trackY-4}" width="4" height="${trackH+8}" fill="#8a1a1a" rx="1"/>`;
  svgContent += `<text x="${hcX}" y="${trackY+trackH+16}" text-anchor="middle" font-size="9" fill="#8a1a1a" font-family="IBM Plex Sans">Hassink cap</text>`;

  // Current marker (circle)
  const curX = toX(current);
  svgContent += `<circle cx="${curX}" cy="${trackY + trackH/2}" r="7" fill="#1a2e1a" stroke="white" stroke-width="1.5"/>`;
  svgContent += `<text x="${curX}" y="${trackY-9}" text-anchor="middle" font-size="9" fill="#1a2e1a" font-family="IBM Plex Mono" font-weight="600">${current.toFixed(1)}</text>`;
  svgContent += `<text x="${curX}" y="${trackY-20}" text-anchor="middle" font-size="8" fill="#4a6a4a" font-family="IBM Plex Sans">Current</text>`;

  // Target marker (diamond)
  const tX = toX(Math.min(target, maxVal * 0.99));
  const tColor = target > hassinkCap ? '#8a1a1a' : target > agroCeil ? '#8a3a08' : '#1a2e6a';
  const d = 6;
  svgContent += `<polygon points="${tX},${trackY-d} ${tX+d},${trackY+trackH/2} ${tX},${trackY+trackH+d} ${tX-d},${trackY+trackH/2}" fill="${tColor}" opacity="0.9"/>`;
  svgContent += `<text x="${tX}" y="${trackY+trackH+22}" text-anchor="middle" font-size="9" fill="${tColor}" font-family="IBM Plex Mono" font-weight="600">${target.toFixed(1)}</text>`;
  svgContent += `<text x="${tX}" y="${trackY+trackH+33}" text-anchor="middle" font-size="8" fill="${tColor}" font-family="IBM Plex Sans">Target</text>`;

  // BAU placeholder (dashed line, Phase 2)
  svgContent += `<text x="${padL+4}" y="14" font-size="8.5" fill="#7a9a7a" font-family="IBM Plex Sans" font-style="italic">BAU trajectory: available in Phase 2 (farmer interview required)</text>`;

  // Scale ticks
  const ticks = [0, hassinkCap * 0.25, hassinkCap * 0.5, hassinkCap * 0.75, hassinkCap];
  ticks.forEach(v => {
    const tx = toX(v);
    svgContent += `<line x1="${tx}" y1="${trackY+trackH}" x2="${tx}" y2="${trackY+trackH+4}" stroke="#9a9a7a" stroke-width="0.8"/>`;
    svgContent += `<text x="${tx}" y="${trackY+trackH+13}" text-anchor="middle" font-size="7.5" fill="#7a9a7a" font-family="IBM Plex Mono">${v.toFixed(0)}</text>`;
  });
  svgContent += `<text x="${toX(maxVal/2)}" y="104" text-anchor="middle" font-size="8" fill="#9a9a7a" font-family="IBM Plex Sans">Carbon stock (t C/ha)</text>`;

  svg.innerHTML = svgContent;
}

