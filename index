/* ── Allometric engine ──────────────────────────────────────────────
   Tier 1: MAI-based annual C increment
   Tier 2: Chave et al. 2014 pantropical (requires DBH + height)
   BGB: IPCC Tier 1 root:shoot ratios
────────────────────────────────────────────────────────────────── */
function treeAGBStock(sp, density, dbh_cm, age_class) {
  /* Returns AGB C stock in t C/ha at current state.
     If DBH is provided, uses Chave 2014 allometry;
     otherwise estimates from MAI × age midpoint. */
  const def = TREE_SPECIES[sp];
  if (!def) return 0;
  if (dbh_cm && dbh_cm > 0) {
    // Chave et al. 2014 eq.4 (tropical): AGB = 0.0673 × (ρ × D² × H)^0.976
    // Use H = 0.8 × D^0.65 (tropical height-diameter: Feldpausch 2011)
    const rho   = def.wood_density;
    const D     = dbh_cm;
    const H     = 0.8 * Math.pow(D, 0.65);
    const agb_kg = 0.0673 * Math.pow(rho * D * D * H, 0.976);
    const agb_t_per_tree = agb_kg / 1000;
    return (agb_t_per_tree * density * 0.47) / 1;  // 0.47 = wood C fraction
  }
  // Tier 1: MAI × age midpoint
  const ageMid = { 'young':1.5, 'mid':5.5, 'mat':11.5, 'old':20 };
  const mid = ageMid[age_class] || 5.5;
  const mai = def.mai_c[age_class] || def.mai_c.mid || 1.0;
  return mai * mid * density / 100;  // t C/ha
}

function treeAGBIncrement(sp, density, age_class) {
  /* Annual AGB C increment t C/ha/yr — Tier 1 MAI */
  const def = TREE_SPECIES[sp];
  if (!def) return 0;
  const mai = def.mai_c[age_class] || def.mai_c.mid || 1.0;
  return mai * density / 100;  // scale by stocking density (MAI is at 100 trees/ha reference)
}

function treeBGBIncrement(sp, density, age_class) {
  const def = TREE_SPECIES[sp];
  if (!def) return 0;
  return treeAGBIncrement(sp, density, age_class) * (def.root_shoot || 0.26);
}

function treeLitterCin(sp, density) {
  const def = TREE_SPECIES[sp];
  if (!def) return 0;
  return def.litter_cin * density / 100;  // t C/ha/yr
}

function treeCanopyCover(sp, density, age_class) {
  const def = TREE_SPECIES[sp];
  if (!def) return 0;
  const ageFactor = { young:0.25, mid:0.60, mat:1.00, old:1.00 }[age_class] || 0.60;
  return Math.min(95, def.shade_cast * density / 100 * ageFactor);  // %
}

function calcTotalTreeCDR(years) {
  /* Compute cumulative AGB+BGB CDR trajectory over target period.
     Returns array of { year, agb_c, bgb_c, total_c } — CO₂e. */
  const trees = ST.farm.trees || [];
  if (!trees.length) return null;
  const areaf = ST.farm.treeAreaFraction ?? 1.0;
  const traj  = [];
  for (let yr = 0; yr <= years; yr++) {
    let agb_c = 0, bgb_c = 0;
    trees.forEach(t => {
      const sp  = t.id;
      const den = (t.density || 100) * areaf;
      agb_c += treeAGBIncrement(sp, den, t.age_class || 'mid') * yr;
      bgb_c += treeBGBIncrement(sp, den, t.age_class || 'mid') * yr;
    });
    traj.push({ year: yr,
      agb_c: agb_c * 0.47 * (44/12),   // t C → t CO₂e
      bgb_c: bgb_c * 0.47 * (44/12),
      total_c: (agb_c + bgb_c) * 0.47 * (44/12),
    });
  }
  return traj;
}

function calcTreeLitterContrib() {
  /* Total annual litter Cin from all tree entries, t C/ha/yr */
  const trees = ST.farm.trees || [];
  const areaf = ST.farm.treeAreaFraction ?? 1.0;
  return trees.reduce((s, t) => {
    return s + treeLitterCin(t.id, (t.density||100) * areaf);
  }, 0);
}

