}

/* ── REST retry wrapper ── */
async function fetchWithRetry(url, maxAttempts = 3, baseDelayMs = 1200) {
  let lastErr;
  for (let i = 1; i <= maxAttempts; i++) {
    try {
      const resp = await fetch(url, { signal: AbortSignal.timeout(12000) });
      if (resp.ok) return resp;
      if ([503, 502, 429, 500].includes(resp.status)) {
        lastErr = new Error(`HTTP ${resp.status}`);
        if (i < maxAttempts) { await new Promise(r => setTimeout(r, baseDelayMs * Math.pow(2, i - 1))); continue; }
        throw lastErr;
      }
      throw new Error(`HTTP ${resp.status}`);
    } catch(e) {
      lastErr = e;
      if (e.name === 'AbortError') { lastErr = new Error('Timed out'); break; }
      if (i < maxAttempts) await new Promise(r => setTimeout(r, baseDelayMs * Math.pow(2, i - 1)));
    }
  }
  throw lastErr;
}

async function fetchSoilGrids() {
  await ensureGeoTIFF();
  if (ST.mode === 'field') return;
  if (!ST.lat || !ST.lon) return;

  const btn    = document.getElementById('fetch-btn');
  const status = document.getElementById('fetch-status');
  btn.disabled = true;
  const lat = ST.lat, lon = ST.lon;

  // ── Source 1: SoilGrids REST (rest.isric.org) ───────────────────────────
  status.textContent = '⏳ Trying SoilGrids REST…';
  status.className   = 'fetch-status loading';

  const sgProps = ['soc','clay','silt','sand','bdod','phh2o','nitrogen','cec','cfvo'].map(p=>`property=${p}`).join('&');
  const sgUrl   = `https://rest.isric.org/soilgrids/v2.0/properties/query?lon=${lon.toFixed(6)}&lat=${lat.toFixed(6)}&${sgProps}&depth=0-5cm&depth=5-15cm&depth=15-30cm&value=mean`;

  let sgData = null;
  try {
    const resp = await fetchWithRetry(sgUrl, 1, 500);  // only 1 retry — 503 is server-side
    if (resp.ok) sgData = await resp.json();
    // On 503/502: REST is down — fall through to WCS (maps.isric.org is a separate server)
  } catch(e) { /* fall through to WCS */ }

  if (sgData) {
    const ex = (prop, depth) => {
      const L = (sgData.properties?.layers || []).find(l => l.name === prop);
      return L?.depths?.find(d => d.label === depth)?.values?.mean ?? null;
    };
    applyExtractedData({
      soc1:  avg2(ex('soc','0-5cm'),  ex('soc','5-15cm')),   soc2:  ex('soc','15-30cm'),
      clay1: avg2(ex('clay','0-5cm'), ex('clay','5-15cm')),  clay2: ex('clay','15-30cm'),
      silt1: avg2(ex('silt','0-5cm'), ex('silt','5-15cm')),  silt2: ex('silt','15-30cm'),
      sand1: avg2(ex('sand','0-5cm'), ex('sand','5-15cm')),  sand2: ex('sand','15-30cm'),
      bd1:   avg2(ex('bdod','0-5cm'), ex('bdod','5-15cm')),  bd2:   ex('bdod','15-30cm'),
      ph1:   avg2(ex('phh2o','0-5cm'),ex('phh2o','5-15cm')), ph2:   ex('phh2o','15-30cm'),
      tn1:   avg2(ex('nitrogen','0-5cm'),ex('nitrogen','5-15cm')), tn2: ex('nitrogen','15-30cm'),
      cec1:  ex('cec','0-5cm'), cfvo1: ex('cfvo','0-5cm'),
    }, 'soilgrids', {soc:0.1,clay:0.1,silt:0.1,sand:0.1,bd:0.01,ph:0.1,tn:0.001,cec:0.1,cfvo:0.1},
    status, btn);
    return;
  }

  // ── Source 2: SoilGrids WCS (maps.isric.org) ────────────────────────────
  // maps.isric.org is independent from rest.isric.org — different server.
  // WCS GetCoverage: returns a reprojected tiny GeoTIFF; geotiff.js decodes it.
  // CORS confirmed working from browser (same domain served WMS earlier).
  // 22 parallel requests, each returning ~1 KB GeoTIFF. Total ~25 KB.
  if (typeof GeoTIFF === 'undefined') {
    status.innerHTML = `<strong>⚠ geotiff.js not loaded</strong> — reload the page.`;
    status.className = 'fetch-status err'; btn.disabled = false; return;
  }

  status.textContent = '⏳ REST unavailable — trying WCS (maps.isric.org — separate server)…';

  try {
    // Unit divisors match REST API raw integer values:
    // soc ÷10=dg/kg; clay÷10=%; bdod÷100=g/cm³; phh2o÷10; nitrogen÷1000=%; cec÷10; cfvo÷10
    const [
      soc05, soc515, soc1530,
      clay05, clay515, clay1530,
      silt05, silt515, silt1530,
      sand05, sand515, sand1530,
      bd05, bd515, bd1530,
      ph05, ph515, ph1530,
      tn05, tn515,
      cec05, cfvo05
    ] = await Promise.all([
      readWCSPixel('soc',     'soc_0-5cm_mean',      lat, lon),
      readWCSPixel('soc',     'soc_5-15cm_mean',     lat, lon),
      readWCSPixel('soc',     'soc_15-30cm_mean',    lat, lon),
      readWCSPixel('clay',    'clay_0-5cm_mean',     lat, lon),
      readWCSPixel('clay',    'clay_5-15cm_mean',    lat, lon),
      readWCSPixel('clay',    'clay_15-30cm_mean',   lat, lon),
      readWCSPixel('silt',    'silt_0-5cm_mean',     lat, lon),
      readWCSPixel('silt',    'silt_5-15cm_mean',    lat, lon),
      readWCSPixel('silt',    'silt_15-30cm_mean',   lat, lon),
      readWCSPixel('sand',    'sand_0-5cm_mean',     lat, lon),
      readWCSPixel('sand',    'sand_5-15cm_mean',    lat, lon),
      readWCSPixel('sand',    'sand_15-30cm_mean',   lat, lon),
      readWCSPixel('bdod',    'bdod_0-5cm_mean',     lat, lon),
      readWCSPixel('bdod',    'bdod_5-15cm_mean',    lat, lon),
      readWCSPixel('bdod',    'bdod_15-30cm_mean',   lat, lon),
      readWCSPixel('phh2o',   'phh2o_0-5cm_mean',    lat, lon),
      readWCSPixel('phh2o',   'phh2o_5-15cm_mean',   lat, lon),
      readWCSPixel('phh2o',   'phh2o_15-30cm_mean',  lat, lon),
      readWCSPixel('nitrogen','nitrogen_0-5cm_mean',  lat, lon),
      readWCSPixel('nitrogen','nitrogen_5-15cm_mean', lat, lon),
      readWCSPixel('cec',     'cec_0-5cm_mean',      lat, lon),
      readWCSPixel('cfvo',    'cfvo_0-5cm_mean',      lat, lon),
    ]);

    if (soc05 === null && soc515 === null) {
      throw new Error('No data returned — point may be in ocean or outside coverage');
    }

    applyExtractedData({
      soc1:  avg2(soc05,  soc515),   soc2:  soc1530,
      clay1: avg2(clay05, clay515),  clay2: clay1530,
      silt1: avg2(silt05, silt515),  silt2: silt1530,
      sand1: avg2(sand05, sand515),  sand2: sand1530,
      bd1:   avg2(bd05,   bd515),    bd2:   bd1530,
      ph1:   avg2(ph05,   ph515),    ph2:   ph1530,
      tn1:   avg2(tn05,   tn515),    tn2:   null,
      cec1:  cec05, cfvo1: cfvo05,
    }, 'soilgrids', {soc:0.1,clay:0.1,silt:0.1,sand:0.1,bd:0.01,ph:0.1,tn:0.001,cec:0.1,cfvo:0.1},
    status, btn, 'SoilGrids v2 WCS (maps.isric.org)');

  } catch(e) {
    showSoilGridsOutageMessage(status, btn, e.message);
  }
}

/* ── SoilGrids outage handler ─────────────────────────────────────────────
   Called when both REST and WCS fail. Shows a clear, actionable message
   distinguishing between: ISRIC outage, CORS block, or bad coordinates.
────────────────────────────────────────────────────────────────────────── */
function showSoilGridsOutageMessage(status, btn, errMsg) {
  const isOutage = errMsg?.includes('503') || errMsg?.includes('502') ||
                   errMsg?.includes('Failed to fetch') || errMsg?.includes('ERR_FAILED');
  const isCORS   = errMsg?.includes('CORS') || errMsg?.includes('origin');

  const msgTitle = isOutage
    ? '⚠ SoilGrids servers are currently offline (ISRIC outage)'
    : isCORS
    ? '⚠ SoilGrids blocked — run from localhost instead of file://'
    : `⚠ Soil data unavailable — ${errMsg}`;

  const helpLine = isOutage
    ? 'ISRIC has paused the API with no timeline. Enter values manually or retry later.'
    : isCORS
    ? 'Run: <code>python -m http.server 8080</code> then open http://localhost:8080'
    : 'Check coordinates are on land, then retry.';

  const btnStyle = 'border:none;border-radius:4px;padding:3px 10px;cursor:pointer;font-size:0.75rem;font-weight:600;margin:0 3px';
  status.innerHTML =
    `<div style="margin-bottom:4px"><strong>${msgTitle}</strong></div>` +
    `<div style="font-size:0.75rem;margin-bottom:6px">${helpLine}</div>` +
    `<button onclick="fetchSoilGrids()" style="background:var(--teal);color:white;${btnStyle}">🔄 Retry</button>` +
    `<button onclick="activateManualEntry()" style="background:var(--amber-2);color:white;${btnStyle}">✏ Enter Manually</button>` +
    (isOutage ? `<button onclick="openOutageGuide()" style="background:var(--paper-3);color:var(--ink-2);${btnStyle}">📋 Typical Values</button>` : '');
  status.className = 'fetch-status err';
  btn.disabled = false;
}

