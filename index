function loadSession() {
  try {
    const raw = localStorage.getItem('scp_session_v3');
    if (!raw) { showToast('No saved session found'); return; }
    const snap = JSON.parse(raw);

    // ── Crop ID migration map (v1 → v2 IDs) ──────────────────────────────
    // Old single-ID crops split into specific varieties in v2 CROPS database
    const CROP_MIGRATE = {
      rice:            'rice_wetland',
      mustard:         'mustard_brown',
      cotton:          'cotton_bt',
      small_millets:   'kodo_millet',
      pulses:          'chickpea',
      agroforestry:    'napier',       // fallback — agroforestry removed from annual crops
      pasture:         'pasture_mixed',
    };
    const migrateCropId = id => CROP_MIGRATE[id] || (CROPS[id] ? id : 'wheat');

    // Reset auto-detect override flags so automations re-run cleanly
    ST._irrigManual = false; ST._tillageManual = false; ST._depthManual = false;

    // Restore lat/lon
    if (snap.lat && snap.lon) {
      ST.lat = snap.lat; ST.lon = snap.lon; ST.locationName = snap.locationName;
      if (window._map) window._map.setView([snap.lat, snap.lon], 12);
      document.getElementById('loc-text').textContent =
        snap.locationName || `${snap.lat.toFixed(4)}, ${snap.lon.toFixed(4)}`;
      fetchClimate(snap.lat, snap.lon);
    }

    // Restore farm rotation (v2 format with migration)
    if (snap.farm) {
      if (snap.farm.crops?.length) {
        ST.farm.crops = snap.farm.crops.map(s => {
          const newId  = migrateCropId(s.id);
          const defCal = getCropCalendar(newId);
          return {
            id:           newId,
            residue:      s.residue    || 'surface',
            residue_pct:  (s.residue_pct !== undefined) ? s.residue_pct : null,
            tillage:      (s.tillage    && TILLAGE[s.tillage])          ? s.tillage    : 'shallow',
            irrigation:   (s.irrigation && IRRIGATION_DEF[s.irrigation]) ? s.irrigation : 'rainfed',
            sow_month:     (s.sow_month     !== undefined) ? s.sow_month     : defCal.sow,
            harvest_month: (s.harvest_month !== undefined) ? s.harvest_month : defCal.harvest,
          };
        });
      }
      if (snap.farm.tillage && TILLAGE[snap.farm.tillage])   { ST.farm.tillage = snap.farm.tillage; ST._tillageManual = true; }
      if (snap.farm.irrigation && IRRIGATION_DEF[snap.farm.irrigation]) { ST.farm.irrigation = snap.farm.irrigation; ST._irrigManual = true; }
      if (snap.farm.organics) {
        // Merge snap organics, preserving apply_month defaults for keys not in snapshot
        Object.entries(snap.farm.organics).forEach(([k,v]) => {
          if (ST.farm.organics[k]) {
            ST.farm.organics[k] = {
              ...ST.farm.organics[k], ...v,
              apply_month: (v.apply_month !== undefined) ? v.apply_month : ST.farm.organics[k].apply_month,
            };
          }
        });
      }
      if (snap.farm.history)   ST.farm.history   = { ...ST.farm.history,  ...snap.farm.history };
      if (snap.farm.trees) {
        ST.farm.trees = snap.farm.trees.filter(t => TREE_SPECIES[t.id]);
      }
      if (snap.farm.treeAreaFraction !== undefined) {
        ST.farm.treeAreaFraction = snap.farm.treeAreaFraction;
        const sl = document.getElementById('tree-area-slider');
        const dp = document.getElementById('tree-area-display');
        if (sl) sl.value = Math.round(snap.farm.treeAreaFraction * 100);
        if (dp) dp.textContent = Math.round(snap.farm.treeAreaFraction * 100) + '%';
      }
    }

    // Restore soil test inputs
    if (snap.soilTest) {
      Object.entries(snap.soilTest).forEach(([id, val]) => {
        const el = document.getElementById(id);
        if (el) { el.value = val; el.dispatchEvent(new Event('input')); }
      });
    }

    // Restore target
    if (snap.targetL1_tha !== undefined) {
      ST.targetL1_tha = snap.targetL1_tha;
      ST.targetL2_tha = snap.targetL2_tha;
      const el1 = document.getElementById('target-l1');
      const el2 = document.getElementById('target-l2');
      if (el1 && snap.targetL1_tha !== null) el1.value = snap.targetL1_tha.toFixed(1);
      if (el2 && snap.targetL2_tha !== null) el2.value = snap.targetL2_tha.toFixed(1);
    }
    if (snap.targetYear) {
      ST.targetYear = snap.targetYear;
      const slider = document.getElementById('target-year-slider');
      if (slider) slider.value = snap.targetYear;
      const label = document.getElementById('target-year-val');
      if (label) label.textContent = `${snap.targetYear} yr`;
    }
    if (snap.targetPct) {
      const el = document.getElementById('target-pct');
      if (el) { el.value = snap.targetPct; onTargetInput('pct'); }
    } else if (snap.targetTha) {
      const el = document.getElementById('target-tha');
      if (el) { el.value = snap.targetTha; onTargetInput('tha'); }
    }

    // Restore feasibility
    if (snap.bcInterval) {
      ST.farm.bcInterval = snap.bcInterval;
      const _sel = document.getElementById('bc-interval-select');
      if (_sel) _sel.value = snap.bcInterval;
    }
    if (snap.feas) {
      Object.entries(snap.feas).forEach(([k, excluded]) => {
        ST.feas[k] = excluded;
        document.getElementById(`feas-${k}`)?.classList.toggle('excluded', excluded);
      });
    }

    // Restore mineralogy
    if (snap.mineralogy) {
      ST.mineralogy = snap.mineralogy;
      ['alluvial','vertisol','alfisol','paddy','aridisol'].forEach(mc =>
        document.getElementById(`mc-${mc}`)?.classList.toggle('selected', mc === snap.mineralogy));
    }

    // Restore field boundary polygon
    if (snap.fieldBoundary) {
      ST.fieldBoundary = snap.fieldBoundary;
      ST.fieldAreaHa   = snap.fieldAreaHa || null;
      try {
        _featureGroup.clearLayers();
        const layer = L.geoJSON(snap.fieldBoundary, {
          style: { color: '#2e8040', fillColor: '#4aaf6a', fillOpacity: 0.18, weight: 2 }
        });
        layer.addTo(_featureGroup);
        document.getElementById('draw-btn-clear').style.display  = 'inline-block';
        document.getElementById('draw-btn-export').style.display = 'inline-block';
        map.fitBounds(_featureGroup.getBounds(), { padding: [20, 20] });
        updateFieldInfoStrip();
      } catch(e) { console.warn('Field boundary restore failed', e); }
    }

    // Re-render Phase 2 UI with restored farm state
    renderRotationSlots();
    renderTreeSlots();
    setTillage(ST.farm.tillage);
    setIrrigation(ST.farm.irrigation);
    renderOrganicRows();

    showToast('Session restored ✓');
    setTimeout(() => { triggerBAU(); updateWizardState(); }, 400);
  } catch(e) {
    console.warn('Session load failed', e);
    showToast('Session load failed');
  }
}

function showToast(msg, ms=2200) {
  let t = document.getElementById('scp-toast');
  if (!t) {
    t = document.createElement('div');
    t.id = 'scp-toast';
    t.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#0e4a3a;color:#c8ece0;' +
      'padding:10px 20px;border-radius:8px;font-size:0.78rem;font-family:var(--sans);' +
      'box-shadow:0 4px 20px rgba(0,0,0,0.3);z-index:9999;transition:opacity 0.3s;pointer-events:none;';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = '1';
  clearTimeout(t._timer);
  t._timer = setTimeout(() => { t.style.opacity = '0'; }, ms);
}

