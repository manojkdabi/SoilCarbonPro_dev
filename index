}

function renderBAUNarrative(cur, bau_end, cin, years) {
  const delta    = bau_end - cur;
  const rate     = delta / years;
  const co2eRate = (rate * 3.664).toFixed(2);
  const el       = document.getElementById('bau-narrative');
  const gap      = ST.targetTha ? (ST.targetTha - bau_end) : null;
  const bd       = paramVal('bd1') || 1.3;
  const depth    = ST.analysisDepth || 30;

  // Line 1: trajectory status
  let statusIcon, statusClass, line1;
  if (delta < -1.0) {
    statusIcon = '📉'; statusClass = 'declining';
    line1 = `<strong>${statusIcon} Declining:</strong> BAU projects <strong>${Math.abs(delta).toFixed(1)} t C/ha loss</strong> over ${years} yr (${Math.abs(rate).toFixed(2)} t C/ha/yr · ${Math.abs(co2eRate)} t CO₂e/ha/yr emitted)`;
  } else if (delta < 0.5) {
    statusIcon = '⚖'; statusClass = 'stable';
    line1 = `<strong>${statusIcon} Stable:</strong> BAU projects near steady-state — <strong>${delta>=0?'+':''}${delta.toFixed(1)} t C/ha</strong> over ${years} yr under current management`;
  } else {
    statusIcon = '📈'; statusClass = 'gaining';
    line1 = `<strong>${statusIcon} Building:</strong> BAU projects <strong>+${delta.toFixed(1)} t C/ha</strong> over ${years} yr (+${rate.toFixed(2)} t C/ha/yr · +${co2eRate} t CO₂e/ha/yr sequestered)`;
  }

  // H5: Plantation/tree crop AGB disclaimer
  const PLANTATION_GROUP = 'Plantation & Tree Crops';
  const hasPlantation = ST.farm.crops.some(s => CROPS[s.id]?.group === PLANTATION_GROUP);

  // Line 2: drivers
  const tillSummary  = [...new Set(ST.farm.crops.map(s=>TILLAGE[s.tillage||'shallow']?.name||''))].join('/');
  const irrigSummary = [...new Set(ST.farm.crops.map(s=>IRRIGATION_DEF[s.irrigation||'rainfed']?.name||''))].join('/');
  const line2 = `<strong>Drivers:</strong> ${cin.total.toFixed(1)} t C/ha/yr input · ${tillSummary} · ${irrigSummary} · ${ST.farm.crops.map(s=>RESIDUE_FRAC[s.residue]?.label||'').join('/')}`;
  const ensNote = ST.bau?.ensembleNote || '';
  const lineEns = ensNote ? `<strong>Uncertainty basis:</strong> ${ensNote}` : '';

  // Line 3: gap to target
  let line3 = '';
  if (gap !== null) {
    if (gap <= 0) {
      line3 = `<strong>✓ Target reached by BAU</strong> — consider raising target or shortening timeframe`;
    } else {
      const gapCO2e = (gap * 3.664).toFixed(1);
      line3 = `<strong>Gap to target:</strong> ${gap.toFixed(1)} t C/ha (${gapCO2e} t CO₂e) must be closed by Phase 3 interventions`;
      if (delta < -0.5) line3 += ' — gap includes ongoing BAU losses, not just current-to-target shortfall';
    }
  }

  // H5: Plantation AGB disclaimer line
  const line4 = hasPlantation
    ? `<strong>🌳 Plantation scope note:</strong> This model projects <em>soil C only</em> (RothC litterfall + root turnover). Above-ground woody biomass (AGB) and below-ground structural roots are NOT included. For plantation CDR claims, add AGB allometric calculations separately. Total ecosystem C >> soil C for tree crops.`
    : '';

  el.className = `bau-narrative ${statusClass}`;
  el.innerHTML = [line1, line2, lineEns, line3, line4].filter(Boolean).map(l=>`<div class="bau-line">${l}</div>`).join('');
}

function estimateNMin(soc0_tha, clay_pct, pH, cin_annual, tillage_mult, climate_monthly) {
  // Run one year to get decomposition flux → N mineralised
  const dpm_rpm = cin_annual.dpm_rpm || 1.44;
  let pools = initPools(soc0_tha, dpm_rpm);
  const cin_per_mo = { total: cin_annual.total / 12, dpm_rpm };
  const irrig = cin_annual.irrig_mult || 1.0;
  let n_min_yr = 0;

  for (let mo = 0; mo < 12; mo++) {
    const { temp, precip } = climate_monthly[mo % 12];
    const t_nm = (temp !== null && !isNaN(temp)) ? temp : 25;
    const mod = Math.min(fT(t_nm) * fW(precip, irrig) * fPH(pH) * tillage_mult, 5.0);
    const x = 1.67 * (1.85 + 1.60 * Math.exp(-0.0786 * clay_pct));
    ['dpm','rpm','bio','hum'].forEach(pool => {
      const dec = pools[pool] * (1 - Math.exp(-K_REF[pool]*mod/12));
      n_min_yr += dec / POOL_CN[pool] * (14/12) * 1000;  // kg N/ha
      pools[pool] -= dec;
      const f = 1/(1+x);
      pools.bio += dec * f * 0.46;
      pools.hum += dec * f * 0.54;
    });
    const r = dpm_rpm;
    pools.dpm += cin_per_mo.total * r/(1+r);
    pools.rpm += cin_per_mo.total / (1+r);
  }

  const nEl = document.getElementById('n-output');
  const nVal = document.getElementById('n-val');
  if (n_min_yr > 0) {
    nEl.style.display = 'flex';
    nVal.textContent = `${n_min_yr.toFixed(0)} kg N/ha/yr`;
  }
}

