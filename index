        <div class="modal-field">
          <label>Farmer Phone</label>
          <input id="modal-farmer-phone" type="tel" placeholder="+91 XXXXX XXXXX">
        </div>
      </div>

      <div class="modal-field">
        <label>Village *
          <span style="font-weight:400;color:var(--ink-5);font-size:0.60rem;margin-left:4px">
