/* ── triggerSatelliteAnalysis: entry point from 🛰 Vegetation button ── */
async function triggerSatelliteAnalysis() {
  if (!ST.fieldBoundary) return;

  const cid  = localStorage.getItem('scp_sh_client_id');
  const csec = localStorage.getItem('scp_sh_client_secret');
  if (!cid || !csec) {
    showToast('⚠ Sentinel Hub credentials not set — go to Settings → Satellite Data');
    return;
  }

  const panel  = document.getElementById('satellite-panel');
  const progEl = document.getElementById('sat-progress');
  const btn    = document.getElementById('analyse-vegetation-btn');
  if (btn) btn.disabled = true;
  if (panel) panel.style.display = 'block';
  if (progEl) { progEl.style.display='block'; progEl.textContent='⏳ Connecting to Sentinel Hub…'; }

  // Compute bbox from field boundary (with 50m buffer for edge pixels)
  const coords = ST.fieldBoundary.geometry.coordinates[0];
  const lons = coords.map(p => p[0]), lats = coords.map(p => p[1]);
  const BUF = 0.0005;  // ~50m buffer
  const bbox = [
    Math.min(...lons) - BUF, Math.min(...lats) - BUF,
    Math.max(...lons) + BUF, Math.max(...lats) + BUF,
  ];

  // 5-year date range ending today
  const today = new Date();
  const endDate   = today.toISOString().slice(0,10);
  const startDate = new Date(today.setFullYear(today.getFullYear()-5)).toISOString().slice(0,10);

  try {
    if (progEl) progEl.textContent = '⏳ Fetching 5-year NDVI time series…';

    const resp = await fetch(`${SUPABASE_URL}/functions/v1/ndvi-proxy`, {
      method: 'POST',
      headers: {
        'Content-Type':  'application/json',
        'apikey':        SUPABASE_ANON,
        'Authorization': `Bearer ${SUPABASE_ANON}`,
      },
      body: JSON.stringify({ clientId:cid, clientSecret:csec, bbox, startDate, endDate }),
      signal: AbortSignal.timeout(45000),
    });

    if (!resp.ok) {
      const err = await resp.json().catch(() => ({error: resp.statusText}));
      throw new Error(err.error || `HTTP ${resp.status}`);
    }

    const result = await resp.json();
    if (result.error) throw new Error(result.error);
    if (!result.data || result.data.length === 0) throw new Error('No NDVI data returned');

    if (progEl) progEl.textContent = '⏳ Computing NPP and carbon inputs…';
    await new Promise(r => setTimeout(r, 50));  // let UI update

    applySatelliteResult(result.data);
    if (progEl) progEl.style.display = 'none';

    document.getElementById('sat-panel-badge').textContent =
      `${result.data.filter(d=>d.valid).length} valid months · SRTM 10m`;

  } catch(e) {
    if (progEl) {
      progEl.textContent = `⚠ Satellite fetch failed: ${e.message}`;
      progEl.style.color = 'var(--red-2)';
    }
    console.error('Sprint 5A error:', e);
  }
  if (btn) btn.disabled = false;
}

/* ── applySatelliteResult: process raw NDVI data → NPP → Cin → UI ── */
function applySatelliteResult(data) {
  // data: [{date:"2020-01", ndvi_mean, ndvi_p25, ndvi_p75, valid}, ...]
  if (!data || !data.length) return;

  ST.satData.ndviMonthly = data;

  // ── 1. Build 12-month climatology (mean NDVI per calendar month) ──────
  const moSum = new Array(12).fill(0), moCnt = new Array(12).fill(0);
  const ndwiSum = new Array(12).fill(0), ndwiCnt = new Array(12).fill(0);
  const ndreSum = new Array(12).fill(0), ndreCnt = new Array(12).fill(0);
  data.forEach(d => {
    if (!d.valid || d.ndvi_mean === null) return;
    const mo = parseInt(d.date.slice(5,7)) - 1;  // 0-indexed
    moSum[mo] += d.ndvi_mean;
    moCnt[mo]++;
    if (d.ndwi_mean !== null && d.ndwi_mean !== undefined) {
      ndwiSum[mo] += d.ndwi_mean;
      ndwiCnt[mo]++;
    }
    if (d.ndre_mean !== null && d.ndre_mean !== undefined) {
      ndreSum[mo] += d.ndre_mean;
      ndreCnt[mo]++;
    }
  });
  const ndviClim = moSum.map((s,i) => moCnt[i] ? s/moCnt[i] : null);
  const ndwiClim = ndwiSum.map((s,i) => ndwiCnt[i] ? s/ndwiCnt[i] : null);
  const ndreClim = ndreSum.map((s,i) => ndreCnt[i] ? s/ndreCnt[i] : null);

  // ── 2. Compute NPP via fPAR → APAR → GPP chain ───────────────────────
  //    Uses ST.climate.monthly.rs (ERA5 shortwave, MJ/m²/month)
  //    Falls back to clear-sky Rs estimate if ERA5 Rs unavailable
  const slots = ST.farm.crops;
  const primaryCropId = slots[0]?.id || '_default';
  const ε = LUE[primaryCropId] ?? LUE._default;  // g C / MJ APAR

  let annualNPP = 0;
  const monthlyNPP = ndviClim.map((ndvi, mo) => {
    if (ndvi === null) return null;
    // fPAR: Baret & Guyot 1991, clamped to [0,1]
    const fPAR = Math.max(0, Math.min(1, 1.257 * ndvi - 0.161));
    // Rs: ERA5 if available, else estimate from latitude/season
    let rs = ST.climate?.monthly?.[mo]?.rs;
    if (!rs) {
      // Clear-sky fallback: Hargreaves (1985) extraterrestrial radiation
      // Simplified: mean India Rs ≈ 14-22 MJ/m²/day by month, use 18 as neutral
      rs = [14,16,19,22,24,22,18,18,19,20,17,14][mo] * 30.44;  // MJ/m²/month
    }
    const PAR   = 0.48 * rs;          // MJ PAR/m²/month (Meek et al. 1984)
    const APAR  = fPAR * PAR;          // MJ absorbed PAR/m²/month
    const GPP   = ε * APAR;            // g C/m²/month
    const NPP   = 0.47 * GPP;          // g C/m²/month (Waring 1998)
    const NPP_t = NPP * 0.01;          // convert g C/m² → t C/ha
    annualNPP += NPP_t;
    return NPP_t;
  });

  // ── 3. Compute above/below-ground Cin ─────────────────────────────────
  const RSR = ROOT_SHOOT[primaryCropId] ?? ROOT_SHOOT._default;
  const HI  = HARVEST_INDEX[primaryCropId] ?? HARVEST_INDEX._default;

  // residue management: use first crop slot or default surface
  const resFrac = (() => {
    const slot = slots[0];
    if (!slot) return 1.0;
    const defaultFrac = RESIDUE_FRAC[slot.residue]?.frac ?? 1.0;
    return (slot.residue_pct !== undefined && slot.residue_pct !== null)
      ? slot.residue_pct / 100 : defaultFrac;
  })();

  const NPP_ag = annualNPP / (1 + RSR);       // above-ground NPP (t C/ha/yr)
  const NPP_bg = annualNPP * RSR / (1 + RSR); // below-ground NPP (t C/ha/yr)
  const Cin_ag = NPP_ag * (1 - HI) * resFrac; // retained above-ground residue
  const Cin_bg = NPP_bg;                       // all root material enters soil
  // Rhizodeposition (root exudates + fine root turnover) — use CROPS rhizodep fraction
  const rhizodepFrac = CROPS[primaryCropId]?.rhizodep ?? 0.18;
  const Cin_rhizo = NPP_ag * rhizodepFrac;
  const Cin_total = Cin_ag + Cin_bg + Cin_rhizo;

  // ── 4. Persistent NDVI → tree canopy contribution (agroforestry) ───────
  const ndviValid = ndviClim.filter(v => v !== null);
  const ndviMin   = ndviValid.length ? Math.min(...ndviValid) : 0;
  const ndviMean  = ndviValid.length ? ndviValid.reduce((a,b)=>a+b,0)/ndviValid.length : 0;
  // Persistent NDVI floor > 0.2 indicates tree canopy
  let treeCin = 0;
  if (ndviMin > 0.20 && ST.farm.trees && ST.farm.trees.length > 0) {
    // Attribute persistent NDVI fraction to trees
    const treeNDVIFrac = (ndviMin - 0.05) / Math.max(ndviMean, 0.01);
    const treeNPP = annualNPP * Math.min(0.5, treeNDVIFrac);
    treeCin = treeNPP * (ROOT_SHOOT._tree + (1 - HARVEST_INDEX._tree) * 0.5);
  }
  const Cin_field = Cin_total + treeCin;

  // ── 5. Compute ndviScale factor ───────────────────────────────────────
  // Compare satellite Cin with interview-derived Cin (without ndviScale)
  const baseInterviewCin = slots.reduce((s, slot) => {
    const cr = CROPS[slot.id];
    if (!cr) return s;
    const dFrac = RESIDUE_FRAC[slot.residue]?.frac ?? 1.0;
    const rFrac = (slot.residue_pct !== undefined && slot.residue_pct !== null)
      ? slot.residue_pct / 100 : dFrac;
    return s + (cr.base_cin * rFrac + cr.base_cin * cr.rhizodep);
  }, 0);

  const scaleFactor = baseInterviewCin > 0.05
    ? Math.max(0.30, Math.min(3.0, Cin_field / baseInterviewCin))
    : 1.0;

  // Store in ST.satData
  ST.satData.ndviScale    = scaleFactor;
  ST.satData.satelliteCin = Cin_field;
  ST.satData.annualNPP    = annualNPP;
  ST.satData.ndviClim     = ndviClim;
  ST.satData.ndwiClim     = ndwiClim;
  ST.satData.ndreClim     = ndreClim;

  // ── 6. Render UI ───────────────────────────────────────────────────────
  renderNDVIChart(data, ndviClim);
  renderSatNPPStrip(annualNPP, Cin_field, Cin_ag, Cin_bg, Cin_rhizo, treeCin);
  renderPhenologyClassification(ndviClim, ndwiClim, ndreClim);
  renderSatScaleStrip(scaleFactor, baseInterviewCin, Cin_field);

  // ── 7. Re-run RothC with satellite Cin ────────────────────────────────
  // ndviScale is now in ST.satData and is read by calcCropCin()
  // which is called by computeBAU() → RothC picks it up automatically
  if (ST.farm.crops.length > 0 && ST.climate) {
    triggerBAU();
  }

  // Update uncertainty badge on Cin input to satellite
  if (ST.farm.crops.length > 0) {
    const cinBadge = document.getElementById('badge-cin-total');
    if (cinBadge) {
      cinBadge.textContent = '🛰';
      cinBadge.className = 'badge badge-sat';
      cinBadge.title = `Sentinel-2 satellite-derived Cin (scale ×${scaleFactor.toFixed(2)})`;
    }
  }
}

/* ── renderNDVIChart: 5-year monthly NDVI time series ── */
function renderNDVIChart(data, ndviClim) {
  const wrap  = document.getElementById('sat-chart-wrap');
  const canvas= document.getElementById('sat-ndvi-chart');
  if (!wrap || !canvas) return;

  // Guard: Chart.js is deferred — should always be loaded by click time,
  // but if somehow not (slow connection), wait up to 3s
  if (typeof Chart === 'undefined') {
    let waited = 0;
    const check = setInterval(() => {
      waited += 100;
      if (typeof Chart !== 'undefined') {
        clearInterval(check);
        renderNDVIChart(data, ndviClim);
      } else if (waited > 3000) {
        clearInterval(check);
        wrap.innerHTML = '<div style="font-size:0.68rem;color:var(--amber-2)">⚠ Chart.js not loaded — reload page</div>';
      }
    }, 100);
    return;
  }

  wrap.style.display = 'block';

  // Destroy existing chart
  if (_satNDVIChart) { _satNDVIChart.destroy(); _satNDVIChart = null; }

  const MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  // Build climatology dataset (12 months)
  const climData = ndviClim.map(v => v !== null ? parseFloat(v.toFixed(3)) : null);

  // Build per-year datasets (up to 5 years)
  const years = [...new Set(data.map(d => d.date.slice(0,4)))].sort().slice(-5);
  const yearDatasets = years.map((yr, i) => {
    const vals = new Array(12).fill(null);
    data.filter(d => d.date.startsWith(yr)).forEach(d => {
      const mo = parseInt(d.date.slice(5,7)) - 1;
      vals[mo] = d.valid ? parseFloat(d.ndvi_mean.toFixed(3)) : null;
    });
    const alpha = 0.3 + (i / years.length) * 0.4;
    return {
      label:           yr,
      data:            vals,
      borderColor:     `rgba(45,106,79,${alpha})`,
      backgroundColor: 'transparent',
      borderWidth:     1,
      pointRadius:     2,
      tension:         0.3,
      spanGaps:        true,
    };
  });

  _satNDVIChart = new Chart(canvas, {
    type: 'line',
    data: {
      labels: MONTH_NAMES,
      datasets: [
        ...yearDatasets,
        {
          label:           '5-yr mean',
          data:            climData,
          borderColor:     '#1a5c48',
          backgroundColor: 'rgba(26,92,72,0.08)',
          borderWidth:     2.5,
          pointRadius:     3,
          tension:         0.3,
          spanGaps:        true,
          fill:            true,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { display:true, position:'top',
                  labels:{ font:{size:9}, color:'var(--ink-3)', padding:8 } },
        tooltip: { callbacks: {
          label: ctx => ` ${ctx.dataset.label}: NDVI ${ctx.parsed.y?.toFixed(2) ?? 'N/A'}`
        }}
      },
      scales: {
        y: { min:0, max:1, title:{ display:true, text:'NDVI', font:{size:9} },
             ticks:{ stepSize:0.2, font:{size:9} }, grid:{ color:'rgba(0,0,0,0.05)' } },
        x: { ticks:{ font:{size:9} }, grid:{ display:false } }
      }
    }
  });
}

