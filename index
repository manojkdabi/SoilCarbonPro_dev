/* ═══════════════════════════════════════════════════════
   ITEM C: MRV SAMPLING PROTOCOL
   Generates a composite sampling specification for Tier 2
   carbon project MRV based on field size, SOC variability,
   and target verification standard.
   
   Compositing logic:
   - Small fields (<1 ha):  10–15 sub-samples per composite
   - Medium (1–5 ha):       15–20 sub-samples; 2–3 composites
   - Large (>5 ha):         20–25 sub-samples; 4–6 composites
   - High CV (>30%):        grid sampling recommended
   
   Depth: analysis depth (15 or 30 cm); BD core at each point.
   Timing: at or near crop harvest to minimise crop-cycle bias.
   Resampling: every 5 years for Verra VCS / Gold Standard.
   
   Ref: VERRA VM0042 v1.0 (2022); Gold Standard LtP Soil Carbon;
        ICAR soil sampling guide; Webster & Oliver 2007.
═══════════════════════════════════════════════════════ */
function generateMRVProtocol() {
  const ha       = ST.fieldAreaHa || 1;
  const depth    = ST.analysisDepth || 30;
  const cv       = ST.derived.spatial?.soc?.cv_pct ?? null;
  const sigma_pct = ST.derived.uncertainty && ST.derived.cstock
    ? (ST.derived.uncertainty / ST.derived.cstock * 100) : 22;
  const soc1     = paramVal('soc1');
  const crops    = ST.farm.crops.map(s => CROPS[s.id]?.name?.split('(')[0].trim() || s.id).join(', ');
  const loc      = ST.locationName || 'Not set';
  const cstock   = ST.derived.cstock?.toFixed(1) ?? '—';

  // Number of composites and sub-samples
  let nComposites, subSamples, samplingNote;
  if (ha < 1) {
    nComposites = 1; subSamples = 12;
    samplingNote = 'Single composite — 12 sub-samples in W-pattern across field';
  } else if (ha < 5) {
    nComposites = 2; subSamples = 15;
    samplingNote = 'Two composites — divide field into halves, 15 sub-samples each';
  } else if (ha < 20) {
    nComposites = 4; subSamples = 20;
    samplingNote = 'Four composites — divide field into quadrants, 20 sub-samples each';
  } else {
    nComposites = Math.ceil(ha / 5); subSamples = 25;
    samplingNote = `${nComposites} composites — systematic grid, 25 sub-samples each`;
  }

  // Grid sampling flag
  const gridFlag = cv !== null && cv > 30
    ? `⚠ High spatial variability (CV ${cv.toFixed(0)}%) — recommend systematic grid sampling over W-pattern`
    : null;

  // Depth layers
  const layers = depth >= 30 ? ['0–15 cm', '15–30 cm'] : ['0–15 cm'];

  // Timing
  const harvestMonths = ST.farm.crops.map(s => {
    const cal = getCropCalendar(s.id);
    const harv = s.harvest_month ?? cal.harvest;
    return ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][harv];
  });
  const timing = `Within 2 weeks of harvest: ${harvestMonths.join(' or ')}`;

  return {
    loc, ha: ha.toFixed(2), cstock, soc1: soc1?.toFixed(1) ?? '—',
    nComposites, subSamples, samplingNote, gridFlag,
    layers, depth, timing, crops,
    resampling: 'Every 5 years (VERRA VCS / Gold Standard)',
    bdCores: `1 BD core per composite (${nComposites} total) at same locations`,
    uncertainty: `Current uncertainty: ±${sigma_pct.toFixed(0)}% ${_rkMode ? '(regression kriging σ²)' : _krigingMode ? '(kriging σ²)' : ST.derived.spatialUncertainty ? '(spatial CV%)' : '(SoilGrids)'}`,
    standard: 'VERRA VM0042 v1.0 · Gold Standard LtP Soil Carbon · IPCC Tier 2',
    // Group 8: tree measurement extension
    treeMeasurement: (() => {
      const trees = ST.farm.trees || [];
      if (!trees.length) return null;
      const names = trees.map(t=>TREE_SPECIES[t.id]?.name?.split('(')[0].trim()||t.id).join(', ');
      return {
        species: names,
        protocol: 'Measure DBH at 1.3 m (±1 mm) on all trees within 20×20 m permanent plots',
        plots: `${nComposites} permanent plots (one per composite sample area)`,
        resampling: 'Every 3 years (Gold Standard) or every 5 years (VERRA VCS)',
        allometry: 'Chave et al. 2014 pantropical — or species-specific FSI equations where available',
      };
    })(),
  };
}

function renderMRVProtocol() {
  const el = document.getElementById('mrv-protocol-body');
  if (!el) return;
  const p = generateMRVProtocol();
  el.innerHTML = `
    <div class="mrv-grid">
