const BC_ANNUAL_DECAY = 0.007;  // 0.7% /yr typical tropical
const BC_TROPICAL_DISC   = 0.85;  // tropical discount vs temperate (Singh 2010, GCB Bioenergy)
const BC_CALCAREOUS_DISC = 0.80;  // additional discount for calcareous/aridisol soils
                                  // CaCO₃ coatings accelerate surface oxidation of biochar
                                  // Singh et al. 2010 GCB Bioenergy 2:251-259

const COVER_CROP_CIN = {
  none:    { extra_c:0.00, dpm_rpm:1.44, label:'None',             coben: [] },
  legume:  { extra_c:0.50, dpm_rpm:0.44, label:'Legume CC',        coben: ['N-fix +30 kg/ha', 'Soil cover'] },
