/* Shared assign helper used by all source branches */
function applyExtractedData(raw, source, mult, status, btn, label) {
  if (raw.soc1 === null || raw.soc1 === undefined) {
    status.textContent = '⚠ No soil data returned for this location — check coordinates are on land.';
    status.className = 'fetch-status err';
    btn.disabled = false;
    return;
  }
  const set = (id, val, m) => {
    if (val !== null && val !== undefined) setParamValue(id, (val * m).toFixed(2), source);
  };
  set('soc1',  raw.soc1,  mult.soc);  set('soc2',  raw.soc2,  mult.soc);
  set('clay1', raw.clay1, mult.clay); set('clay2', raw.clay2, mult.clay);
  set('silt1', raw.silt1, mult.silt); set('silt2', raw.silt2, mult.silt);
  set('sand1', raw.sand1, mult.sand); set('sand2', raw.sand2, mult.sand);
  set('bd1',   raw.bd1,   mult.bd);   set('bd2',   raw.bd2,   mult.bd);
  set('ph1',   raw.ph1,   mult.ph);   set('ph2',   raw.ph2,   mult.ph);
  set('tn1',   raw.tn1,   mult.tn);   set('tn2',   raw.tn2,   mult.tn);
  set('cec1',  raw.cec1,  mult.cec);
  if (raw.cfvo1 !== null) set('cfvo1', raw.cfvo1, mult.cfvo);

  const lbl = label || (source === 'soilgrids' ? 'SoilGrids v2 (ISRIC)' : source);
  // Derive any missing texture / depth values before status update
  deriveTextureMissing();
  // Build notes string — list any params that were derived
  const derivedIds = ['soc2','clay1','silt1','sand1','clay2','silt2','sand2','tn2']
    .filter(id => ST.params[id]?.source === 'derived')
    .map(id => id.replace('1','').replace('2',''));
  const derivedNote = derivedIds.length
    ? ` · 🟣 derived: ${[...new Set(derivedIds)].join(', ')}` : '';
  const notes = source === 'openlandmap' ? ' · coarse fragments n/a' : '';
  status.textContent = `✓ ${lbl} — SOC, texture, BD, pH, TN, CEC${notes}${derivedNote} · 250 m · ±15–25%`;
  status.className = 'fetch-status ok';
  recalcAll();
  if (ST.lat && ST.lon) fetchClimate(ST.lat, ST.lon);
  // Sprint 1: trigger full polygon analysis after SoilGrids fetch
  if (ST.fieldBoundary && window.GeoTIFF) {
    updateFieldInfoStrip();  // re-triggers full analysis with new data
  } else if (ST.lat && ST.lon && window.GeoTIFF) {
    setTimeout(async () => {
      await computeSpatialVariance(ST.lat, ST.lon);
      updateSpatialVarianceDisplay();
    }, 800);
  }
  btn.disabled = false;
}



/* ── deriveTextureMissing() ─────────────────────────────────────────────────
   Called after every SoilGrids fetch. Fills any missing texture value by
   derivation, using 🟣 badge to distinguish from directly fetched values.

   Rules (both depth layers):
     silt  = 100 − clay − sand   (most common WCS gap)
     sand  = 100 − clay − silt
     clay  = 100 − silt − sand
     silt2 = silt1               (subsoil proxy if 15–30 cm missing)
     clay2 = clay1               (subsoil proxy)
     sand2 = sand1               (subsoil proxy)
     tn2   = tn1 × 0.85          (N slightly lower at depth — empirical proxy)
     soc2 from soc1 if missing   (exponential depth decay, k=0.5)
────────────────────────────────────────────────────────────────────────── */
function deriveTextureMissing() {
  const v  = id => paramVal(id);
  const set = (id, val, src) => {
    if (val !== null && val !== undefined && !isNaN(val) && val >= 0)
      setParamValue(id, Math.max(0, Math.min(100, val)).toFixed(2), src);
  };

  // ── Surface layer (0–15 cm) ──────────────────────────────────────────────
  const clay1 = v('clay1'), silt1 = v('silt1'), sand1 = v('sand1');

  if (silt1 === null && clay1 !== null && sand1 !== null) {
    set('silt1', 100 - clay1 - sand1, 'derived');
    console.info('SCP: silt1 derived = 100 − clay1 − sand1');
  }
  if (sand1 === null && clay1 !== null && silt1 !== null) {
    set('sand1', 100 - clay1 - (v('silt1') ?? 0), 'derived');
    console.info('SCP: sand1 derived = 100 − clay1 − silt1');
  }
  if (clay1 === null && silt1 !== null && sand1 !== null) {
    set('clay1', 100 - (v('silt1') ?? 0) - (v('sand1') ?? 0), 'derived');
    console.info('SCP: clay1 derived = 100 − silt1 − sand1');
  }

  // ── Subsoil layer (15–30 cm) ─────────────────────────────────────────────
  // First try to derive within the subsoil
  const clay2 = v('clay2'), silt2 = v('silt2'), sand2 = v('sand2');

  if (silt2 === null && clay2 !== null && sand2 !== null) {
    set('silt2', 100 - clay2 - sand2, 'derived');
  }
  if (sand2 === null && clay2 !== null && silt2 !== null) {
    set('sand2', 100 - clay2 - (v('silt2') ?? 0), 'derived');
  }
  if (clay2 === null && silt2 !== null && sand2 !== null) {
    set('clay2', 100 - (v('silt2') ?? 0) - (v('sand2') ?? 0), 'derived');
  }

  // If subsoil texture entirely missing, proxy from surface layer
  if (v('clay2') === null && v('clay1') !== null) {
    set('clay2', v('clay1'), 'derived');
    console.info('SCP: clay2 proxied from clay1');
  }
  if (v('silt2') === null && v('silt1') !== null) {
    set('silt2', v('silt1'), 'derived');
    console.info('SCP: silt2 proxied from silt1');
  }
  if (v('sand2') === null && v('sand1') !== null) {
    set('sand2', v('sand1'), 'derived');
    console.info('SCP: sand2 proxied from sand1');
  }

  // ── Total Nitrogen subsoil proxy ─────────────────────────────────────────
  // TN typically 10–20% lower at 15–30 cm vs 0–15 cm (Jobbagy & Jackson 2000)
  if (v('tn2') === null && v('tn1') !== null) {
    set('tn2', v('tn1') * 0.85, 'derived');
    console.info('SCP: tn2 derived = tn1 × 0.85 (depth decay proxy)');
  }

  // ── SOC subsoil proxy if missing ─────────────────────────────────────────
  // SOC declines ~50% per 15 cm depth in tropical soils (Jobbagy & Jackson 2000)
  // Only apply if SOC1 available and SOC2 genuinely missing
  if (v('soc2') === null && v('soc1') !== null) {
    set('soc2', v('soc1') * 0.55, 'derived');
    console.info('SCP: soc2 derived = soc1 × 0.55 (depth decay proxy, Jobbagy & Jackson 2000)');
  }
}

