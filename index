    doc.rect(pad, y-4, cW, 7, 'F');
    doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(255,255,255);
    doc.text(title, pad+2, y); y += 6;
    doc.setFont('helvetica','normal'); doc.setFontSize(7.5); doc.setTextColor(26,46,26);
  };

  const addText = (txt, indent=0) => {
    const lines = doc.splitTextToSize(txt, cW - indent);
    doc.text(lines, pad+indent, y); y += lines.length * 4 + 1;
  };

  const addRow = (label, val, alt=false) => {
    if (alt) { doc.setFillColor(248,245,238); doc.rect(pad, y-3.5, cW, 6, 'F'); }
    doc.setFont('helvetica','bold'); doc.setFontSize(7); doc.setTextColor(74,106,74);
    doc.text(label, pad+1, y);
    doc.setFont('helvetica','normal'); doc.setTextColor(26,46,26);
    doc.text(String(val), pad+60, y); y += 5.5;
  };

  // ── SITE SUMMARY
  addSection('1. SITE SUMMARY', '#1e5c26');
  const soc1v = paramVal('soc1');
  const bd1v  = paramVal('bd1') || 1.30;
  [
    ['Location', ST.locationName || '—'],
    ['Lat / Lon', `${ST.lat?.toFixed(4)??'—'} / ${ST.lon?.toFixed(4)??'—'}`],
    ['Current SOC (0–15 cm)', soc1v ? `${soc1v.toFixed(1)} g/kg (${(soc1v/10).toFixed(2)}%)` : '—'],
    ['Current C stock (0–30 cm)', ST.derived.cstock ? `${ST.derived.cstock.toFixed(1)} t C/ha` : '—'],
    ['Target SOC (agg)', ST.targetTha ? `${ST.targetTha.toFixed(1)} t C/ha  (${ST.targetPct?.toFixed(2)??'—'}%)` : '—'],
    ['Target L1 (0–15cm)', ST.targetL1_tha ? `${ST.targetL1_tha.toFixed(1)} t C/ha` : '—'],
    ['Target L2 (15–30cm)', ST.targetL2_tha ? `${ST.targetL2_tha.toFixed(1)} t C/ha` : '—'],
    ['Target year', `${ST.targetYear} yr`],
    ['Hassink cap', ST.derived.hassinkCap ? `${ST.derived.hassinkCap.toFixed(1)} t C/ha (${ST.mineralogy})` : '—'],
    ['Climate (MAT / MAP)', ST.climate ? `${ST.climate.mat.toFixed(1)}°C / ${Math.round(ST.climate.map)} mm/yr` : '—'],
  ].forEach((r, i) => addRow(r[0], r[1], i%2===0));
  y += 4;

  // ── BAU DIAGNOSIS
  addSection('2. BAU TRAJECTORY & CEILING DIAGNOSIS', '#0e4a3a');
  const bau_end = ST.bau?.endpoint;
  const gap = ST.targetTha && bau_end ? ST.targetTha - bau_end : null;
  const outcome = ST.derived.outcome;
  [
    ['BAU endpoint', bau_end ? `${bau_end.toFixed(1)} t C/ha at year ${ST.targetYear}` : 'Not computed'],
    ['BAU gap to target', gap !== null ? `${gap > 0 ? gap.toFixed(1)+' t C/ha' : 'BAU already meets target'}` : '—'],
    ['Ceiling outcome', outcome ? {green:'Achievable (comfortable)',amber:'Achievable (sustained intensity)',orange:'Biochar required',red:'Physically constrained'}[outcome] : '—'],
    ['Farmer tillage',  ST.farm?.crops?.map(s=>TILLAGE[s.tillage||'shallow']?.name||'—').join(' / ') || '—'],
    ['Irrigation',      ST.farm?.crops?.map(s=>IRRIGATION_DEF[s.irrigation||'rainfed']?.name||'—').join(' / ') || '—'],
    ['Total C input (BAU)', ST.bau?.cin_annual?.total ? `${ST.bau.cin_annual.total.toFixed(2)} t C/ha/yr` : '—'],
    ['AWD CH₄ CDR potential', (() => { const a=calcAWDMethane(ST.farm.crops); return a ? `${a.delta_co2e.toFixed(2)} t CO₂e/ha/yr (IPCC Tier 1)` : 'No paddy flood slots'; })()],
  ].forEach((r, i) => addRow(r[0], r[1], i%2===0));
  y += 4;

  // ── BAU TRAJECTORY CHART (Item D) ──────────────────────────────────
  const bauPNG = captureChartPNG('bau-chart');
  if (bauPNG) {
    if (y > 190) { doc.addPage(); y = 20; }
    addSection('2b. BAU TRAJECTORY CHART', '#2a6a4a');
    const chartH = 52;
    const chartW = cW;
    doc.addImage(bauPNG, 'PNG', pad, y, chartW, chartH, undefined, 'FAST');
    y += chartH + 4;
    doc.setFontSize(6.5); doc.setTextColor(100,100,80);
    doc.text('Central trajectory (mean) with uncertainty band. Ensemble: ' +
      (ST.bau?.ensembleNote || 'synthetic ±20% C input'), pad, y);
    y += 8;
  }

  // ── RECOMMENDED BUNDLES
  const tabs = [
    { key:'regen',    label:'REGEN AG RECOMMENDATIONS' },
    { key:'biochar',  label:'BIOCHAR RECOMMENDATIONS' },
    { key:'combined', label:'COMBINED RECOMMENDATIONS' },
  ];

  tabs.forEach(tab => {
    const results = ST.solverResults[tab.key];
    if (!results || results.length === 0) return;
    if (y > 230) { doc.addPage(); y = 20; }
    addSection(`3. ${tab.label}`, '#1a2e6a');

    // Embed trajectory chart for #1 result (Item D)
    const trajCanvasId = `traj-chart-${tab.key}`;
    const trajPNG = captureChartPNG(trajCanvasId);
    if (trajPNG) {
      if (y > 200) { doc.addPage(); y = 20; }
      const cH = 45;
      doc.addImage(trajPNG, 'PNG', pad, y, cW, cH, undefined, 'FAST');
      y += cH + 3;
    }

    results.slice(0,4).forEach((r, rank) => {
      if (y > 255) { doc.addPage(); y = 20; }
      const name = r.type==='biochar'
        ? `${BIOCHAR_FEEDSTOCKS[r.feedstock]?.name} ${PYRO_TEMPS[r.pyro]?.split(' ')[0]} — ${r.dose.toFixed(1)} t/ha`
        : bundleName(r.tillage, r.cc, r.compost_level, r.biochar_fs, r.biochar_pyro);

      doc.setFont('helvetica','bold'); doc.setFontSize(7.5); doc.setTextColor(14,74,58);
      doc.text(`#${rank+1}  ${name}`, pad+1, y); y += 4.5;
      doc.setFont('helvetica','normal'); doc.setTextColor(74,106,74);
      doc.text([
        `Endpoint: ${r.endpoint.toFixed(1)} t C/ha  |  vs BAU: +${r.delta_vs_bau.toFixed(1)}  |  Meets target: ${r.meets?'Yes':'No'}`,
        `Co-benefits: ${(r.cobenefits||[]).join(', ')||'—'}`,
      ].map(l => doc.splitTextToSize(l, cW-4)).flat(), pad+2, y);
      y += 10;
    });
    y += 3;
  });

  // ── TREE INVENTORY (Group 8)
  const trees8 = ST.farm.trees || [];
  if (trees8.length) {
    if (y > 220) { doc.addPage(); y = 20; }
    addSection('3b. AGROFORESTRY — TREE INVENTORY', '#1a5a2a');
    const areaf8 = ST.farm.treeAreaFraction ?? 1.0;
    trees8.forEach((t, i) => {
      const sp = TREE_SPECIES[t.id];
      if (!sp) return;
      const agb_yr = treeAGBIncrement(t.id, (t.density||100)*areaf8, t.age_class||'mid');
      const bgb_yr = treeBGBIncrement(t.id, (t.density||100)*areaf8, t.age_class||'mid');
      const co2e   = (agb_yr + bgb_yr) * 0.47 * (44/12);
      addRow(`${sp.icon} ${sp.name.split('(')[0].trim()}`,
        `${t.density||100} trees/ha · ${t.age_class||'mid'} · ${t.system||'—'} · AGB+BGB CDR ≈ ${co2e.toFixed(2)} t CO₂e/ha/yr`, i%2===0);
    });
    const treeCDR20 = calcTotalTreeCDR(ST.targetYear);
    const totalCO2e = treeCDR20 ? treeCDR20[ST.targetYear]?.total_c?.toFixed(1) ?? '—' : '—';
    addRow('Tree area fraction', `${(areaf8*100).toFixed(0)}% of field`, true);
    addRow(`Tree CDR at yr ${ST.targetYear}`, `${totalCO2e} t CO₂e cumulative (AGB+BGB)`, false);
    y += 4;
  }

  // ── MRV SAMPLING PROTOCOL (Item C)
  if (y > 220) { doc.addPage(); y = 20; }
  addSection('4. MRV SAMPLING PROTOCOL', '#1a5a5a');
  const mrv = generateMRVProtocol();
  [
    ['Site', `${mrv.loc}  ·  ${mrv.ha} ha`],
    ['Composites', `${mrv.nComposites} composite${mrv.nComposites>1?'s':''} · ${mrv.subSamples} sub-samples each`],
