/* ═══════════════════════════════════════════════════════
   AUTOMATION 1 — ARIDITY CLASS + IRRIGATION SUGGESTION
   Ref: Thornthwaite 1948 (Geogr Rev 38:55); Kottek et al. 2006
   PET formula: Thornthwaite simplified (T in °C, monthly)
   AI = MAP / PET_annual
═══════════════════════════════════════════════════════ */
function calcThornthwaitePET(monthly) {
  // monthly: array of {temp, precip}
  // Thornthwaite: PET_mo = 16 × (10×T/I)^a × K  [mm/mo]
  // I = sum of (T/5)^1.514 for T>0; a = 6.75e-7×I³ - 7.71e-5×I² + 1.792e-2×I + 0.49239
  const I = monthly.reduce((s, m) => s + (m.temp > 0 ? Math.pow(m.temp / 5, 1.514) : 0), 0);
  const a = 6.75e-7 * I**3 - 7.71e-5 * I**2 + 1.792e-2 * I + 0.49239;
  // Day-length correction K ≈ 1.0 (lat-neutral simplification for India 8–35°N: error <8%)
  const pet_annual = monthly.reduce((s, m) => {
    if (m.temp <= 0) return s;
    const pet_mo = 16 * Math.pow(10 * m.temp / (I || 1), a);
    return s + pet_mo;
  }, 0);
  return pet_annual; // mm/yr
}

function applyAridityDefaults(climate) {
  if (!climate) return;
  const { mat, map, monthly } = climate;
  const pet = calcThornthwaitePET(monthly);
  const ai  = pet > 0 ? map / pet : 1;  // Aridity Index (>1 = humid, <0.2 = hyper-arid)

  let aridClass, irrigSuggestion, irrigKey, note;

  if      (ai < 0.05) { aridClass = 'Hyper-arid';  irrigKey = 'flood_furrow'; irrigSuggestion = 'Canal / tube-well flood irrigation essential — rainfed not viable (AI < 0.05)'; }
  else if (ai < 0.20) { aridClass = 'Arid';         irrigKey = 'flood_furrow'; irrigSuggestion = 'Irrigation required for crop production (AI 0.05–0.20) — flood/furrow is dominant practice'; }
  else if (ai < 0.50) { aridClass = 'Semi-arid';    irrigKey = 'rainfed';      irrigSuggestion = 'Semi-arid (AI 0.20–0.50) — rainfed feasible but supplemental irrigation common in Rabi'; }
  else if (ai < 0.65) { aridClass = 'Dry sub-humid'; irrigKey = 'rainfed';     irrigSuggestion = 'Dry sub-humid (AI 0.50–0.65) — rainfed default; irrigation improves yield stability'; }
  else                { aridClass = 'Humid/sub-humid'; irrigKey = 'rainfed';   irrigSuggestion = 'Humid climate (AI > 0.65) — rainfed agriculture predominates'; }

  // Don't override if user manually set irrigation already AND it's not the default
  if (!ST._irrigManual) {
    setIrrigation(irrigKey);
    // Special case: paddy mineralogy + humid → suggest paddy_flood
    if (ST.mineralogy === 'paddy' && ai > 0.65) {
      setIrrigation('paddy_flood');
      irrigSuggestion = 'Paddy mineralogy + humid climate → paddy flood irrigation suggested';
    }
    const el = document.getElementById('irrig-auto');
    if (el) {
      el.style.display = 'block';
      el.textContent = `🌦 ${aridClass} (AI = ${ai.toFixed(2)}, PET = ${Math.round(pet)} mm/yr) — ${irrigSuggestion} · Click to override`;
      el.style.background = ai < 0.20 ? 'var(--amber-lt)' : 'var(--blue-lt)';
      el.style.borderColor = ai < 0.20 ? 'var(--amber)' : 'var(--blue)';
      el.style.color       = ai < 0.20 ? 'var(--amber)' : 'var(--blue)';
    }
  }
  // Store aridity index for other automations
  ST._aridity = { ai, pet, aridClass };
}

/* ═══════════════════════════════════════════════════════
   AUTOMATION 2 — ANALYSIS DEPTH FROM CROP ROOTING
   Ref: Schenk & Jackson 2002 (J Ecol 90:480-494)
   Deep roots: pigeonpea >150cm, cotton >120cm, castor >100cm,
   sugarcane >80cm → recommend 60cm profile
   Shallow: rice, small-seeded legumes, spices → 15cm
═══════════════════════════════════════════════════════ */
/* CROP_ROOT_DEPTH now reads from CROPS.rooting_cm — no separate constant needed */

function inferDepthFromCrops() {
  const crops = ST.farm.crops;
  if (!crops || crops.length === 0) return;
  // Map rooting_cm to standard analysis depth buckets: 15, 30, 60 cm
  const depthBucket = cm => cm >= 300 ? 60 : cm >= 80 ? 30 : 15;
  const depths = crops.map(s => {
    const r = CROPS[s.id]?.rooting_cm || 80;
    return depthBucket(r);
  });
  const suggested = Math.max(...depths);
  if (!ST._depthManual) {
    setAnalysisDepth(suggested);
    const el = document.getElementById('depth-suggest');
    if (el) {
      const cropNames = crops.map(s => CROPS[s.id]?.name || s.id).join(', ');
      el.style.display = 'block';
      el.textContent = `📐 Depth set to ${suggested} cm from crop rooting profile (${cropNames}) · Schenk & Jackson 2002`;
    }
  }
}

