/* Get default sow/harvest for a crop, falling back to season-based defaults */
function getCropCalendar(cropId) {
  if (CROP_CALENDAR[cropId]) return { ...CROP_CALENDAR[cropId] };
  const crop = CROPS[cropId] || {};
  const season = crop.season || 'Both';
  // Season-based fallback
  const SEASON_DEFAULTS = {
    'Kharif': { sow: 5, harvest: 9  },  // Jun→Oct
    'Rabi':   { sow:10, harvest: 2  },  // Nov→Mar
    'Annual': { sow: 0, harvest:11  },  // Jan→Dec
    'Both':   { sow: 0, harvest:11  },
    '—':      { sow: 0, harvest:11  },
  };
  return SEASON_DEFAULTS[season] || { sow: 0, harvest: 11 };
}

/* Expand sow→harvest into array of active month indices (0-11).
   Handles year-wrap: sow=10, harvest=2 → [10,11,0,1,2] */
function calendarToMonths(sow, harvest) {
  const months = [];
  let mo = sow;
  // Safety: cap at 12 months to prevent infinite loop
  let count = 0;
  while (count <= 12) {
    months.push(mo % 12);
    if (mo % 12 === harvest) break;
    mo++;
    count++;
  }
  // If sow === harvest (single month crop or annual, count would hit 12 limit)
  // For annual crops where sow=0, harvest=11: loop runs 12 times, produces [0..11]
  if (months.length === 0) months.push(sow % 12);
  return months;
}

function buildSlotMonthSchedule(slots) {
  /* Returns array of 12 monthly objects:
     { irrig_mult, tillage_mult, cin_frac, active, slot_idx, waterlogged }
     
     Pass 3 change: active months now come from slot.sow_month → slot.harvest_month
     via calendarToMonths(), replacing the coarse SEASON_MONTHS lookup.
     This means fT and fW are integrated over the actual crop calendar rather
     than a fixed 5-month season window.
     
     Example: Punjab wheat sow=Oct(10), harvest=Mar(2)
       → months [10,11,0,1,2] = 5 months
     Example: Vidarbha cotton sow=Apr(3), harvest=Nov(10)
       → months [3,4,5,6,7,8,9,10] = 8 months
     
     Ref: ICAR Crop Production Guide 2023; ICRISAT India crop calendar */

  // Start with zeros
  const schedule = Array.from({length:12}, () => ({
    irrig_mult:   1.0,
    tillage_mult: 0.92,
    cin_frac:     0,
    active:       false,
    slot_idx:     -1,
  }));

  if (!slots || slots.length === 0) {
    return schedule.map(s => ({...s, cin_frac: 1/12}));
  }

  // Compute each slot's annual Cin
  const slotCins = slots.map(slot => calcCropCin(slot));
  const totalCin = slotCins.reduce((a,b)=>a+b,0) || 1;

  slots.forEach((slot, si) => {
    const crop = CROPS[slot.id] || {};
    if (crop.season === '—') return;  // explicit fallow

    // Use explicit calendar months; fall back to CROP_CALENDAR/season default
    const cal    = getCropCalendar(slot.id);
    const sow    = slot.sow_month     ?? cal.sow;
    const harv   = slot.harvest_month ?? cal.harvest;
    const months = calendarToMonths(sow, harv);
    if (!months.length) return;

    const irrig = IRRIGATION_DEF[slot.irrigation || 'rainfed']?.fW_mult ?? 1.0;
    const till  = TILLAGE[slot.tillage || 'shallow']?.mult ?? 0.92;
    const slotCinFracPerMonth = (slotCins[si] / totalCin) / months.length;

    months.forEach(mo => {
      schedule[mo].cin_frac     += slotCinFracPerMonth;
      schedule[mo].irrig_mult    = irrig;
      schedule[mo].tillage_mult  = till;
      schedule[mo].active        = true;
      schedule[mo].slot_idx      = si;
    });
  });

  // Fallow months: 10% of average Cin (weed/cover/root turnover)
  const avgCinFrac = 1/12;
  schedule.forEach((mo, i) => {
    if (!mo.active) {
      schedule[i].cin_frac     = avgCinFrac * 0.10;
      schedule[i].irrig_mult   = 1.0;
      schedule[i].tillage_mult = 0.92;
    }
  });

  // Renormalise crop Cin to sum=1.0
  const cropCinTotal = schedule.reduce((s,m)=>s+m.cin_frac, 0);
  if (cropCinTotal > 0) schedule.forEach(m => m.cin_frac /= cropCinTotal);

  // ── ITEM 5: Organic amendment monthly Cin spike ───────────────────
  // Each active organic delivers its entire annual Cin in one month.
  // We add it as an ABSOLUTE fraction relative to total annual Cin
  // (crops + organics). Re-scale the whole schedule afterward.
  const cropCinAbs = slots.reduce((s,slot) => s + calcCropCin(slot), 0);
  const orgCinAbs  = Object.entries(ST.farm?.organics ?? {})
    .filter(([k,v]) => v.on)
    .reduce((s,[k,v]) => s + v.rate * (ORGANICS_DEF[k]?.net_c ?? 0), 0);
  const totalCinAll = (cropCinAbs + orgCinAbs) || 1;

  if (orgCinAbs > 0) {
    // Convert existing crop cin_frac to absolute, add organic spike, renormalise
    schedule.forEach(m => { m.cin_frac = m.cin_frac * (cropCinAbs / totalCinAll); });
    Object.entries(ST.farm?.organics ?? {}).forEach(([key, state]) => {
      if (!state.on) return;
      const def = ORGANICS_DEF[key];
      const orgMo = state.apply_month ?? 5;  // default June
      const orgFrac = (state.rate * (def?.net_c ?? 0)) / totalCinAll;
      schedule[orgMo].cin_frac += orgFrac;
    });
    // Final renormalise: total must sum to 1.0
    const grandTotal = schedule.reduce((s,m) => s + m.cin_frac, 0);
    if (grandTotal > 0) schedule.forEach(m => m.cin_frac /= grandTotal);
  }

  // ── ITEM 2: Waterlogging fW suppression ──────────────────────────
  // Seasonal waterlogging creates anaerobic conditions that suppress
  // aerobic decomposition. Applied as irrig_mult reduction on top of
  // the crop-slot value. Only applied when slot is NOT paddy_flood
  // (which already carries fW_mult 0.65).
  // Ref: Lal 1986 (Soil Till. Res.); IPCC 2006 Wetland CH4 guidance
  const wlog = ST.farm?.history?.waterlog || 'no';
  if (wlog !== 'no') {
    // partial → Jul-Sep (6,7,8); severe → Jun-Oct (5,6,7,8,9)
    const wlogMonths = wlog === 'severe' ? [5,6,7,8,9] : [6,7,8];
    const WLOG_FW = 0.65;  // anaerobic suppression factor
    wlogMonths.forEach(mo => {
      // Don't double-penalise paddy_flood slots (already 0.65)
      if (schedule[mo].irrig_mult > WLOG_FW) {
        schedule[mo].irrig_mult = Math.min(schedule[mo].irrig_mult, WLOG_FW);
        schedule[mo].waterlogged = true;
      }
    });
  }

  return schedule;
}

/* ═══════════════════════════════════════════════════════
   BAU CALCULATION & CHART
═══════════════════════════════════════════════════════ */
let _bauTimer = null;
function triggerBAU() {
  clearTimeout(_bauTimer);
  _bauTimer = setTimeout(computeBAU, 180);
}

function computeBAU() {
  const cstock = ST.derived.cstock;
  const clay1 = paramVal('clay1') || 25;
  const ph1   = paramVal('ph1') || 7.0;
  const climate = ST.climate;

  if (!cstock || !climate || ST.farm.crops.length === 0) {
    document.getElementById('bau-placeholder').style.display = 'block';
    document.getElementById('bau-content').style.display = 'none';
    return;
  }

  // Build C input object
  const cropTotal = ST.farm.crops.reduce((s,slot) => s + calcCropCin(slot), 0);
  const orgTotal = Object.entries(ST.farm.organics)
    .filter(([k,v])=>v.on)
    .reduce((s,[k,v]) => s + v.rate * ORGANICS_DEF[k].net_c, 0);
  // Group 8: add tree litter Cin to organic total
  const treeLitterTotal = calcTreeLitterContrib();
  // ── Slot-weighted irrigation and tillage multipliers ─────────────────
  // Each crop slot contributes its own fW and tillage mult for its active months.
  // We weight by Cin contribution as a proxy for growing-season proportion.
  const slotCins = ST.farm.crops.map(slot => calcCropCin(slot));
  const totalSlotCin = slotCins.reduce((a,b) => a+b, 0) || 1;
  const avg_irrig_mult = slotCins.reduce((acc, cin, i) => {
    const irrig = ST.farm.crops[i].irrigation || 'rainfed';
    return acc + cin * (IRRIGATION_DEF[irrig]?.fW_mult ?? 1.0);
  }, 0) / totalSlotCin;
  const avg_tillage_mult = slotCins.reduce((acc, cin, i) => {
    const till = ST.farm.crops[i].tillage || 'shallow';
    return acc + cin * (TILLAGE[till]?.mult ?? 0.92);
  }, 0) / totalSlotCin;

  // Build per-month slot schedule for the RothC model
  // Each slot assigned months by season: Kharif=Jun–Oct, Rabi=Nov–Mar, Annual=all 12
  const slotMonthSchedule = buildSlotMonthSchedule(ST.farm.crops);

  const cin_annual = {
    total:    cropTotal + orgTotal + treeLitterTotal,
    dpm_rpm:  calcAvgDpmRpm(),
    irrig_mult: avg_irrig_mult,
    slot_schedule: slotMonthSchedule,  // per-month {irrig_mult, tillage_mult, cin_frac}
  };
  // Legacy single value for backward compat (solver uses this)
  ST.farm.tillage    = Object.entries(TILLAGE).sort((a,b) =>
    Math.abs(a[1].mult - avg_tillage_mult) - Math.abs(b[1].mult - avg_tillage_mult))[0][0];
  ST.farm.irrigation = Object.entries(IRRIGATION_DEF).sort((a,b) =>
    Math.abs(a[1].fW_mult - avg_irrig_mult) - Math.abs(b[1].fW_mult - avg_irrig_mult))[0][0];
  const tillage_mult = avg_tillage_mult;
  const years = ST.targetYear;

  // Farmer trend adjustment to C input: declining → −10%, improving → +8%
  const trendMult = ST.farm.history.trend === 'declining' ? 0.90 :
                    ST.farm.history.trend === 'improving' ? 1.08 : 1.0;
  cin_annual.total *= trendMult;

  // Item 9: Ensemble BAU — run one trajectory per year of climate data when available
  // This gives a real spread from inter-annual climate variability rather than
  // a synthetic ±20% C-input perturbation.
  const perYear = climate.perYear;
  let central_traj, high_traj, low_traj, bau_endpoint, bau_high_end, bau_low_end;

  // 2.3.4: Apply terrain fT multiplier (aspect-based) if available
  const terrFTMult = ST.derived?.terrainFTMult ?? 1.0;

  if (perYear && perYear.length >= 3) {
    // Run one trajectory per climate year, cycling year's monthly data each simulation year
    const ensembleTrajs = perYear.map(yrClim =>
      runRothCWithKmult(cstock, clay1, ph1, cin_annual, tillage_mult, yrClim, years, terrFTMult)
    );
    // Central = mean across ensemble at each year point
    central_traj = Array.from({length: years+1}, (_, yr) => ({
      year: yr,
      soc: ensembleTrajs.reduce((s,t) => s + t[yr].soc, 0) / ensembleTrajs.length,
    }));
    // High/low = max/min across ensemble (real climate spread)
    high_traj = Array.from({length: years+1}, (_, yr) => ({
      year: yr, soc: Math.max(...ensembleTrajs.map(t => t[yr].soc)),
    }));
    low_traj = Array.from({length: years+1}, (_, yr) => ({
      year: yr, soc: Math.min(...ensembleTrajs.map(t => t[yr].soc)),
    }));
    ST.bau = { trajectory: central_traj, high: high_traj, low: low_traj,
               trajectoryHi: high_traj, trajectoryLo: low_traj,
               endpoint: central_traj[years].soc,
               ensemble: ensembleTrajs, cin_annual, tillage_mult,
               ensembleNote: `Climate ensemble: ${perYear.length} annual trajectories` };
  } else {
    // Fallback: synthetic uncertainty bounds (no per-year data)
    central_traj = runRothCWithKmult(cstock, clay1, ph1, cin_annual, tillage_mult, climate.monthly, years, terrFTMult);
    high_traj    = runRothCWithKmult(cstock, clay1, ph1,
      {...cin_annual, total: cin_annual.total * 1.20}, tillage_mult, climate.monthly, years, terrFTMult * 0.80);
    low_traj     = runRothCWithKmult(cstock, clay1, ph1,
      {...cin_annual, total: cin_annual.total * 0.80}, tillage_mult, climate.monthly, years, terrFTMult * 1.20);
    ST.bau = { trajectory: central_traj, high: high_traj, low: low_traj,
               trajectoryHi: high_traj, trajectoryLo: low_traj,
               endpoint: central_traj[years].soc, cin_annual, tillage_mult,
               ensembleNote: 'Synthetic uncertainty (±20% C input)' };
  }

  bau_endpoint  = ST.bau.endpoint;
  bau_high_end  = ST.bau.high[years].soc;
  bau_low_end   = ST.bau.low[years].soc;

  updateTotalCinSummary(cin_annual);
  renderBAUChart(central_traj, high_traj, low_traj, years);
  renderGapTable(bau_endpoint, bau_high_end, bau_low_end);
  renderBAUNarrative(cstock, bau_endpoint, cin_annual, years);
  estimateNMin(cstock, clay1, ph1, cin_annual, tillage_mult, climate.monthly);
  // Item A: show AWD CH4 benefit if paddy flood slots exist
  const awdCH4 = calcAWDMethane(ST.farm.crops);
  const awdEl = document.getElementById('awd-ch4-display');
  if (awdEl) {
    if (awdCH4) {
      awdEl.style.display = 'block';
      awdEl.innerHTML = `<strong>🌾 AWD opportunity:</strong> Converting paddy continuous flood to AWD
        would reduce CH₄ emissions by <strong>${awdCH4.delta_co2e.toFixed(2)} t CO₂e/ha/yr</strong>
        (flood ${awdCH4.flood_co2e.toFixed(2)} → AWD ${awdCH4.awd_co2e.toFixed(2)} t CO₂e/ha/yr).
        IPCC Tier 1 · GWP100=28 · ${AWD_PARAMS.season_days}d season × ${awdCH4.n_seasons} crop(s).
        This CH₄ reduction is <em>additional to</em> the soil C sequestration shown above.`;
    } else {
      awdEl.style.display = 'none';
    }
  }
  refreshCDRAfterBAU();

  document.getElementById('bau-placeholder').style.display = 'none';
  document.getElementById('bau-content').style.display = 'block';

  // Update ceiling table BAU row
  const bauRow = document.querySelector('#ref-table tr:nth-child(2) td:nth-child(2)');
  if (bauRow) {
    bauRow.textContent = `${bau_endpoint.toFixed(1)} t C/ha`;
    bauRow.className = 'ref-val bau';
  }
  const bauNote = document.querySelector('#ref-table tr:nth-child(2) td:nth-child(3)');
  if (bauNote) {
    const trend = bau_endpoint > cstock ? `↑ +${(bau_endpoint-cstock).toFixed(1)}` : `↓ −${(cstock-bau_endpoint).toFixed(1)}`;
    bauNote.textContent = `${trend} t C/ha over ${years} yr under current practice`;
  }

  // Force ceiling recalc to pick up new BAU gap
  calcCeiling();

  // Auto-trigger solver if target is already set
  maybeAutoRunSolver('bau');

  // Update wizard — BAU computed unlocks Phase 3
  updateWizardState();
}

function renderBAUChart(central, high, low, years) {
  const ctx = document.getElementById('bau-chart').getContext('2d');
  const labels = central.map(p => p.year);
  const centralData = central.map(p => +p.soc.toFixed(2));
  const highData    = high.map(p => +p.soc.toFixed(2));
  const lowData     = low.map(p => +p.soc.toFixed(2));

  // Reference lines (horizontal)
  const curSOC    = ST.derived.cstock;
  const targetTha = ST.targetTha || null;
  const hassink   = ST.derived.hassinkCap || null;

  if (bauChart) { bauChart.destroy(); bauChart = null; }

  const annotations = {};
  if (curSOC) {
    annotations.curLine = {
      type:'line', yMin:curSOC, yMax:curSOC,
      borderColor:'rgba(26,46,26,0.5)', borderWidth:1.5,
      borderDash:[4,3], label:{content:'Current', display:true, position:'start', font:{size:9}, color:'#4a6a4a'}
    };
  }
  if (targetTha) {
    annotations.targetLine = {
      type:'line', yMin:targetTha, yMax:targetTha,
      borderColor:'rgba(26,46,106,0.75)', borderWidth:1.5,
      borderDash:[5,3], label:{content:'Target', display:true, position:'start', font:{size:9}, color:'#1a2e6a'}
    };
  }
  if (hassink) {
    annotations.hassinkLine = {
      type:'line', yMin:hassink, yMax:hassink,
      borderColor:'rgba(138,26,26,0.6)', borderWidth:1,
      borderDash:[3,4], label:{content:'Hassink cap', display:true, position:'end', font:{size:9}, color:'#8a1a1a'}
    };
  }

  bauChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'BAU (high)',
          data: highData,
          fill: '+1',
          borderColor: 'transparent',
          backgroundColor: 'rgba(46,128,64,0.13)',
          pointRadius: 0, tension: 0.3,
        },
        {
          label: 'BAU central',
          data: centralData,
          borderColor: '#2e8040',
          backgroundColor: 'transparent',
          borderWidth: 2.5,
          pointRadius: (ctx) => ctx.dataIndex === years ? 5 : 0,
          pointBackgroundColor: '#2e8040',
          tension: 0.3,
        },
        {
          label: 'BAU (low)',
          data: lowData,
          fill: '-2',
          borderColor: 'transparent',
          backgroundColor: 'rgba(46,128,64,0.13)',
          pointRadius: 0, tension: 0.3,
        },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: { duration: 400 },
      scales: {
        x: {
          title: { display: true, text: 'Years from now', font:{size:10}, color:'#7a9a7a' },
          grid: { color: 'rgba(0,0,0,0.04)' },
          ticks: { font:{size:9}, color:'#7a9a7a' }
        },
        y: {
          title: { display: true, text: 'Soil C stock (t C/ha)', font:{size:10}, color:'#7a9a7a' },
          grid: { color: 'rgba(0,0,0,0.04)' },
          ticks: { font:{size:9}, color:'#7a9a7a' }
        }
      },
      plugins: {
        legend: { display: false },
        tooltip: {
          mode:'index', intersect:false,
          callbacks: {
            label: ctx => ctx.dataset.label === 'BAU central'
              ? `BAU: ${ctx.parsed.y.toFixed(1)} t C/ha`
              : ctx.dataset.label.includes('high') ? `Upper: ${ctx.parsed.y.toFixed(1)}`
              : ctx.dataset.label.includes('low') ? `Lower: ${ctx.parsed.y.toFixed(1)}` : null,
          }
        },
        annotation: { annotations }
      }
    },
    plugins: (window.ChartAnnotation ? [window.ChartAnnotation] : [])
  });

  // Draw reference lines manually if annotation plugin absent
  if (!window.ChartAnnotation) {
    drawManualAnnotations(bauChart, curSOC, targetTha, hassink);
  }
}

function drawManualAnnotations(chart, cur, target, hassink) {
  // We'll use the afterDraw hook approach via Chart.register
  const plugin = {
    id: 'reflines',
    afterDraw(chart) {
      const {ctx, chartArea:{left,right,top,bottom}, scales:{y}} = chart;
      const drawLine = (val, color, dash, label) => {
        if (!val) return;
        const yp = y.getPixelForValue(val);
        if (yp < top || yp > bottom) return;
        ctx.save();
        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        ctx.setLineDash(dash);
        ctx.beginPath(); ctx.moveTo(left, yp); ctx.lineTo(right, yp); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = color;
        ctx.font = '9px IBM Plex Sans, sans-serif';
        ctx.fillText(label, left+4, yp-3);
        ctx.restore();
      };
      drawLine(cur,    'rgba(26,46,26,0.55)',    [4,3], 'Current');
      drawLine(target, 'rgba(26,46,106,0.75)',   [5,3], 'Target');
      drawLine(hassink,'rgba(138,26,26,0.55)',   [3,4], 'Hassink cap');
    }
  };
  Chart.register(plugin);
  chart.update();
}

