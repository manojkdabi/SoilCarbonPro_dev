    const curTill  = slot.tillage    || 'shallow';

    const irrigOpts = Object.entries(IRRIGATION_DEF).map(([k,v]) =>
      `<option value="${k}" ${k===curIrrig?'selected':''}>${v.name}</option>`).join('');
