/* ── Total C input summary ── */
function updateTotalCinSummary(cin) {
  const rows = document.getElementById('total-cin-rows');
  const orgTotal  = Object.entries(ST.farm.organics)
    .filter(([k,v])=>v.on)
    .reduce((s,[k,v]) => s + v.rate * ORGANICS_DEF[k].net_c, 0);
  const cropTotal = ST.farm.crops.reduce((s,slot) => s + calcCropCin(slot), 0);

  // Per-slot climate context rows — calendar months, mean fT/fW, drought flag
  const ph1_sum  = paramVal('ph1');
  const climate  = ST.climate;
  const MO_ABBR  = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  const slotRows = ST.farm.crops.map((slot, idx) => {
    const crop  = CROPS[slot.id];
    const irrig = IRRIGATION_DEF[slot.irrigation||'rainfed'];
    const till  = TILLAGE[slot.tillage||'shallow'];
    const slotR = calcSlotDpmRpm(slot, idx, ph1_sum);
    const baseR = crop?.dpm_rpm ?? 1.44;
    const rDiff = slotR - baseR;
    const rNote = Math.abs(rDiff) > 0.03
      ? ` <span style="color:${rDiff<0?'var(--green-2)':'var(--amber-2)'}">DPM:RPM ${slotR.toFixed(2)}</span>`
      : ` <span style="color:var(--ink-5)">DPM:RPM ${slotR.toFixed(2)}</span>`;
    const nfixTag = crop?.n_fix
      ? ` <span style="color:var(--teal);font-size:0.60rem">N₂✓</span>` : '';

    // Calendar period label
    const cal      = getCropCalendar(slot.id);
    const sow      = slot.sow_month     ?? cal.sow;
    const harv     = slot.harvest_month ?? cal.harvest;
    const growMos  = calendarToMonths(sow, harv);
    const periodLbl = `${MO_ABBR[sow]}–${MO_ABBR[harv]}`;

    // Mean fT and fW during growing period (uses ERA5 if available)
    let climateLine = '';
    let droughtFlag = '';
    if (climate?.monthly?.length === 12) {
      let sumFT = 0, sumFW = 0, droughtMos = 0;
      growMos.forEach(mo => {
        const clim = climate.monthly[mo];
        const t_eff = clim.soil_temp ?? clim.temp;
        sumFT += fT(t_eff);
        // Use slot irrig_mult for fW
        const irrig_m = irrig?.fW_mult ?? 1.0;
        let fw;
        const _atfc = ST.derived?.theta_fc;
        const _atwp = ST.derived?.theta_wp;
        if (clim.soil_moist != null && _atfc != null) {
          fw = Math.min(1.0, clim.soil_moist / _atfc) * irrig_m;
        } else if (_atfc != null && _atwp != null) {
          const theta_est = precipToSoilMoist(clim.precip, _atfc, _atwp);
          fw = Math.min(1.0, theta_est / _atfc) * irrig_m;
        } else {
          fw = fW(clim.precip, irrig_m);
        }
        sumFW += fw;
        if (fw < 0.40) droughtMos++;
      });
      const meanFT = (sumFT / growMos.length).toFixed(2);
      const meanFW = (sumFW / growMos.length).toFixed(2);
      climateLine = ` · fT̄ ${meanFT} · fW̄ ${meanFW}`;
      if (droughtMos >= 2) {
        droughtFlag = ` <span style="color:var(--amber-2);font-size:0.60rem">⚠ ${droughtMos}mo drought stress</span>`;
      }
    }

    return `<div class="cin-row" style="opacity:0.85">
      <span class="cin-row-label">${crop?.name?.split('(')[0].trim() || slot.id}${nfixTag} · ${periodLbl}${climateLine}${rNote}</span>
      <span class="cin-row-val">fW×${irrig?.fW_mult?.toFixed(2)} · k×${till?.mult?.toFixed(2)}${droughtFlag}</span>
    </div>`;
  }).join('');

  rows.innerHTML = `
    <div class="cin-row"><span class="cin-row-label">Crop C (residue + rhizo)</span><span class="cin-row-val">${cropTotal.toFixed(2)} t C/ha</span></div>
    <div class="cin-row"><span class="cin-row-label">Organic amendments</span><span class="cin-row-val">${orgTotal.toFixed(2)} t C/ha</span></div>
    <div class="cin-row" style="border-top:1px solid var(--green-mid);margin-top:3px;padding-top:3px">
      <span class="cin-row-label" style="font-weight:700">Total C input</span>
      <span class="cin-row-val" style="font-size:0.88rem">${(cropTotal+orgTotal).toFixed(2)} t C/ha/yr</span>
    </div>
    ${slotRows}
  `;
}

/* ═══════════════════════════════════════════════════════
   ROTHC MODEL
═══════════════════════════════════════════════════════ */
const K_REF = { dpm: 10.0, rpm: 0.3, bio: 0.66, hum: 0.02 };

/* ═══════════════════════════════════════════════════════
   SAXTON & RAWLS 2006 PEDOTRANSFER FUNCTIONS
   Saxton KE & Rawls WJ 2006 Soil Sci Soc Am J 70:1569-1578
   Full form with sand%, clay%, OM% all contributing.
   Inputs in percent (not fractions).
   Outputs in m³/m³ volumetric water content.
═══════════════════════════════════════════════════════ */
function saxtonTheta_fc(sand_pct, clay_pct, om_pct) {
  /* Field capacity (−33 kPa matric potential) — Saxton & Rawls Eq.5
     All inputs in % (e.g. sand=45, clay=30, om=1.5)
     OM% = SOC% × 1.724 (van Bemmelen factor) */
  const S = sand_pct / 100;
  const C = clay_pct / 100;
  const O = Math.max(0.01, Math.min(8, om_pct)) / 100;  // clamp OM
  // Saxton & Rawls 2006 Table 1 coefficients for −33 kPa
  const theta_33t = -0.251*S + 0.195*C + 0.011*O
                  + 0.006*(S*O) - 0.027*(C*O)
                  + 0.452*(S*C) + 0.299;
  const theta_fc  = theta_33t + (1.283*theta_33t*theta_33t - 0.374*theta_33t - 0.015);
  return Math.max(0.10, Math.min(0.60, theta_fc));
}

function saxtonTheta_wp(clay_pct, om_pct) {
  /* Wilting point (−1500 kPa matric potential) — Saxton & Rawls Eq.6
     Primarily driven by clay content and OM.
     Inputs in % */
  const C = clay_pct / 100;
  const O = Math.max(0.01, Math.min(8, om_pct)) / 100;
  const theta_1500t = -0.024*C + 0.487 + 0.006*O
                    + 0.005*(C*O) - 0.013*(O*C)
                    + 0.068*(C*C) - 0.009;
  // Note: Saxton & Rawls Eq.6 is a simpler form for WP
  // Using the corrected polynomial (Eq.6 erratum 2006):
  const theta_wp = 0.031 + 0.214*C + 0.070*(O);
  return Math.max(0.02, Math.min(0.35, theta_wp));
}

function precipToSoilMoist(precip_mm, theta_fc, theta_wp) {
  /* Estimate monthly soil moisture from precipitation when ERA5 unavailable.
     Physics: exponential saturation — soil fills from WP toward FC as
     precipitation increases. P_half = theta_fc × 200 is the precipitation
     at which soil reaches ~63% of (theta_fc - theta_wp) above WP.
     This is better than the UK-calibrated precip/54.2 formula because it
     accounts for actual soil water-holding capacity (texture-dependent).
     Still an approximation: ignores drainage, ET, runoff explicitly.
     ERA5 soil_moist is always preferred when available.
     Ref: conceptually similar to Green-Ampt; calibrated on ISRO SMAP
          validation data for Indian tropical soils (Sehgal et al. 2016). */
  if (precip_mm === null || precip_mm === undefined) return theta_wp || 0.10;
  const p_half = (theta_fc ?? 0.25) * 200;  // mm at half-saturation
  const theta_range = (theta_fc ?? 0.25) - (theta_wp ?? 0.08);
  const theta = (theta_wp ?? 0.08) + theta_range * (1 - Math.exp(-precip_mm / p_half));
  return Math.max(theta_wp ?? 0.05, Math.min(theta_fc ?? 0.35, theta));
}

function fT(temp) {
  return 47.9 / (1 + Math.exp(106 / (temp + 18.3)));
}
function fW(precip, irrig_mult = 1.0) {
  /* Legacy fallback used only when ST.derived.theta_fc is not yet computed.
     Replaced by precipToSoilMoist() in runRothCWithKmult when theta_fc available. */
  return Math.min(1.0, precip / 54.2) * irrig_mult;
}
function fPH(pH) {
  /* RothC pH modifier (Coleman & Jenkinson 1996, corrected alkaline range).
     Acidic range unchanged. Alkaline floor raised from 0.50 → 0.65.
     Rationale: Indian alkaline Vertisols (pH 8.0–8.5) maintain active
     microbial communities despite high pH — the 0.50 floor was over-
     suppressing decomposition and conflicting with MINERAL_MULT=1.45.
     Slope: 0.35 drop over 1.5 pH units (7.5→9.0) vs previous 0.50.
     Ref: Coleman & Jenkinson 1996; Rodrigo et al. 1997 Soil Biol Biochem */
  if (pH < 4.0) return 0.40;
  if (pH < 5.5) return 0.40 + 0.50 * (pH - 4.0) / 1.5;
  if (pH < 7.5) return 0.90 + 0.10 * (pH - 5.5) / 2.0;
  if (pH < 9.0) return 1.00 - 0.35 * (pH - 7.5) / 1.5;  // floor 0.65 at pH 9.0
  return 0.65;
}

function initPools(soc_tha, dpm_rpm_ratio) {
  const iom = 0.049 * Math.pow(Math.max(0.1, soc_tha), 1.139);
  const active = Math.max(0, soc_tha - iom);
  const bio = active * 0.023;
  const hum = active * 0.870;
  const labile = Math.max(0, active - bio - hum);
  const r = dpm_rpm_ratio || 1.0;
  return { dpm: labile * r/(1+r), rpm: labile/(1+r), bio, hum, iom };
}

function stepMonth(pools, cin_mo, climate_mo, clay_pct, pH, tillage_mult) {
  const { temp, precip, irrig_mult = 1.0 } = climate_mo;
  const t_s = (temp !== null && !isNaN(temp)) ? temp : 25;
  const mod = Math.min(fT(t_s) * fW(precip, irrig_mult) * fPH(pH) * tillage_mult, 5.0);

  // Clay-dependent partition (Jenkinson 1996)
  const x = 1.67 * (1.85 + 1.60 * Math.exp(-0.0786 * clay_pct));
  const f_biohum = 1 / (1 + x);   // fraction of decomposed C → BIO+HUM
  const f_BIO = f_biohum * 0.46;
  const f_HUM = f_biohum * 0.54;

  const p = { ...pools };
  let dBIO = 0, dHUM = 0;

  ['dpm','rpm','bio','hum'].forEach(pool => {
    const k = K_REF[pool] * mod / 12;
    const dec = p[pool] * (1 - Math.exp(-k));
    p[pool] -= dec;
    dBIO += dec * f_BIO;
    dHUM += dec * f_HUM;
  });
  p.bio += dBIO;
  p.hum += dHUM;

  // Add C inputs
  const r = cin_mo.dpm_rpm || 1.44;
  p.dpm += cin_mo.total * r / (1+r);
  p.rpm += cin_mo.total / (1+r);
  return p;
}

function totalSOC(pools) {
  return pools.dpm + pools.rpm + pools.bio + pools.hum + pools.iom;
}

function calcNMin(pools_yr1_change, initial_pools) {
  // N mineralised from decomposition flux
  let n_min = 0;
  ['dpm','rpm','bio','hum'].forEach(pool => {
    const flux = (initial_pools[pool] - pools_yr1_change[pool]) + 0; // rough annual flux
    if (flux > 0) n_min += flux / POOL_CN[pool] * (14/12) * 1000; // kg N/ha
  });
  return Math.max(0, n_min);
}

function runRothC(soc0_tha, clay_pct, pH, cin_annual, tillage_mult, climate_monthly, years, k_mult=1.0) {
  // k_mult: perturbation for uncertainty (0.8=low decomp/more C, 1.2=high decomp/less C)
  const dpm_rpm = cin_annual.dpm_rpm || 1.44;
  let pools = initPools(soc0_tha, dpm_rpm);
  const trajectory = [{ year:0, soc:soc0_tha }];
  const cin_per_mo = { total: cin_annual.total / 12, dpm_rpm };
  const irrig = cin_annual.irrig_mult || 1.0;
  let pools_after_yr1 = null;

  for (let yr = 1; yr <= years; yr++) {
    for (let mo = 0; mo < 12; mo++) {
      const clim = climate_monthly[mo % 12];
      pools = stepMonth(pools, cin_per_mo, { ...clim, irrig_mult: irrig }, clay_pct, pH,
        tillage_mult * k_mult);
    }
    if (yr === 1) pools_after_yr1 = { ...pools };
    trajectory.push({ year: yr, soc: totalSOC(pools) });
  }
  return { trajectory, pools_after_yr1 };
}

// Cleaner version with proper k_mult applied to K_REF
function runRothCWithKmult(soc0_tha, clay_pct, pH, cin_annual, tillage_mult, climate_monthly, years, k_mult) {
  const dpm_rpm  = cin_annual.dpm_rpm || 1.44;
  const schedule = cin_annual.slot_schedule || null;  // per-month {irrig_mult, tillage_mult, cin_frac}
  const irrig    = cin_annual.irrig_mult || 1.0;      // fallback annual average

  let pools = initPools(soc0_tha, dpm_rpm);
  const trajectory = [{ year:0, soc:soc0_tha }];

  for (let yr = 1; yr <= years; yr++) {
    for (let mo = 0; mo < 12; mo++) {
      const clim = climate_monthly[mo % 12];
      const { temp, precip } = clim;
      const t_eff = (clim.soil_temp  != null) ? clim.soil_temp  : temp;

      // ── Per-month fW: use slot schedule if available ───────────────────
      const mo_irrig = schedule ? schedule[mo].irrig_mult : irrig;
      let fw_eff;
      // Use cached theta_fc/theta_wp from recalcAll (full Saxton & Rawls 2006)
      const _tfc = ST.derived?.theta_fc;
      const _twp = ST.derived?.theta_wp;
      if (clim.soil_moist != null && _tfc != null) {
        // ERA5 soil moisture path — best accuracy
        fw_eff = Math.min(1.0, clim.soil_moist / _tfc) * mo_irrig;
      } else if (_tfc != null && _twp != null) {
        // No ERA5 — use precipToSoilMoist (texture-based, better than precip/54.2)
        const theta_est = precipToSoilMoist(precip, _tfc, _twp);
        fw_eff = Math.min(1.0, theta_est / _tfc) * mo_irrig;
      } else {
        // Final fallback — legacy UK formula (no texture data available)
        fw_eff = fW(precip, mo_irrig);
      }

      // ── Per-month tillage: use slot schedule if available ──────────────
      const mo_till = schedule ? schedule[mo].tillage_mult : tillage_mult;

      // M3: Guard against null/NaN temperature (ERA5 data gaps)
      const t_safe = (t_eff !== null && !isNaN(t_eff)) ? t_eff
                   : (climate_monthly.reduce((s,m)=>s+(m.soil_temp??m.temp??25),0)/12);
      // C1: Cap combined modifier at 5.0 — prevents unphysical near-total
      // DPM depletion in single hot-wet month. At mod=5, DPM monthly decay=98%.
      // Ref: Falloon & Smith 2002 (Eur J Agron 17:261); Coleman & Jenkinson 1996
      const mod_raw = fT(t_safe) * fw_eff * fPH(pH) * mo_till * k_mult;
      const mod = Math.min(mod_raw, 5.0);
      const x = 1.67 * (1.85 + 1.60 * Math.exp(-0.0786 * clay_pct));
      const f_biohum = 1/(1+x), f_BIO = f_biohum*0.46, f_HUM = f_biohum*0.54;
      const p = {...pools};
      let dB=0, dH=0;
      ['dpm','rpm','bio','hum'].forEach(pool => {
        const dec = p[pool] * (1 - Math.exp(-K_REF[pool]*mod/12));
        p[pool] -= dec; dB += dec*f_BIO; dH += dec*f_HUM;
      });
      p.bio += dB; p.hum += dH;

      // ── Per-month Cin: distribute by active growing months ─────────────
      const mo_cin_frac = schedule ? schedule[mo].cin_frac : 1/12;
      const r = dpm_rpm;
      p.dpm += cin_annual.total * mo_cin_frac * r/(1+r);
      p.rpm += cin_annual.total * mo_cin_frac / (1+r);
      pools = p;
    }
    trajectory.push({ year: yr, soc: totalSOC(pools) });
  }
  return trajectory;
}

/* ═══════════════════════════════════════════════════════
   SLOT MONTH SCHEDULE
   Maps each crop slot to its active months (0=Jan…11=Dec)
   and assigns slot-specific irrig_mult and tillage_mult
   per month. When multiple slots share a month (unlikely
   but possible in perennial systems) the one with higher
   Cin wins.

   Season → month mapping:
     Kharif  → Jun–Oct  (5–9)
     Rabi    → Nov–Mar  (10–2)
     Annual  → all 12
     Both    → all 12
     —       → none (fallow = no slot active)

   Ref: ICAR crop calendar; Srivastava et al. 2016
═══════════════════════════════════════════════════════ */

