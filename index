function updateAuditTable() {
  const wrap = document.getElementById('audit-table-wrap');
  if (!wrap) return;
  const get = id => { const el = document.getElementById(id); return el ? el.value : null; };
  const bg  = id => { const el = document.getElementById('badge-' + id); return el ? el.textContent : '🔴'; };

  // Soil parameters
  const soilRows = [
    { label:'SOC 0–15 cm',       id:'soc1',  unit:'g/kg',   formula:'SoilGrids raw ÷10' },
    { label:'SOC 15–30 cm',      id:'soc2',  unit:'g/kg',   formula:'SoilGrids raw ÷10' },
    { label:'Clay 0–15 cm',      id:'clay1', unit:'%',      formula:'SoilGrids raw ÷10' },
    { label:'Clay 15–30 cm',     id:'clay2', unit:'%',      formula:'SoilGrids raw ÷10' },
    { label:'Silt 0–15 cm',      id:'silt1', unit:'%',      formula:'SoilGrids raw ÷10' },
    { label:'Sand 0–15 cm',      id:'sand1', unit:'%',      formula:'SoilGrids raw ÷10' },
    { label:'Bulk Density',      id:'bd1',   unit:'g/cm³',  formula:'SoilGrids bdod ÷100' },
    { label:'pH (water)',        id:'ph1',   unit:'',       formula:'SoilGrids phh2o ÷10' },
    { label:'Total N 0–15 cm',   id:'tn1',   unit:'%',      formula:'SoilGrids nitrogen ÷1000' },
    { label:'CEC 0–15 cm',       id:'cec1',  unit:'cmol/kg',formula:'SoilGrids cec ÷10' },
    { label:'Coarse Frag.',      id:'cfvo1', unit:'vol%',   formula:'SoilGrids cfvo ÷10' },
  ];

  // Derived RothC values from ST
  const derived = [];
  if (ST.climate) {
    derived.push({ label:'MAT (5yr ERA5)',   val: ST.climate.mat?.toFixed(1),   unit:'°C',  src:'era5', formula:'ERA5 5yr monthly mean' });
    derived.push({ label:'MAP (5yr ERA5)',   val: ST.climate.map?.toFixed(0),   unit:'mm/yr', src:'era5', formula:'ERA5 5yr monthly sum' });
    if (ST.satData?.soilTempMonthly?.some(v=>v!==null)) {
      const tSoil = ST.satData.soilTempMonthly.filter(v=>v!==null);
      derived.push({ label:'T_soil 0–7cm mean', val: (tSoil.reduce((a,b)=>a+b,0)/tSoil.length).toFixed(1), unit:'°C', src:'era5', formula:'ERA5-Land soil_temperature_0_to_7cm_mean' });
    }
    if (ST.satData?.soilMoistMonthly?.some(v=>v!==null)) {
      const sm = ST.satData.soilMoistMonthly.filter(v=>v!==null);
      derived.push({ label:'SM 0–7cm mean', val: (sm.reduce((a,b)=>a+b,0)/sm.length*100).toFixed(1), unit:'vol%', src:'era5', formula:'ERA5-Land soil_moisture_0_to_7cm_mean ×100' });
    }
  }
  if (ST.soc) {
    const iom = (0.049 * Math.pow(ST.soc * ST.bd * 0.15, 1.139)).toFixed(2);
    derived.push({ label:'IOM (inert organic)',  val: iom,  unit:'t C/ha', src:'comp', formula:'Falloon 1998: 0.049 × (SOC×BD×depth)^1.139' });
  }
  if (ST.hassinkCap) {
    derived.push({ label:'Hassink ceiling',  val: ST.hassinkCap.toFixed(1), unit:'t C/ha', src:'comp', formula:'Hassink 1997 × mineralogy multiplier' });
  }
  if (ST.fT !== undefined) {
    // M1: note if using air temp as proxy (ERA5 soil temp absent)
    const ftSrc = ST.satData?.soilTempMonthly ? 'ERA5 soil temp' : 'air temp proxy (ERA5 soil temp unavailable — may underestimate fT by up to 1.3× in hot months)';
    derived.push({ label:'fT modifier',  val: ST.fT?.toFixed(3), unit:'', src:'comp', formula:`RothC: 47.9/(1+exp(106/(T+18.3))) · using ${ftSrc}` });
  }
  if (ST.fW !== undefined) {
    derived.push({ label:'fW modifier',  val: ST.fW?.toFixed(3), unit:'', src:'comp', formula:'min(1, θ/θ_FC) × irrigation factor' });
  }

  let html = '<table class="audit-table"><thead><tr>' +
    '<th>Parameter</th><th>Value</th><th>Source</th><th>Derivation</th><th></th>' +
    '</tr></thead><tbody>';

  soilRows.forEach(r => {
    const v = get(r.id);
    const b = bg(r.id);
    const verified = b === '🟢' ? '' : `<span class="audit-unverified">⚠ not lab-verified</span>`;
    const override = v ? `<span class="audit-override" onclick="toggleParamsDisclosure(true);document.getElementById('${r.id}')?.focus()" title="Click to edit">edit</span>` : '';
    html += `<tr>
      <td>${r.label}</td>
      <td class="audit-val-cell">${v || '<span style="color:var(--ink-5)">—</span>'} <span style="font-size:0.60rem;color:var(--ink-5)">${r.unit}</span></td>
      <td>${srcBadge(b)}</td>
      <td style="color:var(--ink-4);font-size:0.62rem">${r.formula}</td>
      <td>${v ? override : ''} ${verified}</td>
    </tr>`;
  });

  if (derived.length) {
    html += `<tr><td colspan="5" style="padding:6px 8px 2px;font-size:0.60rem;color:var(--ink-5);letter-spacing:0.06em;font-weight:700">DERIVED / COMPUTED</td></tr>`;
    derived.forEach(r => {
      const srcClass = r.src === 'era5' ? 'audit-src-era5' : 'audit-src-comp';
      const srcLabel = r.src === 'era5' ? 'ERA5-Land' : 'Computed';
      html += `<tr>
        <td>${r.label}</td>
        <td class="audit-val-cell">${r.val || '—'} <span style="font-size:0.60rem;color:var(--ink-5)">${r.unit}</span></td>
        <td><span class="audit-src-badge ${srcClass}">${srcLabel}</span></td>
        <td style="color:var(--ink-4);font-size:0.62rem">${r.formula}</td>
        <td></td>
      </tr>`;
    });
  }

  html += '</tbody></table>';
  wrap.innerHTML = html;
}

