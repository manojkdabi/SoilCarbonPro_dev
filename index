/* ══════════════════════════════════════════════════
   WIZARD STEPPER — nav bar + phase panels
══════════════════════════════════════════════════ */
.wizard-nav {
  background: #111e11;
  border-bottom: 2px solid var(--green);
  padding: 0 20px;
  display: flex;
  align-items: stretch;
  position: sticky;
  top: 52px;
  z-index: 980;
  height: 58px;
  gap: 0;
}
.wiz-step {
  display: flex;
  align-items: center;
  gap: 11px;
  padding: 0 18px;
  cursor: default;
  opacity: 0.36;
  transition: opacity 0.22s, background 0.22s;
  border-bottom: 3px solid transparent;
  position: relative;
  user-select: none;
  min-width: 0;
}
.wiz-step.active {
  opacity: 1;
  border-bottom-color: var(--green-2);
  background: rgba(46,128,64,0.14);
}
.wiz-step.done {
  opacity: 0.72;
  cursor: pointer;
}
.wiz-step.done:hover {
  opacity: 1;
  background: rgba(46,128,64,0.10);
}
.wiz-step.locked { cursor: not-allowed; }
.wiz-num {
  width: 30px; height: 30px;
  border-radius: 50%;
  background: var(--ink-3);
  color: var(--ink-5);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--mono);
  font-size: 0.80rem; font-weight: 700;
  flex-shrink: 0;
  transition: background 0.22s, color 0.22s;
  letter-spacing: 0;
}
.wiz-step.active .wiz-num { background: var(--green-2); color: #fff; }
.wiz-step.done   .wiz-num { background: var(--green);   color: var(--green-mid); }
.wiz-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.wiz-label {
  font-family: var(--sans);
  font-size: 0.70rem; font-weight: 700;
  color: var(--ink-4);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  white-space: nowrap;
}
.wiz-step.active .wiz-label, .wiz-step.done .wiz-label { color: #b8e8b8; }
.wiz-sublabel {
  font-family: var(--mono);
  font-size: 0.58rem;
  color: var(--ink-3);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.wiz-step.active .wiz-sublabel { color: var(--green-mid); }
.wiz-status-pill {
  display: inline-flex; align-items: center; gap: 4px;
  font-family: var(--mono); font-size: 0.58rem; font-weight: 600;
  padding: 2px 8px; border-radius: 10px;
  background: rgba(74,106,74,0.22); color: var(--ink-4);
  margin-top: 2px;
  white-space: nowrap;
}
.wiz-status-pill.wiz-pill-ok     { background: rgba(30,92,38,0.25); color: #70d070; }
.wiz-status-pill.wiz-pill-active { background: rgba(154,94,8,0.20); color: var(--amber-2); }
.wiz-status-pill.wiz-pill-done   { background: rgba(30,92,38,0.18); color: #56b056; }
.wiz-status-pill.wiz-pill-locked { background: rgba(60,60,60,0.25); color: var(--ink-3); }

.wiz-connector {
  display: flex; align-items: center;
  padding: 0 6px;
  color: var(--ink-3);
  font-size: 1rem;
  flex-shrink: 0;
  opacity: 0.5;
}

/* Phase navigation controls embedded in phase 2/3 headers */
.phase-nav-strip {
  display: flex; align-items: center;
  gap: 12px;
  padding: 10px 28px;
  background: var(--ink-2);
  border-bottom: 1px solid var(--ink-3);
}
.phase-back-btn {
  display: flex; align-items: center; gap: 6px;
  background: transparent;
  border: 1px solid var(--ink-3);
  color: var(--ink-5);
  border-radius: var(--radius);
  padding: 6px 14px;
  font-family: var(--sans); font-size: 0.72rem; font-weight: 500;
  cursor: pointer;
  transition: border-color 0.18s, color 0.18s;
}
.phase-back-btn:hover { border-color: var(--green-mid); color: var(--green-mid); }
.phase-nav-crumb {
  font-family: var(--mono); font-size: 0.62rem; color: var(--ink-4);
  flex: 1;
}
.phase-nav-crumb strong { color: var(--ink-5); }

/* Proceed bar at bottom of phases 1 and 2 */
.phase-proceed-bar {
  background: #0d1a0d;
  border-top: 2px solid var(--green);
  padding: 20px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}
.phase-proceed-left { display: flex; flex-direction: column; gap: 5px; flex: 1; min-width: 200px; }
.phase-proceed-title {
  font-family: var(--serif);
  font-size: 0.85rem; font-weight: 400;
  color: #b0d8b0;
}
.phase-proceed-reqs {
  display: flex; gap: 8px; flex-wrap: wrap;
}
.proc-req {
  display: inline-flex; align-items: center; gap: 4px;
  font-family: var(--mono); font-size: 0.60rem; font-weight: 600;
  padding: 3px 9px; border-radius: 10px;
  border: 1px solid var(--ink-3);
  color: var(--ink-4);
  background: rgba(255,255,255,0.04);
  transition: border-color 0.2s, color 0.2s, background 0.2s;
}
.proc-req.met {
  border-color: var(--green-2);
  color: #70d070;
  background: rgba(30,92,38,0.18);
}
.phase-proceed-btn {
  background: var(--green-2);
  color: white;
  border: none;
  border-radius: var(--radius);
  padding: 13px 32px;
  font-family: var(--sans); font-size: 0.88rem; font-weight: 700;
  cursor: pointer;
  display: flex; align-items: center; gap: 10px;
  transition: background 0.18s, transform 0.12s, box-shadow 0.18s;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(30,92,38,0.25);
}
.phase-proceed-btn:hover:not(:disabled) {
  background: var(--green);
  transform: translateX(3px);
  box-shadow: 0 4px 16px rgba(30,92,38,0.35);
}
.phase-proceed-btn:disabled {
  background: var(--ink-3);
  color: var(--ink-4);
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}
.phase-proceed-btn .btn-arrow { font-size: 1.1rem; transition: transform 0.15s; }
.phase-proceed-btn:hover:not(:disabled) .btn-arrow { transform: translateX(3px); }

/* Phase panels */
.phase-panel { display: none; }
.phase-panel.active { display: block; animation: phaseIn 0.26s ease; }
@keyframes phaseIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

  /* Loading splash */
  #scp-splash {
    position:fixed; inset:0; z-index:9999;
    background:#0d2b23;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    gap:16px; transition:opacity 0.4s ease;
  }
  #scp-splash.hidden { opacity:0; pointer-events:none; }
  #scp-splash svg { width:48px; height:48px; animation:splashSpin 1.2s linear infinite; }
  @keyframes splashSpin { to { transform:rotate(360deg); } }
  #scp-splash-text { color:#4ecda0; font-family:ui-monospace,monospace; font-size:0.85rem; letter-spacing:0.08em; }
  #scp-splash-sub { color:#2a6b50; font-family:ui-monospace,monospace; font-size:0.68rem; }


/* ── Submit Assessment Modal ─────────────────────────────────── */
#submit-modal-overlay {
  display:none; position:fixed; inset:0; z-index:8000;
  background:rgba(0,0,0,0.55); backdrop-filter:blur(3px);
  align-items:center; justify-content:center;
}
#submit-modal-overlay.open { display:flex; }
#submit-modal {
  background:var(--paper-1); border:1px solid var(--paper-3);
