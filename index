  t2params.forEach((r, i) => paramRow(i, ...r));

  y += 5;
  // BD protocol box
  doc.setFillColor(254,244,228); doc.setDrawColor(col.amber);
  doc.setLineWidth(0.5);
  doc.rect(pad, y-2, cW, 32, 'FD');
