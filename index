<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
  <!-- Performance: preconnect to CDN domains -->
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="dns-prefetch" href="https://maps.isric.org">
  <link rel="dns-prefetch" href="https://nominatim.openstreetmap.org">
  <link rel="dns-prefetch" href="https://api.opentopodata.org">
  <link rel="dns-prefetch" href="https://archive-api.open-meteo.com">

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SoilCarbon Pro — Target Solver v1.5.0</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<!-- GeoTIFF loaded lazily on first SoilGrids fetch -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Turf.js/6.5.0/turf.min.js" defer></script>
<!-- jsPDF loaded lazily on first PDF export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js" defer></script>

<style>
/* ═══════════════════════════════════════════════════
   DESIGN TOKENS
══════════════════════════════════════════════════ */
:root {
  --ink:        #1a2e1a;
  --ink-2:      #2e4a2e;
  --ink-3:      #4a6a4a;
  --ink-4:      #7a9a7a;
  --ink-5:      #b0c8b0;
  --paper:      #f7f4ee;
  --paper-2:    #f0ece2;
  --paper-3:    #e6e0d2;
  --panel:      #faf8f3;
  --panel-b:    #eeead8;
  --green:      #1e5c26;
  --green-2:    #2e8040;
  --green-lt:   #e4f2e6;
  --green-mid:  #c0e0c4;
  --amber:      #9a5e08;
  --amber-2:    #c07a10;
  --amber-lt:   #fdf4e4;
  --amber-mid:  #f2ddb0;
  --orange:     #8a3a08;
  --orange-lt:  #fdf0e4;
  --red:        #8a1a1a;
  --red-2:      #c02828;
  --red-lt:     #fdeaea;
  --red-mid:    #f0c0c0;
  --teal:       #0e4a3a;
  --teal-lt:    #e4f2ee;
  --blue:       #1a2e6a;
  --blue-lt:    #e4e8f8;
  --shadow-sm:  0 1px 3px rgba(26,46,26,0.10);
  --shadow-md:  0 4px 16px rgba(26,46,26,0.12);
  --radius:     6px;
  --radius-lg:  10px;
  --mono:       'IBM Plex Mono', 'Courier New', monospace;
  --serif:      'IBM Plex Serif', 'Georgia', serif;
  --sans:       'IBM Plex Sans', system-ui, sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 14px; }
body {
  font-family: var(--sans);
  background: var(--paper);
  color: var(--ink);
  line-height: 1.55;
  min-height: 100vh;
}

/* ── HEADER ── */
.site-header {
  background: var(--ink);
  color: var(--paper);
  padding: 0 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 52px;
  position: sticky;
  top: 0;
  z-index: 1000;
  border-bottom: 2px solid var(--green-2);
}
.site-header h1 {
  font-family: var(--serif);
  font-size: 1.05rem;
  font-weight: 400;
  letter-spacing: 0.02em;
  color: #d0e8d0;
}
.site-header h1 span {
  font-weight: 600;
  color: #90d8a0;
}
.phase-badge {
  font-family: var(--mono);
  font-size: 0.70rem;
  background: var(--green);
  color: var(--green-lt);
  padding: 3px 10px;
  border-radius: 12px;
  letter-spacing: 0.08em;
  margin-left: 12px;
}

/* ── MODE TOGGLE ── */
.mode-bar {
  background: var(--ink-2);
  padding: 7px 28px;
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: var(--sans);
  font-size: 0.78rem;
  color: var(--ink-5);
  border-bottom: 1px solid var(--ink-3);
}
.mode-label { font-weight: 500; color: var(--ink-4); }
.mode-toggle {
  display: flex;
  background: var(--ink);
  border-radius: 20px;
  padding: 3px;
  gap: 2px;
}
.mode-btn {
  padding: 4px 14px;
  border-radius: 16px;
  border: none;
  cursor: pointer;
  font-family: var(--mono);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  transition: all 0.2s;
  background: transparent;
  color: var(--ink-4);
}
.mode-btn.active {
  background: var(--green-2);
  color: white;
}
.mode-hint {
  color: var(--ink-4);
  font-size: 0.75rem;
  font-style: italic;
}

/* ── MAIN LAYOUT ── */
.main-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  min-height: calc(100vh - 100px);
}
.left-col {
  border-right: 1px solid var(--paper-3);
  overflow-y: auto;
}
.right-col {
  overflow-y: auto;
  background: var(--panel);
}

/* ── SECTION HEADERS ── */
.sec-header {
  padding: 14px 24px 10px;
  border-bottom: 1px solid var(--paper-3);
  display: flex;
  align-items: baseline;
  gap: 10px;
}
.sec-tag {
  font-family: var(--mono);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  color: var(--green-2);
  text-transform: uppercase;
}
.sec-title {
  font-family: var(--serif);
  font-size: 1.0rem;
  font-weight: 400;
  color: var(--ink);
}

/* ── MAP ── */
.map-section { padding: 16px 24px 0; }
.map-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}
.field-label {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--ink-3);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
#map {
  height: 200px;
  border-radius: var(--radius);
  border: 1px solid var(--paper-3);
  cursor: crosshair;
}

/* ── Geofence draw controls ── */
.draw-controls {
  display: flex; align-items: center; gap: 6px;
  margin-top: 5px; flex-wrap: wrap;
}
.draw-btn {
  font-family: var(--mono); font-size: 0.62rem; font-weight: 600;
  letter-spacing: 0.04em; padding: 3px 9px; border-radius: 4px;
  cursor: pointer; border: 1px solid var(--paper-3);
  background: var(--paper-2); color: var(--ink-4);
  transition: all 0.15s;
}
.draw-btn:hover { border-color: var(--green-2); color: var(--green); }
.draw-btn.active { background: var(--green); border-color: var(--green); color: white; }
.draw-btn.danger { color: var(--red); border-color: var(--red); }
.draw-btn.danger:hover { background: var(--red); color: white; }
.field-info-strip {
  display: none; margin-top: 6px; padding: 7px 12px;
  background: var(--teal-lt); border: 1px solid var(--teal);
  border-radius: 6px; font-family: var(--mono); font-size: 0.68rem;
  color: var(--teal); line-height: 1.7;
}
.field-info-strip.visible { display: block; }
.field-info-row { display: flex; gap: 16px; flex-wrap: wrap; }
.field-info-val { font-weight: 700; font-size: 0.78rem; }
.field-info-label { font-size: 0.60rem; color: var(--teal); opacity: 0.8; }
.geojson-import { display: none; }
#geojson-file-input { display: none; }
.sat-diag-section {
  margin: 0 0 0 0;
  border-top: 1px solid var(--paper-3);
}
.sat-diag-toggle {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 24px; cursor: pointer;
  font-family: var(--mono); font-size: 0.65rem;
  font-weight: 700; letter-spacing: 0.10em;
  color: var(--teal); user-select: none;
  background: var(--paper);
}
.sat-diag-toggle:hover { background: var(--paper-2); }
.sat-diag-toggle-icon { transition: transform 0.2s; font-size: 0.8rem; }
.sat-diag-toggle.open .sat-diag-toggle-icon { transform: rotate(90deg); }
.sat-diag-body { display: none; padding: 0 24px 14px; }
.sat-diag-body.open { display: block; }
.satd-row {
  display: flex; flex-direction: column; gap: 2px;
  padding: 6px 10px; border-radius: 5px; margin-bottom: 5px;
  border: 1px solid var(--paper-3); background: var(--paper-2);
  font-family: var(--mono);
}
.satd-row.active { border-color: var(--teal); background: var(--teal-lt); }
.satd-row.locked { border-color: var(--paper-3); opacity: 0.7; }
.satd-val  { font-size: 0.70rem; font-weight: 600; color: var(--ink-2); }
.satd-row.active .satd-val { color: var(--teal); }
.satd-row.locked .satd-val { color: var(--ink-5); }
.satd-note { font-size: 0.60rem; color: var(--ink-5); }
.satd-key-row {
  display: flex; gap: 6px; align-items: center; margin-top: 8px;
  flex-wrap: wrap;
}
.satd-key-input {
  flex: 1; min-width: 180px;
  font-family: var(--mono); font-size: 0.62rem;
  background: var(--paper); color: var(--ink-2);
  border: 1px solid var(--paper-3); border-radius: 4px;
  padding: 4px 8px;
}
.satd-key-input:focus { outline: 2px solid var(--teal); border-color: transparent; }
.satd-key-label {
  font-family: var(--mono); font-size: 0.60rem;
  color: var(--ink-5); white-space: nowrap;
}
.satd-key-btn {
  font-family: var(--mono); font-size: 0.60rem; font-weight: 700;
  background: var(--teal); color: white; border: none;
  border-radius: 4px; padding: 4px 10px; cursor: pointer;
}
.satd-key-btn:hover { opacity: 0.85; }
.sat-controls {
  display: flex; align-items: center; gap: 6px;
  margin-top: 6px; flex-wrap: wrap;
}
.sat-btn {
  font-family: var(--mono); font-size: 0.62rem; font-weight: 600;
  letter-spacing: 0.04em; padding: 3px 9px; border-radius: 4px;
  cursor: pointer; border: 1px solid var(--paper-3);
  background: var(--paper-2); color: var(--ink-4);
  transition: all 0.15s;
}
.sat-btn.active { background: var(--teal); border-color: var(--teal); color: white; }
.sat-btn:hover:not(.active) { border-color: var(--teal); color: var(--teal); }
.sat-month-wrap {
  display: none; align-items: center; gap: 5px;
  margin-left: 4px;
}
.sat-month-wrap.visible { display: flex; }
.sat-month-wrap select, .sat-month-wrap input[type=range] {
  font-family: var(--mono); font-size: 0.60rem;
  background: var(--paper-2); color: var(--ink-3);
  border: 1px solid var(--paper-3); border-radius: 4px;
  padding: 2px 4px;
}
.sat-month-wrap input[type=range] { width: 70px; padding: 0; }
.sat-opacity-label {
  font-family: var(--mono); font-size: 0.58rem; color: var(--ink-5);
}
.location-row {
  display: flex;
  gap: 8px;
  margin-top: 8px;
  align-items: center;
}
.coord-box {
  flex: 1;
  position: relative;
}
.coord-box input {
  width: 100%;
  font-family: var(--mono);
  font-size: 0.80rem;
  padding: 6px 10px;
  border: 1px solid var(--paper-3);
  border-radius: var(--radius);
  background: white;
  color: var(--ink);
}
.coord-box input:focus { outline: 2px solid var(--green-2); border-color: transparent; }
.coord-label {
  position: absolute;
  top: -7px; left: 8px;
  background: white;
  padding: 0 4px;
  font-size: 0.62rem;
  font-weight: 600;
  color: var(--ink-4);
  letter-spacing: 0.04em;
}
.fetch-btn {
  padding: 7px 16px;
  background: var(--green);
  color: white;
  border: none;
  border-radius: var(--radius);
  font-family: var(--sans);
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s;
}
.fetch-btn:hover { background: var(--green-2); }
.fetch-btn:disabled { background: var(--ink-4); cursor: not-allowed; }
.location-name {
  padding: 5px 0 0;
  font-size: 0.78rem;
  color: var(--ink-3);
  font-style: italic;
  min-height: 20px;
}
.fetch-status {
  font-family: var(--mono);
  font-size: 0.72rem;
  padding: 4px 0;
  min-height: 20px;
}
.fetch-status.loading { color: var(--amber-2); }
.fetch-status.ok { color: var(--green-2); }
.fetch-status.err { color: var(--red-2); }

/* ── PARAMETER SECTIONS ── */
.params-section { padding: 16px 24px; }
.depth-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 14px;
}
.depth-tab {
  padding: 5px 14px;
  border: 1px solid var(--paper-3);
  border-radius: 16px;
  font-family: var(--mono);
  font-size: 0.72rem;
  font-weight: 500;
  cursor: pointer;
  background: white;
  color: var(--ink-3);
  transition: all 0.15s;
}
.depth-tab.active {
  background: var(--ink);
  color: var(--paper);
  border-color: var(--ink);
}

/* ── PARAMETER FIELD ── */
.param-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.param-field {
  position: relative;
}
.param-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}
.param-name {
  font-size: 0.73rem;
  font-weight: 600;
  color: var(--ink-3);
  letter-spacing: 0.02em;
}
.param-unit {
  font-family: var(--mono);
  font-size: 0.64rem;
  color: var(--ink-4);
}
.param-input-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.param-input {
  flex: 1;
  min-width: 0;
  font-family: var(--mono);
  font-size: 0.84rem;
  font-weight: 500;
  padding: 7px 9px;
  border: 1px solid var(--paper-3);
  border-radius: var(--radius);
  background: white;
  color: var(--ink);
  transition: border-color 0.15s;
}
.param-input:focus { outline: none; border-color: var(--green-2); }
.param-input.has-value { border-color: var(--green-mid); }
.param-input.auto-filled { background: var(--paper); border-color: var(--amber-mid); }
.param-input.derived    { background: #faf5ff; border-color: #c4b5fd; }
.param-input.pedotransfer { background: var(--blue-lt); border-color: #b0c0e8; }
.badge {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  white-space: nowrap;
  cursor: help;
}
.badge-lab { color: var(--green-2); }
.badge-sg  { color: var(--amber-2); }
.badge-olm { color: #d07000; }
.badge-pt  { color: var(--blue); }
.badge-def { color: var(--red-2); }
.badge-drv { color: #7c3aed; }   /* violet — derived/calculated */
.badge-sat { color: #2d6a4f; }   /* forest green — satellite-derived */
.param-derived {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--ink-4);
  margin-top: 3px;
  min-height: 14px;
}

/* consistency warning */
.texture-warn {
  font-size: 0.72rem;
  color: var(--amber);
  margin-top: 4px;
  font-style: italic;
}

/* ── TIER 2 COLLAPSIBLE ── */
.tier2-toggle {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 16px 0 10px;
  cursor: pointer;
  user-select: none;
}
.tier2-toggle-icon {
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--green-lt);
  border: 1.5px solid var(--green-2);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem;
  color: var(--green-2);
  font-weight: 700;
  flex-shrink: 0;
  transition: transform 0.2s;
}
.tier2-toggle.open .tier2-toggle-icon { transform: rotate(45deg); }
.tier2-toggle-label {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--green);
  font-family: var(--sans);
}
.tier2-toggle-sub {
  font-size: 0.70rem;
  color: var(--ink-4);
  font-style: italic;
}
.tier2-panel {
  display: none;
  padding-top: 4px;
}
.tier2-panel.open { display: block; }

/* ── POXC INDICATOR ── */
.poxc-indicator {
  margin-top: 4px;
  padding: 6px 10px;
  border-radius: var(--radius);
  font-size: 0.72rem;
  font-weight: 500;
  display: none;
}
.poxc-indicator.building { background: var(--green-lt); color: var(--green); }
.poxc-indicator.stable   { background: var(--teal-lt); color: var(--teal); }
.poxc-indicator.declining{ background: var(--amber-lt); color: var(--amber); }

/* ── UNCERTAINTY METER ── */
.uncertainty-strip {
  margin: 0 24px 16px;
  padding: 12px 16px;
}

/* ─── Soil Summary Strip ─── */
.soil-summary-strip {
  display: flex; flex-wrap: wrap; gap: 8px;
  padding: 10px 24px 4px; margin-top: 2px;
}
.sss-chip {
  display: flex; align-items: center; gap: 5px;
  background: var(--panel); border: 1px solid var(--paper-3);
  border-radius: 6px; padding: 5px 10px;
  font-family: var(--mono); font-size: 0.72rem;
}
.sss-lbl { color: var(--ink-4); font-size: 0.65rem; min-width: 28px; }
.sss-val { color: var(--ink-1); font-weight: 700; font-size: 0.80rem; min-width: 30px; }
.sss-unit { color: var(--ink-5); font-size: 0.60rem; }
.sss-badge { font-size: 0.70rem; }
.dq-line {
  font-family: var(--mono); font-size: 0.66rem; color: var(--ink-4);
  padding: 2px 24px 8px; line-height: 1.4;
}
.dq-line.ok { color: var(--green-2); }
.dq-line.warn { color: var(--amber-2); }

/* ─── Audit Panel ─── */
.audit-section {
  margin: 0 24px 8px; border: 1px solid var(--paper-3);
  border-radius: var(--radius); overflow: hidden;
}
.audit-toggle {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 14px; cursor: pointer;
  font-family: var(--mono); font-size: 0.68rem;
  font-weight: 700; letter-spacing: 0.06em; color: var(--ink-3);
  background: var(--paper-2); user-select: none;
  transition: background 0.15s;
}
.audit-toggle:hover { background: var(--paper-3); }
.audit-toggle-icon { font-size: 0.60rem; transition: transform 0.2s; }
.audit-toggle-icon.open { transform: rotate(90deg); }
.audit-body { display: none; padding: 0 14px 10px; }
.audit-body.open { display: block; }
.audit-table { width: 100%; border-collapse: collapse; font-family: var(--mono); font-size: 0.67rem; margin-top: 8px; }
.audit-table th { color: var(--ink-5); font-weight: 600; padding: 4px 8px; border-bottom: 1px solid var(--paper-3); text-align: left; letter-spacing: 0.05em; }
.audit-table td { padding: 5px 8px; border-bottom: 1px solid var(--paper-2); color: var(--ink-2); vertical-align: middle; }
.audit-table tr:last-child td { border-bottom: none; }
.audit-table tr:hover td { background: var(--paper-2); }
.audit-src-badge { font-size: 0.60rem; padding: 1px 5px; border-radius: 3px; font-weight: 600; }
.audit-src-sg   { background: rgba(200,170,0,0.15); color: #c8aa00; }
.audit-src-lab  { background: rgba(60,180,90,0.15); color: var(--green-2); }
.audit-src-pt   { background: rgba(80,130,200,0.15); color: var(--blue); }
.audit-src-era5 { background: rgba(80,200,180,0.15); color: var(--teal); }
.audit-src-comp { background: rgba(120,120,120,0.15); color: var(--ink-3); }
.audit-val-cell { font-weight: 700; color: var(--ink-1); }
.audit-override { font-size: 0.60rem; color: var(--teal); cursor: pointer; text-decoration: underline; }
.audit-override:hover { color: var(--green-2); }
.audit-unverified { color: var(--amber-2); font-size: 0.60rem; }

/* ─── Params Disclosure ─── */
.params-disclosure {
  margin: 4px 24px 8px; border: 1px solid var(--paper-3);
  border-radius: var(--radius); overflow: hidden;
}
.params-disclosure-hdr {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 14px; cursor: pointer;
  font-family: var(--mono); font-size: 0.68rem;
  font-weight: 700; letter-spacing: 0.06em; color: var(--ink-3);
  background: var(--paper-2); user-select: none; transition: background 0.15s;
}
.params-disclosure-hdr:hover { background: var(--paper-3); }
.params-disc-icon { font-size: 0.60rem; transition: transform 0.2s; }
.params-disc-icon.open { transform: rotate(90deg); }

/* ─── Phase 2 Advanced ─── */
.p2-advanced-wrap {
  margin: 0 0 4px; border-top: 1px solid var(--paper-3);
}
.p2-advanced-hdr {
  display: flex; align-items: center; gap: 8px;
  padding: 9px 22px; cursor: pointer;
  font-family: var(--mono); font-size: 0.68rem;
  font-weight: 700; letter-spacing: 0.06em; color: var(--ink-3);
  background: var(--paper-2); user-select: none; transition: background 0.15s;
}
.p2-advanced-hdr:hover { background: var(--paper-3); }
.p2-adv-icon { font-size: 0.60rem; transition: transform 0.2s; }
/* .uncertainty-strip body properties restored */
.uncertainty-strip {
  background: var(--ink);
  border-radius: var(--radius-lg);
  color: var(--paper);
}
.uncertainty-title {
  font-family: var(--mono);
  font-size: 0.64rem;
  letter-spacing: 0.12em;
  color: var(--ink-5);
  margin-bottom: 8px;
}
.uncertainty-bar-wrap {
  position: relative;
  height: 8px;
  background: var(--ink-2);
  border-radius: 4px;
  margin-bottom: 6px;
  overflow: hidden;
}
.uncertainty-bar {
  height: 100%;
  border-radius: 4px;
  transition: width 0.4s ease, background 0.4s;
}
.uncertainty-labels {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.uncertainty-value {
  font-family: var(--mono);
  font-size: 0.88rem;
  font-weight: 600;
  color: #90d8a0;
}
.uncertainty-range {
  font-family: var(--mono);
  font-size: 0.70rem;
  color: var(--ink-4);
}
.uncertainty-detail {
  font-size: 0.68rem;
  color: var(--ink-5);
  margin-top: 5px;
  line-height: 1.4;
}

/* ── RIGHT COL: SETTINGS + TARGET ── */
.right-section { padding: 16px 24px; border-bottom: 1px solid var(--paper-3); }

/* mineralogy selector */
.mineral-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 8px;
}
.mineral-card {
  border: 1.5px solid var(--paper-3);
  border-radius: var(--radius);
  padding: 8px 10px;
  cursor: pointer;
  transition: all 0.15s;
  background: white;
}
.mineral-card:hover { border-color: var(--green-mid); }
.mineral-card.selected {
  border-color: var(--green-2);
  background: var(--green-lt);
}
.mineral-card-name {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 2px;
}
.mineral-card-sub {
  font-size: 0.68rem;
  color: var(--ink-4);
  font-style: italic;
}
.mineral-card-mult {
  font-family: var(--mono);
  font-size: 0.68rem;
  color: var(--green-2);
  margin-top: 3px;
  font-weight: 600;
}

/* depth selector */
.depth-selector {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}
.depth-option {
  flex: 1;
  padding: 7px;
  border: 1.5px solid var(--paper-3);
  border-radius: var(--radius);
  cursor: pointer;
  text-align: center;
  background: white;
  transition: all 0.15s;
}
.depth-option.selected {
  border-color: var(--green-2);
  background: var(--green-lt);
}
.depth-option-val {
  font-family: var(--mono);
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--ink);
  display: block;
}
.depth-option-sub {
  font-size: 0.65rem;
  color: var(--ink-4);
}

/* ── TARGET ENTRY ── */
.target-section {
  padding: 16px 24px;
  border-bottom: 1px solid var(--paper-3);
}
.target-inputs {
  display: flex;
  gap: 12px;
  align-items: flex-end;
  margin-top: 10px;
}
.target-field {
  flex: 1;
  position: relative;
}
.target-field label {
  display: block;
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--ink-3);
  letter-spacing: 0.04em;
  margin-bottom: 4px;
  text-transform: uppercase;
}
.target-input {
  width: 100%;
  font-family: var(--mono);
  font-size: 1.1rem;
  font-weight: 600;
  padding: 10px 12px;
  border: 2px solid var(--paper-3);
  border-radius: var(--radius);
  background: white;
  color: var(--ink);
  transition: border-color 0.2s;
}
.target-input:focus { outline: none; border-color: var(--green-2); }
.target-input.has-value { border-color: var(--ink); }
.target-unit {
  font-size: 0.70rem;
  color: var(--ink-4);
  margin-top: 3px;
  font-family: var(--mono);
  text-align: center;
}
.target-eq {
  font-size: 1.2rem;
  color: var(--ink-5);
  padding-bottom: 10px;
  flex-shrink: 0;
}
.target-confidence {
  display: flex;
  gap: 6px;
  margin-top: 12px;
}
.conf-btn {
  flex: 1;
  padding: 6px;
  border: 1.5px solid var(--paper-3);
  border-radius: var(--radius);
  cursor: pointer;
  text-align: center;
  background: white;
  transition: all 0.15s;
}
.conf-btn.active { border-color: var(--green-2); background: var(--green-lt); }
.conf-btn-name {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--ink);
  display: block;
}
.conf-btn-sub {
  font-size: 0.64rem;
  color: var(--ink-4);
}

/* ── CEILING DIAGNOSIS ── */
.ceiling-section { padding: 16px 24px; }
.ceiling-empty {
  text-align: center;
  padding: 40px 20px;
  color: var(--ink-4);
  font-style: italic;
  font-size: 0.85rem;
}

/* GAUGE */
.gauge-wrap { margin-bottom: 16px; }
.gauge-svg-container {
  width: 100%;
  overflow: visible;
}
svg.gauge { width: 100%; overflow: visible; }

/* Ceiling outcome banner */
.outcome-banner {
  padding: 12px 16px;
  border-radius: var(--radius-lg);
  margin-bottom: 14px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  border-left: 4px solid;
}
.outcome-banner.green  { background: var(--green-lt); border-color: var(--green-2); }
.outcome-banner.amber  { background: var(--amber-lt); border-color: var(--amber-2); }
.outcome-banner.orange { background: var(--orange-lt); border-color: var(--orange); }
.outcome-banner.red    { background: var(--red-lt);   border-color: var(--red-2); }
.outcome-icon { font-size: 1.4rem; flex-shrink: 0; line-height: 1; }
.outcome-text-wrap {}
.outcome-headline {
  font-family: var(--serif);
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 3px;
}
.outcome-banner.green  .outcome-headline { color: var(--green); }
.outcome-banner.amber  .outcome-headline { color: var(--amber); }
.outcome-banner.orange .outcome-headline { color: var(--orange); }
.outcome-banner.red    .outcome-headline { color: var(--red); }
.outcome-sub {
  font-size: 0.78rem;
  color: var(--ink-3);
  line-height: 1.5;
}

/* Reference table */
.ref-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
.ref-table td {
  padding: 6px 10px;
  font-size: 0.78rem;
  border-bottom: 1px solid var(--paper-3);
  vertical-align: middle;
}
.ref-table tr:last-child td { border-bottom: none; }
.ref-table .ref-label {
  font-weight: 600;
  color: var(--ink-3);
  width: 44%;
}
.ref-table .ref-val {
  font-family: var(--mono);
  font-weight: 600;
  font-size: 0.84rem;
  width: 22%;
  text-align: right;
}
.ref-table .ref-note {
  color: var(--ink-4);
  font-style: italic;
  font-size: 0.72rem;
}
.ref-val.current { color: var(--ink); }
.ref-val.bau { color: var(--ink-4); }
.ref-val.target { color: var(--blue); }
.ref-val.agro { color: var(--amber); }
.ref-val.hassink { color: var(--red-2); }

/* explanation card */
.explanation-card {
  padding: 12px 14px;
  border-radius: var(--radius);
  background: var(--paper-2);
  border: 1px solid var(--paper-3);
  margin-bottom: 14px;
}
.explanation-card p {
  font-size: 0.80rem;
  color: var(--ink-2);
  line-height: 1.6;
  margin-bottom: 6px;
}
.explanation-card p:last-child { margin-bottom: 0; }
.explanation-card strong { color: var(--ink); }

/* MAOM diagnostic strip */
.maom-diagnostic {
  padding: 10px 12px;
  border-radius: var(--radius);
  margin-bottom: 12px;
  font-size: 0.78rem;
  border-left: 3px solid;
}
.maom-diagnostic h5 {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
  text-transform: uppercase;
}
.maom-diag-ll { background: var(--red-lt); border-color: var(--red-2); color: var(--red); }
.maom-diag-lh { background: var(--amber-lt); border-color: var(--amber-2); color: var(--amber); }
.maom-diag-hl { background: var(--blue-lt); border-color: var(--blue); color: var(--blue); }
.maom-diag-hh { background: var(--green-lt); border-color: var(--green-2); color: var(--green); }

/* SOIL TEST PDF BUTTON */
.pdf-section { padding: 14px 24px 20px; }
.pdf-btn {
  width: 100%;
  padding: 12px;
  background: var(--ink);
  color: var(--paper);
  border: none;
  border-radius: var(--radius);
  font-family: var(--sans);
  font-size: 0.84rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.pdf-btn:hover { background: var(--ink-2); }
.pdf-btn:disabled { background: var(--ink-4); cursor: not-allowed; }

/* info tooltip */
.info-tip {
  display: inline-block;
  width: 14px; height: 14px;
  border-radius: 50%;
  background: var(--paper-3);
  color: var(--ink-4);
  font-size: 0.60rem;
  font-weight: 700;
  text-align: center;
  line-height: 14px;
  cursor: help;
  flex-shrink: 0;
}

/* ═══════════════════════════════════════
   PHASE 2 — FARMER INTERVIEW + BAU
═══════════════════════════════════════ */
.phase2-wrap {
  border-top: 3px solid var(--green);
  background: var(--paper);
}
.phase2-header {
  background: var(--ink);
  color: var(--paper);
  padding: 13px 28px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}
.phase2-header-left { display:flex; align-items:center; gap:10px; }
.phase2-title {
  font-family: var(--serif);
  font-size: 1.05rem;
  font-weight: 400;
  color: #d0e8d0;
}
.phase2-title span { font-weight: 600; color: #90d8a0; }
.phase2-badge {
  font-family: var(--mono);
  font-size: 0.66rem;
  background: var(--green);
  color: var(--green-lt);
  padding: 3px 9px;
  border-radius: 12px;
  letter-spacing: 0.08em;
}
.p2-climate-strip {
  font-family: var(--mono);
  font-size: 0.70rem;
  color: var(--ink-5);
}
.p2-climate-strip.loaded { color: #78c888; }
.phase2-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 500px;
}
.p2-left {
  border-right: 1px solid var(--paper-3);
  overflow-y: auto;
}
.p2-right {
  background: var(--panel);
  overflow-y: auto;
}

/* ── Target year slider ── */
.target-year-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 10px;
}
.target-year-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--ink-3);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
}
.target-year-slider {
  flex: 1;
  accent-color: var(--green);
}
.target-year-val {
  font-family: var(--mono);
  font-weight: 600;
  font-size: 0.88rem;
  color: var(--ink);
  min-width: 50px;
}

/* ── Accordion ── */
.accordion {
  border-bottom: 1px solid var(--paper-3);
}
.acc-header {
  padding: 11px 22px;
  cursor: pointer;
  user-select: none;
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--panel);
  transition: background 0.12s;
  border-bottom: 1px solid var(--paper-3);
}
.acc-header:hover { background: var(--paper-2); }
.acc-header.done { background: var(--green-lt); }
.acc-num {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 600;
  color: var(--green-2);
  width: 22px;
  flex-shrink: 0;
}
.acc-title {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--ink);
  flex: 1;
}
.acc-status {
  font-size: 0.70rem;
  color: var(--ink-4);
  font-style: italic;
  font-family: var(--mono);
}
.acc-arrow {
  color: var(--ink-4);
  font-size: 0.72rem;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.acc-header.open .acc-arrow { transform: rotate(90deg); }
.acc-body {
  display: none;
  padding: 14px 22px;
  background: var(--paper);
}
.acc-body.open { display: block; }
.acc-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--ink-3);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 7px;
}

/* ── Crop rotation builder ── */
.rotation-slots { margin-bottom: 8px; }
/* ── Crop Picker ── */
.crop-picker-wrap {
  position: relative; margin-bottom: 7px;
  padding: 7px 10px; background: white;
  border: 1px solid var(--paper-3); border-radius: var(--radius);
}
.crop-picker-row { display: flex; align-items: center; gap: 8px; }
.crop-picker-num {
  font-family: var(--mono); font-size: 0.68rem;
  font-weight: 600; color: var(--ink-5); width: 16px; flex-shrink: 0;
}
.crop-picker-selected {
  display: flex; align-items: center; gap: 6px;
  flex: 1; cursor: pointer; padding: 4px 8px;
  border: 1px solid var(--paper-3); border-radius: var(--radius);
  background: var(--paper); min-width: 0;
}
.crop-picker-selected:hover { border-color: var(--green-mid); }
.crop-picker-icon { font-size: 1.0rem; flex-shrink: 0; }
.crop-picker-name { font-size: 0.76rem; font-weight: 600; color: var(--ink); flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.crop-picker-sci { font-size: 0.60rem; color: var(--ink-5); font-style: italic; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px; }
.crop-picker-season { font-family: var(--mono); font-size: 0.58rem; color: var(--teal); flex-shrink: 0; }
.crop-picker-chevron { color: var(--ink-5); font-size: 0.62rem; flex-shrink: 0; }
/* dropdown */
.crop-picker-dropdown {
  display: none; position: absolute; left: 0; right: 0;
  top: calc(100% + 3px); z-index: 1000;
  background: white; border: 1px solid var(--paper-3);
  border-radius: var(--radius); box-shadow: 0 6px 24px rgba(0,0,0,0.15);
  max-height: 320px; overflow: hidden;
  flex-direction: column;
}
.crop-picker-dropdown.open { display: flex; }
.crop-picker-search {
  padding: 8px 10px; border-bottom: 1px solid var(--paper-3);
  flex-shrink: 0;
}
.crop-picker-search input {
  width: 100%; border: 1px solid var(--paper-3); border-radius: 4px;
  padding: 5px 8px; font-family: var(--sans); font-size: 0.78rem;
  outline: none; color: var(--ink);
}
.crop-picker-search input:focus { border-color: var(--green-2); }
.crop-picker-list { overflow-y: auto; flex: 1; }
.crop-picker-group {
  padding: 5px 10px 2px;
  font-family: var(--mono); font-size: 0.58rem; font-weight: 700;
  letter-spacing: 0.08em; color: var(--ink-5);
  background: var(--paper-2); position: sticky; top: 0;
}
.crop-picker-item {
  display: flex; align-items: center; gap: 8px;
  padding: 5px 12px; cursor: pointer;
  transition: background 0.1s;
}
.crop-picker-item:hover { background: var(--paper-2); }
.crop-picker-item.selected { background: var(--green-lt); }
.cpi-icon { font-size: 1.0rem; flex-shrink: 0; }
.cpi-name { font-size: 0.74rem; font-weight: 600; color: var(--ink); flex: 1; }
.cpi-sci { font-size: 0.60rem; color: var(--ink-5); font-style: italic; }
.cpi-season { font-family: var(--mono); font-size: 0.58rem; color: var(--teal); flex-shrink: 0; }
.cpi-cin { font-family: var(--mono); font-size: 0.60rem; color: var(--green-2); flex-shrink: 0; }
.crop-picker-empty { padding: 14px; text-align: center; font-size: 0.74rem; color: var(--ink-5); }
.crop-picker-nfix { font-size: 0.58rem; color: #78c8a8; }
/* ── Slot management row (water · tillage · residue) ── */
.slot-mgmt-row {
  display: flex; align-items: center; gap: 5px;
  padding: 5px 0 2px 24px; flex-wrap: wrap;
}
.slot-mgmt-lbl { font-size: 0.78rem; flex-shrink: 0; }
.slot-mgmt-select {
  font-family: var(--mono); font-size: 0.68rem;
  padding: 3px 6px; border: 1px solid var(--paper-3);
  border-radius: var(--radius); background: var(--paper);
  color: var(--ink); cursor: pointer; flex: 1; min-width: 90px; max-width: 160px;
}
.slot-mgmt-select:focus { border-color: var(--green-2); outline: none; }
/* ── Tree inventory slots ── */
.tree-slot {
  border: 1px solid var(--paper-3); border-radius: var(--radius);
  padding: 8px 10px; margin-bottom: 8px; background: var(--paper);
}
.tree-slot-header {
  display: flex; align-items: center; gap: 6px; margin-bottom: 6px;
}
.tree-slot-icon { font-size: 1.2rem; flex-shrink: 0; }
.tree-slot-row {
  display: flex; align-items: center; gap: 5px; flex-wrap: wrap;
  padding-left: 2px; margin-bottom: 4px;
}
.tree-slot-stats {
  display: flex; gap: 12px; flex-wrap: wrap; font-size: 0.63rem;
  font-family: var(--mono); color: var(--teal); padding-top: 3px;
  border-top: 1px solid var(--paper-3); margin-top: 4px;
}
/* ── Sprint 1: Spatial layer UI ── */
.spatial-layer-btn {
  font-family: var(--mono); font-size: 0.60rem; font-weight: 700;
  padding: 2px 8px; border: 1px solid var(--ink-4);
  border-radius: var(--radius); background: transparent;
  color: var(--ink-4); cursor: pointer; transition: all 0.15s;
}
.spatial-layer-btn:hover { border-color: var(--teal); color: var(--teal); }
.spatial-layer-btn.active {
  background: var(--teal); border-color: var(--teal);
  color: white;
}
.spatial-tooltip {
  font-family: var(--mono); font-size: 0.65rem;
  background: rgba(14,74,58,0.92); color: #c8ece0;
  border: none; border-radius: 4px; padding: 3px 7px;
}
/* Kriging uncertainty overlay colours */
#kriging-variance-strip { color: #6644aa; }
#optimal-samples-strip  { color: var(--ink-4); }
/* ── Sprint 2: Terrain panel ── */
#terrain-panel { border-top: 1px solid var(--paper-3); padding-top: 6px; }
#terrain-layer-bar { margin-bottom: 5px; }
#terrain-stats { font-size: 0.66rem; line-height: 1.5; color: var(--ink-3); }
#terrain-flags { font-size: 0.67rem; line-height: 1.7; color: var(--ink-3); }
/* ── Income pathway table ── */
.income-table {
  width: 100%; border-collapse: collapse; font-size: 0.70rem;
  font-family: var(--mono);
}
.income-table th {
  background: var(--green-dark); color: #c8ece0;
  padding: 5px 8px; text-align: left; font-size: 0.65rem;
}
.income-table td {
  padding: 4px 8px; border-bottom: 1px solid var(--paper-3);
}
.income-table tr:nth-child(even) td { background: var(--paper-2); }
.rot-slot {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 7px;
  padding: 7px 10px;
  background: white;
  border: 1px solid var(--paper-3);
  border-radius: var(--radius);
}
.rot-slot-num {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 600;
  color: var(--ink-5);
  width: 16px;
  flex-shrink: 0;
}
.rot-select {
  font-family: var(--sans);
  font-size: 0.78rem;
  padding: 4px 7px;
  border: 1px solid var(--paper-3);
  border-radius: var(--radius);
  background: white;
  color: var(--ink);
  flex: 1;
  min-width: 0;
}
.rot-residue-select {
  font-family: var(--sans);
  font-size: 0.72rem;
  padding: 4px 7px;
  border: 1px solid var(--paper-3);
  border-radius: var(--radius);
  background: white;
  color: var(--ink);
}
.rot-remove {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-5);
  font-size: 0.9rem;
  padding: 0 3px;
  line-height: 1;
}
.rot-remove:hover { color: var(--red-2); }
.rot-cin {
  font-family: var(--mono);
  font-size: 0.66rem;
  color: var(--green-2);
  white-space: nowrap;
}
.add-crop-btn {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--green);
  background: none;
  border: 1px dashed var(--green-mid);
  padding: 5px 12px;
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.15s;
}
.add-crop-btn:hover { background: var(--green-lt); }
.add-crop-btn:disabled { color: var(--ink-5); border-color: var(--paper-3); cursor: not-allowed; }

/* ── Tillage cards ── */
.tillage-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
}
.til-card {
  border: 1.5px solid var(--paper-3);
  border-radius: var(--radius);
  padding: 8px 10px;
  cursor: pointer;
  background: white;
  transition: all 0.15s;
}
.til-card:hover { border-color: var(--green-mid); }
.til-card.selected { border-color: var(--green-2); background: var(--green-lt); }
.til-name { font-size: 0.76rem; font-weight: 600; color: var(--ink); margin-bottom: 2px; }
.til-sub { font-size: 0.64rem; color: var(--ink-4); margin-bottom: 2px; }
.til-mult { font-family: var(--mono); font-size: 0.66rem; color: var(--green-2); font-weight: 600; }

/* ── Organic inputs ── */
.organic-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 0;
  border-bottom: 1px solid var(--paper-3);
}
.organic-row:last-child { border-bottom: none; }
.org-toggle {
  -webkit-appearance: none;
  appearance: none;
  width: 28px; height: 15px;
  border-radius: 8px;
  background: var(--paper-3);
  cursor: pointer;
  position: relative;
  flex-shrink: 0;
  transition: background 0.2s;
  border: none;
}
.org-toggle:checked { background: var(--green-2); }
.org-toggle::after {
  content: '';
  position: absolute;
  top: 2px; left: 2px;
  width: 11px; height: 11px;
  border-radius: 50%;
  background: white;
  transition: left 0.2s;
}
.org-toggle:checked::after { left: 15px; }
.org-name {
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--ink);
  width: 100px;
  flex-shrink: 0;
}
.org-controls {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
  opacity: 0.35;
  pointer-events: none;
  transition: opacity 0.2s;
}
.org-controls.active { opacity: 1; pointer-events: all; }
.org-rate {
  width: 62px;
  font-family: var(--mono);
  font-size: 0.78rem;
  padding: 4px 6px;
  border: 1px solid var(--paper-3);
  border-radius: var(--radius);
  background: white;
  color: var(--ink);
}
.org-unit { font-size: 0.65rem; color: var(--ink-4); white-space: nowrap; }
.org-cin { font-family: var(--mono); font-size: 0.66rem; color: var(--green-2); margin-left: auto; white-space: nowrap; }
.org-month-select {
  font-family: var(--mono); font-size: 0.63rem;
  padding: 2px 4px; border: 1px solid var(--paper-3);
  border-radius: var(--radius); background: var(--paper);
  color: var(--ink-4); cursor: pointer; margin-left: 4px;
}

/* ── Irrigation options ── */
.irrig-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 6px;
}
.irrig-card {
  border: 1.5px solid var(--paper-3);
  border-radius: var(--radius);
  padding: 7px 8px;
  cursor: pointer;
  text-align: center;
  background: white;
  transition: all 0.15s;
}
.irrig-card:hover { border-color: var(--green-mid); }
.irrig-card.selected { border-color: var(--green-2); background: var(--green-lt); }
.irrig-icon { font-size: 1.1rem; display: block; margin-bottom: 2px; }
.irrig-name { font-size: 0.72rem; font-weight: 600; color: var(--ink); display: block; }
.irrig-sub { font-size: 0.60rem; color: var(--ink-4); }

/* ── Compact pill selectors (replace card grids) ── */
.pill-row {
  display: flex; flex-wrap: wrap; gap: 5px; margin-top: 4px;
}
.opt-pill {
  padding: 5px 12px;
  border: 1.5px solid var(--paper-3);
  border-radius: 20px;
  font-family: var(--mono); font-size: 0.71rem; font-weight: 600;
  color: var(--ink-3); cursor: pointer; user-select: none;
  background: var(--paper); transition: all 0.14s;
  white-space: nowrap;
}
.opt-pill:hover { border-color: var(--green-mid); color: var(--ink); background: var(--paper-2); }
.opt-pill.selected { border-color: var(--green-2); background: var(--green-lt); color: var(--ink); }
.pill-hint { font-size: 0.62rem; color: var(--ink-5); font-style: italic; margin-top: 4px; font-family: var(--mono); }

/* ── History section ── */
.history-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 4px;
}
.hist-field label {
  display: block;
  font-size: 0.70rem;
  font-weight: 600;
  color: var(--ink-3);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.hist-select {
  width: 100%;
  font-family: var(--sans);
  font-size: 0.78rem;
  padding: 6px 8px;
  border: 1px solid var(--paper-3);
  border-radius: var(--radius);
  background: white;
  color: var(--ink);
}
.trend-opts {
  display: flex;
  gap: 6px;
}
.trend-opt {
  flex: 1;
  padding: 6px 4px;
  border: 1.5px solid var(--paper-3);
  border-radius: var(--radius);
  cursor: pointer;
  text-align: center;
  background: white;
  transition: all 0.12s;
  font-size: 0.70rem;
  font-weight: 600;
  color: var(--ink-3);
}
.trend-opt:hover { border-color: var(--green-mid); }
.trend-opt.selected.improving { border-color: var(--green-2); background: var(--green-lt); color: var(--green); }
.trend-opt.selected.stable    { border-color: var(--teal); background: var(--teal-lt); color: var(--teal); }
.trend-opt.selected.declining { border-color: var(--amber-2); background: var(--amber-lt); color: var(--amber); }

/* ── C input summary strip ── */
.cin-summary {
  margin-top: 12px;
  padding: 10px 12px;
  background: var(--green-lt);
  border-radius: var(--radius);
  border: 1px solid var(--green-mid);
}
.cin-title {
  font-size: 0.66rem;
  font-weight: 700;
  color: var(--green);
  letter-spacing: 0.10em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.cin-row {
  display: flex;
  justify-content: space-between;
  font-size: 0.74rem;
  padding: 2px 0;
}
.cin-row-label { color: var(--ink-3); }
.cin-row-val { font-family: var(--mono); font-weight: 600; color: var(--green); }

/* ── BAU chart section ── */
.bau-chart-section {
  padding: 16px 24px 12px;
}
.bau-canvas-wrap {
  position: relative;
  height: 240px;
  margin-bottom: 14px;
}
.bau-legend {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}
.bau-legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.68rem;
  color: var(--ink-3);
}
.bau-legend-dot {
  width: 14px; height: 3px;
  border-radius: 2px;
  flex-shrink: 0;
}
.bau-legend-dot.dashed {
  background: repeating-linear-gradient(90deg, currentColor 0, currentColor 4px, transparent 4px, transparent 7px);
}

/* ── Gap table ── */
.gap-table { width: 100%; margin-bottom: 12px; }
.gap-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid var(--paper-3);
  font-size: 0.78rem;
  gap: 8px;
}
.gap-row:last-child { border-bottom: none; }
.gap-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.gap-label { flex: 1; color: var(--ink-3); font-weight: 500; }
.gap-val { font-family: var(--mono); font-weight: 700; font-size: 0.84rem; text-align: right; min-width: 80px; }
.gap-note { font-size: 0.68rem; color: var(--ink-5); font-style: italic; min-width: 80px; text-align: right; }

/* ── BAU narrative ── */
.bau-narrative {
  padding: 11px 14px;
  border-radius: var(--radius);
  font-size: 0.78rem;
  color: var(--ink-2);
  line-height: 1.65;
  border-left: 3px solid;
  margin-bottom: 12px;
}
.bau-narrative.declining { background: var(--amber-lt); border-color: var(--amber-2); }
.bau-narrative.stable    { background: var(--teal-lt);  border-color: var(--teal); }
.bau-narrative.gaining   { background: var(--green-lt); border-color: var(--green-2); }

/* ── N mineralisation output ── */
.n-output {
  padding: 8px 12px;
  background: var(--blue-lt);
  border-radius: var(--radius);
  border: 1px solid #b0c0e8;
  margin-bottom: 10px;
  font-size: 0.76rem;
  color: var(--blue);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.n-val { font-family: var(--mono); font-weight: 700; font-size: 0.88rem; }
.n-note { font-size: 0.66rem; color: var(--ink-4); font-style: italic; }

.phase2-empty {
  text-align: center;
  padding: 50px 24px;
  color: var(--ink-4);
}
.phase2-empty h3 {
  font-family: var(--serif);
  font-size: 1rem;
  font-weight: 400;
  margin-bottom: 8px;
  color: var(--ink-3);
}
.phase2-empty p { font-size: 0.80rem; line-height: 1.6; }

@media (max-width: 860px) {
  .phase2-grid { grid-template-columns: 1fr; }
  .p2-left { border-right: none; border-bottom: 1px solid var(--paper-3); }
}

/* ═══════════════════════════════════════
   PHASE 3 — SOLVER ENGINE
═══════════════════════════════════════ */
.phase3-wrap { border-top: 3px solid var(--teal); background: var(--paper); }
.phase3-header {
  background: var(--teal); color: var(--paper);
  padding: 13px 28px; display: flex; align-items: center;
  justify-content: space-between; gap: 14px;
}
.phase3-title { font-family: var(--serif); font-size: 1.05rem; font-weight: 400; color: #c8ece0; }
.phase3-title span { font-weight: 600; color: #80e8c0; }
.phase3-badge { font-family: var(--mono); font-size: 0.66rem; background: var(--green); color: var(--green-lt); padding: 3px 9px; border-radius: 12px; letter-spacing: 0.08em; }
/* ── CDR Target Bar ── */
.cdr-target-bar {
  display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  padding: 14px 28px; background: linear-gradient(135deg, #0a2a1a 0%, #0c2010 100%);
  border-bottom: 1px solid rgba(120,200,140,0.2);
}
.cdr-target-left { display: flex; flex-direction: column; min-width: 160px; }
.cdr-target-label { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.12em; color: var(--ink-5); font-weight: 700; }
.cdr-target-val { font-family: var(--mono); font-size: 1.30rem; font-weight: 800; color: #78e8a8; line-height: 1.1; }
.cdr-target-note { font-family: var(--mono); font-size: 0.60rem; color: var(--ink-4); margin-top: 2px; }
.cdr-target-right { flex: 1; min-width: 200px; }
.cdr-slider {
  -webkit-appearance: none; appearance: none;
  width: 100%; height: 6px;
  background: linear-gradient(to right, var(--green-2) 0%, var(--green-2) 10%, var(--ink-3) 10%);
  border-radius: 3px; outline: none; cursor: pointer;
}
.cdr-slider::-webkit-slider-thumb {
  -webkit-appearance: none; width: 18px; height: 18px;
  border-radius: 50%; background: #78e8a8;
  cursor: pointer; border: 2px solid var(--ink);
}
.cdr-slider-labels {
  display: flex; justify-content: space-between;
  font-family: var(--mono); font-size: 0.58rem; color: var(--ink-5); margin-top: 3px;
}
.cdr-mode-hint {
  font-family: var(--mono); font-size: 0.62rem; color: var(--ink-4);
  font-style: italic; flex-basis: 100%;
}
.solver-bar { display: flex; align-items: center; gap: 14px; padding: 12px 28px; background: var(--ink-2); border-bottom: 1px solid var(--ink-3); flex-wrap: wrap; }
.solver-bar-label { font-family: var(--mono); font-size: 0.70rem; color: var(--ink-5); flex: 1; min-width: 200px; }
.run-solver-btn { padding: 9px 26px; background: var(--teal); color: white; border: none; border-radius: var(--radius); font-family: var(--sans); font-size: 0.84rem; font-weight: 700; cursor: pointer; transition: background 0.2s, transform 0.1s; letter-spacing: 0.02em; white-space: nowrap; }
.run-solver-btn:hover { background: #166040; transform: translateY(-1px); }
.run-solver-btn:disabled { background: var(--ink-3); cursor: not-allowed; transform: none; }
.solver-progress { font-family: var(--mono); font-size: 0.70rem; color: #78c8a8; min-width: 200px; }
.feasibility-toggles { display: flex; gap: 8px; flex-wrap: wrap; }
.feas-pill { display: flex; align-items: center; gap: 5px; padding: 4px 10px; border: 1px solid var(--ink-3); border-radius: 12px; cursor: pointer; font-size: 0.68rem; font-weight: 500; color: var(--ink-5); background: transparent; transition: all 0.15s; user-select: none; }
.feas-pill.excluded { background: rgba(138,26,26,0.2); border-color: var(--red-2); color: #f0a0a0; }
.sol-tabs { display: flex; background: var(--paper-2); border-bottom: 2px solid var(--paper-3); }
.sol-tab { flex: 1; padding: 12px 8px; text-align: center; cursor: pointer; font-size: 0.78rem; font-weight: 600; color: var(--ink-3); border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.15s; user-select: none; }
.sol-tab:hover { color: var(--ink); }
.sol-tab.active { color: var(--teal); border-color: var(--teal); background: var(--paper); }
.sol-tab .tab-status { display: block; font-size: 0.62rem; font-weight: 400; color: var(--ink-5); margin-top: 2px; font-family: var(--mono); }
.sol-pane { display: none; }
.sol-pane.active { display: block; }
.sol-results-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 0; min-height: 480px; }
.sol-cards-col { border-right: 1px solid var(--paper-3); padding: 16px 20px; overflow-y: auto; max-height: 660px; }
.sol-charts-col { padding: 16px 20px; background: var(--panel); overflow-y: auto; max-height: 660px; }
.solver-empty { text-align: center; padding: 56px 24px; color: var(--ink-4); }
.solver-empty h3 { font-family: var(--serif); font-size: 1rem; font-weight: 400; margin-bottom: 8px; color: var(--ink-3); }
.rank-card { border: 1.5px solid var(--paper-3); border-radius: var(--radius-lg); padding: 12px 14px; margin-bottom: 10px; background: white; cursor: pointer; transition: border-color 0.15s, box-shadow 0.15s; }
.rank-card:hover { border-color: var(--teal); box-shadow: var(--shadow-sm); }
.rank-card.selected { border-color: var(--teal); background: var(--teal-lt); box-shadow: var(--shadow-md); }
.rank-card-header { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
.rank-num { font-family: var(--mono); font-size: 0.72rem; font-weight: 700; color: var(--ink-5); width: 20px; flex-shrink: 0; }
.rank-name { font-family: var(--serif); font-size: 0.90rem; font-weight: 600; color: var(--ink); flex: 1; }
.rank-outcome-pill { font-family: var(--mono); font-size: 0.62rem; font-weight: 700; padding: 3px 8px; border-radius: 10px; white-space: nowrap; flex-shrink: 0; }
.pill-meets { background: var(--green-lt); color: var(--green); }
.pill-close  { background: var(--amber-lt); color: var(--amber); }
.pill-partial{ background: var(--orange-lt); color: var(--orange); }
.rank-delta-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 6px; }
.delta-chip { font-family: var(--mono); font-size: 0.68rem; padding: 2px 8px; border-radius: 10px; background: var(--paper-2); color: var(--ink-3); border: 1px solid var(--paper-3); }
.delta-chip.green { background: var(--green-lt); color: var(--green); border-color: var(--green-mid); }
.delta-chip.amber { background: var(--amber-lt); color: var(--amber); border-color: var(--amber-mid); }
.delta-chip.teal  { background: var(--teal-lt);  color: var(--teal);  border-color: #a0d8c8; }
.delta-chip.blue  { background: var(--blue-lt);  color: var(--blue);  border-color: #b0c8f0; }
.delta-chip.purple{ background: #f4e8f8; color: #6030a0; border-color: #d0b0e8; }
.rank-practices { font-size: 0.73rem; color: var(--ink-3); line-height: 1.55; }
.rank-practices strong { color: var(--ink); }
.rank-cobenefits { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 7px; }
/* ── Prescription card rationale ── */
/* ── MRV protocol panel ── */
.mrv-protocol-wrap {
  border: 1px solid var(--teal); border-radius: var(--radius-lg);
  overflow: hidden; margin: 0 0 12px 0;
}
.mrv-protocol-hdr {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 14px; background: var(--teal-lt); cursor: pointer;
  font-size: 0.72rem; font-weight: 700; color: var(--teal);
  font-family: var(--mono);
}
.mrv-grid { display: grid; gap: 0; }
.mrv-row {
  display: grid; grid-template-columns: 130px 1fr;
  padding: 4px 8px; border-bottom: 1px solid var(--paper-3);
  font-size: 0.69rem; line-height: 1.5;
}
.mrv-row:last-child { border-bottom: none; }
.mrv-label { font-weight: 600; color: var(--ink-4); padding-right: 8px; }
.mrv-warn { background: var(--amber-lt); }
.rank-rationale {
  font-size: 0.68rem; color: var(--ink-4); font-style: italic;
  margin-top: 5px; line-height: 1.45; padding: 4px 8px;
  background: var(--paper-2); border-radius: 4px;
  border-left: 2px solid var(--teal);
}
/* ── Permanence flags ── */
/* ── Slot compatibility warnings ── */
.slot-compat-warn {
  font-size: 0.67rem; font-family: var(--mono); font-weight: 600;
  color: #c04040; background: rgba(200,60,60,0.09);
  border-left: 3px solid #c04040;
  padding: 3px 8px; margin: 2px 0 4px 24px; border-radius: 3px;
  line-height: 1.4;
}
.perm-flag {
  font-size: 0.67rem; font-family: var(--mono); font-weight: 600;
  margin-top: 6px; padding: 4px 8px; border-radius: 4px; line-height: 1.4;
}
.perm-high { background: rgba(200,60,60,0.12); color: #c04040; border-left: 3px solid #c04040; }
.perm-med  { background: rgba(200,140,0,0.12); color: var(--amber-2); border-left: 3px solid var(--amber-2); }
.perm-low  { background: rgba(80,140,200,0.10); color: var(--blue); border-left: 3px solid var(--blue); }
/* Texture feasibility warnings */
.texture-warn { margin:4px 0; padding:5px 8px; border-radius:4px; font-size:0.66rem;
  font-family:var(--mono); line-height:1.5; font-weight:500; }
.tw-block   { background:rgba(200,60,60,0.08);  color:#c04040;         border-left:3px solid #c04040; }
.tw-caution { background:rgba(200,140,0,0.08);  color:var(--amber-2);  border-left:3px solid var(--amber-2); }
.tw-boost   { background:rgba(26,92,72,0.08);   color:var(--teal);     border-left:3px solid var(--teal); }
/* ── BAU narrative lines ── */
.bau-line { margin-bottom: 5px; font-size: 0.76rem; line-height: 1.5; }
.bau-line:last-child { margin-bottom: 0; }
/* ── PAW display ── */
.paw-label { color: var(--ink-5); font-size: 0.64rem; }
.paw-val   { font-weight: 700; padding: 1px 5px; border-radius: 3px; font-size: 0.68rem; }
.paw-high  { background: rgba(40,160,80,0.12); color: var(--green-2); }
.paw-med   { background: rgba(80,140,200,0.12); color: var(--blue); }
.paw-low   { background: rgba(200,140,0,0.12); color: var(--amber-2); }
.paw-note  { color: var(--ink-5); font-size: 0.62rem; }
.cobenefit-tag { font-size: 0.62rem; padding: 2px 7px; border-radius: 8px; background: var(--paper-2); color: var(--ink-4); border: 1px solid var(--paper-3); }
.chart-section-title { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.10em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 8px; }
.waterfall-canvas-wrap { position: relative; height: 190px; margin-bottom: 14px; }
.traj-canvas-wrap { position: relative; height: 200px; margin-bottom: 14px; }
.cal-row { display: grid; grid-template-columns: 88px repeat(12, 1fr); gap: 2px; align-items: center; margin-bottom: 3px; }
.cal-label { font-size: 0.62rem; color: var(--ink-3); font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cal-cell { height: 16px; border-radius: 2px; background: var(--paper-3); }
.cal-cell.active   { background: var(--teal); }
.cal-cell.partial  { background: var(--green-mid); }
.cal-cell.biochar  { background: #9040a0; }
.cal-cell.compost  { background: #8a6020; }
.cal-month-hdr { font-size: 0.54rem; color: var(--ink-5); text-align: center; font-family: var(--mono); }
.pareto-section { padding: 12px 20px; border-top: 1px solid var(--paper-3); background: var(--paper-2); display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.pareto-label { font-size: 0.72rem; font-weight: 600; color: var(--ink-3); white-space: nowrap; }
.pareto-slider { flex: 1; min-width: 120px; accent-color: var(--teal); }
.pareto-val { font-family: var(--mono); font-size: 0.80rem; font-weight: 700; color: var(--teal); min-width: 40px; }
.pareto-note { font-size: 0.68rem; color: var(--ink-5); font-style: italic; flex: 2; }
