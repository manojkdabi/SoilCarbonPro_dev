/* ═══════════════════════════════════════════════════════
   CLIMATE FETCH (Open-Meteo Archive)
═══════════════════════════════════════════════════════ */
async function fetchClimate(lat, lon) {
  const strip = document.getElementById('p2-climate-strip');
  strip.textContent = '⏳ Loading climate…';
  strip.className = 'p2-climate-strip';
  try {
    const now = new Date();
    const endDate = new Date(now); endDate.setDate(endDate.getDate() - 10);
    const startDate = new Date(endDate); startDate.setFullYear(startDate.getFullYear() - 5);
    const start = startDate.toISOString().slice(0,10);
    const end   = endDate.toISOString().slice(0,10);

    // ── Fetch 1: ERA5 climate (temperature + precipitation) — always reliable ──
    const urlClimate = `https://archive-api.open-meteo.com/v1/archive?latitude=${lat.toFixed(4)}&longitude=${lon.toFixed(4)}&start_date=${start}&end_date=${end}&daily=temperature_2m_mean,precipitation_sum,shortwave_radiation_sum&timezone=auto`;
    const resp = await fetch(urlClimate);
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    const data = await resp.json();

    const tSum = new Array(12).fill(0), pSum = new Array(12).fill(0), cnt = new Array(12).fill(0);
    const rsSum = new Array(12).fill(0), rsCnt = new Array(12).fill(0);
    const stSum = new Array(12).fill(0), smSum = new Array(12).fill(0);
    const stCnt = new Array(12).fill(0), smCnt = new Array(12).fill(0);
    // Item 9: per-year accumulation for ensemble BAU
    // yearlyT[yr][mo] = monthly mean temp for that calendar year
    const yearMap = {};   // keyed by year string
    data.daily.time.forEach((d, i) => {
      const mo = parseInt(d.slice(5,7)) - 1;
      const yr = d.slice(0,4);
      const t = data.daily.temperature_2m_mean[i];
      const p = data.daily.precipitation_sum[i];
      const rs = data.daily.shortwave_radiation_sum?.[i];
      if (t !== null && p !== null) {
        tSum[mo] += t; pSum[mo] += p; cnt[mo]++;
        if (rs !== null && rs !== undefined) { rsSum[mo] += rs; rsCnt[mo]++; }
        if (!yearMap[yr]) yearMap[yr] = {
          tS: new Array(12).fill(0), pS: new Array(12).fill(0), cnt: new Array(12).fill(0)
        };
        yearMap[yr].tS[mo] += t; yearMap[yr].pS[mo] += p; yearMap[yr].cnt[mo]++;
      }
    });

    // ── Fetch 2: ERA5-Land soil variables — dedicated endpoint ──
    // ERA5-Land endpoint: /v1/era5-land (NOT /v1/archive)
    // Variables: soil_temperature_0_to_7cm, soil_moisture_0_to_1cm
    // ERA5-Land soil vars via /v1/archive (no model param needed)
    // Daily aggregated variables require _mean suffix
    try {
      const soilEnd   = new Date(); soilEnd.setMonth(soilEnd.getMonth() - 3);
      const soilStart = new Date(soilEnd); soilStart.setFullYear(soilStart.getFullYear() - 3);
      const ss = soilStart.toISOString().slice(0,10);
      const se = soilEnd.toISOString().slice(0,10);
      // Correct daily variable names: _mean suffix required; 0_to_7cm is the shallowest daily layer
      const urlSoil = `https://archive-api.open-meteo.com/v1/archive?latitude=${lat.toFixed(4)}&longitude=${lon.toFixed(4)}&start_date=${ss}&end_date=${se}&daily=soil_temperature_0_to_7cm_mean,soil_moisture_0_to_7cm_mean&timezone=auto`;
      const respSoil = await fetch(urlSoil, { signal: AbortSignal.timeout(12000) });
      if (respSoil.ok) {
        const soilData = await respSoil.json();
        (soilData.daily?.time || []).forEach((d, i) => {
          const mo = parseInt(d.slice(5,7)) - 1;
          const st = soilData.daily.soil_temperature_0_to_7cm_mean?.[i];
          const sm = soilData.daily.soil_moisture_0_to_7cm_mean?.[i];
          if (st !== null && st !== undefined) { stSum[mo] += st; stCnt[mo]++; }
          if (sm !== null && sm !== undefined && sm >= 0) { smSum[mo] += sm; smCnt[mo]++; }
        });
      }
    } catch(soilErr) { /* soil variables unavailable — model falls back to precip-based fW */ }
    const monthly = tSum.map((t, i) => ({
      temp:       cnt[i]  ? t / cnt[i]  : 22,
      precip:     cnt[i]  ? (pSum[i] / cnt[i]) * 30.44 : 50,
      soil_temp:  stCnt[i] ? stSum[i] / stCnt[i] : null,
      soil_moist: smCnt[i] ? smSum[i] / smCnt[i] : null,
      // Rs = mean daily shortwave × mean days/month → MJ/m²/month
      // Used by Sprint 5A: PAR = 0.48 × Rs (Meek et al. 1984)
      rs:         rsCnt[i] ? (rsSum[i] / rsCnt[i]) * 30.44 : null,
    }));
    const mat = monthly.reduce((s,m) => s + m.temp, 0) / 12;
    const map = monthly.reduce((s,m) => s + m.precip, 0);
    // Store soil temp/moisture in satData
    ST.satData.ndviMonthly      = ST.satData.ndviMonthly  || null;
    ST.satData.satelliteCin     = ST.satData.satelliteCin || null;
    ST.satData.annualNPP        = ST.satData.annualNPP    || null;
    ST.satData.soilTempMonthly  = monthly.map(m => m.soil_temp);
    ST.satData.soilMoistMonthly = monthly.map(m => m.soil_moist);
    const hasSoilT = ST.satData.soilTempMonthly.some(v => v !== null);
    const hasSoilM = ST.satData.soilMoistMonthly.some(v => v !== null);
    // Item 9: build per-year monthly arrays (up to 5 years)
    const sortedYears = Object.keys(yearMap).sort().slice(-5);
    const perYear = sortedYears.map(yr => {
      const yd = yearMap[yr];
      return yd.tS.map((t, mo) => ({
        temp:       yd.cnt[mo] ? t / yd.cnt[mo] : monthly[mo].temp,
        precip:     yd.cnt[mo] ? (yd.pS[mo] / yd.cnt[mo]) * 30.44 : monthly[mo].precip,
        soil_temp:  monthly[mo].soil_temp,   // use mean soil vars (not split by year)
        soil_moist: monthly[mo].soil_moist,
      }));
    });
    ST.climate = { monthly, perYear, mat, map };

    const extras = [hasSoilT ? '🌡 T_soil' : '', hasSoilM ? '💧 SM' : ''].filter(Boolean).join(' · ');
    strip.textContent = `MAT ${mat.toFixed(1)}°C · MAP ${Math.round(map)} mm/yr · Open-Meteo 5-yr${extras ? ' · ' + extras : ''}`;
    strip.className = 'p2-climate-strip loaded';
    applyAridityDefaults(ST.climate);
    autoPickDriestMonth(monthly);
    triggerBAU();
  } catch(e) {
    strip.textContent = `Climate fetch failed — using MAT 22°C / MAP 800 mm/yr defaults`;
    strip.className = 'p2-climate-strip';
    // Use default India average climate
    const mat = 22, map = 800;
    const monthly = [
      {temp:17,precip:18},{temp:20,precip:14},{temp:24,precip:12},{temp:29,precip:8},
      {temp:32,precip:18},{temp:31,precip:90},{temp:28,precip:180},{temp:27,precip:180},
      {temp:27,precip:120},{temp:25,precip:60},{temp:21,precip:18},{temp:17,precip:8}
    ];
    ST.climate = { monthly, mat, map };
    applyAridityDefaults(ST.climate);
    autoPickDriestMonth(monthly);
    triggerBAU();
  }
}

