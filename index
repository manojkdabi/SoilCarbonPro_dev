function updateTreeCDRSummary() {
  const el = document.getElementById('tree-cdr-summary');
  if (!el || !ST.farm.trees.length) { if(el) el.style.display='none'; return; }
  const areaf = ST.farm.treeAreaFraction ?? 1.0;
  const totalAGB = ST.farm.trees.reduce((s,t) =>
    s + treeAGBIncrement(t.id, (t.density||100)*areaf, t.age_class||'mid') * (1 + (TREE_SPECIES[t.id]?.root_shoot||0.26)), 0);
  const totalLit = ST.farm.trees.reduce((s,t) =>
    s + treeLitterCin(t.id, (t.density||100)*areaf), 0);
  const totalCO2e = totalAGB * 0.47 * (44/12);
  el.style.display = 'block';
  el.innerHTML = `🌳 Trees (${(areaf*100).toFixed(0)}% area): ` +
    `AGB+BGB ≈ <strong>${totalCO2e.toFixed(2)} t CO₂e/ha/yr</strong> · ` +
    `Litter to soil: <strong>${totalLit.toFixed(2)} t C/ha/yr</strong>`;
}

function updateTreeCompatPanel() {
  const panel = document.getElementById('tree-compat-panel');
  const rows  = document.getElementById('tree-compat-rows');
  if (!panel || !rows) return;
  if (!ST.farm.crops.length) { panel.style.display='none'; return; }

  const suggestions = [];
  ST.farm.crops.forEach(slot => {
    const crop = CROPS[slot.id];
    if (!crop) return;
    const shade = CROP_SHADE_TOLERANCE[slot.id] || 'partial';
    const cropName = crop.name.split('(')[0].trim();

    // Find compatible trees not already in inventory
    const existingIds = new Set(ST.farm.trees.map(t=>t.id));
    const compatible = Object.entries(TREE_SPECIES)
      .filter(([tid, tsp]) => {
        if (existingIds.has(tid)) return false;
        if (!tsp.compatible_crops.includes(slot.id)) return false;
        // Check shade tolerance
        if (shade === 'sensitive' && tsp.shade_cast > 20) return false;
        return true;
      })
      .slice(0, 3);

    if (compatible.length) {
      suggestions.push(`<div style="margin-bottom:5px">
        <strong>${cropName}</strong>
        <span style="color:var(--ink-5)">(shade: ${shade})</span>
        → ${compatible.map(([tid,tsp])=>
          `<span style="color:var(--teal);cursor:pointer" onclick="quickAddTree('${tid}')"
            title="Click to add · ${tsp.system}">${tsp.icon} ${tsp.name.split('(')[0].trim()}</span>`
        ).join(', ')}
      </div>`);
    }
  });

  if (suggestions.length) {
    panel.style.display = 'block';
    rows.innerHTML = suggestions.join('') +
      '<div style="font-size:0.60rem;color:var(--ink-5);margin-top:4px">Click species name to add to inventory</div>';
  } else {
    panel.style.display = 'none';
  }
}

