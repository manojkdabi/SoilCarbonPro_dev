/* ── Income pathway table (Group 8) ──────────────────────────────── */
function renderIncomePathway() {
  const emptyEl  = document.getElementById('empty-income');
  const resultsEl= document.getElementById('results-income');
  const tableWrap= document.getElementById('income-table-wrap');
  if (!emptyEl || !resultsEl || !tableWrap) return;

  const trees = ST.farm.trees || [];
  const hasTrees = trees.length > 0;
  const hasSolver = ST.solverResults.regen.length > 0 || ST.solverResults.biochar.length > 0;

  if (!hasSolver) { emptyEl.style.display='block'; resultsEl.style.display='none'; return; }
  emptyEl.style.display = 'none'; resultsEl.style.display = 'block';

  const areaf  = ST.farm.treeAreaFraction ?? 1.0;
  const years  = ST.targetYear;
  const checkYears = [1,3,5,10,Math.min(years,20)].filter((v,i,a)=>a.indexOf(v)===i&&v<=years);
  const cstock = ST.derived.cstock || 0;
  const CDR_PRICE_INR = 2000; // ₹/t CO₂e — conservative VCS market mid (≈$24)

  // Best regen bundle SOC increment
  const bestRegen = ST.solverResults.regen[0];
  const bestBC    = ST.solverResults.biochar[0];

  // Tree annual income per species
  const treeIncomeYr = (yr) => trees.reduce((s, t) => {
    const sp = TREE_SPECIES[t.id];
    if (!sp) return s;
    const ageFactor = yr < 3 ? 0.2 : yr < 8 ? 0.6 : 1.0;
    return s + sp.product.yield_per_tree_yr * sp.product.price_inr
             * (t.density||100) * areaf * ageFactor / 1000; // ₹ thousand/ha
  }, 0);

  // Total CDR at year (SOC Δ + AGB Δ) × CDR price
  const cdpAtYear = (yr) => {
    const socDelta = bestRegen ? Math.max(0, (bestRegen.traj[Math.min(yr,years)]?.soc||cstock) - cstock) : 0;
    const treeTraj = calcTotalTreeCDR(yr);
    const agbCO2e  = treeTraj ? treeTraj[yr]?.total_c || 0 : 0;
    return (socDelta * (44/12) + agbCO2e) * CDR_PRICE_INR / 1000; // ₹ thousand/ha
  };

  const rows = checkYears.map(yr => {
    const treeInc = treeIncomeYr(yr);
    const cdp     = cdpAtYear(yr);
    const canopy  = trees.length
      ? trees.reduce((s,t)=>s+treeCanopyCover(t.id,(t.density||100)*areaf,t.age_class||'mid'),0)
      : 0;
    const socDelta = bestRegen ? (bestRegen.traj[Math.min(yr,years)]?.soc||cstock)-cstock : 0;
    const treeCO2e = (calcTotalTreeCDR(yr)?.[yr]?.total_c || 0);
    const total    = treeInc + cdp;
    return `<tr>
      <td><strong>Yr ${yr}</strong></td>
      <td>${socDelta.toFixed(2)} t C/ha</td>
      <td>${treeCO2e.toFixed(2)} t CO₂e</td>
      <td>₹ ${cdp.toFixed(1)}k/ha</td>
      <td>${hasTrees ? '₹ '+treeInc.toFixed(1)+'k/ha' : '—'}</td>
      <td><strong style="color:var(--green-2)">₹ ${total.toFixed(1)}k/ha</strong></td>
      <td>${canopy.toFixed(0)}%</td>
    </tr>`;
  }).join('');

  tableWrap.innerHTML = `
    <div style="font-size:0.70rem;color:var(--ink-4);margin-bottom:8px">
      Carbon price assumption: ₹${CDR_PRICE_INR}/t CO₂e · Tree income at conservative yields ·
      ${areaf<1 ? (areaf*100).toFixed(0)+'% of field under trees' : 'Full field'}
    </div>
    <table class="income-table">
      <thead><tr>
        <th>Year</th><th>SOC Δ</th><th>Tree CDR</th>
        <th>Carbon revenue</th><th>Tree income</th>
        <th>Total upside</th><th>Canopy %</th>
      </tr></thead>
      <tbody>${rows}</tbody>
    </table>
    <div style="font-size:0.62rem;color:var(--ink-5);margin-top:6px">
      ⚠ Projections only. Carbon revenue depends on project registration (VERRA/Gold Standard).
      Tree income assumes conservative yields — actual may vary by ±30–50%.
    </div>`;

  document.getElementById('tab-income-status').textContent =
    hasTrees ? `₹${cdpAtYear(5).toFixed(0)}k/ha yr5` : 'No trees';
}

