/* ═══════════════════════════════════════════════════════
   CDR TARGET SLIDER (Phase 3)
   Operates in tCO₂e/ha/yr — converted to t C/ha for solver gap
   1 t C = 3.664 t CO₂e
═══════════════════════════════════════════════════════ */
function onCDRSlider(val) {
  const v = parseFloat(val);
  ST.targetCDR = v;  // tCO₂e/ha/yr

  const display = document.getElementById('cdr-target-display');
  if (display) display.textContent = `${v.toFixed(1)} tCO₂e/ha/yr`;

  // Update slider gradient fill
  const slider = document.getElementById('cdr-target-slider');
  if (slider) {
    const pct = ((v - 0.1) / (5.0 - 0.1) * 100).toFixed(1);
    slider.style.background = `linear-gradient(to right, var(--green-2) 0%, var(--green-2) ${pct}%, var(--ink-3) ${pct}%)`;
  }

  updateCDRTargetNote();
}

function updateCDRTargetNote() {
  const note = document.getElementById('cdr-target-note');
  if (!note) return;
  const cdr = ST.targetCDR || 0.5;
  const cPerYr = (cdr / 3.664).toFixed(2);  // t C/ha/yr sequestration needed

  if (ST.bau?.endpoint && ST.targetTha) {
    const gap = ST.targetTha - ST.bau.endpoint;
    const yrs = ST.targetYear || 20;
    const annualNeeded = gap > 0 ? (gap / yrs).toFixed(2) : '0.00';
    const cdrEquiv = (gap / yrs * 3.664).toFixed(2);
    note.textContent = `Stock gap: ${gap.toFixed(1)} t C/ha over ${yrs}yr · needs ${annualNeeded} t C/ha/yr · ≈${cdrEquiv} tCO₂e/ha/yr`;
  } else if (ST.derived?.cstock) {
    note.textContent = `${cPerYr} t C/ha/yr sequestration · Set Phase 1 target SOC% to compute gap`;
  } else {
    note.textContent = 'Complete Phases 1 & 2 to see gap calculation';
  }
}

