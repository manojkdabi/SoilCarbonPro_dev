    const harvOpts = MO_NAMES.map((m,i) =>
      `<option value="${i}" ${i===curHarv?'selected':''}>${m}</option>`).join('');
    const growMos  = calendarToMonths(curSow, curHarv);
    const growMonthsLabel = `${MO_NAMES[curSow]}–${MO_NAMES[curHarv]} (${growMos.length}mo)`;

    // H3: Irrigation × crop incompatibility check
