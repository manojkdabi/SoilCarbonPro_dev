/* ═══════════════════════════════════════════════════════
   AUTOMATION 4 — N₀ MINERALISATION POTENTIAL
   Ref: Stanford & Smith 1972 (SSSA Proc 36:465-472)
   N₀ = k × TN_stock_kg × exp(β × (MAT − T_ref))
   k = 0.17 (tropical incubation adjustment, Ellert & Bettany 1995)
   β = 0.115 °C⁻¹ (Q10 ≈ 3.2 for mineralisation, Stanford & Smith 1972)
   T_ref = 20°C (standard incubation temp)
   Clay correction: × (1 − 0.0062 × clay%) (Hassink 1992, Biol Fertil Soils)
   Units: kg N/ha/yr available (potential, pre-loss)
═══════════════════════════════════════════════════════ */
function calcN0Stanford() {
  const tn1  = paramVal('tn1');   // % (g N / 100 g soil)
  const bd1  = paramVal('bd1') || 1.3;
  const clay1= paramVal('clay1');
  const mat  = ST.climate?.mat;
  if (tn1 === null || mat === null) return null;

  // Convert TN% → kg N/ha in 0–15 cm
  const tn_stock = tn1 / 100 * bd1 * 15 * 10000 * 1000; // kg N/ha (depth 15cm, 10000 m²/ha, 1000 kg/t × ×0.001)
  // Simplified: tn1 (%) × bd (g/cm³) × 15 cm × 1e6 cm²/ha × 1e-3 (g→kg) × 1e-2 (% conversion)
  const tn_kg_ha = tn1 * bd1 * 150;  // = tn1/100 * bd1 * 1e4 * 15 / 10  (t/ha × 1000 kg/t)

  const k    = 0.17;  // fraction mineralised/yr at 20°C (Stanford & Smith 1972 Table 4 mean)
  const beta = 0.115; // °C⁻¹
  const clay_corr = clay1 !== null ? Math.max(0.3, 1 - 0.0062 * clay1) : 0.85;
  const n0 = k * tn_kg_ha * Math.exp(beta * (mat - 20)) * clay_corr;
  return Math.round(n0);
}

/* ═══════════════════════════════════════════════════════
   AUTOMATION 5 — REFERENCE SOC TARGET SUGGESTION
   Ref: Srinivasarao et al. 2014 (Curr Sci 107:1739-1747)
       Bhattacharyya et al. 2008 (Geoderma 146:452-464)
       NBSS&LUP baseline SOC by soil order + aridity zone
   Returns {low, mid, high} in SOC% and rationale string
═══════════════════════════════════════════════════════ */
/* ═══════════════════════════════════════════════════════
   ITEM B: REGIONAL SOC BASELINE COMPARISON
   Uses existing NBSSLUP + Srinivasarao 2014 baselines from
   suggestSOCTarget() to contextualise current SOC against
   the regional mean for this soil type and aridity zone.
   Required for additionality demonstration in carbon projects.
   Ref: Srinivasarao et al. 2014 (Curr Sci 107:1739-1747);
        NBSSLUP soil series SOC data.
═══════════════════════════════════════════════════════ */
function getRegionalBaseline() {
  const soc1 = paramVal('soc1');
  if (soc1 === null) return null;
  const s = suggestSOCTarget();
  if (!s) return null;
  const cur_mean_pct = s.cur;        // regional current mean SOC%
  const good_pct     = s.good;       // good-practice SOC%
  const cur_mean_gkg = cur_mean_pct * 10;
  const diff_pct = ((soc1/10 - cur_mean_pct) / cur_mean_pct) * 100;
  let status, note;
  if (soc1/10 < cur_mean_pct * 0.70) {
    status = 'depleted';
    note   = `${Math.abs(diff_pct).toFixed(0)}% below regional mean — high sequestration potential, strong additionality`;
  } else if (soc1/10 < cur_mean_pct * 1.10) {
    status = 'average';
    note   = `Near regional mean (±10%) — moderate additionality; document baseline clearly`;
  } else {
    status = 'above';
    note   = `${diff_pct.toFixed(0)}% above regional mean — additionality may be challenged; justify practices`;
  }
  return { cur_mean_pct, good_pct, cur_mean_gkg, diff_pct, status, note };
}

function updateRegionalBaselineDisplay() {
  const el = document.getElementById('regional-baseline-display');
  if (!el) return;
  const b = getRegionalBaseline();
  if (!b) { el.style.display = 'none'; return; }
  const statusColour = b.status === 'depleted' ? 'var(--green-2)'
                     : b.status === 'above'    ? 'var(--amber-2)'
                     : 'var(--teal)';
  el.style.display = 'block';
  el.innerHTML = `<span style="font-size:0.64rem;font-family:var(--mono);color:var(--ink-5)">
    📊 Regional baseline (${ST.mineralogy}/${ST._aridity?.aridClass||'—'}):
    mean <strong>${(b.cur_mean_pct*10).toFixed(1)} g/kg</strong> ·
    good practice <strong>${(b.good_pct*10).toFixed(1)} g/kg</strong> ·
    <span style="color:${statusColour}">${b.note}</span>
  </span>`;
}

function suggestSOCTarget() {
  const soc1 = paramVal('soc1');
  const min  = ST.mineralogy || 'alluvial';
  const ai   = ST._aridity?.ai ?? 0.5;
  const aridClass = ST._aridity?.aridClass || 'Semi-arid';

  // NBSS&LUP + Srinivasarao 2014 SOC baselines (g/kg = × 10 for %)
  // Table: {mineralogy} × {aridity} → [current typical, good practice, potential]
  // Values in SOC % (0–15 cm)
  const targets = {
    //                  [current_mean, good_practice, high_potential]   — SOC%
    aridisol:  { hyper: [0.12, 0.25, 0.40], arid: [0.18, 0.35, 0.55], semi: [0.22, 0.45, 0.65] },
    vertisol:  { semi:  [0.45, 0.80, 1.20], subh: [0.60, 1.00, 1.50], humi: [0.75, 1.20, 1.80] },
    alfisol:   { semi:  [0.35, 0.65, 0.95], subh: [0.45, 0.80, 1.20], humi: [0.55, 0.90, 1.35] },
    paddy:     { semi:  [0.60, 1.00, 1.50], subh: [0.80, 1.30, 1.80], humi: [1.00, 1.60, 2.20] },
    alluvial:  { semi:  [0.40, 0.75, 1.10], subh: [0.55, 0.90, 1.30], humi: [0.65, 1.05, 1.50] },
  };

  const minKey = targets[min] ? min : 'alluvial';
  const zoneKey = ai < 0.20 ? 'hyper' : ai < 0.50 ? (minKey === 'aridisol' ? 'arid' : 'semi')
                             : ai < 0.65 ? (minKey === 'aridisol' ? 'semi' : 'subh') : 'humi';

  const row = targets[minKey][zoneKey] || targets[minKey]['semi'] || [0.40, 0.75, 1.10];
  const [cur, good, high] = row;

  if (soc1 === null) return null;
  const soc1_pct = soc1 / 10;  // g/kg → %

  // Suggest: if current is below good-practice, suggest good-practice; if near, suggest high
  const suggestedPct = soc1_pct < good * 0.9 ? good : high;
  const rationale    = soc1_pct < good * 0.9
    ? `Below good-practice baseline for ${aridClass} ${minKey} soils`
    : `Near good-practice level — high-potential target shown`;

  return { suggestedPct, good, high, cur, rationale, minKey, aridClass };
}

