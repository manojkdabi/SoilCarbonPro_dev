function updateSoilSummaryStrip() {
  const get = id => parseFloat(document.getElementById(id)?.value) || null;
  const badge = id => document.getElementById('badge-' + id)?.textContent || '🔴';

  const fields = [
    { key:'soc',  id:'soc1',  unit:'g/kg' },
    { key:'clay', id:'clay1', unit:'%'    },
    { key:'ph',   id:'ph1',   unit:''     },
    { key:'bd',   id:'bd1',   unit:'g/cm³'},
    { key:'sand', id:'sand1', unit:'%'    },
    { key:'tn',   id:'tn1',   unit:'%'    },
  ];

  let filled = 0, total = fields.length;
  fields.forEach(f => {
    const v = get(f.id);
    const el = document.getElementById('sss-' + f.key + '-val');
    const be = document.getElementById('sss-' + f.key + '-badge');
    if (el) el.textContent = v !== null ? v.toFixed(f.key === 'bd' ? 2 : f.key === 'tn' ? 3 : 1) : '—';
    if (be) be.textContent = badge(f.id);
    if (v !== null) filled++;
  });

  // Data quality line
  const dq = document.getElementById('dq-line');
  if (dq) {
    if (filled === 0) {
      dq.textContent = 'No soil data — drop pin and click Fetch SoilGrids';
      dq.className = 'dq-line';
    } else {
      const labCount = fields.filter(f => badge(f.id) === '🟢').length;
      const sgCount  = fields.filter(f => badge(f.id) === '🟡').length;
      const ptCount  = fields.filter(f => badge(f.id) === '🔵').length;
      let parts = [];
      if (sgCount)  parts.push(`${sgCount} SoilGrids`);
      if (ptCount)  parts.push(`${ptCount} pedotransfer`);
      if (labCount) parts.push(`${labCount} lab-verified`);
      dq.textContent = parts.join(' · ') + ` · ${filled}/${total} parameters loaded`;
      dq.className = labCount > 0 ? 'dq-line ok' : 'dq-line warn';
    }
  }

  updateAuditTable();
}

