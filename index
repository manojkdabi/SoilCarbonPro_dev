/* ═══════════════════════════════════════════════════════
   CARBON CONTRIBUTION: BIOCHAR
═══════════════════════════════════════════════════════ */
/* ── Biochar clay-texture effectiveness multiplier ───────────────
   High clay soils show reduced net CDR from biochar due to
   MAOM surface competition and priming of native SOC.
   Ref: Fang et al. 2014 GCB Bioenergy; Singh et al. 2012 SBB;
        Zimmerman et al. 2011 SBB 43:1295-1309
   clay < 25%:  ×1.00 (full benefit)
   clay 25–45%: ×1.00 declining linearly to ×0.85
   clay > 45%:  ×0.70 (high priming risk)
────────────────────────────────────────────────────────────────── */
function bcClayEff(clay_pct) {
  if (clay_pct === null || clay_pct === undefined) return 1.0;
  if (clay_pct < 25)  return 1.00;
  if (clay_pct <= 45) return 1.00 - 0.15 * (clay_pct - 25) / 20;  // 1.00→0.85
  return 0.70;  // >45%
}

function bcStableC(dose, feedstock_key, pyro_level, years, clay_pct) {
  const fs = BIOCHAR_FEEDSTOCKS[feedstock_key];
  if (!fs) return 0;
  const stab = fs.pyro_stab[pyro_level];
  const calc_disc = (ST.mineralogy === 'aridisol') ? BC_CALCAREOUS_DISC : 1.0;
  // Item 17: clay-texture effectiveness multiplier
  const clay_eff = bcClayEff(clay_pct ?? paramVal('clay1'));
  const stable_init = dose * fs.c_frac * stab * BC_TROPICAL_DISC * calc_disc * clay_eff;
  return stable_init * Math.pow(1 - BC_ANNUAL_DECAY, years);
}

function bcCO2e(dose, feedstock_key, pyro_level, clay_pct) {
  const fs = BIOCHAR_FEEDSTOCKS[feedstock_key];
  const calc_disc = (ST.mineralogy === 'aridisol') ? BC_CALCAREOUS_DISC : 1.0;
  // Item 17: clay-texture effectiveness multiplier
  const clay_eff = bcClayEff(clay_pct ?? paramVal('clay1'));
  return dose * fs.c_frac * fs.pyro_stab[pyro_level] * BC_TROPICAL_DISC * calc_disc * clay_eff * (44/12);
}

/* ═══════════════════════════════════════════════════════
   MAIN SOLVER ENTRY
═══════════════════════════════════════════════════════ */
async function runSolver() {
  const cstock = ST.derived.cstock;
  const targetTha = ST.targetTha;
  const bau = ST.bau;

  if (!cstock || !targetTha || !bau || !ST.climate) {
    document.getElementById('solver-progress').textContent =
      '⚠ Need: SOC + target + climate + at least one crop in Phase 2';
    return;
  }

  const btn = document.getElementById('run-solver-btn');
  btn.disabled = true;
  document.getElementById('solver-progress').textContent = '⏳ Running regen search…';

  const clay1 = paramVal('clay1') || 25;
  const ph1   = paramVal('ph1')   || 7.0;
  const years = ST.targetYear;
  const bau_end = bau.endpoint;
  const gap = targetTha - bau_end;

  // Base C input from current farm practice
  const base_cin = bau.cin_annual;

  await sleep(20);
  const regenResults = solveRegen(cstock, clay1, ph1, base_cin, years, targetTha, gap);
  document.getElementById('solver-progress').textContent = `⏳ Biochar search… (${regenResults.length} regen found)`;
  await sleep(20);

  const biocharResults = ST.feas.biochar ? [] : solveBiochar(cstock, clay1, ph1, base_cin, years, targetTha, gap);
  document.getElementById('solver-progress').textContent = '⏳ Combined optimiser…';
  await sleep(20);

  const combinedResults = solveCombined(cstock, clay1, ph1, base_cin, years, targetTha, gap, regenResults, biocharResults);
  await sleep(20);

  ST.solverResults = { regen: regenResults, biochar: biocharResults, combined: combinedResults };

  renderSolverResults('regen');
  renderSolverResults('biochar');
  renderSolverResults('combined');
  renderIncomePathway();
  updateTabStatuses();

  document.getElementById('pareto-section').style.display = 'flex';
  document.getElementById('p3-pdf-section').style.display = 'flex';
  const totalResults = regenResults.length + biocharResults.length + combinedResults.length;
  document.getElementById('p3-header-status').textContent = totalResults > 0
    ? `✓ ${regenResults.length} regen · ${biocharResults.length} biochar · ${combinedResults.length} combined bundles`
    : '⚠ No feasible pathways found — try adjusting the target or timeline';
  // Item C: show MRV protocol panel
  const mrvWrap = document.getElementById('mrv-protocol-wrap');
  if (mrvWrap) mrvWrap.style.display = 'block';

  btn.disabled = false;
  document.getElementById('solver-progress').textContent = `✓ Solver complete`;
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

/* ═══════════════════════════════════════════════════════
   REGEN GRID SEARCH
═══════════════════════════════════════════════════════ */
/* ── Build modified slot schedule for solver intervention ────────
   Clones the BAU slot_schedule and applies the intervention
   tillage multiplier to all active months. This ensures the
   solver's trajectory uses the same seasonal Cin distribution and
   irrigation profile as BAU, but with the intervention tillage.
   Called from solveRegen and buildBiocharTraj. ──────────────── */
function buildInterventionSchedule(base_schedule, new_tillage_key) {
  if (!base_schedule) return null;
  const till_mult = TILLAGE[new_tillage_key]?.mult ?? 0.92;
  return base_schedule.map(mo => ({
    ...mo,
    tillage_mult: mo.active ? till_mult : mo.tillage_mult,
  }));
}

function solveRegen(cstock, clay, pH, base_cin, years, target, gap) {
  const results = [];

  // Additionality: derive current tillage practices from slots
  // Only recommend practices NOT already in use across all slots
  const currentTillageSet = new Set(
    ST.farm.crops.map(s => s.tillage || 'shallow')
  );
  const currentIrrigSet = new Set(
    ST.farm.crops.map(s => s.irrigation || 'rainfed')
  );

  // Texture feasibility: get blocked practices
  const texFeas = ST.derived?.textureFeas || [];
  const texBlocked = new Set(texFeas.filter(f=>f.severity==='block').map(f=>f.practice));

  const tillageOpts = Object.keys(TILLAGE).filter(t => {
    if (ST.feas.no_till && t === 'no_till') return false;
    // Texture block: raised bed on sand, etc.
    if (texBlocked.has(t)) return false;
    // ADDITIONALITY: only include if it represents an improvement vs current
    if (currentTillageSet.has(t) && currentTillageSet.size === 1) return false;
    return true;
  });
  // ITEM 10: Cover crop only available if fallow months exist.
  // Compute fallow months from current slot schedule.
  const _schedule = buildSlotMonthSchedule(ST.farm.crops);
  const _fallowMonths = _schedule.filter(m => !m.active).length;
  const _texCCBlock = texBlocked.has('cover_crop');
  const _noCoverCropReason = _fallowMonths === 0
    ? 'no-fallow'
    : ST.feas.cover_crop ? 'excluded'
    : _texCCBlock ? 'texture-block'
    : null;
  const ccOpts = (_noCoverCropReason !== null)
    ? ['none']
    : Object.keys(COVER_CROP_CIN);
  const compostOpts = ST.feas.compost_heavy
    ? ['none','low','medium']
    : Object.keys(COMPOST_LEVELS);

  tillageOpts.forEach(tillage => {
    ccOpts.forEach(cc => {
      compostOpts.forEach(compost_level => {
        // Build modified C input with intervention schedule
        const cin = buildRegenCin(base_cin, tillage, cc, compost_level);
        // Intervention schedule: BAU seasonal profile + new tillage multiplier
        const intv_schedule = buildInterventionSchedule(base_cin.slot_schedule, tillage);
        const cin_intv = { ...cin, slot_schedule: intv_schedule };
        const traj = runRothCWithKmult(cstock, clay, pH, cin_intv, TILLAGE[tillage].mult,
          ST.climate.monthly, years, 1.0);
        const endpoint = traj[years].soc;
        const delta_vs_bau = endpoint - (ST.bau?.endpoint || cstock);
        const delta_vs_current = endpoint - cstock;
        const meets = endpoint >= target * 0.99;
        const close = endpoint >= target * 0.92;

        // Co-benefits
        const cobenefits = buildCobenefits(tillage, cc, compost_level, null, null);
        const effort = calcEffort(tillage, cc, compost_level, null, null);
        const n_min = estimateNMinFromCin(cin, clay, pH);

        results.push({
          tillage, cc, compost_level,
          cin, endpoint, delta_vs_bau, delta_vs_current,
          meets, close, traj, cobenefits, effort, n_min,
          type: 'regen',
        });
      });
    });
  });

  // Sort: meets target first, then by delta_vs_bau desc, then effort asc
  results.sort((a, b) => {
    if (a.meets !== b.meets) return b.meets - a.meets;
    if (a.close !== b.close) return b.close - a.close;
    if (Math.abs(a.delta_vs_bau - b.delta_vs_bau) > 0.1) return b.delta_vs_bau - a.delta_vs_bau;
    return a.effort - b.effort;
  });

  return results.slice(0, 8);
}

function buildRegenCin(base_cin, tillage, cc, compost_level) {
  const cc_def   = COVER_CROP_CIN[cc];
  const comp_def = COMPOST_LEVELS[compost_level];
  const compost_dpm_rpm = ORGANICS_DEF.compost.dpm_rpm ?? 0.40;

  // Item 6 — Tillage-change DPM:RPM adjustment.
  // No-till and raised-bed leave residue on surface → lower effective DPM:RPM
  // vs deep inversion/shallow which incorporate residue → higher DPM:RPM.
  // When the solver tries a tillage change, reflect this in C input quality.
  const SURFACE_TILLAGE = new Set(['no_till','raised_bed','chisel']);
  const base_is_surface  = SURFACE_TILLAGE.has(
    (ST.farm.crops[0]?.tillage || 'shallow'));  // use first slot as representative
  const regen_is_surface = SURFACE_TILLAGE.has(tillage);
  let base_dpm = base_cin.dpm_rpm;
  if (!base_is_surface && regen_is_surface) {
    // Switching from inversion/shallow to no-till/raised bed:
    // residues stay on surface → DPM:RPM decreases (more physical protection)
    base_dpm *= 0.90;
  } else if (base_is_surface && !regen_is_surface) {
    // Switching from no-till to inversion: incorporation accelerates DPM
    base_dpm *= 1.08;
  }

  const total = base_cin.total + cc_def.extra_c + comp_def.extra_c;
  let wDpm = base_cin.total * base_dpm;
  if (cc_def.extra_c > 0) wDpm += cc_def.extra_c * cc_def.dpm_rpm;
  if (comp_def.extra_c > 0) wDpm += comp_def.extra_c * compost_dpm_rpm;
  return {
    total,
    dpm_rpm:       total > 0 ? wDpm / total : base_cin.dpm_rpm,
    irrig_mult:    base_cin.irrig_mult,
    slot_schedule: base_cin.slot_schedule,
  };
}

/* ═══════════════════════════════════════════════════════
   BIOCHAR BISECTION SEARCH
═══════════════════════════════════════════════════════ */
function solveBiochar(cstock, clay, pH, base_cin, years, target, gap) {
  if (gap <= 0) return [];
  const results = [];
  const farm_till_mult = TILLAGE[ST.farm?.tillage||'shallow'].mult;

  Object.entries(BIOCHAR_FEEDSTOCKS).forEach(([fs_key, fs]) => {
    ['low','medium','high'].forEach(pyro => {
      const dose = bisectBiocharDose(cstock, clay, pH, base_cin, years, target, fs_key, pyro, farm_till_mult);
      if (dose === null) return;

      const traj = buildBiocharTraj(cstock, clay, pH, base_cin, years, dose, fs_key, pyro, farm_till_mult);
      const endpoint = traj[years];
      const co2e_total = bcCO2e(dose, fs_key, pyro);
      const cdp_revenue = co2e_total * 35;
      const effort = PRACTICE_EFFORT.biochar.effort;
      const cobenefits = buildCobenefits(null, null, null, fs_key, pyro);
      const n_min = estimateNMinFromCin(base_cin, clay, pH);

      results.push({
        feedstock: fs_key, pyro, dose,
        cin: base_cin, endpoint,
        delta_vs_bau: endpoint - (ST.bau?.endpoint||cstock),
        delta_vs_current: endpoint - cstock,
        meets: endpoint >= target * 0.99,
        close: endpoint >= target * 0.92,
        traj: traj.map((soc,i) => ({year:i, soc})),
        cobenefits, effort, n_min, co2e_total, cdp_revenue,
        type: 'biochar',
      });
    });
  });

  const clay1_bc = paramVal('clay1') ?? 25;

  // Item 18: Priming risk flag — tag each result
  results.forEach(r => {
    r.priming_risk = (ST.mineralogy === 'vertisol' && clay1_bc > 40 && r.dose > 5);
  });

  // Item 20: Vertisol + clay > 45% → biochar ranked last
  // Sort: meets→close→priming_risk(penalise)→dose
  const isHighClayVertisol = (ST.mineralogy === 'vertisol' && clay1_bc > 45);
  results.sort((a, b) => {
    if (isHighClayVertisol) {
      // De-prioritise all biochar for high-clay Vertisol
      if (a.priming_risk !== b.priming_risk) return a.priming_risk ? 1 : -1;
    }
    if (a.meets !== b.meets) return b.meets - a.meets;
    return a.dose - b.dose;
  });
  return results.slice(0, 6);
}

function bisectBiocharDose(cstock, clay, pH, base_cin, years, target, fs_key, pyro, tillage_mult) {
  // Item 19: cap dose for high-clay soils — priming risk above 5 t/ha
  // Zimmerman et al. 2011 SBB; ICRISAT Vertisol data
  const hiDose = (clay !== null && clay > 40) ? 5.0 : 40.0;
  let lo = 0, hi = hiDose;
  for (let i = 0; i < 12; i++) {
    const mid = (lo + hi) / 2;
    const traj = buildBiocharTraj(cstock, clay, pH, base_cin, years, mid, fs_key, pyro, tillage_mult);
    if (traj[years] >= target) hi = mid; else lo = mid;
  }
  // Check if even max dose fails
  const maxTraj = buildBiocharTraj(cstock, clay, pH, base_cin, years, hiDose, fs_key, pyro, tillage_mult);
  if (maxTraj[years] < target * 0.95) return null;
  return parseFloat(hi.toFixed(1));
}

/* ── bcTotalAtYear: sum stable biochar C from repeated applications ──
   For each application at year 0, interval, 2×interval, ...:
   remaining C at target year = sum of bcStableC(dose, fs, pyro, age)
   for each past application.
   'once': single application at year 0 only.
   Ref: Woolf et al. 2010 Nature Climate Change; ICAR biochar guidelines.
────────────────────────────────────────────────────────────────── */
function bcTotalAtYear(dose, fs_key, pyro, yr, interval) {
  // Application years: 0, interval, 2×interval … ≤ yr
  const intMap = { annual:1, every2yr:2, every3yr:3, once:9999 };
  const step = intMap[interval] ?? 9999;
  let total = 0;
  for (let applyYr = 0; applyYr <= yr; applyYr += step) {
    const age = yr - applyYr;
    total += bcStableC(dose, fs_key, pyro, age);
  }
  return total;
}

function buildBiocharTraj(cstock, clay, pH, base_cin, years, dose, fs_key, pyro, tillage_mult) {
  // Biochar adds stable C directly (bypasses RothC biological pools)
  const till_mult = tillage_mult ?? TILLAGE[ST.farm?.tillage||'shallow'].mult;
  // Pass slot_schedule if available (from base_cin built in computeBAU)
  const rothc_traj = runRothCWithKmult(cstock, clay, pH, base_cin,
    till_mult, ST.climate.monthly, years, 1.0);
  const interval = ST.farm?.bcInterval ?? 'once';
  const traj = rothc_traj.map((pt, yr) => {
    // Item 6: sum contributions from all application events
    const bc_remaining = bcTotalAtYear(dose, fs_key, pyro, yr, interval);
    return pt.soc + bc_remaining;
  });
  return traj;
}

/* ═══════════════════════════════════════════════════════
   COMBINED OPTIMISER
═══════════════════════════════════════════════════════ */
function solveCombined(cstock, clay, pH, base_cin, years, target, gap, regenR, biocharR) {
  const results = [];
  const topRegen = regenR.slice(0, 4);
  const fsKeys = Object.keys(BIOCHAR_FEEDSTOCKS);
  const pyros = ['low', 'medium', 'high'];

  topRegen.forEach(regen => {
    const regen_endpoint = regen.endpoint;
    const regen_gap = target - regen_endpoint;

    if (regen_gap <= 0 || regen.meets) {
      // Regen alone meets or exceeds target — no biochar needed
      results.push({ ...regen,
        biochar_dose:0, biochar_fs:null, biochar_pyro:null,
        type:'combined' });
      return;
    }

    // Find minimum biochar to close remaining gap after regen
    fsKeys.forEach(fs_key => {
      pyros.forEach(pyro => {
        const dose = bisectBiocharDoseFromBase(regen_endpoint, regen_gap, years, fs_key, pyro);
        if (dose === null) return;

        const regen_till_mult = TILLAGE[regen.tillage]?.mult ?? TILLAGE['shallow'].mult;
        const combined_traj = regen.traj.map((pt, i) => {
          const bc_stock = bcTotalAtYear(dose, fs_key, pyro, i, ST.farm?.bcInterval ?? 'once');
          return { year: i, soc: pt.soc + bc_stock };
        });

        const endpoint = combined_traj[years].soc;
        const effort = Math.min(100, Math.round((regen.effort + PRACTICE_EFFORT.biochar.effort * 0.6) / 2 * 1.3));
        const cobenefits = [...new Set([...regen.cobenefits, ...buildCobenefits(null, null, null, fs_key, pyro)])].slice(0,7);
        const co2e_total = bcCO2e(dose, fs_key, pyro);
        const n_min = estimateNMinFromCin(regen.cin, clay, pH);
        const cdp_revenue = co2e_total * 35; // ₹ est. @ ~$35/t CO₂e CDR market midpoint → rough ₹

        results.push({
          tillage: regen.tillage, cc: regen.cc, compost_level: regen.compost_level,
          biochar_dose: dose, biochar_fs: fs_key, biochar_pyro: pyro,
          cin: regen.cin, endpoint,
          delta_vs_bau: endpoint - (ST.bau?.endpoint||cstock),
          delta_vs_current: endpoint - cstock,
          meets: endpoint >= target * 0.99,
          close: endpoint >= target * 0.92,
          traj: combined_traj, cobenefits, effort, n_min,
          co2e_total, cdp_revenue,
          type: 'combined',
        });
      });
    });
  });

  results.sort((a,b) => {
    if (a.meets !== b.meets) return b.meets - a.meets;
    if (a.close !== b.close) return b.close - a.close;
    const dose_a = a.biochar_dose||0, dose_b = b.biochar_dose||0;
    if (Math.abs(dose_a - dose_b) > 1) return dose_a - dose_b;
    return a.effort - b.effort;
  });

  return results.slice(0, 8);
}

function bisectBiocharDoseFromBase(current_soc, gap, years, fs_key, pyro) {
  if (gap <= 0) return 0;
  let lo = 0, hi = 40;
  for (let i = 0; i < 12; i++) {
    const mid = (lo + hi) / 2;
    if (bcStableC(mid, fs_key, pyro, years) >= gap) hi = mid;
    else lo = mid;
  }
  if (bcStableC(40, fs_key, pyro, years) < gap * 0.95) return null;
  return parseFloat(hi.toFixed(1));
}

/* ═══════════════════════════════════════════════════════
   HELPERS
═══════════════════════════════════════════════════════ */
/* ═══════════════════════════════════════════════════════
   ITEM A: AWD CH₄ QUANTIFICATION
   IPCC 2006 GL Vol.4 Ch.5 Tier 1 methane emission factors.
   Paddy continuous flood → AWD transition reduces CH₄ by
   applying a scaling factor (SFw) to the baseline emission.
   
   Baseline EF (EF_c):
     Continuously flooded, no organic amendments: 1.30 kg CH₄/ha/day
     (IPCC 2006 Table 5.11 default for irrigated rice)
   Scaling factor SFw:
     Continuous flood (SFw=1.0), AWD (SFw=0.52)
     Ref: IPCC 2006 Table 5.12; Yan et al. 2009 Global Change Biol
   
   CH₄ → CO₂e: GWP100 = 28 (AR5) for biogenic CH₄
   Annual emission = EF_c × SFw × growing_days × 28/1000 t CO₂e/ha/yr
   CDR from AWD = (paddy_flood emission) − (AWD emission)
   
   Also applies to solveBiochar (AWD SOC trajectory uses awd fW_mult).
   Ref: IPCC 2006 Vol.4 Ch.5; Minamikawa et al. 2015; VCS VM0006.
═══════════════════════════════════════════════════════ */
const AWD_PARAMS = {
  EF_c:          1.30,   // kg CH₄/ha/day — IPCC Tier 1 baseline (irrigated, no manure)
  SFw_flood:     1.00,   // scaling factor — continuous flood
  SFw_awd:       0.52,   // scaling factor — AWD (50% reduction mid-season drain)
  GWP_CH4:       28,     // AR5 GWP100 for biogenic CH4
  season_days:   120,    // typical kharif rice growing season (IRRI India)
};

/* Compute annual CH₄ CDR benefit from converting paddy flood → AWD
   Returns { flood_co2e, awd_co2e, delta_co2e } in t CO₂e/ha/yr
   or null if no paddy_flood slot exists */
function calcAWDMethane(slots) {
  const paddySlots = (slots || []).filter(s =>
    (s.id === 'rice_wetland' || s.id === 'rice_upland') &&
    (s.irrigation === 'paddy_flood')
  );
  if (!paddySlots.length) return null;

  const n = paddySlots.length;  // number of paddy seasons
  const p = AWD_PARAMS;
  // kg CH₄/ha/yr → t CH₄/ha/yr → t CO₂e/ha/yr
  const toCO2e = (sfW) =>
    p.EF_c * sfW * p.season_days * n / 1000 * p.GWP_CH4;

  return {
    flood_co2e: toCO2e(p.SFw_flood),
    awd_co2e:   toCO2e(p.SFw_awd),
    delta_co2e: toCO2e(p.SFw_flood) - toCO2e(p.SFw_awd),
    n_seasons:  n,
  };
}

function buildCobenefits(tillage, cc, compost_level, bc_fs, bc_pyro) {
  const cob = [];
  if (tillage === 'no_till' || tillage === 'raised_bed')
    cob.push('Reduced erosion', 'Aggregate protection');
  if (cc && cc !== 'none') {
    COVER_CROP_CIN[cc]?.coben?.forEach(c => cob.push(c));
  }
  if (compost_level && COMPOST_LEVELS[compost_level]?.rate > 0)
    cob.push('Improved water retention', 'Microbial diversity');
  if (bc_fs) {
    cob.push('CDR-eligible (biochar)', `${bcCO2e(1, bc_fs, bc_pyro||'medium').toFixed(1)} t CO₂e/t`);
    if (bc_pyro === 'high') cob.push('Liming effect (high-T)');
  }
  if (cc === 'legume' || cc === 'mixed') cob.push('Reduced N fertiliser need');
  return [...new Set(cob)].slice(0, 6);
}

function calcEffort(tillage, cc, compost_level, bc_fs, bc_pyro) {
  let e = PRACTICE_EFFORT[tillage]?.effort || 30;
  if (cc && cc !== 'none') e += PRACTICE_EFFORT[`cover_${cc}`]?.effort || 40;
  if (compost_level && compost_level !== 'none') {
    const map = {low:30, medium:50, high:70, veryhigh:80};
    e += map[compost_level] || 0;
  }
  if (bc_fs) e += PRACTICE_EFFORT.biochar.effort;
  // Penalise for departing from current farmer tillage
  const cur_till = ST.farm?.tillage || 'shallow';
  if (tillage !== cur_till) e += 15;
  return Math.min(100, Math.round(e / 3));
}

function estimateNMinFromCin(cin, clay, pH) {
  // Quick N mineralisation estimate from total C input and DPM:RPM
  const dpm_fraction = cin.dpm_rpm / (1 + cin.dpm_rpm);
  const dpm_flux = cin.total * dpm_fraction * 0.72;  // ~72% of DPM decomposes yr1
  const rpm_flux = cin.total * (1 - dpm_fraction) * 0.05;
  const n_min = (dpm_flux / POOL_CN.dpm + rpm_flux / POOL_CN.rpm) * (14/12) * 1000;
  return Math.round(n_min);
}

function bundleName(tillage, cc, compost, bc_fs, bc_pyro) {
  const parts = [];
  if (tillage && tillage !== (ST.farm?.tillage||'shallow')) parts.push(TILLAGE[tillage]?.name);
  if (cc && cc !== 'none') parts.push(COVER_CROP_CIN[cc]?.label);
  if (compost && compost !== 'none') parts.push(COMPOST_LEVELS[compost]?.label);
  if (bc_fs) parts.push(`${BIOCHAR_FEEDSTOCKS[bc_fs]?.name} biochar`);
  return parts.length ? parts.join(' + ') : 'Current practice (optimised)';
}

