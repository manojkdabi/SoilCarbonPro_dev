function generateSoilTestPDF() {
  ensureJsPDF();
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
  const W = 210, pad = 18;
  const cW = W - 2 * pad;
  let y = pad;

  const col = { ink:'#1a2e1a', green:'#1e5c26', amber:'#9a5e08', red:'#8a1a1a', mid:'#4a6a4a', light:'#7a9a7a', bg:'#f0ece2' };

  // Header
  doc.setFillColor(26,46,26);
  doc.rect(0, 0, 210, 28, 'F');
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(14); doc.setTextColor(208,232,208);
  doc.text('SOIL TEST REQUEST SHEET', pad, 11);
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(8); doc.setTextColor(176,200,176);
  doc.text('SoilCarbon Pro — Target Solver Phase 1', pad, 17);
  doc.setFontSize(8);
  doc.text(`Location: ${ST.locationName || 'Not set'}  |  Lat: ${ST.lat?.toFixed(4) ?? '—'}  Lon: ${ST.lon?.toFixed(4) ?? '—'}`, pad, 22);
  doc.text(`Generated: ${new Date().toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'})}`, W - pad, 22, {align:'right'});
  y = 36;

  // Purpose
  doc.setFont('helvetica', 'bold'); doc.setFontSize(8); doc.setTextColor(col.green);
  doc.text('PURPOSE', pad, y); y += 4;
  doc.setFont('helvetica', 'normal'); doc.setFontSize(7.5); doc.setTextColor(col.ink);
  const purpose = 'Request your soil laboratory to analyse the parameters below, collected from the field location shown above. Separate samples are required at two depths. Bulk density requires an UNDISTURBED CORE — see BD protocol on page 2. Submit this sheet with your samples.';
  const pLines = doc.splitTextToSize(purpose, cW);
  doc.text(pLines, pad, y); y += pLines.length * 4 + 3;

  doc.setDrawColor(col.light); doc.setLineWidth(0.3); doc.line(pad, y, W-pad, y); y += 5;

  // Tier 1
  const headerRow = (title, color) => {
    doc.setFillColor(...hexToRgb(color));
    doc.rect(pad, y-4, cW, 7, 'F');
    doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(255,255,255);
