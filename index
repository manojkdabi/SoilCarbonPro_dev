function importFieldFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      let geojson;
      if (file.name.endsWith('.kml')) {
        // Basic KML → GeoJSON: parse coordinates from <coordinates> tag
        const parser = new DOMParser();
        const kml = parser.parseFromString(e.target.result, 'text/xml');
        const coords = kml.querySelector('coordinates')?.textContent?.trim();
        if (!coords) throw new Error('No coordinates in KML');
        const latlngs = coords.split(/\s+/).map(c => {
          const [lon, lat] = c.split(',').map(Number);
          return [lon, lat];
        }).filter(c => !isNaN(c[0]));
        geojson = { type: 'Feature', geometry: { type: 'Polygon', coordinates: [latlngs] }, properties: {} };
      } else {
        geojson = JSON.parse(e.target.result);
        if (geojson.type === 'FeatureCollection') geojson = geojson.features[0];
      }
      if (!geojson?.geometry) throw new Error('Invalid geometry');

      // Render on map
      _featureGroup.clearLayers();
      const layer = L.geoJSON(geojson, {
        style: { color: '#2e8040', fillColor: '#4aaf6a', fillOpacity: 0.18, weight: 2 }
      });
      layer.addTo(_featureGroup);
      _drawnLayer = layer;
      onFieldDrawn(geojson);
      showToast('Field boundary imported ✓');
    } catch(err) {
      showToast('Import failed: ' + err.message);
    }
  };
  reader.readAsText(file);
  event.target.value = ''; // reset so same file can be re-imported
}

