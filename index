    { dot:gap!==null&&gap>0?'#c07a10':'#2e8040', label:`BAU gap to target`,
      val:gap !== null ? `${gap>0?'+':''}${gap.toFixed(1)} t C/ha` : '—',
      note:gap!==null&&gap>0 ? `Gap the solver must close` : gap!==null&&gap<=0 ? `BAU already meets target` : '' },
  ];

  document.getElementById('gap-table').innerHTML = rows.map(r => `
