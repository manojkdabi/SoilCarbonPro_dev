     </span>`;
}

async function triggerSpatialAnalysis() {
  if (!ST.fieldBoundary) return;
  const progEl = document.getElementById('spatial-progress');
  const btn    = document.getElementById('analyse-soil-btn');
  if (btn) btn.disabled = true;
  if (progEl) { progEl.style.display='block'; progEl.textContent='⏳ Fetching soil pixels…'; }

  try {
    _spatialRasterCache = {};
    _krigingCache       = {};
    _regKrigCache       = {};
    const result = await computeFullPolygonSpatialAnalysis(
      ST.fieldBoundary,
      (step, total, msg) => {
        if (progEl) progEl.textContent = `⏳ Step ${step+1}/${total}: ${msg}`;
      }
    );
    if (result) {
      _spatialPixelData  = result.pixelData;
      _spatialStats      = result.stats;
      ST.derived.spatial = result.stats;
      ST.derived.pixelBimodal = result.bimodal;
      const socS = result.stats?.soc;
      if (socS && ST.derived.cstock) {
        const sigma_pct = socS.cv_pct / 100;
        ST.derived.uncertainty = ST.derived.cstock * sigma_pct;
        ST.derived.spatialUncertainty = true;
        updateUncertaintyMeter(ST.derived.cstock, ST.derived.uncertainty, sigma_pct);
      }
      updateSpatialVarianceDisplay();
      updateSpatialAnalysisPanel(result);
      renderSpatialOverlay(_spatialActiveKey);
      // Show terrain button now that pixels are ready
      const terrBtn = document.getElementById('analyse-terrain-btn');
      if (terrBtn) terrBtn.style.display = 'inline-block';
    } else {
      if (progEl) progEl.textContent = '⚠ Soil pixel analysis failed — check console';
    }
  } catch(e) {
    if (progEl) progEl.textContent = `⚠ Error: ${e.message}`;
    console.error('Spatial analysis error:', e);
  }
  if (progEl) progEl.style.display = 'none';
  if (btn) btn.disabled = false;
}

async function triggerTerrainAnalysis() {
  if (!ST.fieldBoundary) return;
  const progEl = document.getElementById('spatial-progress');
  const btn    = document.getElementById('analyse-terrain-btn');
  const badge  = document.getElementById('terrain-source-badge');
  if (btn) btn.disabled = true;
  if (progEl) { progEl.style.display = 'block'; progEl.textContent = '⏳ Fetching terrain data…'; }

  try {
    const dem = await fetchDEM(ST.fieldBoundary,
      msg => { if (progEl) progEl.textContent = msg; });

    if (!dem || !dem.grid) {
      if (progEl) progEl.textContent = '⚠ DEM unavailable — check OpenTopography key or retry';
      if (btn) btn.disabled = false;
      return;
    }

    if (progEl) progEl.textContent = '⏳ Computing terrain derivatives…';
    const clay1  = _spatialStats?.clay?.mean ?? paramVal('clay1') ?? 25;
    const map_mm = ST.climate?.map ?? 600;
    const terrain = computeTerrainDerivatives(dem, clay1, map_mm);

    if (terrain) {
      applyTerrainCrossValidation(terrain, dem);
      updateTerrainPanel(terrain, dem);
      if (badge) badge.textContent = `${dem.source === 'copernicus' ? 'Copernicus' : 'SRTM'} 30m`;
      // Sprint 4: show RK button now that terrain is available
      const rkBtn = document.getElementById('rk-toggle-btn');
      if (rkBtn) rkBtn.style.display = 'inline-block';
    }

    // Re-run BAU if climate already loaded (temperature corrections may have changed)
    if (ST.climate && ST.farm.crops.length > 0) triggerBAU();

    if (progEl) progEl.style.display = 'none';
  } catch(e) {
    if (progEl) progEl.textContent = `⚠ Terrain error: ${e.message}`;
    console.error('Terrain analysis error:', e);
  }
  if (btn) btn.disabled = false;
}

function renderTerrainOverlay(key) {
  if (!ST.terrain || !ST.dem.grid) return;
  if (_terrainOverlay) { map.removeLayer(_terrainOverlay); _terrainOverlay = null; }

  const dem  = ST.dem;
  const terr = ST.terrain;
  const arr  = key === 'slope'    ? terr.slope
             : key === 'aspect'   ? terr.aspect
             : key === 'twi'      ? terr.twi
             : key === 'rough'    ? terr.roughness
             : key === 'riparian' ? terr.riparian
             :                     terr.landslide;

  const ramp = TERRAIN_RAMPS[key];
  const vals = Array.from(arr).filter(v => !isNaN(v) && isFinite(v));
  if (!vals.length) return;
  const minV = Math.min(...vals), maxV = Math.max(...vals);

  _terrainOverlay = L.layerGroup();
  const cellH = Math.abs(dem.cellSizeLat);
  const cellW = Math.abs(dem.cellSizeLon);

  // Render every 2nd cell (downsample 2×) for performance
  const step = Math.max(1, Math.round(30 / (cellW * 111320)));
  for (let r = 0; r < dem.nRows; r += step) {
    for (let c = 0; c < dem.nCols; c += step) {
      const val = arr[r * dem.nCols + c];
      if (isNaN(val) || !isFinite(val)) continue;
      const lat = dem.originLat + r * dem.cellSizeLat;
      const lon = dem.originLon + c * cellW;
      const col = interpolateColour(ramp.stops, Math.max(0, Math.min(1, (val-minV)/(maxV-minV||1))));
      L.rectangle(
        [[lat - cellH*step/2, lon - cellW*step/2],
         [lat + cellH*step/2, lon + cellW*step/2]],
        { color:'none', weight:0,
          fillColor:`rgb(${col[0]},${col[1]},${col[2]})`,
          fillOpacity: key === 'riparian' ? (val ? 0.85 : 0) : 0.55,
          interactive: false }
      ).addTo(_terrainOverlay);
    }
  }
  _terrainOverlay.addTo(map);

  // Update legend
  const legEl = document.getElementById('spatial-legend');
  if (legEl) {
    legEl.style.display = 'block';
    const grad = ramp.stops.map(s=>`${s[1]} ${(s[0]*100).toFixed(0)}%`).join(', ');
    legEl.innerHTML = `<div style="font-size:0.60rem;font-family:var(--mono);font-weight:700;color:var(--ink-4);margin-bottom:2px">
      ${ramp.label}</div>
      <div style="height:10px;border-radius:3px;background:linear-gradient(to right,${grad})"></div>
      <div style="display:flex;justify-content:space-between;font-size:0.57rem;font-family:var(--mono);color:var(--ink-5);margin-top:2px">
        <span>${minV.toFixed(1)}</span><span>${maxV.toFixed(1)} ${ramp.unit}</span>
      </div>`;
  }
}


/* ═══════════════════════════════════════════════════════
   SPRINT 2 — PLAN 2.3: TERRAIN CROSS-VALIDATION
   
   Reads terrain stats and applies corrections to:
   - ST.analysisDepth (depth cap from slope)
   - ST.climate.monthly temperatures (lapse rate + aspect)
   - Phase 2 waterlogging field (TWI)
   - Feasibility flags (tillage from slope/roughness)
   - Generates cross-check warnings (TWI/SOC, slope/clay)
   
   All reversible — stored in ST.terrainAdj so they can be
   removed when terrain is cleared or polygon changes.
   
   Refs: Lapse rate: Barry & Chorley 2003;
         Aspect-fT: Chen et al. 2011 (Agr Forest Meteorol);
         TWI-waterlogging: Beven & Kirkby 1979;
         Slope-depth: ICAR soil sampling manual.
═══════════════════════════════════════════════════════ */
function applyTerrainCrossValidation(terrain, dem) {
  if (!terrain) return;
  const s = terrain.stats;
  const slope_mean  = s.slope?.mean  ?? 0;
  const slope_max   = s.slope?.max   ?? 0;
  const twi_mean    = s.twi?.mean    ?? 0;
  const rough_mean  = s.roughness?.mean ?? 0;
  const risk_max    = s.landslide?.max  ?? 0;

  // Compute mean elevation from DEM grid
  const elevVals = Array.from(dem.grid).filter(v => !isNaN(v) && v > -1000 && v < 9000);
  const elev_mean = elevVals.length ? elevVals.reduce((a,b)=>a+b,0)/elevVals.length : 0;
  const elev_max  = elevVals.length ? Math.max(...elevVals) : 0;

  // Compute mean aspect for fT direction correction
  const aspVals = Array.from(terrain.aspect).filter(v => !isNaN(v));
  const asp_mean = aspVals.length ? aspVals.reduce((a,b)=>a+b,0)/aspVals.length : 180;

  // Initialise terrain adjustment store
  ST.terrainAdj = {
    elev_mean, slope_mean, slope_max, twi_mean, rough_mean,
    risk_max, asp_mean,
    tempDeltaC:    0,   // ERA5 lapse rate correction
    fT_mult:       1.0, // aspect-based fT multiplier
    depthCapped:   false,
    depthCapValue: null,
    tillageFlags:  [],
    crossChecks:   [],
  };

  // ── 2.3.5: Elevation → ERA5 temperature lapse rate ─────────────────
  // Standard environmental lapse rate -0.65°C per 100 m
  // ERA5 provides near-surface temperature (~10 m resolution vertically)
  // For elevations > 200 m, a correction is meaningful
  if (elev_mean > 200 && ST.climate?.monthly) {
    const deltaT = -(elev_mean / 100) * 0.65;
    ST.terrainAdj.tempDeltaC = deltaT;
    // Apply to ST.climate monthly (store originals first)
    if (!ST.climate._origTemps) {
      ST.climate._origTemps = ST.climate.monthly.map(m => m.temp);
    }
    ST.climate.monthly.forEach((m, i) => {
      m.temp = ST.climate._origTemps[i] + deltaT;
    });
    ST.climate.mat = ST.climate.monthly.reduce((s,m)=>s+m.temp,0)/12;
    ST.terrainAdj.crossChecks.push(
      `🌡 Elevation ${elev_mean.toFixed(0)} m: ERA5 temperature corrected by ${deltaT.toFixed(1)}°C (lapse rate -0.65°C/100m)`
    );
  }

  // ── 2.3.4: Aspect + latitude → fT correction ────────────────────────
  // South-facing slopes (135–225°) receive more direct solar radiation
  // at Indian latitudes → soil T ~1–2°C higher → fT multiplier
  // North-facing (315–45°) → cooler → lower fT
  // Effect: ±5–10% on decomposition rate
  // Ref: Chen et al. 2011 Agr Forest Meteorol 151:1728
  const lat_rad = (ST.lat ?? 20) * Math.PI / 180;
  const southFacingBonus = Math.abs(Math.cos((asp_mean - 180) * Math.PI / 180))
                         * Math.sin(lat_rad) * 0.08;  // max ±8% at equator-facing slopes
  ST.terrainAdj.fT_mult = 1.0 + (asp_mean > 90 && asp_mean < 270 ? southFacingBonus : -southFacingBonus * 0.5);
  if (Math.abs(ST.terrainAdj.fT_mult - 1.0) > 0.01) {
    const dir  = asp_mean > 90 && asp_mean < 270 ? 'south-facing' : 'north-facing';
    const sign = ST.terrainAdj.fT_mult > 1.0 ? '+' : '';
    ST.terrainAdj.crossChecks.push(
      `☀ Aspect ${asp_mean.toFixed(0)}° (${dir}): fT multiplier ${sign}${((ST.terrainAdj.fT_mult-1)*100).toFixed(1)}% on decomposition rate`
    );
  }
  // Store fT_mult in ST.derived so runRothCWithKmult can read it
  ST.derived.terrainFTMult = ST.terrainAdj.fT_mult;

  // ── 2.3.2: Slope → analysis depth cap ───────────────────────────────
  // Steep slopes have shallower effective soil depth (erosion + shallow regolith)
  // ICAR soil sampling guide; Richter & Markewitz 2001
  if (slope_max > 35 && ST.analysisDepth > 15) {
    ST.analysisDepth = 15;
    ST.terrainAdj.depthCapped = true;
    ST.terrainAdj.depthCapValue = 15;
    ST.terrainAdj.crossChecks.push(
      '⛰ Slope >35° — analysis depth auto-capped at 15 cm (shallow regolith likely)'
    );
    // Update depth display
    const depthEl = document.getElementById('analysis-depth-select') ||
                    document.getElementById('depth-select');
    if (depthEl) depthEl.value = '15';
    recalcAll();
  } else if (slope_max > 20 && ST.analysisDepth > 30) {
    ST.analysisDepth = 30;
    ST.terrainAdj.crossChecks.push(
      '🌄 Slope >20° — analysis depth capped at 30 cm'
    );
  }

  // ── 2.3.1: TWI → waterlogging auto-detection ────────────────────────
  if (twi_mean > 9 && document.getElementById('hist-waterlog')) {
    const wlEl = document.getElementById('hist-waterlog');
    if (wlEl && wlEl.value === 'no') {
      wlEl.value = 'severe';
      ST.farm.history.waterlog = 'severe';
      ST.terrainAdj.crossChecks.push(
        '💧 Very high TWI (' + twi_mean.toFixed(1) + ') — waterlogging set to SEVERE in Phase 2'
      );
    }
  } else if (twi_mean > 7 && document.getElementById('hist-waterlog')) {
    const wlEl = document.getElementById('hist-waterlog');
    if (wlEl && wlEl.value === 'no') {
      wlEl.value = 'partial';
      ST.farm.history.waterlog = 'partial';
      ST.terrainAdj.crossChecks.push(
        '💧 High TWI (' + twi_mean.toFixed(1) + ') — waterlogging set to PARTIAL in Phase 2'
      );
    }
  }

  // ── 2.3.3: Slope → tillage feasibility ──────────────────────────────
  if (slope_max > 25) {
    ST.terrainAdj.tillageFlags.push('no_deep_inversion');
    ST.terrainAdj.crossChecks.push(
      '⛰ Slope >25° — deep inversion tillage infeasible; no-till or conservation tillage only'
    );
  } else if (slope_max > 15) {
    ST.terrainAdj.tillageFlags.push('prefer_conservation');
    ST.terrainAdj.crossChecks.push(
      '🌄 Slope >15° — raised bed or minimum tillage preferred over deep inversion'
    );
  }

  // ── 2.3.6: Roughness → tillage feasibility ──────────────────────────
  if (rough_mean > 3.0) {
    ST.terrainAdj.tillageFlags.push('high_roughness');
    ST.terrainAdj.crossChecks.push(
      '🪨 High surface roughness (' + rough_mean.toFixed(1) + ' m) — stony/irregular terrain; no-till preferred'
    );
  }

  // ── 2.3.7: TWI vs SOC anomaly check ─────────────────────────────────
  // Expect high-TWI pixels to have higher SOC (moisture supports SOC)
  // If the opposite is true, flag as potential land use anomaly
  if (_spatialStats?.soc && _spatialPixelData?.length >= 4) {
    const pixWithData = _spatialPixelData.filter(p => p.soc !== null);
    if (pixWithData.length >= 4) {
      // Rough TWI proxy from lat (lower lat = lower elevation in toposequence)
      // Use lat as elevation proxy only if DEM not available at pixel level
      const sorted = [...pixWithData].sort((a,b) => a.lat - b.lat);
      const lowZone  = sorted.slice(0, Math.ceil(sorted.length/2));
      const highZone = sorted.slice(Math.ceil(sorted.length/2));
      const lowSOC   = lowZone.reduce((s,p)=>s+p.soc,0)/lowZone.length;
      const highSOC  = highZone.reduce((s,p)=>s+p.soc,0)/highZone.length;
      if (lowSOC < highSOC * 0.7 && twi_mean > 6) {
        ST.terrainAdj.crossChecks.push(
          '⚠ TWI/SOC anomaly: low-lying zones have lower SOC than upslope — possible land use disturbance or drainage intervention'
        );
      }
    }
  }

  // ── 2.3.8: Slope vs clay cross-check ─────────────────────────────────
  const clay_mean = _spatialStats?.clay?.mean ?? paramVal('clay1') ?? 25;
  if (slope_max > 20 && clay_mean > 40) {
    ST.terrainAdj.crossChecks.push(
      '🔶 Steep slope + high clay (' + clay_mean.toFixed(0) + '%) — possible colluvial deposition; verify soil depth in field'
    );
  }

  // ── 2.3.9: Curvature → runoff erosion risk ──────────────────────────
  if (terrain.profCurv) {
    const convexCells = Array.from(terrain.profCurv)
      .filter(v => !isNaN(v) && v < -0.01).length;  // negative profCurv = convex
    const convexPct = (convexCells / terrain.profCurv.length * 100);
    if (convexPct > 30 && slope_mean > 8) {
      ST.terrainAdj.crossChecks.push(
        '🌊 ' + convexPct.toFixed(0) + '% of field is convex + sloping — elevated runoff/erosion risk; cover crops and mulching priority'
      );
    }
  }

  // ── 2.3.10: Riparian zone agroforestry note ──────────────────────────
  const riparianCells = Array.from(terrain.riparian).filter(v=>v>0).length;
  if (riparianCells > 0) {
    const riparianPct = (riparianCells / terrain.riparian.length * 100);
    ST.terrainAdj.crossChecks.push(
      '🌊 Riparian zones (' + riparianPct.toFixed(0) + '% of field) — priority agroforestry zones; Gliricidia, Bamboo, Albizzia recommended along drainage lines'
    );
    // Surface in compatibility panel if tree inventory is open
    updateTreeCompatPanel();
  }

  // Show cross-validation notes in terrain flags panel
  const xvalEl = document.getElementById('terrain-xval');
  if (xvalEl && ST.terrainAdj.crossChecks.length) {
    xvalEl.style.display = 'block';
    xvalEl.innerHTML = '<div style="font-weight:700;color:var(--teal);margin-bottom:3px;font-size:0.63rem">🔗 TERRAIN × SOIL CROSS-VALIDATION:</div>' +
      ST.terrainAdj.crossChecks.map(t =>
        '<div style="margin-bottom:2px">' + t + '</div>'
      ).join('');
  }
}

function updateTerrainPanel(terrain, dem) {
  const panel = document.getElementById('terrain-panel');
  const statsEl = document.getElementById('terrain-stats');
  const flagsEl = document.getElementById('terrain-flags');
  if (!panel || !terrain) return;

  panel.style.display = 'block';

  // Stats summary
  const s = terrain.stats;
  if (statsEl && s.slope) {
    statsEl.innerHTML =
      `<strong>Slope:</strong> ${s.slope.mean.toFixed(1)}° (max ${s.slope.max.toFixed(1)}°) · ` +
      `<strong>TWI:</strong> ${s.twi?.mean.toFixed(1) ?? '—'} · ` +
      `<strong>Roughness:</strong> ${s.roughness?.mean.toFixed(2) ?? '—'} m · ` +
      `<strong>Source:</strong> ${dem.source === 'copernicus' ? 'Copernicus 30m' : 'SRTM 30m'}`;
  }

  // Interpretation flags
  if (flagsEl) {
    const flags = [];
    const slope_mean = s.slope?.mean ?? 0;
    const slope_max  = s.slope?.max  ?? 0;
    const twi_mean   = s.twi?.mean   ?? 0;
    const rough_mean = s.roughness?.mean ?? 0;
    const risk_max   = s.landslide?.max  ?? 0;

    if (slope_max > 35)
      flags.push('⛰ <strong>Steep slopes</strong> (>35°) — mechanised tillage not feasible; deep inversion excluded');
    else if (slope_max > 15)
      flags.push('🌄 <strong>Moderate slopes</strong> (>15°) — raised bed and conservation tillage preferred');

    if (twi_mean > 8)
      flags.push('💧 <strong>High TWI</strong> — waterlogging-prone zones detected; auto-applied to Phase 2');
    else if (twi_mean > 6)
      flags.push('💧 <strong>Moderate TWI</strong> — seasonal waterlogging possible in low zones');

    if (rough_mean > 2.5)
      flags.push('🪨 <strong>High surface roughness</strong> — stony or irregular terrain; no-till preferred');

    if (risk_max > 0.65)
      flags.push('⚠ <strong>Landslide risk zones</strong> detected — deep-rooting species (Teak, Dalbergia, Bamboo) recommended on high-risk slopes');

    // Riparian zones
    const riparianCells = Array.from(terrain.riparian).filter(v => v > 0).length;
    if (riparianCells > 0) {
      const riparianPct = (riparianCells / terrain.riparian.length * 100).toFixed(0);
      flags.push(`🌊 <strong>Riparian zones</strong> identified (${riparianPct}% of field) — priority agroforestry zones; Gliricidia, Albizzia, Bamboo recommended`);
    }

    // Auto-apply waterlogging to Phase 2 if high TWI
    if (twi_mean > 8 && document.getElementById('hist-waterlog')) {
      const wlSelect = document.getElementById('hist-waterlog');
      if (wlSelect && wlSelect.value === 'no') {
        wlSelect.value = 'partial';
        ST.farm.history.waterlog = 'partial';
        flags.push('✅ <strong>Waterlogging auto-set</strong> to "Partial" in Phase 2 from TWI data');
      }
    }

    flagsEl.innerHTML = flags.length
      ? flags.map(f => `<div style="margin-bottom:3px">${f}</div>`).join('')
      : '<div style="color:var(--ink-5)">No significant terrain constraints detected for this field.</div>';
  }

  // Render default overlay
  renderTerrainOverlay(_terrainActiveKey);
}

function enumeratePolygonPixels(polygon) {
  const PIXEL_DEG = 250 / 111320;  // 250 m in decimal degrees (approx)
  const bbox = turf.bbox(polygon); // [minLon, minLat, maxLon, maxLat]

  // Snap grid to 250 m pixel boundaries aligned to ISRIC grid
  const minLon = Math.floor(bbox[0] / PIXEL_DEG) * PIXEL_DEG;
  const minLat = Math.floor(bbox[1] / PIXEL_DEG) * PIXEL_DEG;
  const maxLon = Math.ceil(bbox[2]  / PIXEL_DEG) * PIXEL_DEG;
  const maxLat = Math.ceil(bbox[3]  / PIXEL_DEG) * PIXEL_DEG;

  const pixels = [];
  const halfDeg = PIXEL_DEG / 2;

  for (let lon = minLon + halfDeg; lon <= maxLon; lon += PIXEL_DEG) {
    for (let lat = minLat + halfDeg; lat <= maxLat; lat += PIXEL_DEG) {
      const pt = turf.point([lon, lat]);

      // Fast interior test
      if (turf.booleanPointInPolygon(pt, polygon)) {
        pixels.push({ lat, lon, weight: 1.0 });
        continue;
      }

      // Boundary test: does the pixel cell overlap the polygon?
      const cell = turf.bboxPolygon([
        lon - halfDeg, lat - halfDeg,
        lon + halfDeg, lat + halfDeg,
      ]);
      try {
        // Turf.js v6.5.0: intersect takes two separate features, not a FeatureCollection
        const overlap = turf.intersect(cell, polygon);
        if (overlap) {
          const overlapArea = turf.area(overlap);
          const cellArea    = turf.area(cell);
          const weight      = overlapArea / cellArea;
          if (weight > 0.05) {  // ignore <5% overlap — noise
            pixels.push({ lat, lon, weight });
          }
        }
      } catch(e) { /* turf.intersect may throw on edge cases — skip */ }
    }
  }

  return pixels;
}

/* ── 1.1.3: Fetch all 9 SoilGrids properties at all pixel points ─────
   Properties: soc, clay, silt, sand, bdod, phh2o, nitrogen, cec, cfvo
   Fires requests in batches to avoid overwhelming the WCS server.
   Batch size 10 — empirically safe for maps.isric.org concurrency.
────────────────────────────────────────────────────────────────────── */
const PIXEL_PROPS = [
  { prop:'soc',      layer:'soc_0-5cm_mean',      key:'soc',   mult:0.1,   unit:'g/kg',   label:'SOC' },
  { prop:'clay',     layer:'clay_0-5cm_mean',      key:'clay',  mult:0.1,   unit:'%',      label:'Clay' },
  { prop:'silt',     layer:'silt_0-5cm_mean',      key:'silt',  mult:0.1,   unit:'%',      label:'Silt' },
  { prop:'sand',     layer:'sand_0-5cm_mean',      key:'sand',  mult:0.1,   unit:'%',      label:'Sand' },
  { prop:'bdod',     layer:'bdod_0-5cm_mean',      key:'bd',    mult:0.01,  unit:'g/cm³',  label:'Bulk density' },
  { prop:'phh2o',    layer:'phh2o_0-5cm_mean',     key:'ph',    mult:0.1,   unit:'',       label:'pH' },
  { prop:'nitrogen', layer:'nitrogen_0-5cm_mean',  key:'tn',    mult:0.001, unit:'g/kg',   label:'Total N' },
  { prop:'cec',      layer:'cec_0-5cm_mean',       key:'cec',   mult:0.1,   unit:'cmol/kg',label:'CEC' },
  { prop:'cfvo',     layer:'cfvo_0-5cm_mean',      key:'cfvo',  mult:0.1,   unit:'%',      label:'Coarse frags' },
];

async function fetchPixelValues(pixels, onProgress) {
  /* Returns pixelData[i] = { lat, lon, weight, soc, clay, ... }
     Concurrency-limited: max 6 simultaneous WCS requests to avoid
     ERR_INSUFFICIENT_RESOURCES on large polygons. Properties fetched
     sequentially; pixels within each property batched at 6 concurrent. */
  const CONCURRENCY = 6;
  const data = pixels.map(p => ({ ...p }));

  // Helper: run tasks with max N concurrent
  async function batchedFetch(tasks) {
    const results = new Array(tasks.length);
    let idx = 0;
    async function worker() {
      while (idx < tasks.length) {
        const i = idx++;
        results[i] = await tasks[i]();
      }
    }
    const workers = Array.from({length: Math.min(CONCURRENCY, tasks.length)}, worker);
    await Promise.all(workers);
    return results;
  }

  for (let pi = 0; pi < PIXEL_PROPS.length; pi++) {
    const { prop, layer, key, mult } = PIXEL_PROPS[pi];
    if (onProgress) onProgress(pi, PIXEL_PROPS.length, prop);

    const tasks = pixels.map(px => () => readWCSPixel(prop, layer, px.lat, px.lon));
    const vals  = await batchedFetch(tasks);
    vals.forEach((v, i) => {
      data[i][key] = (v !== null) ? v * mult : null;
    });
  }
  return data;
}

/* ── 1.1.4+1.1.5: Outlier detection + spatial statistics ─────────────
   Per property:
   - Weight each pixel value by its overlap fraction
   - Compute weighted mean and weighted SD
   - Flag outliers: |value − mean| > 2 × SD
   - Recompute clean stats excluding outliers
   - Compute CV%, min, max, median, n_valid, n_outlier
────────────────────────────────────────────────────────────────────── */
function computePixelStats(pixelData) {
  const stats = {};

  PIXEL_PROPS.forEach(({ key, label, unit }) => {
    const valid = pixelData.filter(p => p[key] !== null && p[key] !== undefined);
    if (!valid.length) { stats[key] = null; return; }

    const weights = valid.map(p => p.weight);
    const vals    = valid.map(p => p[key]);
    const wTotal  = weights.reduce((a,b) => a+b, 0);

    // Weighted mean
    const wmean = vals.reduce((s,v,i) => s + v*weights[i], 0) / wTotal;

    // Weighted variance
    const wvar = vals.reduce((s,v,i) => s + weights[i]*(v-wmean)**2, 0) / wTotal;
    const wsd  = Math.sqrt(wvar);

    // Outlier detection — modified Z-score (median + MAD)
    // Robust to outlier-inflation of SD. Threshold 3.5 (Iglewicz & Hoaglin 1993).
    // ±2σ from mean is non-robust: a single extreme outlier inflates SD enough
    // to hide itself within the threshold.
    const allVals  = valid.map(p => p[key]);
    const sortedAll = [...allVals].sort((a,b) => a-b);
    const medAll = sortedAll.length % 2 === 0
      ? (sortedAll[sortedAll.length/2-1] + sortedAll[sortedAll.length/2]) / 2
      : sortedAll[Math.floor(sortedAll.length/2)];
    const mads   = allVals.map(v => Math.abs(v - medAll)).sort((a,b) => a-b);
    const mad    = mads.length % 2 === 0
      ? (mads[mads.length/2-1] + mads[mads.length/2]) / 2
      : mads[Math.floor(mads.length/2)];
    const madScale = mad > 0 ? mad : (wsd || 1);  // fallback if MAD=0 (identical values)
    const MOD_Z_THRESH = 3.5;
    const clean   = valid.filter(p => (0.6745 * Math.abs(p[key] - medAll) / madScale) <= MOD_Z_THRESH);
    const outliers = valid.filter(p => (0.6745 * Math.abs(p[key] - medAll) / madScale) > MOD_Z_THRESH);

    // Recompute stats on clean data
    const cVals = clean.map(p => p[key]);
    const cW    = clean.map(p => p.weight);
    const cwTotal = cW.reduce((a,b) => a+b, 0) || 1;
    const cmean = cVals.reduce((s,v,i) => s + v*cW[i], 0) / cwTotal;
    const cvar  = cVals.reduce((s,v,i) => s + cW[i]*(v-cmean)**2, 0) / cwTotal;
    const csd   = Math.sqrt(cvar);

    // Median (unweighted — on clean values)
    const sorted = [...cVals].sort((a,b) => a-b);
    const mid = Math.floor(sorted.length/2);
    const median = sorted.length % 2 === 0
      ? (sorted[mid-1] + sorted[mid]) / 2 : sorted[mid];

    stats[key] = {
      label, unit,
      mean:      cmean,
      sd:        csd,
      cv_pct:    cmean > 0 ? (csd/cmean)*100 : 0,
      min:       Math.min(...cVals),
      max:       Math.max(...cVals),
      median,
      n_valid:   clean.length,
      n_outlier: outliers.length,
      n_total:   valid.length,
      raw_vals:  cVals,      // for histogram
      outlier_vals: outliers.map(p => p[key]),
    };
  });

  return stats;
}

/* ── 1.1.6: Bimodal distribution detection (Hartigan dip proxy) ───────
   Hartigan & Hartigan 1985 dip statistic is complex.
   We use a practical proxy: if the distribution has two local maxima
   in its histogram and the valley between them is < 60% of the lower
   peak height, flag as bimodal.
   This is conservative — only flags clear bimodality.
────────────────────────────────────────────────────────────────────── */
function detectBimodal(vals, maxBins = 8) {
  if (vals.length < 6) return false;
  const min = Math.min(...vals), max = Math.max(...vals);
  if (max === min) return false;
  // Auto-scale bins to unique value count — prevents artificial zero-count gaps
  // when values are discrete integers mapped to too many bins.
  // e.g. [10,11,12] with 8 bins → binW=0.25 → bins 0,4,7 with empty gaps → false bimodal
  const nUnique = new Set(vals.map(v => Math.round(v * 10))).size;
  const nBins = Math.min(maxBins, Math.max(3, nUnique));
  const binW = (max - min) / nBins;
  const hist = new Array(nBins).fill(0);
  vals.forEach(v => {
    const b = Math.min(nBins-1, Math.floor((v-min)/binW));
    hist[b]++;
  });
  // Find local maxima — include endpoints (peaks can be at bin 0 or nBins-1)
  const peaks = [];
  for (let i = 0; i < nBins; i++) {
    const left  = i > 0       ? hist[i-1] : 0;
    const right = i < nBins-1 ? hist[i+1] : 0;
    if (hist[i] >= left && hist[i] >= right && hist[i] > 0) {
      peaks.push({ bin: i, count: hist[i] });
    }
  }
  if (peaks.length < 2) return false;
  // Check valley depth between first two peaks
  const p1 = peaks[0].bin, p2 = peaks[peaks.length-1].bin;
  const valley = Math.min(...hist.slice(p1, p2+1));
  const minPeak = Math.min(peaks[0].count, peaks[peaks.length-1].count);
  return valley < minPeak * 0.6;
}

/* ── Master spatial analysis function (replaces computeSpatialVariance) */
async function computeFullPolygonSpatialAnalysis(polygon, onProgress) {
  /* Returns { pixels, stats, bimodal, pixelData }
     Fully replaces the old 5-point sampling when polygon is available. */
  if (!polygon || !window.GeoTIFF) return null;

  // 1.1.1+1.1.2: enumerate pixels
  const pixels = enumeratePolygonPixels(polygon);
  if (!pixels.length) return null;

  // Show pixel count to user
  if (onProgress) onProgress(0, 1, `${pixels.length} pixel${pixels.length>1?'s':''} inside polygon`);

  // 1.1.3: fetch all properties
  const pixelData = await fetchPixelValues(pixels, onProgress);

  // 1.1.4+1.1.5: compute stats
  const stats = computePixelStats(pixelData);

  // 1.1.6: bimodal detection per key property
  const bimodal = {};
  ['soc','clay','ph'].forEach(key => {
    const s = stats[key];
    if (s?.raw_vals?.length >= 6) {
      bimodal[key] = detectBimodal(s.raw_vals);
    }
  });

  return { pixels, pixelData, stats, bimodal };
}

/* Legacy 5-point fallback — used when no polygon is drawn */
async function computeSpatialVariance(lat, lon) {
  // Determine offset distance from field polygon if available
  let offsetDeg = 0.0015;  // ~165 m default
  if (ST.fieldBoundary && ST.fieldAreaHa) {
    // sqrt(area) gives rough side length; use 15% as offset
    const side_m = Math.sqrt(ST.fieldAreaHa * 10000);
    const offset_m = Math.max(150, Math.min(500, side_m * 0.15));
    offsetDeg = offset_m / 111320;  // degrees latitude (approx)
  }

  // 5 sample points: centroid + N, S, E, W
  const points = [
    { lat, lon },
    { lat: lat + offsetDeg, lon },
    { lat: lat - offsetDeg, lon },
    { lat, lon: lon + offsetDeg / Math.cos(lat * Math.PI / 180) },
    { lat, lon: lon - offsetDeg / Math.cos(lat * Math.PI / 180) },
  ];

  // Fetch SOC 0-5cm and clay 0-5cm at all 5 points in parallel
  const props = [
    { prop:'ocs', layer:'ocs_0-30cm_mean',   key:'soc', mult:0.1 },
    { prop:'clay', layer:'clay_0-5cm_mean',  key:'clay', mult:0.1 },
  ];

  const results = {};
  for (const p of props) {
    const vals = await Promise.all(
      points.map(pt => readWCSPixel(p.prop, p.layer, pt.lat, pt.lon))
    );
    const valid = vals.filter(v => v !== null).map(v => v * p.mult);
    if (valid.length >= 3) {
      const mean = valid.reduce((a,b)=>a+b,0) / valid.length;
      const variance = valid.reduce((s,v)=>s+(v-mean)**2,0) / valid.length;
      const sd = Math.sqrt(variance);
      results[p.key] = { mean, sd, cv_pct: mean > 0 ? (sd/mean)*100 : 0, n: valid.length };
    }
  }

  ST.derived.spatial = results;
  return results;
}

/* Show spatial variance in the uncertainty strip */
/* ── Updated spatial variance display — now shows pixel count ── */
function updateSpatialVarianceDisplay() {
  const sp = ST.derived.spatial;
  const el = document.getElementById('spatial-variance-display');
  if (!el) return;
  if (!sp || !sp.soc) { el.innerHTML = ''; return; }
  const socSp = sp.soc;
  const claySp = sp.clay;
  const nPx  = socSp.n_valid || 0;
  const src  = nPx > 5 ? `${nPx}-pixel polygon` : '5-point';
  let html = `<span style="font-size:0.65rem;color:var(--ink-5);font-family:var(--mono)">` +
    `📍 Field spatial (${src}): ` +
    (socSp ? `SOC ${socSp.mean.toFixed(1)}±${socSp.sd.toFixed(1)} g/kg (CV ${socSp.cv_pct.toFixed(0)}%) ` : '') +
    (claySp ? `· Clay ${claySp.mean.toFixed(0)}±${claySp.sd.toFixed(0)}%` : '') +
    `</span>`;
  if (socSp && socSp.cv_pct > 30) {
    html += ` <span style="color:var(--amber-2);font-size:0.63rem">` +
      `⚠ High SOC variability (CV ${socSp.cv_pct.toFixed(0)}%) — grid sampling recommended before MRV</span>`;
  }
  el.innerHTML = html;
  if (socSp && ST.derived.cstock) {
    const sigma_pct = socSp.cv_pct / 100;
    ST.derived.uncertainty = ST.derived.cstock * sigma_pct;
    ST.derived.spatialUncertainty = true;
    updateUncertaintyMeter(ST.derived.cstock, ST.derived.uncertainty, sigma_pct);
  }
}

/* ── 1.1.8: Spatial analysis panel + histograms ── */
function updateSpatialAnalysisPanel(result) {
  const panel = document.getElementById('spatial-analysis-panel');
  const layerBar = document.getElementById('spatial-layer-bar');
  const statsSummary = document.getElementById('spatial-stats-summary');
  const histWrap = document.getElementById('spatial-histograms');
  if (!panel || !result) return;
  panel.style.display = 'block';
  if (layerBar) layerBar.style.display = 'block';
  // Terrain button shown by triggerSpatialAnalysis after soil pixels complete

  const { stats, bimodal, pixels } = result;
  const nPx = pixels.length;

  // Stats summary strip
  if (statsSummary && stats.soc) {
    const s = stats.soc;
    let sumHtml = `<strong>${nPx} pixels</strong> (${nPx} × 250m) inside polygon · ` +
      `SOC mean <strong>${s.mean.toFixed(1)} g/kg</strong> ` +
      `SD ${s.sd.toFixed(1)} CV ${s.cv_pct.toFixed(0)}% · ` +
      `range ${s.min.toFixed(1)}–${s.max.toFixed(1)} g/kg`;
    if (s.n_outlier > 0) sumHtml += ` · <span style="color:var(--amber-2)">${s.n_outlier} outlier pixel${s.n_outlier>1?'s':''} excluded</span>`;
    // Bimodal flags
    const bimodalFlags = Object.entries(bimodal||{})
      .filter(([k,v])=>v).map(([k])=>k.toUpperCase());
    if (bimodalFlags.length) {
      sumHtml += ` · <span style="color:var(--amber-2)">⚠ Possible bimodal distribution: ${bimodalFlags.join(', ')} — two soil types?</span>`;
    }
    statsSummary.innerHTML = sumHtml;
    statsSummary.style.display = 'block';
  }

  // Histogram rows for key properties
  if (histWrap) {
    const histKeys = ['soc','clay','ph','bd','cec'];
    histWrap.style.display = 'block';
    histWrap.innerHTML = '<div style="font-size:0.62rem;font-weight:700;color:var(--ink-4);' +
      'margin-bottom:5px;font-family:var(--mono)">PIXEL VALUE DISTRIBUTIONS:</div>' +
      histKeys.map(key => {
        const s = stats[key];
        if (!s || s.n_valid < 2) return '';
        return renderMiniHistogram(key, s);
      }).join('');
  }
}

function renderMiniHistogram(key, stats) {
  const vals = stats.raw_vals || [];
  if (!vals.length) return '';
  const N_BINS = 8;
  const min = stats.min, max = stats.max;
  if (max === min) return '';
  const binW = (max-min)/N_BINS;
  const hist = new Array(N_BINS).fill(0);
  vals.forEach(v => { const b = Math.min(N_BINS-1, Math.floor((v-min)/binW)); hist[b]++; });
  const maxCount = Math.max(...hist);
  const ramp = RAMP_DEFS[key] || RAMP_DEFS.soc;
  const bars = hist.map((count, i) => {
    const t = (i + 0.5) / N_BINS;
    const col = interpolateColour(ramp.stops, t);
    const h = maxCount > 0 ? Math.round((count/maxCount)*28) : 0;
    return `<div title="${(min+i*binW).toFixed(1)}–${(min+(i+1)*binW).toFixed(1)} ${stats.unit}: ${count}px"
      style="width:14px;height:${h}px;background:rgb(${col[0]},${col[1]},${col[2]});
             margin-top:${28-h}px;border-radius:2px 2px 0 0;flex-shrink:0"></div>`;
  }).join('');
  return `<div style="display:flex;align-items:flex-end;gap:6px;margin-bottom:6px;flex-wrap:wrap">
    <span style="font-size:0.60rem;font-family:var(--mono);color:var(--ink-5);width:30px">${stats.label}</span>
    <div style="display:flex;gap:2px;align-items:flex-end;height:30px">${bars}</div>
    <span style="font-size:0.58rem;font-family:var(--mono);color:var(--ink-5)">${stats.mean.toFixed(1)}±${stats.sd.toFixed(1)} ${stats.unit} (n=${stats.n_valid})</span>
  </div>`;
}

