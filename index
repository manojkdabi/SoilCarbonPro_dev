/* ═══════════════════════════════════════════════════════
   SATELLITE DATA — GROUP B: NASA EARTHDATA / EMIT
   CMR STAC search (no auth) to find granule
   EMIT L2A Reflectance (60 m) — bearer token for download
   Mineral targets: clay @ 2200nm, carbonate @ 2340nm,
   iron oxide @ 490/870 nm (Cawse-Nicholson et al. 2021)
═══════════════════════════════════════════════════════ */
async function fetchEMIT(lat, lon) {
  const token = localStorage.getItem('scp_nasa_key') || '';
  try {
    // Step 1: CMR STAC search (no auth needed)
    const bbox = `${(lon-0.05).toFixed(3)},${(lat-0.05).toFixed(3)},${(lon+0.05).toFixed(3)},${(lat+0.05).toFixed(3)}`;
    const cmrUrl = `https://cmr.earthdata.nasa.gov/stac/LPCLOUD/search` +
      `?collections=EMITL2ARFL_001&bbox=${bbox}&limit=1&datetime=2023-01-01T00:00:00Z/2024-12-31T23:59:59Z`;
    const cmrResp = await fetch(cmrUrl, { headers: { Accept: 'application/json' } });
    if (!cmrResp.ok) throw new Error(`CMR HTTP ${cmrResp.status}`);
    const cmrData = await cmrResp.json();
    const granule = cmrData?.features?.[0];
    if (!granule) { ST.satData.emitMineral = 'No EMIT granule found for this location/date'; updateSatDiagnostics(); return; }

    const granuleId = granule.id;
    ST.satData.emitMineral = `Granule found: ${granuleId.slice(0,30)}…`;
    if (!token) {
      ST.satData.emitMineral += ' · Enter NASA Earthdata token to extract mineralogy';
      updateSatDiagnostics(); return;
    }

    // Step 2: Fetch EMIT L2B mineral identification product (requires auth)
    const mineralUrl = cmrData?.features?.[0]?.assets?.data?.href;
    if (!mineralUrl) throw new Error('No data asset URL');
    const dataResp = await fetch(mineralUrl, { headers: { Authorization: `Bearer ${token}` } });
    if (!dataResp.ok) throw new Error(`EMIT data HTTP ${dataResp.status}`);
    // EMIT files are HDF5 — full parsing requires h5wasm library
    // Mark as available, guide user to EMIT viewer for now
    ST.satData.emitMineral = `✓ EMIT granule accessible — ${granuleId.slice(0,25)}`;
    ST.satData.emitCarbonate = 'See LP DAAC portal for mineral map extraction';
    updateSatDiagnostics();
  } catch(e) {
    ST.satData.emitMineral = `EMIT search error: ${e.message}`;
    updateSatDiagnostics();
  }
}

