<script>
/* ═══════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════ */
const ST = {
  mode: 'desk',
  lat: null, lon: null, locationName: '',
  analysisDepth: 30,
  mineralogy: 'alluvial',
  confidence: 'central',
  fieldBoundary: null,   // GeoJSON polygon feature drawn by user
  fieldAreaHa:   null,   // computed area in hectares
  params: {},
  targetPct: null, targetTha: null,
  // Item 7: layer-specific targets (optional; when set, solver checks per-layer)
  targetL1_tha: null,  // 0–15 cm target t C/ha
  targetL2_tha: null,  // 15–30 cm target t C/ha
  derived: {
    cstock: null, hassinkCap: null, agroCeil: null,
    uncertainty: null, outcome: null,
    socPct1: null, socPct2: null
  }
};

/* ═══════════════════════════════════════════════════════
   WIZARD STEPPER
═══════════════════════════════════════════════════════ */
let WIZ = { current: 1, unlocked: 1 };  // max unlocked phase


/* ── Dismiss splash when map + Leaflet.Draw ready ── */
function dismissSplash() {
  const splash = document.getElementById('scp-splash');
  if (splash) { splash.classList.add('hidden'); setTimeout(() => splash.remove(), 500); }
}

/* ── Lazy-load jsPDF on first PDF export click ───────────────────── */
let _jspdfLoaded = false;
function ensureJsPDF() {
  if (window.jspdf) return Promise.resolve();
  if (_jspdfLoaded) return new Promise(r => {
    const check = setInterval(() => { if (window.jspdf) { clearInterval(check); r(); }}, 50);
  });
  _jspdfLoaded = true;
  return new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
    s.onload = resolve; s.onerror = reject;
    document.head.appendChild(s);
  });
}

/* ── Lazy-load GeoTIFF on first SoilGrids fetch ─────────────────── */
let _geotiffLoaded = false;
function ensureGeoTIFF() {
  if (window.GeoTIFF) return Promise.resolve();
  if (_geotiffLoaded) return new Promise(r => {
    const check = setInterval(() => { if (window.GeoTIFF) { clearInterval(check); r(); }}, 50);
  });
  _geotiffLoaded = true;
  return new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/geotiff@2.1.3/dist-browser/geotiff.js';
    s.onload = resolve; s.onerror = reject;
    document.head.appendChild(s);
  });
}

function gotoPhase(n) {
  if (n < 1 || n > 3) return;
  if (n > WIZ.unlocked) return;   // locked — do nothing

  WIZ.current = n;

  // Show/hide panels
  for (let i = 1; i <= 3; i++) {
    const panel = document.getElementById(`phase-panel-${i}`);
    if (panel) panel.classList.toggle('active', i === n);
  }

  // Leaflet needs invalidateSize when its container comes back into view
  if (n === 1 && window._leafletMap) {
    setTimeout(() => window._leafletMap.invalidateSize(), 120);
  }

  // Scroll to below wizard nav
  window.scrollTo({ top: 0, behavior: 'smooth' });

  // If entering Phase 3, auto-trigger solver
  if (n === 3) {
    setTimeout(() => maybeAutoRunSolver('phase_enter'), 300);
  }

  renderWizardNav();
  updateWizardSubLabels();   // refresh step sublabels with current decisions
}

function wizClick(n) {
  if (n > WIZ.unlocked) return;
  gotoPhase(n);
}

/* Call this whenever state changes that might unlock the next phase */
function updateWizardState() {
  const soc1     = paramVal('soc1');
  const hasLoc   = ST.lat !== null && ST.lon !== null;
  const hasSOC   = soc1 !== null;
  const hasTarget= ST.targetTha !== null && ST.targetTha > 0;
  const hasCrops = (ST.farm?.crops?.length || 0) > 0;
  const hasTill  = !!ST.farm?.tillage;
  const hasBAU   = !!ST.bau;

  // ── Phase 1 → 2 proceed requirements
  const req = (id, met) => {
    const el = document.getElementById(id);
    if (el) el.classList.toggle('met', met);
    return met;
  };
  const p1ok = req('req-location', hasLoc) &
               req('req-soc',      hasSOC) &
               req('req-target',   hasTarget);

  const p1btn = document.getElementById('p1-proceed-btn');
  if (p1btn) p1btn.disabled = !p1ok;

  if (p1ok && WIZ.unlocked < 2) {
    WIZ.unlocked = 2;
  }

  // ── Phase 2 → 3 proceed requirements
  const p2ok = req('req-crops',  hasCrops) &
               req('req-tillage',hasTill)  &
               req('req-bau',    hasBAU);

  const p2btn = document.getElementById('p2-proceed-btn');
  if (p2btn) p2btn.disabled = !p2ok;

  if (p2ok && WIZ.unlocked < 3) {
    WIZ.unlocked = 3;
  }

  renderWizardNav();
}

function renderWizardNav() {
  const labels = ['', 'Ceiling Diagnosis', 'Farm Baseline', 'Recommendations'];
  const subs   = ['', 'Soil data · Target · Hassink cap', 'Crops · Tillage · RothC BAU', 'Grid solver · Prescriptions'];
  const icons  = ['', '1', '2', '3'];

  for (let i = 1; i <= 3; i++) {
    const step = document.getElementById(`wiz-step-${i}`);
    const pill = document.getElementById(`wiz-pill-${i}`);
    if (!step || !pill) continue;

    const isCurrent  = i === WIZ.current;
    const isUnlocked = i <= WIZ.unlocked;
    const isDone     = isUnlocked && i < WIZ.current;

    step.className = 'wiz-step' +
      (isCurrent  ? ' active' : '') +
      (isDone     ? ' done'   : '') +
      (!isUnlocked && !isCurrent ? ' locked' : '');

    if (isCurrent) {
      pill.className = 'wiz-status-pill wiz-pill-active';
      pill.textContent = '● In progress';
    } else if (isDone) {
      pill.className = 'wiz-status-pill wiz-pill-done';
      pill.textContent = '✓ Done';
    } else if (isUnlocked) {
      pill.className = 'wiz-status-pill wiz-pill-ok';
      pill.textContent = '↑ Unlocked';
    } else {
      pill.className = 'wiz-status-pill wiz-pill-locked';
      pill.textContent = '🔒 Locked';
    }
  }
}

const MINERAL_MULT = { alluvial:1.00, vertisol:1.45, alfisol:0.75, paddy:1.10, aridisol:0.55 };

/* ── Build version ── */
const SCP_VERSION = 'v1.6.3';
const SCP_BUILD   = '2026-03-17';

const BADGE = {
  lab:         { emoji:'🟢', cls:'badge-lab',  tip:'Lab Measured — lowest uncertainty' },
  soilgrids:   { emoji:'🟡', cls:'badge-sg',   tip:'SoilGrids 250m estimate — ±15–25% at field scale' },
  openlandmap: { emoji:'🟠', cls:'badge-olm',  tip:'OpenLandMap (OpenGeoHub) 250m estimate — alternative to SoilGrids' },
  pedotransfer:{ emoji:'🔵', cls:'badge-pt',   tip:'Pedotransfer function — calculated from other parameters' },
  derived:     { emoji:'🟣', cls:'badge-drv',  tip:'Derived: calculated from other fetched values (e.g. Silt = 100 − Sand − Clay)' },
  satellite:   { emoji:'🛰', cls:'badge-sat',  tip:'Satellite-derived: from Sentinel-2 NDVI time series (Sprint 5A)' },
  default:     { emoji:'🔴', cls:'badge-def',  tip:'Default value — highest uncertainty' },
};

function getParam(id) { return ST.params[id] || { value: null, source: 'default' }; }
function paramVal(id) { const p = getParam(id); return (p.value !== null && p.value !== '') ? parseFloat(p.value) : null; }

/* ═══════════════════════════════════════════════════════
   LEAFLET MAP
═══════════════════════════════════════════════════════ */
const map = L.map('map', { zoomControl: true }).setView([20.59, 78.96], 4);
window._leafletMap = map;

/* ── Base tile layers ── */
const _layers = {
  osm: L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors', maxZoom: 19
  }),
  esri: L.tileLayer(
    'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution: 'Tiles © Esri — Source: Esri, Maxar, Earthstar Geographics',
    maxZoom: 19
  }),
};

let _currentLayer = 'osm';
_layers.osm.addTo(map);

function setSatLayer(key) {
  ['osm','esri'].forEach(k => {
    document.getElementById(`sat-btn-${k}`)?.classList.toggle('active', k === key);
  });
  Object.values(_layers).forEach(l => { if (map.hasLayer(l)) map.removeLayer(l); });
  _currentLayer = key;
  _layers[key].addTo(map);
  document.getElementById('sat-res-note').textContent =
    key === 'esri' ? '0.3–15 m · Esri Maxar composite' : '';
}

/* ═══════════════════════════════════════════════════════
   FIELD GEOFENCE — Leaflet.Draw + Turf.js
   Ref: Hijmans et al. 2001 (area formula); Turf.js area()
   Sampling density: Gruijter et al. 2006 (Sampling for
   Natural Resource Monitoring) — sqrt(area_ha) × 2 points
═══════════════════════════════════════════════════════ */
let _drawnLayer = null;
let _drawControl = null;
let _featureGroup = null;

// Initialise draw feature group
_featureGroup = new L.FeatureGroup().addTo(map);

// Draw control (toolbar hidden — we use custom buttons instead)
_drawControl = new L.Control.Draw({
  edit:  { featureGroup: _featureGroup, remove: true },
  draw: {
    polygon:   { shapeOptions: { color: '#2e8040', fillColor: '#4aaf6a', fillOpacity: 0.18, weight: 2 } },
    rectangle: { shapeOptions: { color: '#2e8040', fillColor: '#4aaf6a', fillOpacity: 0.18, weight: 2 } },
    circle: false, circlemarker: false, marker: false, polyline: false,
  }
});
// Don't add toolbar to map — we use custom buttons

// Listen for draw completion
map.on(L.Draw.Event.CREATED, function(e) {
  _featureGroup.clearLayers();
  _drawnLayer = e.layer;
  _featureGroup.addLayer(_drawnLayer);
  onFieldDrawn(_drawnLayer.toGeoJSON());
});

map.on(L.Draw.Event.EDITED, function() {
  const layers = _featureGroup.getLayers();
  if (layers.length > 0) onFieldDrawn(layers[0].toGeoJSON());
});

map.on(L.Draw.Event.DELETED, function() {
  clearFieldBoundary();
});

function startDrawPolygon() {
  _cancelActiveDraw();
  const handler = new L.Draw.Polygon(map, {
    shapeOptions: { color: '#2e8040', fillColor: '#4aaf6a', fillOpacity: 0.18, weight: 2 },
    showArea: true, metric: true,
  });
  handler.enable();
  document.getElementById('draw-btn-polygon').classList.add('active');
  document.getElementById('draw-btn-rect').classList.remove('active');
  map._activeDrawHandler = handler;
}

function startDrawRect() {
  _cancelActiveDraw();
  const handler = new L.Draw.Rectangle(map, {
    shapeOptions: { color: '#2e8040', fillColor: '#4aaf6a', fillOpacity: 0.18, weight: 2 },
  });
  handler.enable();
  document.getElementById('draw-btn-rect').classList.add('active');
  document.getElementById('draw-btn-polygon').classList.remove('active');
  map._activeDrawHandler = handler;
}

function _cancelActiveDraw() {
  if (map._activeDrawHandler) {
    try { map._activeDrawHandler.disable(); } catch(e) {}
    map._activeDrawHandler = null;
  }
  document.getElementById('draw-btn-polygon').classList.remove('active');
  document.getElementById('draw-btn-rect').classList.remove('active');
}

function onFieldDrawn(geojsonFeature) {
  _cancelActiveDraw();
  // Ensure it's a Feature (not FeatureCollection)
  const feat = geojsonFeature.type === 'FeatureCollection'
    ? geojsonFeature.features[0]
    : geojsonFeature;
  if (!feat) return;

  ST.fieldBoundary = feat;

  // Compute area via Turf (m²) → ha
  const areaM2 = turf.area(feat);
  ST.fieldAreaHa = areaM2 / 10000;

  // Centroid → update pin location
  const centroid = turf.centroid(feat);
  const [cLon, cLat] = centroid.geometry.coordinates;

  // Move marker to centroid
  if (marker) map.removeLayer(marker);
  marker = L.marker([cLat, cLon]).addTo(map);

  // Update ST location to centroid
  ST.lat = cLat; ST.lon = cLon;
  document.getElementById('inp-lat').value = cLat.toFixed(4);
  document.getElementById('inp-lon').value = cLon.toFixed(4);

  // Fit map to polygon
  map.fitBounds(_featureGroup.getBounds(), { padding: [20, 20] });

  // Show/hide buttons
  document.getElementById('draw-btn-clear').style.display  = 'inline-block';
  document.getElementById('draw-btn-export').style.display = 'inline-block';

  updateFieldInfoStrip();
  updateWizardState();

  // Re-fire all data fetches with centroid
  reverseGeocode(cLat, cLon);
  applyMineralogyFromLocation(cLat, cLon);
  document.getElementById('fetch-btn').disabled = false;
  if (ST.mode === 'desk') {
    document.getElementById('fetch-status').textContent = '';
    document.getElementById('fetch-status').className = 'fetch-status';
  }
  clearTimeout(window._climateTimer);
  window._climateTimer = setTimeout(() => fetchClimate(cLat, cLon), 800);
  fetchNDVI(cLat, cLon);
  fetchEMIT(cLat, cLon);
}

function clearFieldBoundary() {
  _cancelActiveDraw();
  _featureGroup.clearLayers();
  _drawnLayer = null;
  ST.fieldBoundary = null;
  ST.fieldAreaHa   = null;
  // Sprint 1+2: clear spatial and terrain analysis state
  const actionDivClear = document.getElementById('field-action-btns');
  if (actionDivClear) actionDivClear.style.display = 'none';
  const vegBtnClear = document.getElementById('analyse-vegetation-btn');
  if (vegBtnClear) vegBtnClear.style.display = 'none';
  const soilBtnClear = document.getElementById('analyse-soil-btn');
  if (soilBtnClear) soilBtnClear.style.display = 'none';
  // Clear satellite state
  ST.satData.ndviMonthly = null;
  ST.satData.ndviScale   = 1.0;
  ST.satData.satelliteCin = null;
  const satPanel = document.getElementById('satellite-panel');
  if (satPanel) satPanel.style.display = 'none';
  const terrBtnClear = document.getElementById('analyse-terrain-btn');
  if (terrBtnClear) terrBtnClear.style.display = 'none';
  const badgeClear = document.getElementById('terrain-source-badge');
  if (badgeClear) badgeClear.textContent = '';
  _spatialPixelData = null;
  _spatialStats     = null;
  _spatialRasterCache = {};
  _krigingCache     = {};
  _regKrigCache     = {};
  _krigingMode      = false;
  _rkMode           = false;
  const ktb = document.getElementById('krig-toggle-btn');
  if (ktb) { ktb.textContent='◈ IDW'; ktb.style.background='transparent';
             ktb.style.borderColor='var(--teal)'; ktb.style.color='var(--teal)'; }
  const rktb = document.getElementById('rk-toggle-btn');
  if (rktb) { rktb.style.display='none'; rktb.style.background='transparent'; }
  _rkMode = false;
  _regKrigCache = {};
  ST.derived.spatial = null;
  ST.derived.pixelBimodal = null;
  clearSpatialOverlay();
  const sp = document.getElementById('spatial-analysis-panel');
  if (sp) sp.style.display = 'none';
  // Sprint 2: clear terrain state
  ST.dem.grid = null; ST.dem.polyHash = null;
  ST.terrain = null;
  ST.terrainAdj = null;
  ST.rkFit = null;
  ST.derived.terrainFTMult = 1.0;
  // Restore original ERA5 temperatures if lapse rate was applied
  if (ST.climate?._origTemps) {
    ST.climate.monthly.forEach((m, i) => { m.temp = ST.climate._origTemps[i]; });
    ST.climate.mat = ST.climate.monthly.reduce((s,m)=>s+m.temp,0)/12;
    delete ST.climate._origTemps;
  }
  const tp = document.getElementById('terrain-panel');
  if (tp) tp.style.display = 'none';
  document.getElementById('draw-btn-clear').style.display  = 'none';
  document.getElementById('draw-btn-export').style.display = 'none';
  document.getElementById('field-info-strip').classList.remove('visible');
}

function updateFieldInfoStrip() {
  if (!ST.fieldBoundary || !ST.fieldAreaHa) return;
  // Spatial pixel analysis triggered manually via button — not automatic.
  // Auto-trigger removed: large polygons caused ERR_INSUFFICIENT_RESOURCES.
  // Show the Analyse Soil button when polygon is ready.
  const actionDiv = document.getElementById('field-action-btns');
  if (actionDiv) actionDiv.style.display = 'flex';
  // Show vegetation button only if SH credentials are configured
  const vegBtn = document.getElementById('analyse-vegetation-btn');
  if (vegBtn) vegBtn.style.display = 'inline-block';
  const soilBtn = document.getElementById('analyse-soil-btn');
  if (soilBtn) soilBtn.style.display = 'inline-block';

  // 5-point fallback removed — all spatial analysis is manual via buttons
  const strip = document.getElementById('field-info-strip');
  strip.classList.add('visible');

  const ha = ST.fieldAreaHa;
  document.getElementById('field-area-ha').textContent = ha.toFixed(2) + ' ha';

  // Perimeter
  const perimM = turf.length(ST.fieldBoundary, { units: 'kilometers' }) * 1000;
  document.getElementById('field-perimeter').textContent = Math.round(perimM) + ' m';

  // Total C stock
  const cstock = ST.derived?.cstock;
  if (cstock !== null && cstock !== undefined) {
    const totalC = (cstock * ha).toFixed(1);
    document.getElementById('field-total-c').textContent = totalC + ' t C';

    // CDR potential: (target - current) × area × 44/12
    const targetTha = ST.targetTha;
    if (targetTha && targetTha > cstock) {
      const deltaTha = targetTha - cstock;
      const tco2e = (deltaTha * ha * 44 / 12).toFixed(1);
      document.getElementById('field-total-cdr').textContent = tco2e + ' tCO₂e';
    } else {
      document.getElementById('field-total-cdr').textContent = '— (set target)';
    }
  } else {
    document.getElementById('field-total-c').textContent = '— (fetch soil data)';
    document.getElementById('field-total-cdr').textContent = '—';
  }

  // Insoil sampling recommendation
  // Gruijter et al. 2006: n = max(5, ceil(sqrt(area_ha) × 2))
  const nSamples = Math.max(5, Math.ceil(Math.sqrt(ha) * 2));
  document.getElementById('field-samples').textContent = nSamples + ' pts';

  // Shape note: compactness (circle = 1.0, elongated < 0.7)
  const compactness = (4 * Math.PI * ha * 10000) / (perimM * perimM);
  let shapeNote = '';
  if (compactness < 0.50) shapeNote = '⬦ Elongated field — consider transect sampling along long axis';
  else if (ha < 0.5)      shapeNote = '◈ Small field (<0.5 ha) — composite 5-point W pattern recommended';
  else if (ha > 20)       shapeNote = '◈ Large field (>20 ha) — consider splitting into management zones';
  document.getElementById('field-shape-note').textContent = shapeNote;
}

function exportFieldGeoJSON() {
  if (!ST.fieldBoundary) return;
  const feat = {
    type: 'FeatureCollection',
    features: [{ ...ST.fieldBoundary, properties: {
      area_ha:        ST.fieldAreaHa?.toFixed(4),
      location:       ST.locationName,
      soc_percent:    document.getElementById('soc1')?.value || '',
      cstock_tha:     ST.derived?.cstock?.toFixed(2) || '',
      mineralogy:     ST.mineralogy,
      generated_by:   'SoilCarbon Pro',
      date:           new Date().toISOString().slice(0,10),
    }}]
  };
  const blob = new Blob([JSON.stringify(feat, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
